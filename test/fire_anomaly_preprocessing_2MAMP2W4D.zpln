    {
      "title": "BUS preprocessing",
      "text": "%spark_single.pyspark\n\nimport sys\n# sys.path.append(\"/home/kadap/python/pre_processing\") # 이전 테스트 경로\nsys.path.append(\"/home/kadap/QH/Pre_Processed\")\n\nfrom outlier_limits import bus_device_outlier_limits\n\nfrom functools import reduce\nimport joblib\nimport json\nimport logging\nimport shutil\nimport subprocess\nimport tempfile\nimport numpy as np\nimport operator\nimport os\n\nfrom datetime import datetime\nfrom pyspark.sql import SparkSession, DataFrame\nimport pyspark.sql.functions as F\nfrom pyspark.sql.functions import pandas_udf\nfrom pyspark.sql.types import ArrayType, DoubleType\nfrom pyspark.sql.window import Window\nfrom scipy.stats import chi2\nfrom sklearn.decomposition import PCA\nfrom sklearn.linear_model import LinearRegression\nfrom sklearn.metrics import r2_score, mean_squared_error\nimport sklearn.preprocessing as sklearn_prep\n\nlogging.basicConfig(level\u003dlogging.INFO, format\u003d\u0027%(asctime)s - %(levelname)s - %(message)s\u0027)\nlogger \u003d logging.getLogger(\"prep\")\n\nclass PCATrainPreprocessorBus:\n\n    # intialize variables\n\n    def __init__(self, \n                 spark_session: SparkSession,\n                 input_base_path: str,\n                 output_base_path: str,\n                 vehicle_id: str,\n                 outlier_th,\n                 date,\n                 logger \u003d None\n                 ):\n        \n        self.spark \u003d spark_session\n        self.input_base_path \u003d input_base_path\n        self.output_base_path \u003d output_base_path\n        self.vehicle_id \u003d vehicle_id\n        self.outlier_th \u003d outlier_th\n        self.start_date \u003d date[0]\n        self.end_date \u003d date[1]\n        self.logger \u003d logger\n        self.start_time \u003d datetime.now().strftime(\"%Y%m%d%H\")\n        self.artifacts \u003d {}\n        \n    # Public methods\n    \n    def preprocess(self, data_file_name):\n        \n        # 데이터 로드\n        self.logger.info(\"Start data preprocessing for PCA ...\")\n        \n        df \u003d self._load_data(data_file_name, format \u003d \"csv\")\n        df \u003d df.filter(F.col(\"createdAt\").between(self.start_date, self.end_date))\n\n        pack_info \u003d self._load_data(\"battery_pack_serial_info\", format \u003d \"parquet\")\n        vehicle_info \u003d self._load_data(\"vehicle_info\", format \u003d \"parquet\")\n        vehicle_model_info \u003d self._load_data(\"vehicle_model_info\", format \u003d \"parquet\")\n\n        self.logger.info(\"Load data successfully ...\")\n        # 팩 개수 및 모델명 추출\n        # vid \u003d df.select(\"deviceId\").first()[0]\n        pack_cnt \u003d self._pack_count(pack_info)\n        model_name \u003d self._get_model_name(vehicle_info, vehicle_model_info)\n\n        # Data Type 변환 / Voltage slice\n        converted_data \u003d self._convert_data(df, pack_cnt)\n\n        self.logger.info(\"Convert data type and slice array values successfully ...\")\n\n        # 사용 데이터 선택 # break 오타 \n        converted_data \u003d converted_data.select(\n                                \"deviceId\",\"createdAt\", \"speed\", \"totalMileage\", \"isEVReady\",\n                                \"isParkingBreakOn\",  \"isFastChargeConnected\", \"batteryPackVoltages\",\n                                \"batteryPackCurrents\",  \"batteryPackSocs\", \"batteryPackSohs\",\n                                \"maxCellVoltages\", \"minCellVoltages\", \"maxBatteryPackTempertures\",\n                                \"minBatteryPackTempertures\"\n                            )\n                            \n        \n        self.artifacts[\"raw_features\"] \u003d self._extract_features(converted_data)\n        \n        # 단말이상 제거 및 기초 파생변수 생성\n        processed_data \u003d self._process_device_outlier(converted_data, model_name)\n        self.logger.info(\"Completed removing device outlier successfully ...\")\n\n        processed_data \u003d self._get_derivation_features(processed_data, mode \u003d \"PCA\")\n        self.logger.info(\"Completed getting derivation features successfully ...\")\n\n        # Array type data parsing \n    \n        parsing_data \u003d self._parsing_data(processed_data, pack_cnt)\n        selected_data \u003d self._select_train_columns(parsing_data, pack_cnt)\n        \n        self.artifacts[\"input_features\"] \u003d self._extract_features(selected_data)\n        self.artifacts[\"feature_index_map\"] \u003d self._extract_feature_index_map(selected_data)\n        \n        self.logger.info(\"Completed parsing values and selecting columns ...\")\n        \n        # Save preprocessed data\n        self._save_data(selected_data)\n        \n        self.logger.info(\"Finish data preprocessing ...\")\n\n        return \n\n    # Helper methods\n    \n    def _extract_features(self, df):\n        \"\"\"\n        Extract feature name \u0026 type as json\n        \"\"\"\n        return {f.name: f.dataType.simpleString() for f in df.schema.fields}\n    \n    \n    def _extract_feature_index_map(self, df):\n        \"\"\"\n        Extract feature index_map\n        \"\"\"\n        return {name: idx for idx, name in enumerate(df.columns)}\n    \n    def _load_data(self, file_name, format \u003d \"csv\"):\n        \n        input_path \u003d os.path.join(self.input_base_path, file_name)\n\n        if format \u003d\u003d \"csv\":\n            df \u003d self.spark.read.csv(input_path, header \u003d True, inferSchema \u003d True)\n\n        elif format \u003d\u003d \"parquet\":\n            df \u003d self.spark.read.parquet(input_path)\n\n        else:\n            raise Exception(\"Incorrect format value. Use \u0027csv\u0027 or \u0027parquet\u0027\")\n    \n        return df\n    \n    def _pack_count(self, pack_info: DataFrame):\n        pack_cnt \u003d (pack_info.filter(F.col(\"vehicle_id\") \u003d\u003d self.vehicle_id)\n                    .agg(F.max(\"pack_index\"))\n                    .collect()[0][0]) + 1\n\n        return pack_cnt\n\n    \n    def _get_model_name(self, vehicle_info: DataFrame, vehicle_model_info: DataFrame):\n        # get model name\n        model_id \u003d (\n            vehicle_info.filter(F.col(\"id\") \u003d\u003d self.vehicle_id)\n                        .select(\"model_id\")\n                        .collect()[0][0]\n        )\n        model_name \u003d (\n            vehicle_model_info.filter(F.col(\"id\") \u003d\u003d model_id)\n                            .select(\"model_name\")\n                            .collect()[0][0]\n        )\n        return model_name\n\n    def _clean_array(self, col):\n        return F.split(\n                    F.regexp_replace(\n                        F.regexp_replace(F.col(col), \"[\\\\{\\\\[\\\\]\\\\}]\", \"\"), \" \", \"\"\n                        ), \",\").cast(\"array\u003cdouble\u003e\")\n\n    def _convert_data(self, df, pack_cnt):\n    \n        df \u003d (\n        df.withColumn(\"isEVready\", F.col(\"isEvready\").cast(\"int\"))\n        .withColumn(\"isParkingBreakOn\", F.col(\"isParkingBreakOn\").cast(\"int\"))\n        .withColumn(\"isFastChargeConnected\", F.col(\"isFastChargeConnected\").cast(\"int\"))\n        .withColumn(\"isWarnTractionTemp\", F.col(\"isWarnTractionTemp\").cast(\"int\"))\n        .withColumn(\"isWarnBmsIdiotLight\", F.col(\"isWarnBmsIdiotLight\").cast(\"int\"))\n        .withColumn(\"sWarnTractionLimit\", F.col(\"isWarnTractionLimit\").cast(\"int\"))\n        .withColumn(\"warn_isolation_low\", F.col(\"isWarnInsulationLow\").cast(\"int\"))\n        .withColumn(\"warn_front_air\", F.col(\"isWarnFrontAir\").cast(\"int\"))\n        .withColumn(\"warn_rear_air\", F.col(\"isWarnRearAir\").cast(\"int\"))\n        )\n        df \u003d (df.withColumn(\"batteryPackVoltages\", self._clean_array(\"batteryPackVoltages\"))\n                .withColumn(\"batteryPackCurrents\", self._clean_array(\"batteryPackCurrents\"))\n                .withColumn(\"batteryPackSocs\", self._clean_array(\"batteryPackSocs\"))\n                .withColumn(\"batteryPackSohs\", self._clean_array(\"batteryPackSohs\"))\n                .withColumn(\"minCellVoltages\", self._clean_array(\"minCellVoltages\"))\n                .withColumn(\"maxCellVoltages\", self._clean_array(\"maxCellVoltages\"))\n                .withColumn(\"minBatteryPackTempertures\", self._clean_array(\"minBatteryPackTempertures\")) # temperature 스펠링\n                .withColumn(\"maxBatteryPackTempertures\", self._clean_array(\"maxBatteryPackTempertures\"))\n        )\n\n        df \u003d (df.withColumn(\"batteryPackVoltages\", F.slice(F.col(\"batteryPackVoltages\"), 1, pack_cnt))\n                .withColumn(\"batteryPackCurrents\", F.slice(F.col(\"batteryPackCurrents\"), 1, pack_cnt))\n                .withColumn(\"batteryPackSocs\", F.slice(F.col(\"batteryPackSocs\"), 1, pack_cnt))\n                .withColumn(\"batteryPackSohs\", F.slice(F.col(\"batteryPackSohs\"), 1, pack_cnt))\n                .withColumn(\"minCellVoltages\", F.slice(F.col(\"minCellVoltages\"), 1, pack_cnt))\n                .withColumn(\"maxCellVoltages\", F.slice(F.col(\"maxCellVoltages\"), 1, pack_cnt))\n                .withColumn(\"minBatteryPackTempertures\", F.slice(F.col(\"minBatteryPackTempertures\"), 1, pack_cnt))\n                .withColumn(\"maxBatteryPackTempertures\", F.slice(F.col(\"maxBatteryPackTempertures\"), 1, pack_cnt))\n        )\n\n        df \u003d df.withColumn(\"maxCellVoltages\", F.transform(F.col(\"maxCellVoltages\"), lambda x: x * 0.001))\n        df \u003d df.withColumn(\"minCellVoltages\", F.transform(F.col(\"minCellVoltages\"), lambda x: x * 0.001))\n\n        return df\n    \n    def _process_device_outlier(self, df, model_name):\n        \n        def _all_zero_remove(df):\n            remove_target \u003d [\"batteryPackVoltages\", \"batteryPackSocs\", \"minBatteryPackTempertures\", \"maxBatteryPackTempertures\", \n                            \"minCellVoltages\", \"maxCellVoltages\"]\n            conditions \u003d [F.forall(F.col(c), lambda x: x \u003d\u003d 0).cast(\"int\") for c in remove_target]\n            sum_allzero \u003d reduce(lambda a, b: a + b, conditions)\n\n            return df.filter(sum_allzero \u003d\u003d 0)\n            \n        def _remove_outlier(df, col, model_name, outlier_th):\n\n            th \u003d outlier_th[col]\n            if col in [\n                    \"totalMileage\", \"bms_soc\", \"bms_soh\", \"batteryPackVoltages\", \"batteryPackCurrents\", \n                    \"batteryPackSocs\", \"batteryPackSohs\", \"minCellVoltages\", \"maxCellVoltages\", \n                    \"minBatteryPackTempertures\", \"maxBatteryPackTempertures\"\n                    ]:\n                th \u003d th[\"all\"]\n\n            elif col \u003d\u003d \"speed\":\n                if model_name \u003d\u003d \"ap1200_23my\":\n                    th \u003d th[model_name]\n                else:\n                    th \u003d th[\"all\"]\n\n            lower, upper \u003d th[\"min\"], th[\"max\"]\n\n            if dict(df.dtypes)[col].startswith(\"array\"):\n                df \u003d df.filter(\n                    F.forall(F.col(col), lambda x: (x \u003e lower) \u0026 (x \u003c upper)))\n            else:\n                df \u003d df.filter(F.col(col).between(lower, upper))\n\n            return df\n        \n        remove_cols \u003d [\n            \"totalMileage\", \"speed\", \"batteryPackVoltages\", \"batteryPackCurrents\", \"batteryPackSocs\",\n            \"batteryPackSohs\", \"minCellVoltages\", \"maxCellVoltages\", \"minBatteryPackTempertures\", \"maxBatteryPackTempertures\"\n            ]\n\n        removed_data \u003d _all_zero_remove(df)\n        for col in remove_cols:\n            removed_data \u003d _remove_outlier(removed_data, col, model_name, self.outlier_th)\n        \n        return removed_data\n\n    def _get_derivation_features(self, df, mode \u003d \"PCA\"):\n    \n        df \u003d df.withColumn(\"cvdiff\", F.zip_with(\"maxCellVoltages\", \"minCellVoltages\", lambda x, y: F.round(x - y, 2)))\n        df \u003d df.withColumn(\"ctdiff\", F.zip_with(\"maxBatteryPackTempertures\", \"minBatteryPackTempertures\", \n                                                lambda x, y: F.round(x - y, 2)))\n        df \u003d df.withColumn(\"meanpt\", F.zip_with(\"maxBatteryPackTempertures\", \"minBatteryPackTempertures\", \n                                                lambda x, y: F.round((x + y)/2, 3))) # PCA 활용 용도\n\n        if mode \u003d\u003d \"PCA\":\n            return df\n        \n        w \u003d Window.partitionBy(\"vehicle_id\").orderBy(\"time\")\n\n        df \u003d (df.withColumn(\"prev_time\", F.lag(\"time\").over(w))\n                    .withColumn(\"gap_sec\", F.unix_timestamp(\"createdAt\") - F.unix_timestamp(\"prev_time\"))\n        ) \n\n        df \u003d (df.withColumn(\"trip_flag\", F.when(F.col(\"gap_sec\") \u003e\u003d 600, 1).otherwise(0))\n                    .withColumn(\"trip_id\", F.sum(\"trip_flag\").over(w))\n        )\n\n\n        w_trip \u003d Window.partitionBy(\"trip_id\").orderBy(\"time\")\n\n        df \u003d (df.withColumn(\"prev_cell_max_t\", F.lag(\"maxBatteryPackTempertures\", 60).over(w_trip)) # 차후 변수화\n                    .withColumn(\"prev_cell_min_t\", F.lag(\"minBatteryPackTempertures\", 60).over(w_trip))\n                    .withColumn(\"delta_cell_max_t\",F.zip_with(\"maxBatteryPackTempertures\", \"prev_cell_max_t\", lambda x, y: F.round(x - y, 2)))\n                    .withColumn(\"delta_cell_min_t\",F.zip_with(\"minBatteryPackTempertures\", \"prev_cell_min_t\", lambda x, y: F.round(x - y, 2)))\n                    .drop(\"prev_time\", \"gap_sec\", \"trip_flag\", \"trip_id\", \"prev_cell_max_t\", \"prev_cell_min_t\")\n        )\n\n        return df.dropna(subset\u003d[\"delta_cell_max_t\", \"delta_cell_min_t\"])\n        \n    def _parsing_data(self, df, pack_cnt):\n    \n        # 문 여닫음, 앞 뒤축 공기압 데이터 제외 \n        df_parsing \u003d df.select(\u0027deviceId\u0027,\n                                \u0027createdAt\u0027,\n                                \u0027speed\u0027,\n                                \u0027totalMileage\u0027,\n                                \u0027isEVReady\u0027,\n                                \u0027isParkingBreakOn\u0027,\n                                \u0027isFastChargeConnected\u0027,\n                                *[F.col(\"batteryPackVoltages\").getItem(i).alias(f\"p{i+1}_v\") for i in range(pack_cnt)],\n                                *[F.col(\"batteryPackCurrents\").getItem(i).alias(f\"p{i+1}_c\") for i in range(pack_cnt)],\n                                *[F.round(F.col(\"batteryPackSocs\").getItem(i), 1).alias(f\"p{i+1}_soc\") for i in range(pack_cnt)],\n                                *[F.round(F.col(\"batteryPackSohs\").getItem(i), 1).alias(f\"p{i+1}_soh\") for i in range(pack_cnt)],\n                                *[F.round(F.col(\"maxCellVoltages\").getItem(i), 2).alias(f\"p{i+1}_maxcv\") for i in range(pack_cnt)],\n                                *[F.round(F.col(\"minCellVoltages\").getItem(i), 2).alias(f\"p{i+1}_mincv\") for i in range(pack_cnt)],\n                                *[F.col(\"maxBatteryPackTempertures\").getItem(i).alias(f\"p{i+1}_maxct\") for i in range(pack_cnt)],\n                                *[F.col(\"minBatteryPackTempertures\").getItem(i).alias(f\"p{i+1}_minct\") for i in range(pack_cnt)],\n                                *[F.col(\"cvdiff\").getItem(i).alias(f\"p{i+1}_cvdiff\") for i in range(pack_cnt)],\n                                *[F.col(\"ctdiff\").getItem(i).alias(f\"p{i+1}_ctdiff\") for i in range(pack_cnt)],\n                                *[F.col(\"meanpt\").getItem(i).alias(f\"p{i+1}_meanpt\") for i in range(pack_cnt)]\n                    )\n\n        return df_parsing\n\n    def _select_train_columns(self, df, pack_cnt):\n        targets \u003d [f\"p{i}_v\" for i in range(1, pack_cnt + 1)]\n        soc_cols \u003d [f\"p{i}_soc\" for i in range(1, pack_cnt + 1)]\n        temp_cols \u003d [f\"p{i}_meanpt\" for i in range(1, pack_cnt + 1)]\n\n        use_cols \u003d ([\"createdAt\", \"isFastChargeConnected\"] + soc_cols + temp_cols + targets)\n\n        return df.select(*use_cols).orderBy(\"createdAt\")\n        \n    def _sh(self, cmd: str):\n        return subprocess.run(cmd, shell\u003dTrue, capture_output\u003dTrue, text\u003dTrue)    \n        \n    def _save_json_hdfs(self, data: dict, local_path: str, hdfs_path: str):\n        # 1) write local json\n        with open(local_path, \"w\", encoding\u003d\"utf-8\") as f:\n            json.dump(data, f, indent\u003d2, ensure_ascii\u003dFalse)\n    \n        # 2) upload to HDFS\n        cmd \u003d f\"hdfs dfs -put -f {local_path} {hdfs_path}\"\n        proc \u003d self._sh(cmd)\n    \n        if proc.returncode !\u003d 0:\n            raise RuntimeError(\n                f\"Failed to upload JSON to HDFS: {hdfs_path}\\n\"\n                f\"stderr: {proc.stderr}\"\n            )\n            \n    def _save_data(self, df):\n        \n        vehicle_dir \u003d os.path.join(self.output_base_path, str(self.vehicle_id))\n        data_dir \u003d os.path.join(vehicle_dir, \"data\")\n        output_path \u003d os.path.join(data_dir, self.start_time)\n        \n        # timestamp 폴더생성\n        cmd \u003d f\"hdfs dfs -mkdir -p {output_path}/output\"\n        self._sh(cmd)\n        \n        cmd \u003d f\"hdfs dfs -mkdir -p {output_path}/artifacts\"\n        self._sh(cmd)\n        \n        # 임시 로컬 폴더 생성\n        tmp_dir \u003d tempfile.mkdtemp(prefix\u003d\"pca_prep_\", dir\u003d\"/tmp/\")\n        \n        # output, artifact 저장경로 분리\n        data_output_path \u003d os.path.join(output_path, \"output\")\n        artifact_output_path \u003d os.path.join(output_path, \"artifacts\")\n        \n        # input data 저장\n        try:\n            df.write.parquet(data_output_path, mode\u003d\"overwrite\")\n        except Exception as e:\n            raise RuntimeError(f\"Failed to write parquet: {e}\")\n        \n        # artifacts 저장\n        try:\n\n            for name, artifact in self.artifacts.items():\n                local_path \u003d os.path.join(tmp_dir, f\"{name}.json\")\n                hdfs_path \u003d f\"{artifact_output_path}/{name}.json\"\n                self._save_json_hdfs(artifact, local_path, hdfs_path)\n                \n        except Exception as e:\n            raise RuntimeError(f\"Failed to save preprocessed data \u0026 artifacts: {e}\")\n            \n        finally:\n            shutil.rmtree(tmp_dir, ignore_errors\u003dTrue)\n            self.logger.info(f\"Removed temporary directory: {tmp_dir}\")\n        \n        \n        self.logger.info(f\"Complete saving data ...: {output_path}\")\n\ndef get_runtime_params():\n\n    try:\n        auto_base_path \u003d z.input(\"auto_base_path\", \"/Data/MLFLOW/test/2025110409/\")\n    except NameError:\n        auto_base_path \u003d os.environ.get(\"AUTO_BASE_PATH\", \"/Data/MLFLOW/test/2025110409/\")\n\n    \n    # Zeppelin 환경이면 z.input 사용, 아니면 환경변수/기본값\n    try:\n        _ \u003d z  # Zeppelin 제공 객체 존재 여부 체크\n        parquet_glob \u003d z.input(\"parquet_glob\", \"/Data/MLFLOW/sample_data/*\")\n    except NameError:\n        parquet_glob \u003d os.environ.get(\"PARQUET_GLOB\", \"/Data/MLFLOW/sample_data/*\")\n\n    return parquet_glob, auto_base_path\n    \ninput_base, output_base \u003d get_runtime_params()\n\n# pack_info_path \u003d parquet_glob + \"battery_pack_serial_info\"\n# vehicle_info_path \u003d parquet_glob + \"vehicle_info\"\n# vehicle_model_info_path \u003d parquet_glob + \"vehicle_model_info\"\n# data_path \u003d parquet_glob + \"schema_result_woojin_104\"\n\npca_preprocessor \u003d PCATrainPreprocessorBus(spark_session \u003d spark, \n                                           input_base_path \u003d input_base, \n                                           output_base_path \u003d output_base, \n                                           vehicle_id \u003d \"104\", \n                                           outlier_th \u003d bus_device_outlier_limits,\n                                           date \u003d (\"2025-09-01\", \"2025-10-01\"),\n                                           logger \u003d logger)\n\n# df \u003d pca_preprocessor.load_data(\"schema_result_woojin_104\", format \u003d \"csv\")\n# pack_info \u003d pca_preprocessor.load_data(\"battery_pack_serial_info\", format \u003d \"parquet\")\n# vid \u003d df.select(\"deviceId\").first()[0]\n\npca_preprocessor.preprocess(\"schema_result_woojin_104\")\n# df.show(3)\n    ",
      "user": "anonymous",
