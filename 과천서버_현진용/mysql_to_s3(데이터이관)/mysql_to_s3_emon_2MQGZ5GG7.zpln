    {
      "text": "%spark.pyspark\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n# MySQL -\u003e S3(Ceph) 추출 및 저장 (emon)\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\nimport time\r\nfrom datetime import datetime, timedelta\r\n\r\nMYSQL_HOST     \u003d \"59.6.99.131\"\r\nMYSQL_PORT     \u003d \"3306\"\r\nMYSQL_DB       \u003d \"QH_KSLAB\"\r\nMYSQL_USER     \u003d \"qh\"\r\nMYSQL_PASSWORD \u003d \"qh1234!\"\r\nS3_BUCKET      \u003d \"bigdata\"\r\nMYSQL_TABLE    \u003d \"emon\"\r\nS3_BASE_PATH   \u003d f\"s3a://{S3_BUCKET}/{MYSQL_TABLE}/parquet\"\r\nS3_CHECKPOINT  \u003d f\"s3a://{S3_BUCKET}/{MYSQL_TABLE}/checkpoint/completed.txt\"\r\nJDBC_URL \u003d (\r\n    f\"jdbc:mysql://{MYSQL_HOST}:{MYSQL_PORT}/{MYSQL_DB}\"\r\n    f\"?useSSL\u003dfalse\u0026allowPublicKeyRetrieval\u003dtrue\"\r\n)\r\n\r\n# ── 단말기별 indate 범위 ────────────────────────────────────\r\nDEVICE_DATE_RANGES \u003d [\r\n    (\"01229108905\", \"2025-02-13\", \"2025-07-01\"),\r\n    (\"01229358979\", \"2025-02-13\", \"2025-06-12\"),\r\n    (\"01229539024\", \"2025-04-12\", \"2025-05-29\"),\r\n    (\"01229569040\", \"2025-02-14\", \"2025-06-30\"),\r\n    (\"01229619003\", \"2025-02-13\", \"2025-05-13\"),\r\n    (\"01229678905\", \"2025-02-13\", \"2025-07-01\"),\r\n    (\"01229688897\", \"2025-02-13\", \"2025-06-30\"),\r\n    (\"01229849030\", \"2025-06-27\", \"2025-06-27\"),\r\n    (\"01229888946\", \"2025-02-13\", \"2025-07-01\"),\r\n    (\"01229898990\", \"2025-02-13\", \"2025-07-01\"),\r\n    (\"01229959016\", \"2025-04-29\", \"2025-04-29\"),\r\n    (\"01229978962\", \"2025-02-13\", \"2025-07-01\"),\r\n]\r\n\r\n# ── predicates 생성 (indate 기준 주별 분할) ─────────────────\r\ndef generate_predicates(dev_id, start_str, end_str):\r\n    preds \u003d []\r\n    end \u003d datetime.strptime(end_str, \"%Y-%m-%d\") + timedelta(days\u003d1)\r\n    cur \u003d datetime.strptime(start_str, \"%Y-%m-%d\")\r\n\r\n    while cur \u003c end:\r\n        nxt \u003d min(cur + timedelta(weeks\u003d1), end)\r\n        preds.append(\r\n            f\"id \u003d \u0027{dev_id}\u0027 AND indate \u003e\u003d \u0027{cur.strftime(\u0027%Y-%m-%d\u0027)}\u0027 \"\r\n            f\"AND indate \u003c \u0027{nxt.strftime(\u0027%Y-%m-%d\u0027)}\u0027\"\r\n        )\r\n        cur \u003d nxt\r\n\r\n    # indate NULL 포함\r\n    preds.append(f\"id \u003d \u0027{dev_id}\u0027 AND indate IS NULL\")\r\n    return preds\r\n\r\nprops \u003d {\r\n    \"user\":      MYSQL_USER,\r\n    \"password\":  MYSQL_PASSWORD,\r\n    \"driver\":    \"com.mysql.cj.jdbc.Driver\",\r\n    \"fetchsize\": \"10000\",\r\n}\r\n\r\n# ── 체크포인트: Hadoop API ──────────────────────────────────\r\nhadoop_conf \u003d spark._jsc.hadoopConfiguration()\r\nfs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(\r\n    spark._jvm.java.net.URI(f\"s3a://{S3_BUCKET}\"), hadoop_conf\r\n)\r\n\r\ndef checkpoint_load():\r\n    p \u003d spark._jvm.org.apache.hadoop.fs.Path(S3_CHECKPOINT)\r\n    if not fs.exists(p):\r\n        return set()\r\n    stream \u003d fs.open(p)\r\n    reader \u003d spark._jvm.java.io.BufferedReader(\r\n        spark._jvm.java.io.InputStreamReader(stream)\r\n    )\r\n    completed \u003d set()\r\n    line \u003d reader.readLine()\r\n    while line is not None:\r\n        if line.strip():\r\n            completed.add(line.strip())\r\n        line \u003d reader.readLine()\r\n    reader.close()\r\n    return completed\r\n\r\ndef checkpoint_save(dev_id, completed):\r\n    completed.add(dev_id)\r\n    p \u003d spark._jvm.org.apache.hadoop.fs.Path(S3_CHECKPOINT)\r\n    stream \u003d fs.create(p, True)\r\n    writer \u003d spark._jvm.java.io.PrintWriter(\r\n        spark._jvm.java.io.OutputStreamWriter(stream, \"UTF-8\")\r\n    )\r\n    for d in sorted(completed):\r\n        writer.println(d)\r\n    writer.close()\r\n\r\n# ── 체크포인트 로드 ─────────────────────────────────────────\r\ncompleted \u003d checkpoint_load()\r\nif completed:\r\n    print(f\"체크포인트 로드: 완료된 단말기 {len(completed)}개 → 건너뜀\")\r\nelse:\r\n    print(\"체크포인트 없음 → 처음부터 시작\")\r\n\r\nresults \u003d []\r\n\r\n# ── 단말기별 순차 처리 ──────────────────────────────────────\r\nprint(f\"\\n[총 {len(DEVICE_DATE_RANGES)}개 단말기 처리 시작]\")\r\nfor dev_id, min_d, max_d in DEVICE_DATE_RANGES:\r\n    if dev_id in completed:\r\n        print(f\"[SKIP]  {dev_id}\")\r\n        results.append((dev_id, -1, 0, \"SKIP\"))\r\n        continue\r\n\r\n    t0 \u003d time.time()\r\n    preds \u003d generate_predicates(dev_id, min_d, max_d)\r\n    print(f\"[START] {dev_id} | predicates: {len(preds)}개\")\r\n\r\n    try:\r\n        df \u003d spark.read.jdbc(\r\n            url\u003dJDBC_URL,\r\n            table\u003dMYSQL_TABLE,\r\n            predicates\u003dpreds,\r\n            properties\u003dprops\r\n        )\r\n        out_path \u003d f\"{S3_BASE_PATH}/id\u003d{dev_id}\"\r\n        df.write \\\r\n            .mode(\"overwrite\") \\\r\n            .option(\"compression\", \"snappy\") \\\r\n            .option(\"maxRecordsPerFile\", \"2000000\") \\\r\n            .parquet(out_path)\r\n\r\n        saved \u003d spark.read.parquet(out_path).count()\r\n        elapsed \u003d round(time.time() - t0, 1)\r\n\r\n        checkpoint_save(dev_id, completed)\r\n\r\n        print(f\"[OK]    {dev_id} | {saved:,}건 | {elapsed}s\")\r\n        results.append((dev_id, saved, elapsed, \"OK\"))\r\n\r\n    except Exception as e:\r\n        elapsed \u003d round(time.time() - t0, 1)\r\n        print(f\"[FAIL]  {dev_id} | {elapsed}s | {e}\")\r\n        results.append((dev_id, -1, elapsed, \"FAIL\"))\r\n\r\n    finally:\r\n        try:\r\n            df.unpersist()\r\n        except:\r\n            pass\r\n        spark.catalog.clearCache()\r\n\r\n# ── 최종 요약 ───────────────────────────────────────────────\r\nprint(\"\\n\" + \"\u003d\" * 60)\r\nprint(\"최종 결과 요약\")\r\nprint(\"\u003d\" * 60)\r\ntotal_cnt \u003d 0\r\nfail_list \u003d []\r\nfor dev_id, cnt, elapsed, status in results:\r\n    if status \u003d\u003d \"SKIP\":\r\n        print(f\"  [SKIP]  {dev_id}\")\r\n    elif status \u003d\u003d \"OK\":\r\n        print(f\"  [OK]    {dev_id} | {cnt:\u003e10,}건 | {elapsed}s\")\r\n        total_cnt +\u003d cnt\r\n    else:\r\n        print(f\"  [FAIL]  {dev_id} | {elapsed}s\")\r\n        fail_list.append(dev_id)\r\nprint(\"\u003d\" * 60)\r\nprint(f\"  이번 실행 저장 건수: {total_cnt:,}건\")\r\nif fail_list:\r\n    print(f\"  실패 단말기 ({len(fail_list)}개): {fail_list}\")\r\nelse:\r\n    print(\"  실패 없음\")\r\nprint(\"\u003d\" * 60)",
      "user": "anonymous",
      "dateUpdated": "2026-04-01 09:31:36.558",
