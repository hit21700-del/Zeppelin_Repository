    {
      "text": "%spark.pyspark\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n# 저장 결과 검증 - kmon_new 단말기별 건수 확인\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n\r\nmysql_counts \u003d {\r\n    \"01229848911\": 3891104,\r\n    \"01229608897\":  146936,\r\n    \"01229258900\": 1077800,\r\n    \"01222292205\":   72224,\r\n}\r\n\r\nhadoop_conf \u003d spark._jsc.hadoopConfiguration()\r\nfs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(\r\n    spark._jvm.java.net.URI(\"s3a://bigdata\"), hadoop_conf\r\n)\r\n\r\ndef s3_exists(path):\r\n    return fs.exists(spark._jvm.org.apache.hadoop.fs.Path(path))\r\n\r\nprint(\"\u003d\" * 70)\r\nprint(f\"  {\u0027단말기ID\u0027:20s} {\u0027MySQL\u0027:\u003e12s} {\u0027Parquet\u0027:\u003e12s} {\u0027상태\u0027:\u003e6s}\")\r\nprint(\"\u003d\" * 70)\r\n\r\ntotal_mysql \u003d 0\r\ntotal_parq  \u003d 0\r\nfail_list   \u003d []\r\nmissing_list \u003d []\r\n\r\nfor dev_id, mysql_cnt in mysql_counts.items():\r\n    path \u003d f\"{S3_BASE_PATH}/id\u003d{dev_id}\"\r\n    total_mysql +\u003d mysql_cnt\r\n\r\n    if not s3_exists(path):\r\n        print(f\"  {dev_id:20s} {mysql_cnt:\u003e12,} {\u0027\u0027:\u003e12s}  MISSING\")\r\n        missing_list.append(dev_id)\r\n        continue\r\n\r\n    parq_cnt \u003d spark.read.parquet(path).count()\r\n    total_parq +\u003d parq_cnt\r\n    status \u003d \"OK\" if parq_cnt \u003d\u003d mysql_cnt else \"NG\"\r\n    if status \u003d\u003d \"NG\":\r\n        fail_list.append(dev_id)\r\n    print(f\"  {dev_id:20s} {mysql_cnt:\u003e12,} {parq_cnt:\u003e12,}  {status}\")\r\n\r\nprint(\"\u003d\" * 70)\r\nprint(f\"  {\u0027합계\u0027:20s} {total_mysql:\u003e12,} {total_parq:\u003e12,}\")\r\nprint(\"\u003d\" * 70)\r\nif fail_list:\r\n    print(f\"  건수 불일치: {fail_list}\")\r\nif missing_list:\r\n    print(f\"  저장 누락:   {missing_list}\")\r\nif not fail_list and not missing_list:\r\n    print(\"  전체 검증 OK\")\r\nprint(\"\u003d\" * 70)",
