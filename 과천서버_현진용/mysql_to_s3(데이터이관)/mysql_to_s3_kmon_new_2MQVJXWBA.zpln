    {
      "text": "%spark.pyspark\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n# MySQL -\u003e S3(Ceph) 마이그레이션 설정 (kmon_new)\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\nMYSQL_HOST     \u003d \"59.6.99.131\"\r\nMYSQL_PORT     \u003d \"3306\"\r\nMYSQL_DB       \u003d \"QH_KSLAB\"\r\nMYSQL_TABLE    \u003d \"kmon_new\"\r\nMYSQL_USER     \u003d \"qh\"\r\nMYSQL_PASSWORD \u003d \"qh1234!\"\r\nS3_ENDPOINT    \u003d \"http://192.168.0.105:80\"\r\nS3_BUCKET      \u003d \"bigdata\"\r\nS3_BASE_PATH   \u003d f\"s3a://{S3_BUCKET}/{MYSQL_TABLE}/parquet\"\r\nS3_CHECKPOINT  \u003d f\"s3a://{S3_BUCKET}/{MYSQL_TABLE}/checkpoint/completed.txt\"\r\nJDBC_URL \u003d (\r\n    f\"jdbc:mysql://{MYSQL_HOST}:{MYSQL_PORT}/{MYSQL_DB}\"\r\n    f\"?useSSL\u003dfalse\u0026allowPublicKeyRetrieval\u003dtrue\"\r\n)\r\nprint(\"설정 완료\")\r\nprint(f\"JDBC URL   : {JDBC_URL}\")\r\nprint(f\"저장 경로   : {S3_BASE_PATH}\")\r\nprint(f\"체크포인트  : {S3_CHECKPOINT}\")",
      "user": "anonymous",
