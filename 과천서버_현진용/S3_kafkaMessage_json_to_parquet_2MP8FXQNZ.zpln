    {
      "text": "%spark_high.pyspark\r\nfrom pyspark.sql import functions as F\r\nfrom pyspark.sql.types import (\r\n    StructType, StructField,\r\n    StringType, IntegerType, LongType, DoubleType, TimestampType\r\n)\r\nfrom datetime import datetime, timedelta\r\nimport re\r\n\r\nINPUT_ROOT  \u003d \"s3a://kafka\"\r\nOUTPUT_ROOT \u003d \"s3a://parquet\"\r\n# SOURCES     \u003d [\"kslab_emon\", \"kslab_kmon\", \"kslab_kmon3\", \"kslab_kmon_new\", \"skr\"]\r\nSOURCES     \u003d [ \"kslab_kmon\", \"kslab_kmon3\", \"kslab_emon\", \"skr\"]\r\n\r\nhc \u003d sc._jsc.hadoopConfiguration()\r\nhc.set(\"fs.s3a.endpoint\",               \"http://192.168.0.105:80\")\r\nhc.set(\"fs.s3a.access.key\",             \"8XTYLABJCSLJKUTQBK94\")\r\nhc.set(\"fs.s3a.secret.key\",             \"fKlCAYQBPEA9JOoyrfhTsIeVXr2j58M8upPCAVVR\")\r\nhc.set(\"fs.s3a.path.style.access\",      \"true\")\r\nhc.set(\"fs.s3a.impl\",                   \"org.apache.hadoop.fs.s3a.S3AFileSystem\")\r\nhc.set(\"fs.s3a.connection.ssl.enabled\", \"false\")\r\nhc.set(\"fs.s3a.signing-algorithm\",      \"S3SignerType\")\r\nprint(\"S3A 설정 완료\")",
      "user": "anonymous",
      "dateUpdated": "2026-03-27 09:18:39.358",
