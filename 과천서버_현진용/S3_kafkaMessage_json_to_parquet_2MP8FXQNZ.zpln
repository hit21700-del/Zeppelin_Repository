    {
      "text": "%spark_high.pyspark\r\n\r\ndef get_all_input_dates(source_prefix):\r\n    \"\"\"Input S3에 존재하는 모든 날짜 폴더 목록 반환\"\"\"\r\n    input_base \u003d f\"{INPUT_ROOT}/{source_prefix}\"\r\n    try:\r\n        jvm  \u003d spark._jvm\r\n        conf \u003d sc._jsc.hadoopConfiguration()\r\n        path \u003d jvm.org.apache.hadoop.fs.Path(input_base)\r\n        fs   \u003d path.getFileSystem(conf)\r\n        if not fs.exists(path):\r\n            print(f\"  [{source_prefix}] 폴더 없음, 스킵\")\r\n            return []\r\n        return sorted([\r\n            s.getPath().getName()\r\n            for s in fs.listStatus(path)\r\n            if re.match(r\"\\d{4}-\\d{2}-\\d{2}\", s.getPath().getName())\r\n        ])\r\n    except Exception as e:\r\n        print(f\"  [WARN] input 날짜 폴더 조회 실패: {e}\")\r\n        return []\r\n\r\n\r\ndef get_device_max_dates(output_base):\r\n    \"\"\"\r\n    output 폴더 목록만으로 deviceId별 max date 조회\r\n    파일 읽기 없이 폴더 목록만 사용 → 빠름\r\n    반환: {\"Agent01\": \"2024-09-01\", \"Agent02\": \"2024-08-31\"}\r\n    \"\"\"\r\n    try:\r\n        jvm  \u003d spark._jvm\r\n        conf \u003d sc._jsc.hadoopConfiguration()\r\n        path \u003d jvm.org.apache.hadoop.fs.Path(output_base)\r\n        fs   \u003d path.getFileSystem(conf)\r\n\r\n        if not fs.exists(path):\r\n            return {}\r\n\r\n        device_max_dates \u003d {}\r\n        for device in fs.listStatus(path):\r\n            if not device.getPath().getName().startswith(\"_deviceId\u003d\"):\r\n                continue\r\n            device_id \u003d device.getPath().getName().replace(\"_deviceId\u003d\", \"\")\r\n            dates \u003d [\r\n                s.getPath().getName().replace(\"_date\u003d\", \"\")\r\n                for s in fs.listStatus(device.getPath())\r\n                if s.getPath().getName().startswith(\"_date\u003d\")\r\n            ]\r\n            if dates:\r\n                device_max_dates[device_id] \u003d max(dates)\r\n\r\n        return device_max_dates\r\n    except Exception:\r\n        return {}\r\n\r\n\r\ndef get_target_dates(source_prefix):\r\n    \"\"\"\r\n    최초 실행: 전체 날짜 폴더 반환\r\n    증분 실행: deviceId별 max date 중 가장 이른 날짜 이후 폴더만 반환\r\n    \"\"\"\r\n    all_input_dates \u003d get_all_input_dates(source_prefix)\r\n    if not all_input_dates:\r\n        return [], False\r\n\r\n    output_base      \u003d f\"{OUTPUT_ROOT}/{source_prefix}\"\r\n    device_max_dates \u003d get_device_max_dates(output_base)\r\n\r\n    if not device_max_dates:\r\n        # 최초 실행\r\n        print(f\"  [최초 실행] 전체 날짜 {len(all_input_dates)}개 읽기\")\r\n        print(f\"  날짜 범위: {all_input_dates[0]} ~ {all_input_dates[-1]}\")\r\n        return all_input_dates, True\r\n    else:\r\n        # 증분 실행: deviceId별 max date 중 가장 이른 날짜 기준\r\n        min_date     \u003d min(device_max_dates.values())\r\n        target_dates \u003d [d for d in all_input_dates if d \u003e\u003d min_date]\r\n        print(f\"  [증분 실행] deviceId별 마지막 날짜: {device_max_dates}\")\r\n        print(f\"  스캔 시작일: {min_date} / 대상 폴더: {target_dates}\")\r\n        return target_dates, False\r\n\r\nprint(\"헬퍼 함수 정의 완료\")",
      "user": "anonymous",
      "dateUpdated": "2026-03-27 09:19:17.212",
