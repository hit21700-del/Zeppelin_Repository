    {
      "text": "%spark_high.pyspark\n\n# ── JSON 읽기 전용 스키마 (전체 StringType → 스키마 추론 생략용) ──\nJSON_SCHEMA \u003d StructType([\n    StructField(\"id\",                              StringType(), True),\n    StructField(\"sourceCode\",                      StringType(), True),\n    StructField(\"firmwareVersion\",                 StringType(), True),\n    StructField(\"schemaVersion\",                   StringType(), True),\n    StructField(\"insertedAt\",                      StringType(), True),\n    StructField(\"collectedAt\",                     StringType(), True),\n    StructField(\"VIN\",                             StringType(), True),\n    StructField(\"deviceId\",                        StringType(), True),\n    StructField(\"createdAt\",                       StringType(), True),\n    StructField(\"messageCode\",                     StringType(), True),\n    StructField(\"longitude\",                       StringType(), True),\n    StructField(\"latitude\",                        StringType(), True),\n    StructField(\"azimuth\",                         StringType(), True),\n    StructField(\"isEVReady\",                       StringType(), True),\n    StructField(\"totalMileage\",                    StringType(), True),\n    StructField(\"isBrake\",                         StringType(), True),\n    StructField(\"brakeDetail\",                     StringType(), True),\n    StructField(\"accelPedalDepth\",                 StringType(), True),\n    StructField(\"speed\",                           StringType(), True),\n    StructField(\"accelerationX\",                   StringType(), True),\n    StructField(\"accelerationY\",                   StringType(), True),\n    StructField(\"accelerationZ\",                   StringType(), True),\n    StructField(\"SOC\",                             StringType(), True),\n    StructField(\"displaySOC\",                      StringType(), True),\n    StructField(\"totalSlowChargeCount\",            StringType(), True),\n    StructField(\"totalSlowChargeDuration\",         StringType(), True),\n    StructField(\"totalFastChargeCount\",            StringType(), True),\n    StructField(\"totalFastChargeDuration\",         StringType(), True),\n    StructField(\"isMotorPulseWidthModulationOn\",   StringType(), True),\n    StructField(\"inverterDcInputVoltage\",          StringType(), True),\n    StructField(\"motorPhaseCurrent\",               StringType(), True),\n    StructField(\"mcuMotorRpm\",                     StringType(), True),\n    StructField(\"motorTorqueActual\",               StringType(), True),\n    StructField(\"SOH\",                             StringType(), True),\n    StructField(\"totalActiveTime\",                 StringType(), True),\n    StructField(\"batteryPackVoltage\",              StringType(), True),\n    StructField(\"batteryPackCurrent\",              StringType(), True),\n    StructField(\"inverterCapacitorVoltage\",        StringType(), True),\n    StructField(\"batteryTotalChargedCapacity\",     StringType(), True),\n    StructField(\"batteryTotalDischargedCapacity\",  StringType(), True),\n    StructField(\"batteryTotalChargedEnergy\",       StringType(), True),\n    StructField(\"batteryTotalDischargedEnergy\",    StringType(), True),\n    StructField(\"batteryMaxChargePower\",           StringType(), True),\n    StructField(\"batteryMaxDischargePower\",        StringType(), True),\n    StructField(\"isCellBalancing\",                 StringType(), True),\n    StructField(\"cellBalancingCount\",              StringType(), True),\n    StructField(\"batteryCellVoltageDiff\",          StringType(), True),\n    StructField(\"maxCellVoltageNum\",               StringType(), True),\n    StructField(\"maxCellVoltage\",                  StringType(), True),\n    StructField(\"minCellVoltageNum\",               StringType(), True),\n    StructField(\"minCellVoltage\",                  StringType(), True),\n    StructField(\"cellVoltages\",                    StringType(), True),\n    StructField(\"isBatteryHeaterRelayOn\",          StringType(), True),\n    StructField(\"airConditionerCompressor\",        StringType(), True),\n    StructField(\"insulationResistance\",            StringType(), True),\n    StructField(\"obcOutputVoltage\",                StringType(), True),\n    StructField(\"obcOutputCurrent\",                StringType(), True),\n    StructField(\"acInputVoltage\",                  StringType(), True),\n    StructField(\"ldcOutputVoltage\",                StringType(), True),\n    StructField(\"ldcOutputCurrent\",                StringType(), True),\n    StructField(\"auxiliaryBatteryVoltage\",         StringType(), True),\n    StructField(\"auxiliaryBatteryCurrent\",         StringType(), True),\n    StructField(\"auxiliaryBatterySOC\",             StringType(), True),\n    StructField(\"auxiliaryBatteryTemperature\",     StringType(), True),\n    StructField(\"motorTemperature\",                StringType(), True),\n    StructField(\"inverterTemperature\",             StringType(), True),\n    StructField(\"heatSinkTemperature\",             StringType(), True),\n    StructField(\"igbtTemperature\",                 StringType(), True),\n    StructField(\"heater1Temperature\",              StringType(), True),\n    StructField(\"maxCellTemperature\",              StringType(), True),\n    StructField(\"minCellTemperature\",              StringType(), True),\n    StructField(\"batteryModuleTemperatures\",       StringType(), True),\n    StructField(\"batteryCoolantInletTemperature\",  StringType(), True),\n    StructField(\"batteryPraBusbarTemperature\",     StringType(), True),\n    StructField(\"ltrOutletTemperature\",            StringType(), True),\n    StructField(\"internalTemperatureFront\",        StringType(), True),\n    StructField(\"externalTemperature\",             StringType(), True),\n    StructField(\"isMcuFault\",                      StringType(), True),\n    StructField(\"isMcuTorqueLimited\",              StringType(), True),\n    StructField(\"isMcuMotorControllable\",          StringType(), True),\n    StructField(\"isBmsMainRelayOn\",                StringType(), True),\n    StructField(\"isBmsBatteryUsable\",              StringType(), True),\n    StructField(\"isBmsWarning\",                    StringType(), True),\n    StructField(\"isBmsFault\",                      StringType(), True),\n    StructField(\"isBmsFused\",                      StringType(), True),\n    StructField(\"isWinterModeActive\",              StringType(), True),\n    StructField(\"bmsStatusDetail\",                 StringType(), True),\n    StructField(\"isCharge\",                        StringType(), True),\n    StructField(\"isSlowChargeConnected\",           StringType(), True),\n    StructField(\"isFastChargeConnected\",           StringType(), True),\n    StructField(\"isMcuMainRelayOffRequest\",        StringType(), True),\n    StructField(\"isMcuReady\",                      StringType(), True),\n    StructField(\"batteryExternalTemperature\",      StringType(), True),\n    StructField(\"isHvptcDrive\",                    StringType(), True),\n    StructField(\"isObcFault\",                      StringType(), True),\n    StructField(\"isObcChargeComplete\",             StringType(), True),\n    StructField(\"isObcChargeConnectedStatus\",      StringType(), True),\n    StructField(\"paddleShiftUp\",                   StringType(), True),\n    StructField(\"paddleShiftDown\",                 StringType(), True),\n    StructField(\"isFastChargeProcessingStatus\",    StringType(), True),\n    StructField(\"isFastChargeProcessError\",        StringType(), True),\n    StructField(\"obcChargeModeDcVoltage\",          StringType(), True),\n    StructField(\"obcChargeModeDcCurrent\",          StringType(), True),\n    StructField(\"obcInnerDcLinkVoltage\",           StringType(), True),\n    StructField(\"accumRegenBrakeEnergy\",           StringType(), True),\n    StructField(\"slowChargeCount\",                 StringType(), True),\n    StructField(\"fastChargeCount\",                 StringType(), True),\n    StructField(\"status\",                          StringType(), True),\n])\n\n# ── 최종 저장 타입 스키마 (원하는 타입 기준) ──────────────\nTARGET_SCHEMA \u003d StructType([\n    StructField(\"id\",                              StringType(),    True),\n    StructField(\"sourceCode\",                      StringType(),    True),\n    StructField(\"firmwareVersion\",                 StringType(),    True),\n    StructField(\"schemaVersion\",                   StringType(),    True),\n    StructField(\"insertedAt\",                      TimestampType(), True),\n    StructField(\"collectedAt\",                     TimestampType(), True),\n    StructField(\"VIN\",                             StringType(),    True),\n    StructField(\"deviceId\",                        StringType(),    True),\n    StructField(\"createdAt\",                       TimestampType(), True),\n    StructField(\"messageCode\",                     IntegerType(),   True),\n    StructField(\"longitude\",                       DoubleType(),    True),\n    StructField(\"latitude\",                        DoubleType(),    True),\n    StructField(\"azimuth\",                         DoubleType(),    True),\n    StructField(\"isEVReady\",                       IntegerType(),   True),\n    StructField(\"totalMileage\",                    IntegerType(),   True),\n    StructField(\"isBrake\",                         IntegerType(),   True),\n    StructField(\"brakeDetail\",                     StringType(),    True),\n    StructField(\"accelPedalDepth\",                 DoubleType(),    True),\n    StructField(\"speed\",                           IntegerType(),   True),\n    StructField(\"accelerationX\",                   DoubleType(),    True),\n    StructField(\"accelerationY\",                   DoubleType(),    True),\n    StructField(\"accelerationZ\",                   DoubleType(),    True),\n    StructField(\"SOC\",                             DoubleType(),    True),\n    StructField(\"displaySOC\",                      DoubleType(),    True),\n    StructField(\"totalSlowChargeCount\",            LongType(),      True),\n    StructField(\"totalSlowChargeDuration\",         LongType(),      True),\n    StructField(\"totalFastChargeCount\",            LongType(),      True),\n    StructField(\"totalFastChargeDuration\",         LongType(),      True),\n    StructField(\"isMotorPulseWidthModulationOn\",   IntegerType(),   True),\n    StructField(\"inverterDcInputVoltage\",          StringType(),    True),\n    StructField(\"motorPhaseCurrent\",               DoubleType(),    True),\n    StructField(\"mcuMotorRpm\",                     DoubleType(),    True),\n    StructField(\"motorTorqueActual\",               DoubleType(),    True),\n    StructField(\"SOH\",                             DoubleType(),    True),\n    StructField(\"totalActiveTime\",                 LongType(),      True),\n    StructField(\"batteryPackVoltage\",              DoubleType(),    True),\n    StructField(\"batteryPackCurrent\",              DoubleType(),    True),\n    StructField(\"inverterCapacitorVoltage\",        StringType(),    True),\n    StructField(\"batteryTotalChargedCapacity\",     DoubleType(),    True),\n    StructField(\"batteryTotalDischargedCapacity\",  DoubleType(),    True),\n    StructField(\"batteryTotalChargedEnergy\",       DoubleType(),    True),\n    StructField(\"batteryTotalDischargedEnergy\",    DoubleType(),    True),\n    StructField(\"batteryMaxChargePower\",           DoubleType(),    True),\n    StructField(\"batteryMaxDischargePower\",        DoubleType(),    True),\n    StructField(\"isCellBalancing\",                 IntegerType(),   True),\n    StructField(\"cellBalancingCount\",              IntegerType(),   True),\n    StructField(\"batteryCellVoltageDiff\",          DoubleType(),    True),\n    StructField(\"maxCellVoltageNum\",               IntegerType(),   True),\n    StructField(\"maxCellVoltage\",                  DoubleType(),    True),\n    StructField(\"minCellVoltageNum\",               IntegerType(),   True),\n    StructField(\"minCellVoltage\",                  DoubleType(),    True),\n    StructField(\"cellVoltages\",                    StringType(),    True),\n    StructField(\"isBatteryHeaterRelayOn\",          IntegerType(),   True),\n    StructField(\"airConditionerCompressor\",        IntegerType(),   True),\n    StructField(\"insulationResistance\",            DoubleType(),    True),\n    StructField(\"obcOutputVoltage\",                DoubleType(),    True),\n    StructField(\"obcOutputCurrent\",                DoubleType(),    True),\n    StructField(\"acInputVoltage\",                  DoubleType(),    True),\n    StructField(\"ldcOutputVoltage\",                DoubleType(),    True),\n    StructField(\"ldcOutputCurrent\",                DoubleType(),    True),\n    StructField(\"auxiliaryBatteryVoltage\",         DoubleType(),    True),\n    StructField(\"auxiliaryBatteryCurrent\",         DoubleType(),    True),\n    StructField(\"auxiliaryBatterySOC\",             DoubleType(),    True),\n    StructField(\"auxiliaryBatteryTemperature\",     DoubleType(),    True),\n    StructField(\"motorTemperature\",                DoubleType(),    True),\n    StructField(\"inverterTemperature\",             DoubleType(),    True),\n    StructField(\"heatSinkTemperature\",             DoubleType(),    True),\n    StructField(\"igbtTemperature\",                 DoubleType(),    True),\n    StructField(\"heater1Temperature\",              DoubleType(),    True),\n    StructField(\"maxCellTemperature\",              DoubleType(),    True),\n    StructField(\"minCellTemperature\",              DoubleType(),    True),\n    StructField(\"batteryModuleTemperatures\",       StringType(),    True),\n    StructField(\"batteryCoolantInletTemperature\",  DoubleType(),    True),\n    StructField(\"batteryPraBusbarTemperature\",     DoubleType(),    True),\n    StructField(\"ltrOutletTemperature\",            DoubleType(),    True),\n    StructField(\"internalTemperatureFront\",        DoubleType(),    True),\n    StructField(\"externalTemperature\",             DoubleType(),    True),\n    StructField(\"isMcuFault\",                      IntegerType(),   True),\n    StructField(\"isMcuTorqueLimited\",              IntegerType(),   True),\n    StructField(\"isMcuMotorControllable\",          IntegerType(),   True),\n    StructField(\"isBmsMainRelayOn\",                IntegerType(),   True),\n    StructField(\"isBmsBatteryUsable\",              IntegerType(),   True),\n    StructField(\"isBmsWarning\",                    IntegerType(),   True),\n    StructField(\"isBmsFault\",                      IntegerType(),   True),\n    StructField(\"isBmsFused\",                      IntegerType(),   True),\n    StructField(\"isWinterModeActive\",              IntegerType(),   True),\n    StructField(\"bmsStatusDetail\",                 StringType(),    True),\n    StructField(\"isCharge\",                        IntegerType(),   True),\n    StructField(\"isSlowChargeConnected\",           IntegerType(),   True),\n    StructField(\"isFastChargeConnected\",           IntegerType(),   True),\n    StructField(\"isMcuMainRelayOffRequest\",        IntegerType(),   True),\n    StructField(\"isMcuReady\",                      IntegerType(),   True),\n    StructField(\"batteryExternalTemperature\",      DoubleType(),    True),\n    StructField(\"isHvptcDrive\",                    IntegerType(),   True),\n    StructField(\"isObcFault\",                      IntegerType(),   True),\n    StructField(\"isObcChargeComplete\",             IntegerType(),   True),\n    StructField(\"isObcChargeConnectedStatus\",      IntegerType(),   True),\n    StructField(\"paddleShiftUp\",                   IntegerType(),   True),\n    StructField(\"paddleShiftDown\",                 IntegerType(),   True),\n    StructField(\"isFastChargeProcessingStatus\",    IntegerType(),   True),\n    StructField(\"isFastChargeProcessError\",        IntegerType(),   True),\n    StructField(\"obcChargeModeDcVoltage\",          DoubleType(),    True),\n    StructField(\"obcChargeModeDcCurrent\",          DoubleType(),    True),\n    StructField(\"obcInnerDcLinkVoltage\",           DoubleType(),    True),\n    StructField(\"accumRegenBrakeEnergy\",           DoubleType(),    True),\n    StructField(\"slowChargeCount\",                 LongType(),      True),\n    StructField(\"fastChargeCount\",                 LongType(),      True),\n    StructField(\"status\",                          StringType(),    True),\n])\n\n\ndef apply_target_schema(df):\n    \"\"\"TARGET_SCHEMA 기준 타입 변환\"\"\"\n    select_cols \u003d []\n    for field in TARGET_SCHEMA.fields:\n        col_name \u003d field.name\n        col_type \u003d field.dataType\n        if col_name in df.columns:\n            select_cols.append(F.col(col_name).cast(col_type).alias(col_name))\n        else:\n            select_cols.append(F.lit(None).cast(col_type).alias(col_name))\n    return df.select(*select_cols)\n\n\ndef convert_to_parquet(source_prefix):\n    output_base \u003d f\"{OUTPUT_ROOT}/{source_prefix}\"\n\n    print(f\"\\n{\u0027\u003d\u0027*50}\")\n    print(f\"[{source_prefix}] 시작\")\n\n    # ── 1. 처리 대상 날짜 결정 ────────────────────────────\n    target_dates, is_initial \u003d get_target_dates(source_prefix)\n\n    if not target_dates:\n        print(f\"  → 처리 대상 없음, 스킵\")\n        return\n\n    # ── 2. 월별로 그룹핑 ──────────────────────────────────\n    month_groups \u003d {}\n    for d in target_dates:\n        month_key \u003d d[:7]\n        if month_key not in month_groups:\n            month_groups[month_key] \u003d []\n        month_groups[month_key].append(d)\n\n    total_months \u003d len(month_groups)\n    print(f\"  처리 대상: {len(target_dates)}일 / {total_months}개월\")\n\n    # ── 3. 월별로 나눠서 처리 ─────────────────────────────\n    for idx, (month_key, dates) in enumerate(sorted(month_groups.items()), 1):\n        print(f\"\\n  [{idx}/{total_months}] {month_key} ({len(dates)}일치) 처리 중...\")\n\n        input_paths \u003d [\n            f\"{INPUT_ROOT}/{source_prefix}/{d}/*.json\"\n            for d in dates\n        ]\n\n        try:\n            # JSON 읽기 (전체 StringType → 스키마 추론 생략)\n            df \u003d (spark.read\n                 .option(\"mode\", \"PERMISSIVE\")\n                 .schema(JSON_SCHEMA)\n                 .json(input_paths))\n\n            # ArrayType 루트 처리\n            if len(df.columns) \u003d\u003d 1 and df.schema.fields[0].dataType.__class__.__name__ \u003d\u003d \"ArrayType\":\n                root_col \u003d df.columns[0]\n                df \u003d df.select(F.explode(F.col(root_col)).alias(\"_root\")).select(\"_root.*\")\n\n            missing \u003d [c for c in (\"deviceId\", \"createdAt\") if c not in df.columns]\n            if missing:\n                raise ValueError(f\"필수 컬럼 없음: {missing}\")\n\n            # 타입 변환\n            df \u003d apply_target_schema(df)\n\n            # input 내 중복 제거\n            df \u003d df.dropDuplicates([\"deviceId\", \"createdAt\"])\n\n            # ── 증분 실행 시 날짜별 anti-join으로 중복 방지 ──\n            if not is_initial:\n                from functools import reduce\n                anti_joined_dfs \u003d []\n                for date_str in dates:\n                    date_df \u003d df.filter(\n                        F.date_format(F.col(\"createdAt\"), \"yyyy-MM-dd\") \u003d\u003d date_str\n                    )\n                    try:\n                        existing_date_df \u003d spark.read.parquet(\n                            f\"{output_base}/_deviceId\u003d*/_date\u003d{date_str}\"\n                        )\n                        date_df \u003d date_df.join(\n                            existing_date_df.select(\"deviceId\", \"createdAt\"),\n                            on\u003d[\"deviceId\", \"createdAt\"],\n                            how\u003d\"left_anti\"\n                        )\n                        print(f\"    {date_str} anti-join 적용\")\n                    except Exception:\n                        print(f\"    {date_str} 신규 날짜\")\n                    anti_joined_dfs.append(date_df)\n\n                df \u003d reduce(lambda a, b: a.union(b), anti_joined_dfs)\n\n            # parquet 저장\n            (df\n                .withColumn(\"_deviceId\", F.col(\"deviceId\"))\n                .withColumn(\"_date\",     F.date_format(F.col(\"createdAt\"), \"yyyy-MM-dd\"))\n                .write\n                .mode(\"append\")\n                .partitionBy(\"_deviceId\", \"_date\")\n                .parquet(output_base))\n\n            print(f\"  [{idx}/{total_months}] {month_key} 완료 ✓\")\n\n        except Exception as e:\n            print(f\"  [{idx}/{total_months}] {month_key} 오류: {e}\")\n            continue\n\n    print(f\"\\n[{source_prefix}] 전체 완료 ✓\")\n",
