      "text": "%spark.pyspark\r\nfrom pyspark.sql import functions as F\r\nfrom pyspark.sql.window import Window\r\n\r\ndf \u003d spark.read.option(\"basePath\", \"s3a://parquet/kslab_kmon\") \\\r\n    .parquet(\"s3a://parquet/kslab_kmon/_deviceId\u003d01229438897/\") \\\r\n    .filter(\r\n        (F.col(\"_date\") \u003e\u003d \"2022-01-01\") \u0026\r\n        (F.col(\"_date\") \u003c\u003d \"2024-12-31\")\r\n    ) \\\r\n    .drop(\"_deviceId\", \"_date\")\r\n\r\nw \u003d Window.partitionBy(\"deviceId\").orderBy(\"createdAt\")\r\n\r\ndf \u003d df.withColumn(\r\n        \"is_change\",\r\n        F.when(F.col(\"isEvReady\") !\u003d F.lag(\"isEvReady\").over(w), 1).otherwise(0)\r\n    ) \\\r\n    .withColumn(\"evr_group\", F.sum(\"is_change\").over(w))\r\n\r\ndf_group \u003d df.groupBy(\"deviceId\", \"evr_group\", \"isEvReady\") \\\r\n             .agg(F.count(\"*\").alias(\"group_size\"))\r\n\r\ndf \u003d df.join(df_group, on\u003d[\"deviceId\", \"evr_group\", \"isEvReady\"], how\u003d\"left\")\r\n\r\ndf.filter(F.col(\"group_size\") \u003c\u003d 5) \\\r\n  .select(\"deviceId\", \"createdAt\", \"isEvReady\", \"evr_group\", \"group_size\") \\\r\n  .orderBy(\"createdAt\") \\\r\n  .show(100)",
