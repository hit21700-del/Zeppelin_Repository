{
  "paragraphs": [
    {
      "title": "skr parquet 버킷 데이터 건수 확인",
      "text": "#%spark.pyspark\r\n\r\njvm  \u003d spark._jvm\r\nconf \u003d sc._jsc.hadoopConfiguration()\r\nfs   \u003d jvm.org.apache.hadoop.fs.FileSystem.get(\r\n    jvm.java.net.URI(\"s3a://parquet\"),\r\n    conf\r\n)\r\n\r\nbase_path \u003d jvm.org.apache.hadoop.fs.Path(\"s3a://parquet/skr\")\r\ntotal_count \u003d 0\r\n\r\nprint(f\"{\u0027단말기ID\u0027:\u003c20} {\u0027건수\u0027:\u003e15}\")\r\nprint(\"\u003d\" * 40)\r\n\r\nfor device in fs.listStatus(base_path):\r\n    name \u003d device.getPath().getName()\r\n    if not name.startswith(\"_deviceId\u003d\"):\r\n        continue\r\n    device_id \u003d name.replace(\"_deviceId\u003d\", \"\")\r\n    \r\n    # 단말기별 parquet read → count\r\n    df \u003d spark.read.option(\"basePath\", \"s3a://parquet/skr\") \\\r\n               .parquet(f\"s3a://parquet/skr/{name}\")\r\n    cnt \u003d df.count()\r\n    total_count +\u003d cnt\r\n    print(f\"{device_id:\u003c20} {cnt:\u003e15,}\")\r\n\r\nprint(\"\u003d\" * 40)\r\nprint(f\"{\u0027전체 합계\u0027:\u003c20} {total_count:\u003e15,}\")",
      "user": "anonymous",
      "dateUpdated": "2026-04-15 07:58:07.599",
      "progress": 0,
