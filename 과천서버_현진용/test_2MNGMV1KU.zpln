      "text": "%spark.pyspark\nfrom pyspark.sql import functions as F\nfrom pyspark.sql.window import Window\n\ndf \u003d spark.read.option(\"basePath\", \"s3a://parquet/kslab_kmon\") \\\n    .parquet(\"s3a://parquet/kslab_kmon/_deviceId\u003d01229438897/\") \\\n    .drop(\"_deviceId\", \"_date\")\n\nw \u003d Window.partitionBy(\"deviceId\").orderBy(\"createdAt\")\n\ndf \u003d df.withColumn(\"t_dist_prev\", F.lag(\"totalMileage\").over(w)) \\\n       .withColumn(\"bacc_prev\",   F.lag(\"batteryTotalChargedCapacity\").over(w)) \\\n       .withColumn(\"badc_prev\",   F.lag(\"batteryTotalDischargedCapacity\").over(w))\n\ndf.filter(\n    (F.col(\"totalMileage\") \u003c F.col(\"t_dist_prev\")) |\n    (F.col(\"batteryTotalChargedCapacity\") \u003c F.col(\"bacc_prev\")) |\n    (F.col(\"batteryTotalDischargedCapacity\") \u003c F.col(\"badc_prev\"))\n) \\\n.select(\n    \"deviceId\", \"createdAt\",\n    \"totalMileage\", \"t_dist_prev\",\n    \"batteryTotalChargedCapacity\", \"bacc_prev\",\n    \"batteryTotalDischargedCapacity\", \"badc_prev\"\n) \\\n.orderBy(\"createdAt\") \\\n.show(100)",
