    {
      "text": "%spark.pyspark\r\nfrom pyspark.sql import functions as F\r\nMASTER_CSV_PATH \u003d \"s3a://quantum/data_folder/metaData/VehicleMaster.csv\"\r\nRAW_BASE_PATH   \u003d \"s3a://bigdata/kmon/parquet\"\r\n\r\n# ── master 로드 ────────────────────────────────────────────\r\ndf_master \u003d (\r\n    spark.read.format(\"csv\")\r\n        .option(\"header\", \"true\")\r\n        .option(\"multiLine\", \"true\")\r\n        .option(\"escape\", \"\\\"\")\r\n        .load(MASTER_CSV_PATH)\r\n        .select(\r\n            F.col(\"deviceId\").cast(\"string\").alias(\"deviceId\"),\r\n            F.col(\"sourceCode\").cast(\"string\").alias(\"sourceCode\"),\r\n            F.col(\"groupCode\").cast(\"int\").alias(\"groupCode\"),\r\n            F.col(\"vehicleNumber\").cast(\"string\").alias(\"vehicleNumber\")\r\n        )\r\n        .dropna(subset\u003d[\"deviceId\"])\r\n        .dropDuplicates([\"deviceId\"])\r\n        .withColumn(\r\n            \"deviceId_norm\",\r\n            F.when(\r\n                (F.length(F.col(\"deviceId\")) \u003d\u003d 10) \u0026\r\n                (F.substring(F.col(\"deviceId\"), 1, 1) !\u003d F.lit(\u00270\u0027)),\r\n                F.lpad(F.col(\"deviceId\"), 11, \u00270\u0027)\r\n            ).otherwise(F.col(\"deviceId\"))\r\n        )\r\n)\r\n\r\nprint(f\"master 건수: {df_master.count():,}\")\r\n\r\n# ── 단말기 목록 조회 ───────────────────────────────────────\r\njvm  \u003d spark._jvm\r\nconf \u003d sc._jsc.hadoopConfiguration()\r\npath \u003d jvm.org.apache.hadoop.fs.Path(RAW_BASE_PATH)\r\nfs   \u003d path.getFileSystem(conf)\r\n\r\ndevice_ids \u003d sorted([\r\n    s.getPath().getName().replace(\"id\u003d\", \"\")\r\n    for s in fs.listStatus(path)\r\n    if s.getPath().getName().startswith(\"id\u003d\")\r\n])\r\n\r\n# ── 단말기별 join 결과 확인 ───────────────────────────────\r\nmaster_devices \u003d set(df_master.select(\"deviceId_norm\").rdd.flatMap(lambda x: x).collect())\r\n\r\nprint(f\"\\n총 단말기 수: {len(device_ids)}\")\r\nprint(\"\u003d\" * 60)\r\nprint(f\"  {\u0027단말기ID\u0027:20s} {\u0027groupCode\u0027:\u003e10s} {\u0027상태\u0027:\u003e10s}\")\r\nprint(\"\u003d\" * 60)\r\n\r\njoin_fail \u003d []\r\nfor dev_id in device_ids:\r\n    # id_norm 변환\r\n    if len(dev_id) \u003d\u003d 10 and dev_id[0] !\u003d \u00270\u0027:\r\n        id_norm \u003d dev_id.zfill(11)\r\n    else:\r\n        id_norm \u003d dev_id\r\n\r\n    if id_norm in master_devices:\r\n        row \u003d df_master.filter(F.col(\"deviceId_norm\") \u003d\u003d id_norm) \\\r\n                       .select(\"groupCode\").first()\r\n        group_code \u003d row[\"groupCode\"] if row else None\r\n        print(f\"  {dev_id:20s} {str(group_code):\u003e10s}  OK ✅\")\r\n    else:\r\n        print(f\"  {dev_id:20s} {\u0027\u0027:\u003e10s}  JOIN 실패 ❌\")\r\n        join_fail.append(dev_id)\r\n\r\nprint(\"\u003d\" * 60)\r\nif join_fail:\r\n    print(f\"\\nJOIN 실패 단말기 ({len(join_fail)}개): {join_fail}\")\r\nelse:\r\n    print(\"\\n전체 JOIN 성공 ✅\")",
      "user": "anonymous",
