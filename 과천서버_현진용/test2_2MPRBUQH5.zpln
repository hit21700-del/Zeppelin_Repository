    {
      "text": "%spark.pyspark\r\n\r\nOUTPUT_BASE_PATH \u003d \"s3a://parquet/kslab_kmon\"\r\n\r\n# 단말기 목록 조회\r\njvm  \u003d spark._jvm\r\nconf \u003d sc._jsc.hadoopConfiguration()\r\npath \u003d jvm.org.apache.hadoop.fs.Path(OUTPUT_BASE_PATH)\r\nfs   \u003d path.getFileSystem(conf)\r\n\r\ndevice_dirs \u003d sorted([\r\n    s.getPath().getName().replace(\"_deviceId\u003d\", \"\")\r\n    for s in fs.listStatus(path)\r\n    if s.getPath().getName().startswith(\"_deviceId\u003d\")\r\n])\r\n\r\nprint(f\"총 단말기 수: {len(device_dirs)}\")\r\nprint(\"\u003d\" * 50)\r\n\r\ntotal \u003d 0\r\nfor device_id in device_dirs:\r\n    cnt \u003d spark.read.parquet(f\"{OUTPUT_BASE_PATH}/_deviceId\u003d{device_id}\").count()\r\n    total +\u003d cnt\r\n    print(f\"  {device_id}: {cnt:,}건\")\r\n\r\nprint(\"\u003d\" * 50)\r\nprint(f\"  전체 합계: {total:,}건\")",
      "user": "anonymous",
