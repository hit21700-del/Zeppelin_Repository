      "title": "mysql, bigdata 원본 건수 비교",
      "text": "%spark.pyspark\n\nS3_BASE_PATH \u003d \"s3a://bigdata/kmon/parquet\"\n\n# MySQL 기준 건수 (단말기별)\nmysql_counts \u003d {\n    \"01229438897\": 41256568, \"01229438903\": 36924332,\n    \"01229898903\": 33928264, \"01229948961\": 30350616,\n    \"01229438905\": 29862260, \"01229848920\": 29338412,\n    \"01229898943\": 28689768, \"01229898996\": 25044148,\n    \"01229838915\": 24741344, \"01229898935\": 24523332,\n    \"01229948960\": 22266864, \"01229968960\": 21961192,\n    \"01229888959\": 20952468, \"01229858910\": 19920968,\n    \"01229958961\": 18358016, \"01229848978\": 17453080,\n    \"01229618901\": 17738868, \"01229518904\": 15824592,\n    \"01229828903\": 14142776, \"01229868966\": 14726188,\n    \"01229978961\": 14007708, \"01229968996\": 12607708,\n    \"01229978913\": 11362652, \"01229528905\": 11611348,\n    \"01229208905\": 11532460, \"01229838969\": 10947552,\n    \"01229668904\": 10906792, \"01229868912\":  8148632,\n    \"01229528904\":  8124956, \"01229968965\":  7686676,\n    \"01229938960\":  7485424, \"01229559364\":  7509400,\n    \"01229219366\":  4444680, \"01229238905\":  5561764,\n    \"01229258900\":  3935116, \"01229518905\":  4562236,\n    \"01229828961\":  5651848, \"01229848911\":  5005496,\n    \"01229859021\":  5931472, \"01229958978\":  5774216,\n    \"01229968961\":  5927116, \"01229438904\":  3185048,\n    \"01229508904\":  3003884, \"01229838902\":  3665248,\n    \"01229838918\":  4319636, \"01229848956\":  3246228,\n    \"01229888910\":  3257456, \"01229889022\":  3231640,\n    \"01229898971\":  3281588, \"01229948937\":  4531744,\n    \"01229898913\":  4558392, \"01229268895\":  2590936,\n    \"01229298900\":  2205252, \"01229168898\":  2771208,\n    \"01229198901\":  2276744, \"01229848988\":   683000,\n    \"01229838910\":   650688, \"01229518902\":  1501328,\n    \"01229638933\":   795972, \"01229428953\":   861340,\n    \"01229958960\":  2212956, \"01229968962\":  2360620,\n    \"01229279367\":  1612768, \"01229898910\":  1595044,\n    \"01229408898\":      108, \"01229459372\":    26594,\n    \"01229608897\":      448, \"01229628897\":   116424,\n    \"01229808904\":       64, \"01229848907\":       64,\n    \"01229858987\":    65600,\n}\n\nfs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(\n    spark._jvm.java.net.URI(\"s3a://bigdata\"),\n    sc._jsc.hadoopConfiguration()\n)\n\ndef s3_exists(path):\n    return fs.exists(spark._jvm.org.apache.hadoop.fs.Path(path))\n\nprint(\"\u003d\" * 70)\nprint(f\"  {\u0027단말기ID\u0027:20s} {\u0027MySQL\u0027:\u003e12s} {\u0027Parquet\u0027:\u003e12s} {\u0027상태\u0027:\u003e6s}\")\nprint(\"\u003d\" * 70)\n\ntotal_mysql  \u003d 0\ntotal_parq   \u003d 0\nfail_list    \u003d []\nmissing_list \u003d []\n\nfor dev_id, mysql_cnt in sorted(mysql_counts.items()):\n    path \u003d f\"{S3_BASE_PATH}/id\u003d{dev_id}\"\n    total_mysql +\u003d mysql_cnt\n\n    if not s3_exists(path):\n        print(f\"  {dev_id:20s} {mysql_cnt:\u003e12,} {\u0027\u0027:\u003e12s}  MISSING\")\n        missing_list.append(dev_id)\n        continue\n\n    parq_cnt \u003d spark.read.parquet(path).count()\n    total_parq +\u003d parq_cnt\n    status \u003d \"OK\" if parq_cnt \u003d\u003d mysql_cnt else \"NG\"\n    if status \u003d\u003d \"NG\":\n        fail_list.append(dev_id)\n    print(f\"  {dev_id:20s} {mysql_cnt:\u003e12,} {parq_cnt:\u003e12,}  {status}\")\n\nprint(\"\u003d\" * 70)\nprint(f\"  {\u0027합계\u0027:20s} {total_mysql:\u003e12,} {total_parq:\u003e12,}\")\nprint(\"\u003d\" * 70)\nif fail_list:\n    print(f\"\\n  건수 불일치 ({len(fail_list)}개): {fail_list}\")\nif missing_list:\n    print(f\"\\n  저장 누락   ({len(missing_list)}개): {missing_list}\")\nif not fail_list and not missing_list:\n    print(\"\\n  전체 검증 OK ✅\")\nprint(\"\u003d\" * 70)",
