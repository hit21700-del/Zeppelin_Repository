{
  "paragraphs": [
    {
      "text": "%spark.pyspark\r\n\r\nfrom pyspark.sql import functions as F\r\n\r\ndf \u003d (\r\n    spark.read\r\n    .option(\"recursiveFileLookup\", \"true\")\r\n    .parquet(\"s3a://parquet/kslab_kmon_new/\")\r\n)\r\n\r\ndf \u003d df.withColumn(\"createdAt\", F.to_timestamp(\"createdAt\"))\r\n\r\nresult \u003d (\r\n    df.groupBy(\"deviceId\")\r\n      .agg(\r\n          F.min(\"createdAt\").alias(\"min_createdAt\"),\r\n          F.max(\"createdAt\").alias(\"max_createdAt\"),\r\n          F.count(\"*\").alias(\"row_count\")\r\n      )\r\n)\r\n\r\nresult.show(1000, False)",
      "user": "anonymous",
      "dateUpdated": "2026-03-20 01:02:52.165",
      "progress": 90,
      "config": {
        "editorSetting": {
