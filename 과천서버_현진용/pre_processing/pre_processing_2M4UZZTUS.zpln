{
  "paragraphs": [
    {
      "title": "config 파일 import",
      "text": "%spark.pyspark\n\nimport sys\n# sys.path.append(\"/home/kadap/python/pre_processing\") # 이전 테스트 경로\nsys.path.append(\"/home/kadap/QH/Pre_Processed\")\nfrom typing import Optional, List, Dict, Any\nfrom pyspark.sql import functions as F\nfrom pyspark.sql import SparkSession, DataFrame\nfrom pyspark.sql.functions import (\n    col, lit, when, count, sum as sum_, min, max, avg, \n    to_timestamp, unix_timestamp, from_unixtime,\n    date_format, hour, minute, second, \n    lag, lead, window, expr, round\n)\nfrom pyspark.sql.window import Window\nfrom pyspark.sql.types import (\n    StructType, StructField, StringType, IntegerType, \n    DoubleType, TimestampType, BooleanType\n)\n\nfrom kslab_config import( PP_IO_CONFIG, PROCESSING_PARAMS, DB_CONFIG, SELECTED_COLUMNS, \n                        SELECTED_COLUMNS_FINAL, DB_QUERY_KMON_DATA, DB_QUERY_MASTER_DATA, BUS_COLUMNS)\nfrom kslab_utils import (\n    print_timestamp, print_dfcount, create_spark_session,\n    load_data_from_db, load_data_from_csv, save_to_csv, save_to_db, load_vehicle_info,load_vehicle_master,save_to_parquet,load_data_from_parquet\n)\n\nfrom kslab_pp_func import (\n    convert_df_new, bit_process, add_status, select_columns, remove_outlier1,\n    remove_outlier2, add_columns, add_sox, attach_vehicle_master,attach_vehicle_info, get_last_processed_date\n)\n\n#from kslab_anomaly_label_func import AnomalyLabeler\n\n\n\nprint(DB_CONFIG[\"dbname\"], PP_IO_CONFIG[\"output\"][\"format\"])\n",
      "user": "anonymous",
      "dateUpdated": "2026-02-11 05:27:34.674",
      "progress": 0,
