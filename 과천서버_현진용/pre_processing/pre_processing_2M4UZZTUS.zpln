    {
      "title": "서비스용 데이터셋 생성",
      "text": "%spark.pyspark\r\n\r\ndef process_data(spark: SparkSession) -\u003e DataFrame:\r\n    \r\n    # ─────────────────────────────────\r\n    # Step 0: 기존 결과에서 마지막 createdAt 조회\r\n    # ─────────────────────────────────\r\n    print_timestamp(\"Step 0\u003e Get last processed date from output parquet\")\r\n    last_dt \u003d get_last_processed_date(spark)\r\n    print(f\"[LOG] last_dt \u003d {last_dt}\")\r\n\r\n    if last_dt is None:\r\n        print(\"[Batch] 최초 실행: 전체 데이터를 처리합니다.\")\r\n    else:\r\n        print(f\"[Batch] 증분 실행: createdAt \u003e {last_dt} 인 데이터만 처리합니다.\")\r\n    \r\n    # ─────────────────────────────────\r\n    # Step 1: Load data (parquet only)\r\n    # ─────────────────────────────────\r\n    print_timestamp(\"Step 1\u003e Loading data (parquet)\")\r\n    df \u003d load_data_from_parquet(\r\n        spark,\r\n        file_path\u003dPP_IO_CONFIG[\u0027input\u0027][\u0027parquet_path\u0027],\r\n        recursive\u003dTrue,\r\n        only_parquet\u003dTrue\r\n    )\r\n\r\n    # 입력 데이터 전체 개수 로그\r\n    try:\r\n        cnt_total \u003d df.count()\r\n        print(f\"[LOG] Step1 Input Count (Before Filter): {cnt_total}\")\r\n    except:\r\n        print(\"[LOG] Step1 Input Count: unable to count (lazy until action)\")\r\n\r\n    # ─────────────────────────────────\r\n    # Step 1-1: 증분 필터 적용\r\n    # ─────────────────────────────────\r\n    if last_dt is not None:\r\n        print_timestamp(\"Step 1-1\u003e Applying incremental filter\")\r\n        df \u003d df.filter(F.col(\"createdAt\") \u003e F.lit(last_dt))\r\n\r\n        # 필터 후 데이터 수 확인\r\n        cnt_incr \u003d df.count()\r\n        print(f\"[LOG] After Incremental Filter Count: {cnt_incr}\")\r\n\r\n        # pushdown 확인용 explain\r\n        print(\"[LOG] Filter Explain Plan:\")\r\n        df.explain(True)\r\n\r\n    else:\r\n        print(\"[LOG] 최초 실행이므로 필터 적용 안함.\")\r\n\r\n    # Step 6-1: 이상치 제거 1\r\n    print_timestamp(\"Step 6-1\u003e remove_short_evr_anomalies\")\r\n    df \u003d remove_outlier1(df)\r\n\r\n    # Step 6-2: Remove outliers 2\r\n    print_timestamp(\"Step 6-2\u003e Removing outliers\")\r\n    df \u003d remove_outlier2(df)\r\n\r\n    # Step 7: 분석 컬럼(관제용) 추가\r\n    print_timestamp(\"Step 7\u003e Adding analysis columns\")\r\n    df \u003d add_columns(df)\r\n\r\n    # Step metaData merge\r\n    print_timestamp(\"Step meta\u003e Add/merge meta columns\")\r\n    vm \u003d load_vehicle_master(spark, PP_IO_CONFIG[\u0027meta\u0027][\u0027vehicle_master\u0027])\r\n    vi \u003d load_vehicle_info(  spark, PP_IO_CONFIG[\u0027meta\u0027][\u0027vehicle_info\u0027])\r\n\r\n    df \u003d attach_vehicle_master(df, vm)\r\n    df \u003d attach_vehicle_info(df, vi)\r\n\r\n    # Step 8: SOB, SOP 추가\r\n    print_timestamp(\"Step 8\u003e Adding SOB and SOP\")\r\n    df \u003d add_sox(df)\r\n\r\n    # ──────────────────────────────────\r\n    # 파티션용 일자 컬럼 생성\r\n    # ──────────────────────────────────\r\n    df \u003d df.withColumn(\r\n        \"pt_date\",\r\n        F.date_format(F.col(\"createdAt\"), \"yyyyMMdd\")\r\n    )\r\n    \r\n    # Step 10: Select final columns \r\n    print_timestamp(\"Step 10\u003e Selecting final columns\")\r\n    \r\n    cols \u003d SELECTED_COLUMNS_FINAL\r\n    if \"pt_date\" not in cols:\r\n        cols \u003d cols + [\"pt_date\"]\r\n\r\n    result_df \u003d df.select(*cols)\r\n\r\n    print(f\"[LOG] Final Result Count Before Save: {result_df.count()}\")\r\n\r\n    # Step 11: Save results\r\n    print_timestamp(\"Step 11\u003e Saving results\")\r\n    fmt \u003d PP_IO_CONFIG[\u0027output\u0027][\u0027format\u0027].lower()\r\n    \r\n    if fmt \u003d\u003d \u0027parquet\u0027:\r\n        out_path \u003d PP_IO_CONFIG[\u0027output\u0027][\u0027parquet_path\u0027]\r\n        print(f\"[LOG] Saving parquet to Path: {out_path}\")\r\n        save_to_parquet(\r\n            result_df,\r\n            output_path\u003dout_path,\r\n            mode\u003d\"append\",\r\n            partition_cols\u003d[\"deviceId\", \"pt_date\"]\r\n        )\r\n    elif fmt \u003d\u003d \u0027csv\u0027:\r\n        out_path \u003d PP_IO_CONFIG[\u0027output\u0027][\u0027csv_path\u0027]\r\n        print(f\"[LOG] Saving CSV to Path: {out_path}\")\r\n        os.makedirs(os.path.dirname(out_path), exist_ok\u003dTrue)\r\n        save_to_csv(result_df, out_path)\r\n    else:\r\n        print(f\"[LOG] Saving DB Table: {PP_IO_CONFIG[\u0027output\u0027][\u0027db_table\u0027]}\")\r\n        save_to_db(result_df, table_name\u003dPP_IO_CONFIG[\u0027output\u0027][\u0027db_table\u0027], mode\u003d\"overwrite\")\r\n\r\n    print_timestamp(\"Processing complete.\")\r\n    return result_df\r\n",
      "user": "anonymous",
      "dateUpdated": "2026-02-11 05:27:36.701",
      "progress": 0,
