    {
      "title": "메인 처리",
      "text": "%spark.pyspark\r\n\r\nimport time\r\nfrom datetime import datetime, timedelta\r\n\r\n# ── predicates 생성 함수 ────────────────────────────────────\r\ndef generate_predicates(dev_id, start_str, end_str):\r\n    preds \u003d []\r\n    start \u003d datetime.strptime(start_str, \"%Y-%m-%d\")\r\n    end   \u003d datetime.strptime(end_str,   \"%Y-%m-%d\") + timedelta(days\u003d1)\r\n    cur   \u003d start\r\n\r\n    while cur \u003c end:\r\n        nxt \u003d cur + timedelta(weeks\u003d1)\r\n        nxt \u003d min(nxt, end)\r\n        preds.append(\r\n            f\"DEV_ID \u003d \u0027{dev_id}\u0027 AND COLL_DT \u003e\u003d \u0027{cur.strftime(\u0027%Y-%m-%d %H:%M:%S\u0027)}\u0027 \"\r\n            f\"AND COLL_DT \u003c \u0027{nxt.strftime(\u0027%Y-%m-%d %H:%M:%S\u0027)}\u0027\"\r\n        )\r\n        cur \u003d nxt\r\n\r\n    # 이상값 포함 (start_str 이전 데이터)\r\n    preds.append(f\"DEV_ID \u003d \u0027{dev_id}\u0027 AND COLL_DT \u003c \u0027{start_str}\u0027\")\r\n    preds.append(f\"DEV_ID \u003d \u0027{dev_id}\u0027 AND COLL_DT IS NULL\")\r\n    return preds\r\n\r\n# ── 단말기별 min/max COLL_DT ────────────────────────────────\r\nDEVICE_DATE_RANGES \u003d [\r\n    (\"M1200607241\", \"2022-05-01\", \"2024-02-20\"),\r\n    (\"M1200607176\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M1200607194\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M1200607167\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M1200607171\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M1200607232\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M1200607195\", \"2022-05-01\", \"2023-10-13\"),\r\n    (\"M1200606299\", \"2022-05-01\", \"2023-12-06\"),\r\n    (\"M2210703939\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211120170\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211121453\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211120563\", \"2022-05-01\", \"2024-06-30\"),\r\n    (\"M2211120468\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211122630\", \"2022-05-01\", \"2024-05-03\"),\r\n    (\"M2211122704\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211121403\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211120829\", \"1980-01-06\", \"2024-06-30\"),  # 1980년 이상값\r\n    (\"M2211120356\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211121500\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2210704273\", \"2022-05-02\", \"2024-06-30\"),\r\n    (\"M2211120503\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120304\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120865\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211121578\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211122750\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211121326\", \"2023-01-01\", \"2024-06-29\"),\r\n    (\"M2211120936\", \"2022-05-02\", \"2024-07-01\"),\r\n    (\"M2210704240\", \"2022-05-02\", \"2024-06-29\"),\r\n    (\"M2211120490\", \"2022-05-01\", \"2024-03-11\"),\r\n    (\"M2211120907\", \"2022-05-02\", \"2024-04-23\"),\r\n    (\"M2210704201\", \"2022-05-01\", \"2024-06-29\"),\r\n    (\"M2211120504\", \"2022-05-01\", \"2024-03-13\"),\r\n    (\"M2211120854\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120331\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120379\", \"2022-05-02\", \"2024-07-01\"),\r\n    (\"M2211120185\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120798\", \"2022-05-01\", \"2024-06-19\"),\r\n    (\"M2210703615\", \"2022-05-01\", \"2024-06-28\"),\r\n    (\"M2211120479\", \"2022-05-01\", \"2024-06-30\"),\r\n    (\"M2211120220\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120565\", \"2022-05-03\", \"2024-07-01\"),\r\n    (\"M2211120191\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2210704209\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211122916\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120426\", \"2022-05-01\", \"2024-03-05\"),\r\n    (\"M2211120980\", \"2022-05-06\", \"2024-06-30\"),\r\n    (\"M2211120460\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211121223\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120391\", \"2022-05-01\", \"2024-06-30\"),\r\n    (\"M2211120366\", \"2022-05-01\", \"2024-06-29\"),\r\n    (\"M2211120129\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211121330\", \"2023-01-02\", \"2024-06-29\"),\r\n    (\"M2210703944\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211121260\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211121217\", \"2022-05-02\", \"2024-06-30\"),\r\n    (\"M2211120443\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120181\", \"2022-05-02\", \"2024-06-30\"),\r\n    (\"M2211121248\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211121269\", \"2022-05-02\", \"2024-06-30\"),\r\n    (\"M2210704163\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120383\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211122603\", \"2022-05-01\", \"2024-06-30\"),\r\n    (\"M2210703804\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211120496\", \"2022-05-02\", \"2024-01-11\"),\r\n    (\"M2211120982\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120537\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120317\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120918\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211121553\", \"2022-05-02\", \"2024-07-01\"),\r\n    (\"M2211120523\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120405\", \"2022-05-01\", \"2024-06-30\"),\r\n    (\"M2211121566\", \"2022-05-06\", \"2024-07-01\"),\r\n    (\"M2211120189\", \"2022-05-02\", \"2024-06-29\"),\r\n    (\"M2211120393\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211122747\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211121394\", \"2022-05-02\", \"2024-06-30\"),\r\n    (\"M2211120997\", \"2022-05-01\", \"2024-06-29\"),\r\n    (\"M2211120591\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211122880\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120272\", \"2022-05-01\", \"2024-06-30\"),\r\n    (\"M2211120596\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211122941\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2210704248\", \"2022-05-04\", \"2024-06-29\"),\r\n    (\"M2211121292\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211121252\", \"2022-05-01\", \"2024-06-30\"),\r\n    (\"M2211121505\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211120446\", \"2022-05-02\", \"2024-07-01\"),\r\n    (\"M2211123023\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120578\", \"2022-05-02\", \"2024-06-29\"),\r\n    (\"M2211120137\", \"2022-05-02\", \"2024-07-01\"),\r\n    (\"M2211120125\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120230\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120229\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120114\", \"2022-05-02\", \"2024-06-29\"),\r\n    (\"M2211120532\", \"2022-05-01\", \"2024-06-30\"),\r\n    (\"M2210703935\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211120572\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120584\", \"2022-05-04\", \"2024-06-30\"),\r\n    (\"M2211121362\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211121241\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211120771\", \"2022-05-01\", \"2024-07-01\"),\r\n    (\"M2211120247\", \"2023-01-01\", \"2024-06-29\"),\r\n    (\"M2211121272\", \"2023-01-02\", \"2024-07-01\"),\r\n    (\"M2220343345\", \"2023-01-01\", \"2024-01-01\"),\r\n    (\"M2210703946\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211121535\", \"2023-01-03\", \"2024-06-30\"),\r\n    (\"M2210704282\", \"2023-05-26\", \"2024-07-01\"),\r\n    (\"M2210703695\", \"2023-01-21\", \"2024-07-01\"),\r\n    (\"M2211120160\", \"2023-01-01\", \"2024-07-01\"),\r\n    (\"M2211120271\", \"2023-01-01\", \"2024-06-29\"),\r\n    (\"M2211121436\", \"2023-01-02\", \"2024-07-01\"),\r\n    (\"M2211122692\", \"2023-05-26\", \"2024-07-01\"),\r\n    (\"M2211121497\", \"2023-01-02\", \"2024-07-01\"),\r\n    (\"M2211121494\", \"2023-01-01\", \"2024-06-30\"),\r\n    (\"M2220343742\", \"2023-01-01\", \"2024-01-01\"),\r\n    (\"M2211122684\", \"2023-05-26\", \"2024-07-01\"),\r\n    (\"M2220344183\", \"2023-01-01\", \"2024-01-01\"),\r\n    (\"M2211120570\", \"2023-05-26\", \"2024-06-30\"),\r\n    (\"M2211121530\", \"2023-05-26\", \"2024-06-28\"),\r\n    (\"M2211122685\", \"2023-05-26\", \"2024-07-01\"),\r\n    (\"M2210704270\", \"2023-05-25\", \"2024-07-01\"),\r\n    (\"M2211120590\", \"2023-05-26\", \"2024-07-01\"),\r\n    (\"M2220344285\", \"2023-01-01\", \"2023-12-31\"),\r\n    (\"M2220343975\", \"2023-01-02\", \"2023-12-29\"),\r\n    (\"M2211122675\", \"2023-05-26\", \"2024-07-01\"),\r\n    (\"M2210704284\", \"2023-05-26\", \"2024-07-01\"),\r\n    (\"M2220343611\", \"2023-01-04\", \"2024-01-01\"),\r\n    (\"M2220343620\", \"2023-01-01\", \"2024-01-01\"),\r\n    (\"M2220344199\", \"2023-01-01\", \"2024-01-01\"),\r\n    (\"M2220343366\", \"2023-01-02\", \"2024-01-01\"),\r\n    (\"M2211120266\", \"2023-01-01\", \"2024-06-30\"),\r\n    (\"M2220343629\", \"2023-01-01\", \"2024-01-01\"),\r\n    (\"M2220344721\", \"2023-01-01\", \"2023-12-30\"),\r\n    (\"M2220343140\", \"2023-01-01\", \"2024-01-01\"),\r\n    (\"M2220344841\", \"2023-01-01\", \"2024-01-01\"),\r\n    (\"M2211120265\", \"2023-01-01\", \"2024-04-02\"),\r\n    (\"M2220344846\", \"2023-01-01\", \"2024-01-01\"),\r\n    (\"M2220344514\", \"2023-01-02\", \"2024-01-01\"),\r\n    (\"M2220344882\", \"2023-01-01\", \"2024-01-01\"),\r\n    (\"M2220344870\", \"2023-01-02\", \"2023-12-31\"),\r\n    (\"M2220878581\", \"2023-01-01\", \"2024-01-01\"),\r\n    (\"M2220344874\", \"2023-01-01\", \"2024-01-01\"),\r\n]\r\n\r\nprops \u003d {\r\n    \"user\":     MYSQL_USER,\r\n    \"password\": MYSQL_PASSWORD,\r\n    \"driver\":   \"com.mysql.cj.jdbc.Driver\",\r\n    \"fetchsize\": \"10000\",\r\n}\r\n\r\nBASE_PATH  \u003d f\"s3a://{S3_BUCKET}/skr/parquet\"\r\nCHECKPOINT \u003d f\"s3a://{S3_BUCKET}/skr/checkpoint/completed.txt\"\r\n\r\n# ── 체크포인트: Hadoop API 사용 ─────────────────────────────\r\nhadoop_conf \u003d spark._jsc.hadoopConfiguration()\r\nfs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(\r\n    spark._jvm.java.net.URI(f\"s3a://{S3_BUCKET}\"), hadoop_conf\r\n)\r\n\r\ndef checkpoint_load():\r\n    p \u003d spark._jvm.org.apache.hadoop.fs.Path(CHECKPOINT)\r\n    if not fs.exists(p):\r\n        return set()\r\n    stream \u003d fs.open(p)\r\n    reader \u003d spark._jvm.java.io.BufferedReader(\r\n        spark._jvm.java.io.InputStreamReader(stream)\r\n    )\r\n    completed \u003d set()\r\n    line \u003d reader.readLine()\r\n    while line is not None:\r\n        if line.strip():\r\n            completed.add(line.strip())\r\n        line \u003d reader.readLine()\r\n    reader.close()\r\n    return completed\r\n\r\ndef checkpoint_save(dev_id, completed):\r\n    completed.add(dev_id)\r\n    p \u003d spark._jvm.org.apache.hadoop.fs.Path(CHECKPOINT)\r\n    stream \u003d fs.create(p, True)\r\n    writer \u003d spark._jvm.java.io.PrintWriter(\r\n        spark._jvm.java.io.OutputStreamWriter(stream, \"UTF-8\")\r\n    )\r\n    for d in sorted(completed):\r\n        writer.println(d)\r\n    writer.close()\r\n\r\n# ── 체크포인트 로드 ─────────────────────────────────────────\r\ncompleted \u003d checkpoint_load()\r\nif completed:\r\n    print(f\"체크포인트 로드: 완료된 단말기 {len(completed)}개 → 건너뜀\")\r\nelse:\r\n    print(\"체크포인트 없음 → 처음부터 시작\")\r\n\r\nNG_IDS \u003d set()  # 재처리 대상 (초기 실행 시 비워둠)\r\n\r\nresults \u003d []\r\n\r\n# ── 단말기별 순차 처리 ──────────────────────────────────────\r\nprint(f\"\\n[총 {len(DEVICE_DATE_RANGES)}개 단말기 처리 시작]\")\r\nfor dev_id, min_d, max_d in DEVICE_DATE_RANGES:\r\n    if dev_id in completed and dev_id not in NG_IDS:\r\n        print(f\"[SKIP]  {dev_id}\")\r\n        results.append((dev_id, -1, 0, \"SKIP\"))\r\n        continue\r\n\r\n    t0 \u003d time.time()\r\n    preds \u003d generate_predicates(dev_id, min_d, max_d)\r\n    print(f\"[START] {dev_id} | predicates: {len(preds)}개\")\r\n\r\n    try:\r\n        df \u003d spark.read.jdbc(\r\n            url\u003dJDBC_URL,\r\n            table\u003dMYSQL_TABLE,\r\n            predicates\u003dpreds,\r\n            properties\u003dprops\r\n        )\r\n        out_path \u003d f\"{BASE_PATH}/id\u003d{dev_id}\"\r\n        df.write \\\r\n            .mode(\"overwrite\") \\\r\n            .option(\"compression\", \"snappy\") \\\r\n            .option(\"maxRecordsPerFile\", \"2000000\") \\\r\n            .parquet(out_path)\r\n\r\n        saved \u003d spark.read.parquet(out_path).count()\r\n        elapsed \u003d round(time.time() - t0, 1)\r\n\r\n        checkpoint_save(dev_id, completed)\r\n\r\n        print(f\"[OK]    {dev_id} | {saved:,}건 | {elapsed}s\")\r\n        results.append((dev_id, saved, elapsed, \"OK\"))\r\n\r\n    except Exception as e:\r\n        elapsed \u003d round(time.time() - t0, 1)\r\n        print(f\"[FAIL]  {dev_id} | {elapsed}s | {e}\")\r\n        results.append((dev_id, -1, elapsed, \"FAIL\"))\r\n\r\n    finally:\r\n        try:\r\n            df.unpersist()\r\n        except:\r\n            pass\r\n        spark.catalog.clearCache()\r\n\r\n# ── 최종 요약 ───────────────────────────────────────────────\r\nprint(\"\\n\" + \"\u003d\" * 60)\r\nprint(\"최종 결과 요약\")\r\nprint(\"\u003d\" * 60)\r\ntotal_cnt \u003d 0\r\nfail_list \u003d []\r\nfor dev_id, cnt, elapsed, status in results:\r\n    if status \u003d\u003d \"SKIP\":\r\n        print(f\"  [SKIP]  {dev_id:20s}\")\r\n    elif status \u003d\u003d \"OK\":\r\n        print(f\"  [OK]    {dev_id:20s} | {cnt:\u003e12,}건 | {elapsed}s\")\r\n        total_cnt +\u003d cnt\r\n    else:\r\n        print(f\"  [FAIL]  {dev_id:20s} | {elapsed}s\")\r\n        fail_list.append(dev_id)\r\nprint(\"\u003d\" * 60)\r\nprint(f\"  이번 실행 저장 건수: {total_cnt:,}건\")\r\nif fail_list:\r\n    print(f\"  실패 단말기 ({len(fail_list)}개): {fail_list}\")\r\nelse:\r\n    print(\"  실패 없음\")\r\nprint(\"\u003d\" * 60)",
