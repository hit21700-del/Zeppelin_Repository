2210703946\":  1235715, \"M2211121535\":  1232970,\r\n    \"M2210704282\":  1210622, \"M2210703695\":  1199801,\r\n    \"M2211120160\":  1193547, \"M2211120271\":  1189066,\r\n    \"M2211121436\":  1151590, \"M2211122692\":  1131708,\r\n    \"M2211121497\":  1112457, \"M2211121494\":  1064659,\r\n    \"M2220343742\":  1027560, \"M2211122684\":   876325,\r\n    \"M2220344183\":   858702, \"M2211120570\":   807904,\r\n    \"M2211121530\":   783600, \"M2211122685\":   740305,\r\n    \"M2210704270\":   738615, \"M2211120590\":   728380,\r\n    \"M2220344285\":   704417, \"M2220343975\":   698279,\r\n    \"M2211122675\":   684893, \"M2210704284\":   656203,\r\n    \"M2220343611\":   650268, \"M2220343620\":   649749,\r\n    \"M2220344199\":   638136, \"M2220343366\":   576011,\r\n    \"M2211120266\":   569419, \"M2220343629\":   549179,\r\n    \"M2220344721\":   544669, \"M2220343140\":   524380,\r\n    \"M2220344841\":   509312, \"M2211120265\":   501460,\r\n    \"M2220344846\":   495193, \"M2220344514\":   481556,\r\n    \"M2220344882\":   477718, \"M2220344870\":   467416,\r\n    \"M2220878581\":   453948, \"M2220344874\":   416273,\r\n}\r\n\r\nhadoop_conf \u003d spark._jsc.hadoopConfiguration()\r\nfs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(\r\n    spark._jvm.java.net.URI(\"s3a://bigdata\"), hadoop_conf\r\n)\r\n\r\ndef s3_exists(path):\r\n    return fs.exists(spark._jvm.org.apache.hadoop.fs.Path(path))\r\n\r\nBASE_PATH \u003d f\"s3a://{S3_BUCKET}/skr/parquet\"\r\n\r\nprint(\"\u003d\" * 70)\r\nprint(f\"  {\u0027단말기ID\u0027:20s} {\u0027MySQL\u0027:\u003e12s} {\u0027Parquet\u0027:\u003e12s} {\u0027상태\u0027:\u003e6s}\")\r\nprint(\"\u003d\" * 70)\r\n\r\ntotal_mysql \u003d 0\r\ntotal_parq  \u003d 0\r\nfail_list   \u003d []\r\nmissing_list \u003d []\r\n\r\nfor dev_id, mysql_cnt in mysql_counts.items():\r\n    path \u003d f\"{BASE_PATH}/id\u003d{dev_id}\"\r\n    total_mysql +\u003d mysql_cnt\r\n\r\n    if not s3_exists(path):\r\n        print(f\"  {dev_id:20s} {mysql_cnt:\u003e12,} {\u0027\u0027:\u003e12s}  MISSING\")\r\n        missing_list.append(dev_id)\r\n        continue\r\n\r\n    parq_cnt \u003d spark.read.parquet(path).count()\r\n    total_parq +\u003d parq_cnt\r\n    status \u003d \"OK\" if parq_cnt \u003d\u003d mysql_cnt else \"NG\"\r\n    if status \u003d\u003d \"NG\":\r\n        fail_list.append(dev_id)\r\n    print(f\"  {dev_id:20s} {mysql_cnt:\u003e12,} {parq_cnt:\u003e12,}  {status}\")\r\n\r\nprint(\"\u003d\" * 70)\r\nprint(f\"  {\u0027합계\u0027:20s} {total_mysql:\u003e12,} {total_parq:\u003e12,}\")\r\nprint(\"\u003d\" * 70)\r\nif fail_list:\r\n    print(f\"  건수 불일치: {fail_list}\")\r\nif missing_list:\r\n    print(f\"  저장 누락:   {missing_list}\")\r\nif not fail_list and not missing_list:\r\n    print(\"  전체 검증 OK\")\r\nprint(\"\u003d\" * 70)",
