    {
      "title": "특정날짜 기준으로 특정 단말기의 누락이 명확할때 사용",
      "text": "#%spark.pyspark\nimport time\n\nprops \u003d {\n    \"user\":     MYSQL_USER,\n    \"password\": MYSQL_PASSWORD,\n    \"driver\":   \"com.mysql.cj.jdbc.Driver\",\n    \"fetchsize\": \"10000\",\n}\n\nBASE_PATH \u003d f\"s3a://{S3_BUCKET}/{MYSQL_TABLE}/parquet\"\n\n# 1999-01-01 이전 데이터가 누락된 5개 단말기\ntarget_ids \u003d [\n    \"01229518904\",\n    \"01229828903\",\n    \"01229608897\",\n    \"01229628897\",\n    \"01229858987\",\n]\n\nfor dev_id in target_ids:\n    t0 \u003d time.time()\n    print(f\"[START] {dev_id}\")\n    try:\n        df \u003d spark.read.jdbc(\n            url\u003dJDBC_URL,\n            table\u003dMYSQL_TABLE,\n            predicates\u003d[f\"id \u003d \u0027{dev_id}\u0027 AND c_date \u003c \u00271999-01-01\u0027\"],\n            properties\u003dprops\n        )\n        cnt \u003d df.count()\n        print(f\"  읽기 건수: {cnt:,}건\")\n\n        if cnt \u003e 0:\n            out_path \u003d f\"{BASE_PATH}/id\u003d{dev_id}\"\n            # 기존 데이터에 append\n            df.write \\\n                .mode(\"append\") \\\n                .option(\"compression\", \"snappy\") \\\n                .option(\"maxRecordsPerFile\", \"2000000\") \\\n                .parquet(out_path)\n\n        elapsed \u003d round(time.time() - t0, 1)\n        print(f\"[OK]    {dev_id} | {cnt:,}건 append | {elapsed}s\")\n\n    except Exception as e:\n        elapsed \u003d round(time.time() - t0, 1)\n        print(f\"[FAIL]  {dev_id} | {elapsed}s | {e}\")\n\n    finally:\n        try:\n            df.unpersist()\n        except:\n            pass\n        spark.catalog.clearCache()\n\nprint(\"\\n완료. 검증 paragraph를 실행해 건수를 확인하세요.\")",
