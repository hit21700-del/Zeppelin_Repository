    {
      "text": "%spark.pyspark\r\n\r\nimport time\r\nfrom datetime import datetime, timedelta\r\n\r\n# ── predicates 생성 함수 ────────────────────────────────────\r\ndef generate_predicates(dev_id, start_str, end_str):\r\n    preds \u003d []\r\n    end \u003d datetime.strptime(end_str, \"%Y-%m-%d\") + timedelta(days\u003d1)\r\n    cur \u003d datetime.strptime(start_str, \"%Y-%m-%d\")\r\n    yearly_end \u003d datetime(2022, 1, 1)\r\n\r\n    while cur \u003c yearly_end and cur \u003c end:\r\n        nxt \u003d datetime(cur.year + 1, 1, 1)\r\n        nxt \u003d min(nxt, yearly_end, end)\r\n        preds.append(\r\n            f\"id \u003d \u0027{dev_id}\u0027 AND c_date \u003e\u003d \u0027{cur.strftime(\u0027%Y-%m-%d\u0027)}\u0027 \"\r\n            f\"AND c_date \u003c \u0027{nxt.strftime(\u0027%Y-%m-%d\u0027)}\u0027\"\r\n        )\r\n        cur \u003d nxt\r\n\r\n    while cur \u003c end:\r\n        nxt \u003d cur + timedelta(weeks\u003d1)\r\n        nxt \u003d min(nxt, end)\r\n        preds.append(\r\n            f\"id \u003d \u0027{dev_id}\u0027 AND c_date \u003e\u003d \u0027{cur.strftime(\u0027%Y-%m-%d\u0027)}\u0027 \"\r\n            f\"AND c_date \u003c \u0027{nxt.strftime(\u0027%Y-%m-%d\u0027)}\u0027\"\r\n        )\r\n        cur \u003d nxt\r\n\r\n    # 범위 밖 데이터 포함 (1970년대 등 이상값 포함)\r\n    preds.append(f\"id \u003d \u0027{dev_id}\u0027 AND c_date \u003c \u0027{start_str}\u0027\")\r\n    preds.append(f\"id \u003d \u0027{dev_id}\u0027 AND c_date IS NULL\")\r\n    return preds\r\n\r\n# ── 단말기별 min/max c_date ─────────────────────────────────\r\nDEVICE_DATE_RANGES \u003d [\r\n    (\"01229168898\", \"2022-11-28\", \"2025-06-30\"),\r\n    (\"01229198901\", \"2022-11-28\", \"2025-07-01\"),\r\n    (\"01229208905\", \"2000-01-01\", \"2000-01-01\"),\r\n    (\"01229219366\", \"2000-01-01\", \"2024-02-19\"),\r\n    (\"01229238905\", \"2022-11-08\", \"2023-05-17\"),\r\n    (\"01229258900\", \"2000-01-01\", \"2025-01-05\"),\r\n    (\"01229268895\", \"2022-11-28\", \"2025-06-30\"),\r\n    (\"01229279367\", \"2022-11-09\", \"2024-02-18\"),\r\n    (\"01229298900\", \"1999-12-11\", \"2025-07-01\"),\r\n    (\"01229408898\", \"2000-01-01\", \"2000-01-01\"),\r\n    (\"01229428953\", \"2000-01-31\", \"2023-07-04\"),\r\n    (\"01229438897\", \"1999-12-04\", \"2025-10-02\"),\r\n    (\"01229438903\", \"1999-11-30\", \"2025-07-01\"),\r\n    (\"01229438904\", \"2022-11-10\", \"2025-07-01\"),\r\n    (\"01229438905\", \"1999-11-30\", \"2025-07-01\"),\r\n    (\"01229459372\", \"2000-01-01\", \"2022-12-09\"),\r\n    (\"01229508904\", \"1999-12-01\", \"2023-02-22\"),\r\n    (\"01229518902\", \"1999-11-30\", \"2025-03-03\"),\r\n    (\"01229518904\", \"1999-01-01\", \"2025-07-01\"),  # 1973 이상값 → c_date \u003c \u00271999-01-01\u0027 로 포함\r\n    (\"01229518905\", \"1999-12-01\", \"2023-02-22\"),\r\n    (\"01229528904\", \"1999-11-30\", \"2023-11-22\"),\r\n    (\"01229528905\", \"2022-11-08\", \"2023-11-30\"),\r\n    (\"01229559364\", \"2022-11-08\", \"2024-02-19\"),\r\n    (\"01229608897\", \"1999-01-01\", \"2024-08-29\"),  # 1970 이상값 → c_date \u003c \u00271999-01-01\u0027 로 포함\r\n    (\"01229618901\", \"1999-12-07\", \"2025-07-01\"),\r\n    (\"01229628897\", \"1999-01-01\", \"2024-08-16\"),  # 1970 이상값 → c_date \u003c \u00271999-01-01\u0027 로 포함\r\n    (\"01229638933\", \"2022-11-07\", \"2023-01-11\"),\r\n    (\"01229668904\", \"2022-11-09\", \"2023-10-19\"),\r\n    (\"01229808904\", \"2000-01-01\", \"2000-01-01\"),\r\n    (\"01229828903\", \"1999-01-01\", \"2023-10-19\"),  # 1973 이상값 → c_date \u003c \u00271999-01-01\u0027 로 포함\r\n    (\"01229828961\", \"2000-03-01\", \"2023-06-07\"),\r\n    (\"01229838902\", \"2022-11-07\", \"2025-07-01\"),\r\n    (\"01229838910\", \"2022-11-09\", \"2022-12-19\"),\r\n    (\"01229838915\", \"1999-11-30\", \"2025-03-12\"),\r\n    (\"01229838918\", \"2000-01-01\", \"2023-02-21\"),\r\n    (\"01229838969\", \"2022-11-10\", \"2023-12-18\"),\r\n    (\"01229848907\", \"2000-01-01\", \"2000-01-01\"),\r\n    (\"01229848911\", \"1999-11-30\", \"2024-08-30\"),\r\n    (\"01229848920\", \"1999-11-30\", \"2025-03-13\"),\r\n    (\"01229848956\", \"2022-11-09\", \"2023-03-09\"),\r\n    (\"01229848978\", \"1999-12-01\", \"2024-11-16\"),\r\n    (\"01229848988\", \"2000-01-01\", \"2023-02-10\"),\r\n    (\"01229858910\", \"1999-12-01\", \"2025-07-01\"),\r\n    (\"01229858987\", \"1999-01-01\", \"2022-10-29\"),  # 1973 이상값 → c_date \u003c \u00271999-01-01\u0027 로 포함\r\n    (\"01229859021\", \"1999-11-30\", \"2025-07-01\"),\r\n    (\"01229868912\", \"2022-11-17\", \"2025-07-01\"),\r\n    (\"01229868966\", \"1999-11-30\", \"2025-07-01\"),\r\n    (\"01229888910\", \"2022-11-07\", \"2023-08-03\"),\r\n    (\"01229888959\", \"2000-03-05\", \"2025-07-01\"),\r\n    (\"01229889022\", \"2000-01-01\", \"2025-07-01\"),\r\n    (\"01229898903\", \"1999-11-30\", \"2025-07-01\"),\r\n    (\"01229898910\", \"2022-11-11\", \"2023-03-29\"),\r\n    (\"01229898913\", \"1999-12-01\", \"2023-06-07\"),\r\n    (\"01229898935\", \"2022-11-07\", \"2025-05-07\"),\r\n    (\"01229898943\", \"2022-11-09\", \"2025-07-01\"),\r\n    (\"01229898971\", \"1999-12-16\", \"2023-06-07\"),\r\n    (\"01229898996\", \"1999-12-01\", \"2025-06-25\"),\r\n    (\"01229938960\", \"2022-11-08\", \"2024-06-25\"),\r\n    (\"01229948937\", \"1999-11-30\", \"2025-07-01\"),\r\n    (\"01229948960\", \"1999-12-10\", \"2025-06-30\"),\r\n    (\"01229948961\", \"1999-11-30\", \"2025-07-01\"),\r\n    (\"01229958960\", \"2022-11-09\", \"2023-03-02\"),\r\n    (\"01229958961\", \"1999-11-30\", \"2025-07-01\"),\r\n    (\"01229958978\", \"1999-11-30\", \"2025-07-01\"),\r\n    (\"01229968960\", \"1999-12-01\", \"2024-12-05\"),\r\n    (\"01229968961\", \"1999-12-22\", \"2023-10-18\"),\r\n    (\"01229968962\", \"1999-11-30\", \"2025-07-01\"),\r\n    (\"01229968965\", \"2000-01-01\", \"2023-06-07\"),\r\n    (\"01229968996\", \"1999-11-30\", \"2025-07-29\"),\r\n    (\"01229978913\", \"2000-01-01\", \"2023-12-22\"),\r\n    (\"01229978961\", \"1999-11-30\", \"2025-07-01\"),\r\n]\r\n\r\nprops \u003d {\r\n    \"user\":     MYSQL_USER,\r\n    \"password\": MYSQL_PASSWORD,\r\n    \"driver\":   \"com.mysql.cj.jdbc.Driver\",\r\n    \"fetchsize\": \"10000\",\r\n}\r\n\r\nBASE_PATH  \u003d f\"s3a://{S3_BUCKET}/{MYSQL_TABLE}/parquet\"\r\nCHECKPOINT \u003d f\"s3a://{S3_BUCKET}/{MYSQL_TABLE}/checkpoint/completed.txt\"\r\n\r\n# ── 체크포인트: Hadoop API 사용 ─────────────────────────────\r\nhadoop_conf \u003d spark._jsc.hadoopConfiguration()\r\nfs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(\r\n    spark._jvm.java.net.URI(f\"s3a://{S3_BUCKET}\"), hadoop_conf\r\n)\r\n\r\ndef checkpoint_load():\r\n    p \u003d spark._jvm.org.apache.hadoop.fs.Path(CHECKPOINT)\r\n    if not fs.exists(p):\r\n        return set()\r\n    stream \u003d fs.open(p)\r\n    reader \u003d spark._jvm.java.io.BufferedReader(\r\n        spark._jvm.java.io.InputStreamReader(stream)\r\n    )\r\n    completed \u003d set()\r\n    line \u003d reader.readLine()\r\n    while line is not None:\r\n        if line.strip():\r\n            completed.add(line.strip())\r\n        line \u003d reader.readLine()\r\n    reader.close()\r\n    return completed\r\n\r\ndef checkpoint_save(dev_id, completed):\r\n    completed.add(dev_id)\r\n    p \u003d spark._jvm.org.apache.hadoop.fs.Path(CHECKPOINT)\r\n    stream \u003d fs.create(p, True)  # True \u003d overwrite\r\n    writer \u003d spark._jvm.java.io.PrintWriter(\r\n        spark._jvm.java.io.OutputStreamWriter(stream, \"UTF-8\")\r\n    )\r\n    for d in sorted(completed):\r\n        writer.println(d)\r\n    writer.close()\r\n\r\n# ── 체크포인트 로드 ─────────────────────────────────────────\r\ncompleted \u003d checkpoint_load()\r\nif completed:\r\n    print(f\"체크포인트 로드: 완료된 단말기 {len(completed)}개 → 건너뜀\")\r\nelse:\r\n    print(\"체크포인트 없음 → 처음부터 시작\")\r\n\r\n# ── 재처리 대상: NG 단말기는 강제 재처리 ───────────────────\r\nNG_IDS \u003d {\r\n    \"01229518904\", \"01229828903\",\r\n    \"01229608897\", \"01229628897\", \"01229858987\"\r\n}\r\nfor ng in NG_IDS:\r\n    completed.discard(ng)\r\n    print(f\"[재처리] {ng}\")\r\n\r\nresults \u003d []\r\n\r\n# ── 단말기별 순차 처리 ──────────────────────────────────────\r\nprint(f\"\\n[총 {len(DEVICE_DATE_RANGES)}개 단말기 처리 시작]\")\r\nfor dev_id, min_d, max_d in DEVICE_DATE_RANGES:\r\n    if dev_id in completed:\r\n        print(f\"[SKIP]  {dev_id}\")\r\n        results.append((dev_id, -1, 0, \"SKIP\"))\r\n        continue\r\n\r\n    t0 \u003d time.time()\r\n    preds \u003d generate_predicates(dev_id, min_d, max_d)\r\n    print(f\"[START] {dev_id} | predicates: {len(preds)}개\")\r\n\r\n    try:\r\n        df \u003d spark.read.jdbc(\r\n            url\u003dJDBC_URL,\r\n            table\u003dMYSQL_TABLE,\r\n            predicates\u003dpreds,\r\n            properties\u003dprops\r\n        )\r\n        out_path \u003d f\"{BASE_PATH}/id\u003d{dev_id}\"\r\n        df.write \\\r\n            .mode(\"overwrite\") \\\r\n            .option(\"compression\", \"snappy\") \\\r\n            .option(\"maxRecordsPerFile\", \"2000000\") \\\r\n            .parquet(out_path)\r\n\r\n        saved \u003d spark.read.parquet(out_path).count()\r\n        elapsed \u003d round(time.time() - t0, 1)\r\n\r\n        checkpoint_save(dev_id, completed)\r\n\r\n        print(f\"[OK]    {dev_id} | {saved:,}건 | {elapsed}s\")\r\n        results.append((dev_id, saved, elapsed, \"OK\"))\r\n\r\n    except Exception as e:\r\n        elapsed \u003d round(time.time() - t0, 1)\r\n        print(f\"[FAIL]  {dev_id} | {elapsed}s | {e}\")\r\n        results.append((dev_id, -1, elapsed, \"FAIL\"))\r\n\r\n    finally:\r\n        try:\r\n            df.unpersist()\r\n        except:\r\n            pass\r\n        spark.catalog.clearCache()\r\n\r\n# ── 최종 요약 ───────────────────────────────────────────────\r\nprint(\"\\n\" + \"\u003d\" * 60)\r\nprint(\"최종 결과 요약\")\r\nprint(\"\u003d\" * 60)\r\ntotal_cnt \u003d 0\r\nfail_list \u003d []\r\nfor dev_id, cnt, elapsed, status in results:\r\n    if status \u003d\u003d \"SKIP\":\r\n        print(f\"  [SKIP]  {dev_id:20s}\")\r\n    elif status \u003d\u003d \"OK\":\r\n        print(f\"  [OK]    {dev_id:20s} | {cnt:\u003e12,}건 | {elapsed}s\")\r\n        total_cnt +\u003d cnt\r\n    else:\r\n        print(f\"  [FAIL]  {dev_id:20s} | {elapsed}s\")\r\n        fail_list.append(dev_id)\r\nprint(\"\u003d\" * 60)\r\nprint(f\"  이번 실행 저장 건수: {total_cnt:,}건\")\r\nif fail_list:\r\n    print(f\"  실패 단말기 ({len(fail_list)}개): {fail_list}\")\r\nelse:\r\n    print(\"  실패 없음\")\r\nprint(\"\u003d\" * 60)",
