      "text": "%spark.pyspark\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n# 저장 결과 검증 - 단말기별 건수 확인\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n\r\nall_ids \u003d [\r\n    \"01229438897\", \"01229438903\", \"01229898903\", \"01229948961\",\r\n    \"01229438905\", \"01229848920\", \"01229898943\", \"01229898996\",\r\n    \"01229838915\", \"01229898935\", \"01229948960\", \"01229968960\",\r\n    \"01229888959\", \"01229858910\", \"01229958961\", \"01229848978\",\r\n    \"01229618901\", \"01229518904\", \"01229828903\", \"01229868966\",\r\n    \"01229978961\", \"01229968996\", \"01229978913\", \"01229528905\",\r\n    \"01229208905\", \"01229838969\", \"01229668904\", \"01229868912\",\r\n    \"01229528904\", \"01229968965\", \"01229938960\", \"01229559364\",\r\n    \"01229219366\", \"01229238905\", \"01229258900\", \"01229518905\",\r\n    \"01229828961\", \"01229848911\", \"01229859021\", \"01229958978\",\r\n    \"01229968961\", \"01229438904\", \"01229508904\", \"01229838902\",\r\n    \"01229838918\", \"01229848956\", \"01229888910\", \"01229889022\",\r\n    \"01229898971\", \"01229948937\", \"01229898913\", \"01229268895\",\r\n    \"01229298900\", \"01229168898\", \"01229198901\", \"01229848988\",\r\n    \"01229838910\", \"01229518902\", \"01229638933\", \"01229428953\",\r\n    \"01229958960\", \"01229968962\", \"01229279367\", \"01