    {
      "title": "parquet버킷 폴더/파일 확인",
      "text": "%spark.pyspark\n\nURI  \u003d spark._jvm.java.net.URI\nPath \u003d spark._jvm.org.apache.hadoop.fs.Path\n\nconf \u003d spark._jsc.hadoopConfiguration()\n\nfs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(\n    URI(\"s3a://parquet\"),\n    conf\n)\n\nroot \u003d Path(\"s3a://parquet/\")\n\nfor f in fs.listStatus(root):\n    if f.isDirectory():\n        print(\"DIR :\", f.getPath().toString())\n    else:\n        print(\"FILE:\", f.getPath().toString())\n",
      "user": "anonymous",
