    {
      "text": "#%spark.pyspark\r\n\r\nURI  \u003d spark._jvm.java.net.URI\r\nPath \u003d spark._jvm.org.apache.hadoop.fs.Path\r\n\r\nconf \u003d spark._jsc.hadoopConfiguration()\r\n\r\nfs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(\r\n    URI(\"s3a://kafka\"),\r\n    conf\r\n)\r\n\r\nroot \u003d Path(\"s3a://kafka/\")\r\n\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n# 1단계: 삭제 대상 확인\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\nprint(\"\u003d\u003d\u003d 삭제 대상 목록 \u003d\u003d\u003d\")\r\ntargets \u003d fs.listStatus(root)\r\n\r\nfor f in targets:\r\n    print(f.getPath().toString())\r\n\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n# 2단계: 실제 삭제\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\nprint(\"\u003d\u003d\u003d 삭제 시작 \u003d\u003d\u003d\")\r\n\r\nfor f in targets:\r\n    p \u003d f.getPath()\r\n    print(\"삭제:\", p.toString())\r\n    fs.delete(p, True)   # True \u003d recursive 삭제\r\n\r\nprint(\"\u003d\u003d\u003d 삭제 완료 \u003d\u003d\u003d\")",
      "user": "anonymous",
      "dateUpdated": "2026-03-18 10:17:38.443",
      "progress": 0,
      "config": {
        "editorSetting": {
