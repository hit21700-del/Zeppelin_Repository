    {
      "text": "%python\nimport mlflow\nimport json\nimport matplotlib\nmatplotlib.use(\u0027Agg\u0027)  # 제플린 환경에서 GUI 없이 그래프 저장\nimport matplotlib.pyplot as plt\nfrom sklearn.ensemble import GradientBoostingClassifier\nfrom sklearn.datasets import load_breast_cancer\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay, roc_curve, auc\n\n# 데이터 준비\ndata \u003d load_breast_cancer()\nX_train, X_test, y_train, y_test \u003d train_test_split(\n    data.data, data.target, test_size\u003d0.2, random_state\u003d42\n)\n\n# 모델 학습\nclf \u003d GradientBoostingClassifier(n_estimators\u003d100, random_state\u003d42)\nclf.fit(X_train, y_train)\n\nmlflow.set_experiment(\"zeppelin-test\")\n\nwith mlflow.start_run(run_name\u003d\"artifact_test\") as run:\n\n    # 1. config 파일\n    config \u003d {\n        \"model\": \"GradientBoosting\",\n        \"n_estimators\": 100,\n        \"data_version\": \"v1.0\",\n        \"train_period\": \"2024-01 ~ 2024-12\"\n    }\n    with open(\"/tmp/config.json\", \"w\") as f:\n        json.dump(config, f, indent\u003d2)\n    mlflow.log_artifact(\"/tmp/config.json\", artifact_path\u003d\"config\")\n\n    # 2. feature importance\n    with open(\"/tmp/feature_importance.txt\", \"w\") as f:\n        for name, imp in sorted(\n            zip(data.feature_names, clf.feature_importances_),\n            key\u003dlambda x: -x[1]\n        ):\n            f.write(f\"{name}: {imp:.4f}\\n\")\n    mlflow.log_artifact(\"/tmp/feature_importance.txt\", artifact_path\u003d\"analysis\")\n\n    # 3. confusion matrix\n    cm \u003d confusion_matrix(y_test, clf.predict(X_test))\n    fig, ax \u003d plt.subplots()\n    ConfusionMatrixDisplay(cm).plot(ax\u003dax)\n    plt.savefig(\"/tmp/confusion_matrix.png\")\n    plt.close()\n    mlflow.log_artifact(\"/tmp/confusion_matrix.png\", artifact_path\u003d\"plots\")\n\n    # 4. ROC curve\n    fpr, tpr, _ \u003d roc_curve(y_test, clf.predict_proba(X_test)[:, 1])\n    roc_auc_score \u003d auc(fpr, tpr)\n    fig, ax \u003d plt.subplots()\n    ax.plot(fpr, tpr, label\u003df\"AUC \u003d {roc_auc_score:.3f}\")\n    ax.plot([0, 1], [0, 1], \"--\")\n    ax.set_xlabel(\"FPR\")\n    ax.set_ylabel(\"TPR\")\n    ax.legend()\n    plt.savefig(\"/tmp/roc_curve.png\")\n    plt.close()\n    mlflow.log_artifact(\"/tmp/roc_curve.png\", artifact_path\u003d\"plots\")\n\n    print(f\"Run ID: {run.info.run_id}\")\n    print(\"Artifacts 저장 완료\")\n    print(f\"Artifact URI: {run.info.artifact_uri}\")",
      "user": "anonymous",
