      "text": "%python\nfrom mlflow.tracking import MlflowClient\n\n# API를 활용한 상태 변경 시나리오\nclient \u003d MlflowClient()\n\n# 버전 목록 확인\nversions \u003d client.search_model_versions(\"name\u003d\u0027breast_cancer_classifier\u0027\")\nfor v in versions:\n    print(f\"version\u003d{v.version}, aliases\u003d{v.aliases}, run_id\u003d{v.run_id}\")\n\n# 명시적으로 최신 버전 추출 (버전 번호 기준 정렬)\nlatest_version \u003d max(versions, key\u003dlambda v: int(v.version)).version\nprint(f\"\\n최신 버전: {latest_version}\")\n\n# Alias 설정\nclient.set_registered_model_alias(\n    name\u003d\"breast_cancer_classifier\",\n    alias\u003d\"staging\",\n    version\u003dlatest_version\n)\nclient.set_registered_model_alias(\n    name\u003d\"breast_cancer_classifier\",\n    alias\u003d\"production\",\n    version\u003dlatest_version\n)\nprint(f\"version {latest_version} → staging, production alias 설정 완료\")\n\n# artifact 경로 조회 — run_id 통해서 실제 S3 경로 가져오기\nprod \u003d client.get_model_version_by_alias(\"breast_cancer_classifier\", \"production\")\nrun \u003d client.get_run(prod.run_id)\n\nprint(f\"\\nProduction 모델:\")\nprint(f\"  version: {prod.version}\")\nprint(f\"  run_id: {prod.run_id}\")\nprint(f\"  artifact_uri (실제 S3): {run.info.artifact_uri}\")  # s3://mlflow/... 형태\nprint(f\"  model 경로: {run.info.artifact_uri}/model\")",
