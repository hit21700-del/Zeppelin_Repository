      "text": "%python\n# 커스텀 태그 테스트\nfrom mlflow.tracking import MlflowClient\n\nclient \u003d MlflowClient()\n\n# 모델 레지스트리에 태그 설정\nclient.set_registered_model_tag(\"breast_cancer_classifier\", \"team\", \"quantum-hitech\")\nclient.set_registered_model_tag(\"breast_cancer_classifier\", \"use_case\", \"binary_classification\")\nclient.set_registered_model_tag(\"breast_cancer_classifier\", \"status\", \"verified\")\n\n# 특정 버전에 태그 설정\nclient.set_model_version_tag(\"breast_cancer_classifier\", \"2\", \"data_version\", \"v1.0\")\nclient.set_model_version_tag(\"breast_cancer_classifier\", \"2\", \"reviewer\", \"kim-jaehyun\")\n\n# 태그 조회\nmodel \u003d client.get_registered_model(\"breast_cancer_classifier\")\nprint(\"\u003d\u003d\u003d 모델 태그 \u003d\u003d\u003d\")\nfor k, v in model.tags.items():\n    print(f\"  {k}: {v}\")\n\n# 태그 기준 필터링\nprint(\"\\n\u003d\u003d\u003d 태그 필터링 \u003d\u003d\u003d\")\nresults \u003d client.search_registered_models(filter_string\u003d\"tags.team \u003d \u0027quantum-hitech\u0027\")\nfor m in results:\n    print(f\"  모델명: {m.name}, 태그: {m.tags}\")\n",
