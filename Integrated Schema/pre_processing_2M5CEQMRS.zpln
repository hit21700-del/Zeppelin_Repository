    {
      "text": "%spark.pyspark\r\nfrom pyspark.sql.functions import input_file_name\r\n\r\nBASE_PATH \u003d \"/QH/TEST_DATA\"  # HDFS 루트\r\n\r\nREAD_OPTS \u003d {\r\n    \"header\": \"true\",\r\n    \"inferSchema\": \"true\",          # 우선 전체 스키마 자동 추론\r\n    \"mode\": \"PERMISSIVE\",           # 깨진 레코드 허용\r\n    \"columnNameOfCorruptRecord\": \"_corrupt_record\",\r\n    \"badRecordsPath\": \"/QH/_bad_records_raw\",  # 파싱 실패 레코드 저장(검토용)\r\n    \"multiLine\": \"false\",\r\n    \"escape\": \"\\\\\",\r\n    \"quote\": \"\\\"\",\r\n    # 하위 디렉토리까지 재귀적으로 읽고 싶으면 아래 주석 해제\r\n    # \"recursiveFileLookup\": \"true\",\r\n}\r\n\r\ndf \u003d (spark.read\r\n      .options(**READ_OPTS)\r\n      .csv(BASE_PATH)               # 또는 f\"{BASE_PATH}/*\"\r\n      .withColumn(\"_src_file\", input_file_name()))\r\n",
      "user": "anonymous",
      "dateUpdated": "2025-09-17 11:25:44.854",
      "progress": 0,
      "config": {
