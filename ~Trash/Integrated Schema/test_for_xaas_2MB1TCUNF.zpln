    {
      "text": "%spark_user.pyspark\nfrom pyspark.sql import functions as F\n\n# createdAt 컬럼의 최소, 최대, 전체 행 개수 조회\ndf.select(\n    F.min(\"createdAt\").alias(\"min_createdAt\"),\n    F.max(\"createdAt\").alias(\"max_createdAt\"),\n    #F.count(\"*\").alias(\"row_count\")\n).show(truncate\u003dFalse)\n",
