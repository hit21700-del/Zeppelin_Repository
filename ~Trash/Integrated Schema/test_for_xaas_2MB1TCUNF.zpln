    {
      "text": "%spark_user.pyspark\r\nfrom pyspark.sql import functions as F\r\n\r\ndevice_id \u003d \"01229968996\"\r\nbase_path \u003d \"hdfs:///QH/SOH_Model/discharge/soh_stress_factor\"\r\nsrc_path  \u003d f\"{base_path}/deviceId\u003d{device_id}\"\r\n\r\nhdfs_out  \u003d f\"hdfs:///home/tmp/for_xaas_data/{device_id}\"\r\n\r\n# 1) 데이터 로드 (deviceId 파티션 컬럼 포함해서 읽기)\r\ndf \u003d (\r\n    spark.read\r\n         .option(\"basePath\", base_path)   # 👈 이게 있어야 deviceId가 컬럼으로 생김\r\n         .parquet(src_path)\r\n)\r\n\r\ndf.printSchema()\r\n\r\n# 2) day_of_soh 기준 날짜 필터\r\ndf_filtered \u003d (\r\n    df\r\n    .filter(\r\n        (F.col(\"day_of_soh\") \u003e\u003d F.lit(\"2025-04-02\")) \u0026\r\n        (F.col(\"day_of_soh\") \u003c\u003d F.lit(\"2025-05-02\"))\r\n    )\r\n    .select(\r\n        \"deviceId\",\r\n        \"day_of_soh\",\r\n        \"daily_soh\",\r\n        \"longterm_soh\",\r\n        \"feature_value\",\r\n        \"feature_importance\"\r\n    )\r\n)\r\n\r\nprint(\"필터 후 건수:\", df_filtered.count())\r\n\r\n# 3) HDFS로 CSV 저장\r\n(df_filtered\r\n    .coalesce(1)\r\n    .write\r\n    .mode(\"overwrite\")\r\n    .option(\"header\", True)\r\n    .csv(hdfs_out)\r\n)\r\n",
