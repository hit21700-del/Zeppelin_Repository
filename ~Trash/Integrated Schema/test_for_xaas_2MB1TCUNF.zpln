    {
      "text": "%spark_user.pyspark\r\nfrom pyspark.sql import functions as F\r\n\r\ndevice_id   \u003d \"01229968996\"\r\nbase_path   \u003d \"hdfs:///QH/Pre_Processed/Passenger_Car/PP_Set\"\r\nsrc_path    \u003d f\"{base_path}/deviceId\u003d{device_id}\"\r\n\r\n# HDFS 임시 저장 경로\r\nhdfs_out    \u003d f\"hdfs:///home/tmp/for_xaas_data/{device_id}\"\r\n\r\n# 1) 데이터 로드\r\ndf \u003d (\r\n    spark.read\r\n         .option(\"basePath\", base_path)\r\n         .parquet(src_path)\r\n)\r\n\r\n# 2) pt_date 기준 필터 예시 (이미 잘 되던 코드 사용)\r\ndf_filtered \u003d (\r\n    df\r\n    .filter(\r\n        (F.col(\"pt_date\") \u003e\u003d \"20250430\") \u0026\r\n        (F.col(\"pt_date\") \u003c\u003d \"20250502\")\r\n    )\r\n    .select(\r\n        \"deviceId\",\r\n        \"createdAt\",\r\n        \"status\",\r\n        \"cvdiff\",\r\n        \"ctdiff\",\r\n        \"socdiff\",\r\n        \"sop\",\r\n        \"sob\",\r\n        \"sot\"\r\n    )\r\n)\r\n\r\nprint(\"필터 후 건수:\", df_filtered.count())\r\n\r\n# 3) HDFS로 CSV 저장\r\n(df_filtered\r\n    .coalesce(1)               # 한 파일로\r\n    .write\r\n    .mode(\"overwrite\")\r\n    .option(\"header\", True)\r\n    .csv(hdfs_out)\r\n)\r\n",
      "user": "anonymous",
      "dateUpdated": "2025-11-28 18:44:24.485",
      "progress": 0,
