      "text": "%spark.pyspark\r\nfrom pyspark.sql.functions import input_file_name\r\n\r\n# 전체 디렉토리 경로로\r\nBASE_PATH \u003d \"/QH/TEST_DATA\"  # HDFS 루트\r\n\r\n# 단일 CSV 파일 경로\r\nFILE_PATH \u003d \"/QH/TEST_DATA/part-00000-3560c061-d7ff-4041-b1a2-7f775112f8b2-c000.csv\"\r\n\r\nREAD_OPTS \u003d {\r\n    \"header\": \"true\",\r\n    \"inferSchema\": \"true\",\r\n    \"mode\": \"PERMISSIVE\",\r\n    \"columnNameOfCorruptRecord\": \"_corrupt_record\",\r\n    \"badRecordsPath\": \"/QH/_bad_records_raw\",\r\n    \"multiLine\": \"false\",\r\n    \"escape\": \"\\\\\",\r\n    \"quote\": \"\\\"\",\r\n}\r\n\r\n# 단일 파일만 읽기\r\ndf \u003d (spark.read\r\n      .options(**READ_OPTS)\r\n      .csv(FILE_PATH)                      # ← 단일 파일 지정\r\n      .withColumn(\"_src_file\", input_file_name()))\r\n\r\ndf.show(5)        # 데이터 일부 확인\r\nprint(\"Row count:\", df.count())\r\n",
