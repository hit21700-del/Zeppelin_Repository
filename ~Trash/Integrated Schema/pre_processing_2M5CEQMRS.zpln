    {
      "text": "%spark.pyspark\ndef process_data(spark: SparkSession) -\u003e DataFrame: # DataFrame 대신에 None을 입력하고 return값을 없앤뒤 main() 사용\n\n    # Step 1: Load data (csv or db) \n    print_timestamp(\"Step 1\u003e Loading data\")\n    if PP_IO_CONFIG[\u0027input\u0027][\u0027source\u0027].lower() \u003d\u003d \u0027csv\u0027: \n        df \u003d load_data_from_csv(spark, PP_IO_CONFIG[\u0027input\u0027][\u0027csv_path\u0027])\n    else:  # \u0027db\u0027\n        df \u003d load_data_from_db(spark,DB_QUERY_KMON_DATA)\n    \n    if df.count() \u003e 0:\n        print(f\"Loaded Data Count: {df.count()} rows\")\n    else:\n        print(\"No Data Loaded\")\n        sys.exit(\"Program terminated due to empty input data.\")\n\n    #step 2: Load master data and add group_code \n    df_master \u003d load_data_from_db(spark,DB_QUERY_MASTER_DATA)\n    \n    df \u003d df.join(\n        df_master.select(\"sensor_num\", \"group_cd\", \"car_num\"),\n        df.id \u003d\u003d df_master.sensor_num,\n        \"left\"\n    ).drop(\"sensor_num\").fillna({\"group_cd\": 0, \"car_num\": \"\"})\n    \n    # Step 3: 컬럼명,데이터타입 변환작업 -\u003e kmon_new 단말 적용\n    print_timestamp(\"Step 2\u003e Converting column names and data types\")\n    df \u003d convert_df_new(df)\n\n    # Step 4: 비트연산\n    print_timestamp(\"Step 3\u003e Processing bit operation\") \n    df \u003d bit_process(df)\n   \n    # Step 5: status컬럼 추가\n    print_timestamp(\"Step 4\u003e Adding status column\")\n    df \u003d add_status(df)\n\n    # Step 6: Save results\n    print_timestamp(\"Step 11\u003e Saving results\")\n    if PP_IO_CONFIG[\u0027output\u0027][\u0027format\u0027].lower() \u003d\u003d \u0027csv\u0027:\n        output_path \u003d PP_IO_CONFIG[\u0027output\u0027][\u0027csv_path\u0027]\n        import os\n        os.makedirs(os.path.dirname(output_path), exist_ok\u003dTrue)\n        # PySpark DataFrame을 직접 CSV로 저장\n        df.write.mode(\u0027overwrite\u0027).option(\u0027header\u0027, True).csv(output_path)\n        print(f\"Results saved to: {output_path}\")\n    else:  # \u0027db\u0027\n        save_to_db(df, PP_IO_CONFIG[\u0027output\u0027][\u0027db_table\u0027], spark)\n        print(f\"Results saved to database table: {PP_IO_CONFIG[\u0027output\u0027][\u0027db_table\u0027]}\")\n    \n    print_timestamp(\"Processing complete.\")\n    return df\n",
