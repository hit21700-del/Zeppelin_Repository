      "dateFinished": "2025-12-01 14:23:23.899",
      "status": "FINISHED"
    },
    {
      "text": "%spark_user.pyspark\r\n\r\ndef load_mlp_source(spark):\r\n    \"\"\"\r\n    MLP 단계 소스 로더\r\n    - 입력 : soh_capa 전체 parquet\r\n    - 경로 : MLP_IO_CONFIG[\u0027input\u0027][\u0027parquet_path\u0027] 에서 가져온다\r\n    - deviceId를 11자리 string으로 통일\r\n    \"\"\"\r\n    capa_path \u003d MLP_IO_CONFIG[\u0027input\u0027][\u0027parquet_path\u0027]\r\n\r\n    logger.info(f\"[MLP] capa parquet 로드: {capa_path}\")\r\n    capa_df \u003d (\r\n        spark.read\r\n             .format(\"parquet\")\r\n             .load(capa_path)\r\n    )\r\n\r\n    cols \u003d capa_df.columns\r\n\r\n    # 1) 이미 deviceId가 있으면 → 11자리 zero-padding\r\n    if \"deviceId\" in cols:\r\n        capa_df \u003d capa_df.withColumn(\r\n            \"deviceId\",\r\n            F.lpad(F.col(\"deviceId\").cast(\"string\"), 11, \"0\")\r\n        )\r\n        return capa_df\r\n\r\n    # 2) deviceId 없고 id만 있으면 → rename + 11자리 zero-padding\r\n    if \"id\" in cols:\r\n        logger.info(\"[MLP] id 컬럼을 deviceId로 rename 합니다.\")\r\n        capa_df \u003d (\r\n            capa_df\r\n            .withColumnRenamed(\"id\", \"deviceId\")\r\n            .withColumn(\"deviceId\", F.lpad(F.col(\"deviceId\").cast(\"string\"), 11, \"0\"))\r\n        )\r\n        return capa_df\r\n\r\n    # 3) 둘 다 없으면 에러 로그 + 빈 DF\r\n    logger.error(\"[MLP] capa_df에 deviceId/id 컬럼이 없습니다.\")\r\n    return spark.createDataFrame([], StructType([]))\r\n",
      "user": "anonymous",
      "dateUpdated": "2025-12-01 14:23:23.973",
      "progress": 0,
      "config": {
