      "text": "%spark_user.pyspark\r\n\r\n# 단일 deviceId 데이터 전처리 및 모델 저장/버전관리\r\ndef process_single_id_data(data_id, device_id, model_type\u003d\u0027MLP\u0027, **model_params):\r\n\r\n    # 1) day_of_soh 기준 정렬\r\n    data_id \u003d data_id.sort_values(\u0027day_of_soh\u0027).reset_index(drop\u003dTrue)\r\n\r\n    # 2) IQR 기반 이상치 마스크 (원래 로직 그대로)\r\n    def iqr_mask(x, k\u003d3.0):\r\n        x \u003d np.asarray(x, dtype\u003dfloat)\r\n        x_len \u003d int(len(x))\r\n\r\n        finite \u003d np.isfinite(x)\r\n        x_ok \u003d x[finite]\r\n        if x_ok.size \u003c 4:\r\n            return finite\r\n        q1, q3 \u003d np.percentile(x_ok, [25, 75])\r\n        iqr \u003d q3 - q1\r\n        lo, hi \u003d q1 - k * iqr, q3 + k * iqr\r\n        m \u003d finite \u0026 (x \u003e\u003d lo) \u0026 (x \u003c\u003d hi)\r\n        m_sum \u003d int(m.sum())\r\n        threshold_1 \u003d 10\r\n        threshold_2 \u003d int(0.2 * x_len)\r\n        threshold \u003d threshold_1 if threshold_1 \u003e threshold_2 else threshold_2\r\n        if m_sum \u003c threshold:\r\n            return finite\r\n        return m\r\n\r\n    ec_vals \u003d data_id[\"energy_capacity\"].values.astype(float)\r\n\r\n    if len(ec_vals) \u003c 10:\r\n        keep_mask_sorted \u003d np.isfinite(ec_vals)\r\n    else:\r\n        keep_mask_sorted \u003d iqr_mask(ec_vals, k\u003d3.0)\r\n        if not keep_mask_sorted.any():\r\n            keep_mask_sorted \u003d np.isfinite(ec_vals)\r\n\r\n    data_id[\"keep_mask\"] \u003d keep_mask_sorted\r\n\r\n    # 3) 정규화 파라미터 계산 (원래 로직 그대로)\r\n    df_filt \u003d data_id[keep_mask_sorted].copy()\r\n    n_filt \u003d len(df_filt)\r\n\r\n    if n_filt \u003e\u003d 10:\r\n        split_idx \u003d int(n_filt * 0.8)\r\n    else:\r\n        split_idx \u003d 0\r\n\r\n    df_fit \u003d df_filt.iloc[:split_idx] if split_idx \u003e 0 else df_filt\r\n\r\n    eps \u003d 1e-9\r\n\r\n    def fit_z(x):\r\n        x \u003d np.asarray(x, float)\r\n        mu \u003d float(np.mean(x)) if x.size else 0.0\r\n        sd \u003d float(np.std(x)) + eps\r\n        return mu, sd\r\n\r\n    # Z-score 파라미터\r\n    t_mu, t_sd \u003d fit_z(df_fit[\"avg_bms_temp\"].values)\r\n    c_mu, c_sd \u003d fit_z(df_fit[\"discharge_rate\"].values)\r\n    d_mu, d_sd \u003d fit_z(df_fit[\"accum_dod\"].values)\r\n\r\n    # 4) 정규화 적용\r\n    data_id[\"temp_norm\"]  \u003d (data_id[\"avg_bms_temp\"].values.astype(float)   - t_mu) / t_sd\r\n    data_id[\"crate_norm\"] \u003d (data_id[\"discharge_rate\"].values.astype(float) - c_mu) / c_sd\r\n    data_id[\"dod_norm\"]   \u003d (data_id[\"accum_dod\"].values.astype(float)      - d_mu) / d_sd\r\n\r\n    df_filt[\"temp_norm\"]  \u003d (df_filt[\"avg_bms_temp\"].values.astype(float)   - t_mu) / t_sd\r\n    df_filt[\"crate_norm\"] \u003d (df_filt[\"discharge_rate\"].values.astype(float) - c_mu) / c_sd\r\n    df_filt[\"dod_norm\"]   \u003d (df_filt[\"accum_dod\"].values.astype(float)      - d_mu) / d_sd\r\n\r\n    # 5) 용량 정규화\r\n    capa_min \u003d float(np.min(df_fit[\"energy_capacity\"].values)) if len(df_fit) else float(np.min(ec_vals))\r\n    capa_max \u003d float(np.max(df_fit[\"energy_capacity\"].values)) if len(df_fit) else float(np.max(ec_vals))\r\n    capa_den \u003d (capa_max - capa_min) + eps\r\n    data_id[\"capacity_norm\"] \u003d (data_id[\"energy_capacity\"].values.astype(float) - capa_min) / capa_den\r\n    df_filt[\"capacity_norm\"] \u003d (df_filt[\"energy_capacity\"].values.astype(float) - capa_min) / capa_den\r\n\r\n    normalization_params \u003d {\r\n        \u0027temp_mu\u0027: t_mu,  \u0027temp_sd\u0027: t_sd,\r\n        \u0027crate_mu\u0027: c_mu, \u0027crate_sd\u0027: c_sd,\r\n        \u0027dod_mu\u0027: d_mu,   \u0027dod_sd\u0027: d_sd,\r\n        \u0027capa_min\u0027: capa_min, \u0027capa_max\u0027: capa_max\r\n    }\r\n\r\n    # 6) 학습/검증 세트 구성\r\n    X_filt \u003d df_filt[[\"temp_norm\", \"crate_norm\", \"dod_norm\"]].values.astype(np.float32)\r\n    Y_filt \u003d df_filt[\"capacity_norm\"].values.reshape(-1, 1).astype(np.float32)\r\n\r\n    if n_filt \u003c 10:\r\n        X_train, Y_train \u003d X_filt, Y_filt\r\n        X_val, Y_val     \u003d X_filt, Y_filt\r\n    else:\r\n        X_train, Y_train \u003d X_filt[:split_idx],  Y_filt[:split_idx]\r\n        X_val,   Y_val   \u003d X_filt[split_idx:],  Y_filt[split_idx:]\r\n\r\n    X_all \u003d data_id[[\"temp_norm\", \"crate_norm\", \"dod_norm\"]].values.astype(np.float32)\r\n\r\n    # 7) Random seed 설정\r\n    seed \u003d model_params.get(\u0027random_seed\u0027, 42)\r\n    set_random_seed(seed)\r\n\r\n    # 8) 모델 초기화\r\n    model \u003d MLP(input_size\u003d3, hidden_size\u003d6, output_size\u003d1)\r\n    device_id_str \u003d str(device_id).zfill(11)\r\n\r\n    # 9) 로컬 모델 저장 경로 (deviceId 폴더링)\r\n    #    /home/kadap/QH/SOH_Model/models/discharge/{deviceId}/\r\n    local_device_dir \u003d os.path.join(LOCAL_MODEL_DIR, device_id_str)\r\n    os.makedirs(local_device_dir, exist_ok\u003dTrue)\r\n\r\n    # 최신 버전 파일 이름 (항상 이 경로에 latest를 유지)\r\n    model_filename_latest \u003d f\"{model_type.lower()}_model_dch_v4_{device_id_str}.pth\"\r\n    model_save_path \u003d os.path.join(local_device_dir, model_filename_latest)\r\n\r\n    # 9-1) 기존 모델 존재 여부 확인 후, 있으면 로드 / 없으면 학습 플래그 ON\r\n    if os.path.exists(model_save_path):\r\n        try:\r\n            model_info \u003d torch.load(model_save_path, weights_only\u003dFalse)\r\n            model.load_state_dict(model_info[\u0027model_state_dict\u0027])\r\n            train_model_flag \u003d False\r\n            logger.info(\r\n                f\"deviceId {device_id_str}: 저장된 모델을 로드하여 사용합니다. \"\r\n                f\"(경로: {model_save_path})\"\r\n            )\r\n        except Exception as e:\r\n            train_model_flag \u003d True\r\n            logger.warning(\r\n                f\"deviceId {device_id_str}: 저장된 모델 로드 실패, 새로 학습합니다. \"\r\n                f\"(오류: {str(e)})\"\r\n            )\r\n    else:\r\n        train_model_flag \u003d True\r\n        logger.info(\r\n            f\"deviceId {device_id_str}: 저장된 모델이 없어 새로 학습합니다. \"\r\n            f\"(경로: {model_save_path})\"\r\n        )\r\n\r\n    # 10) 모델 학습 (필요한 경우에만)\r\n    if train_model_flag:\r\n        logger.info(f\"deviceId {device_id_str}: 모델 학습을 시작합니다.\")\r\n        model, training_info, validation_metrics \u003d train_model_with_validation(\r\n            model, X_train, Y_train, X_val, Y_val, model_save_path,\r\n            normalization_params, model_type, **model_params\r\n        )\r\n        logger.info(\r\n            f\"deviceId {device_id_str}: 모델 학습이 완료되었습니다. \"\r\n            f\"(epochs: {training_info[\u0027epochs\u0027]}, val_mse: {validation_metrics[\u0027mse\u0027]:.6f})\"\r\n        )\r\n\r\n        # 11) 로컬 타임스탬프 버전 파일 생성 (YYYYMMDD_HHMMSS)\r\n        try:\r\n            timestamp_str \u003d datetime.now().strftime(\"%Y%m%d_%H%M%S\")\r\n            version_filename \u003d f\"{model_type.lower()}_model_dch_v4_{device_id_str}_{timestamp_str}.pth\"\r\n            version_path \u003d os.path.join(local_device_dir, version_filename)\r\n\r\n            shutil.copy2(model_save_path, version_path)\r\n            logger.info(\r\n                f\"deviceId {device_id_str}: 로컬 모델 버전 저장 완료 → {version_path}\"\r\n            )\r\n        except Exception as e:\r\n            logger.warning(\r\n                f\"deviceId {device_id_str}: 로컬 모델 버전 저장 실패: {e}\"\r\n            )\r\n\r\n        # 12) HDFS 백업 (deviceId 폴더 + timestamp 파일명)\r\n        if HDFS_MODEL_DIR:\r\n            try:\r\n                spark \u003d SparkSession.getActiveSession()\r\n                if spark is not None:\r\n                    jvm   \u003d spark._sc._jvm\r\n                    hconf \u003d spark._sc._jsc.hadoopConfiguration()\r\n                    fs    \u003d jvm.org.apache.hadoop.fs.FileSystem.get(hconf)\r\n                    Path  \u003d jvm.org.apache.hadoop.fs.Path\r\n\r\n                    base_dir   \u003d HDFS_MODEL_DIR.rstrip(\u0027/\u0027)\r\n                    device_dir \u003d f\"{base_dir}/{device_id_str}\"\r\n                    fs.mkdirs(Path(device_dir))\r\n\r\n                    # 로컬과 동일 timestamp 사용\r\n                    hdfs_filename \u003d f\"{model_type.lower()}_model_dch_v4_{device_id_str}_{timestamp_str}.pth\"\r\n\r\n                    src_path \u003d Path(model_save_path)\r\n                    dst_path \u003d Path(f\"{device_dir}/{hdfs_filename}\")\r\n\r\n                    # overwrite\u003dTrue\r\n                    fs.copyFromLocalFile(False, True, src_path, dst_path)\r\n\r\n                    logger.info(\r\n                        f\"deviceId {device_id_str}: HDFS 모델 백업 완료 → {device_dir}/{hdfs_filename}\"\r\n                    )\r\n                else:\r\n                    logger.warning(\r\n                        f\"deviceId {device_id_str}: SparkSession이 없어 HDFS 백업을 건너뜁니다.\"\r\n                    )\r\n            except Exception as e:\r\n                logger.warning(\r\n                    f\"deviceId {device_id_str}: HDFS 모델 백업 실패: {e}\"\r\n                )\r\n    else:\r\n        logger.info(\r\n            f\"deviceId {device_id_str}: 기존 저장된 모델로 예측을 진행합니다. \"\r\n            f\"(재학습 없음)\"\r\n        )\r\n\r\n    # 13) 예측 및 DoD 효과 계산 (연산 로직 그대로)\r\n    performance_metrics \u003d evaluate_model_performance_v2(\r\n        model,\r\n        X_all,\r\n        data_id[\"capacity_norm\"].values.reshape(-1, 1).astype(np.float32),\r\n        normalization_params,\r\n        data_id[\"energy_capacity\"].values\r\n    )\r\n    data_id[\"capa_pred\"] \u003d performance_metrics[\u0027predictions\u0027]\r\n\r\n    # DoD 참조점 고정\r\n    X_dod_ref \u003d data_id[[\"temp_norm\", \"crate_norm\", \"dod_norm\"]].copy()\r\n    X_dod_ref[\"dod_norm\"] \u003d 0.0\r\n    with torch.no_grad():\r\n        base_pred_norm \u003d model(torch.tensor(X_dod_ref.values.astype(np.float32))).numpy().flatten()\r\n        base_pred_real \u003d base_pred_norm * ((capa_max - capa_min) + eps) + capa_min\r\n    data_id[\"capa_2factor\"] \u003d base_pred_real\r\n    data_id[\"dod_effect\"]   \u003d data_id[\"capa_pred\"] - data_id[\"capa_2factor\"]\r\n\r\n    # 최대 용량 산출\r\n    ec_filt \u003d data_id.loc[keep_mask_sorted, \"energy_capacity\"].values.astype(float)\r\n    if ec_filt.size \u003e 0:\r\n        max_capa \u003d float(np.max(ec_filt))\r\n    else:\r\n        max_capa \u003d float(np.max(ec_vals))\r\n\r\n    # capacity 보정 : max_capacity + dod_effect\r\n    data_id[\"capa_decomposed\"] \u003d max_capa + data_id[\"dod_effect\"]\r\n\r\n    # 성능 지표 추가\r\n    for key, value in performance_metrics.items():\r\n        if key !\u003d \u0027predictions\u0027:\r\n            data_id[key] \u003d value\r\n\r\n    # 14) 결과 컬럼 (deviceId 기준)\r\n    result_columns \u003d [\r\n        \u0027deviceId\u0027, \u0027day_of_soh\u0027, \u0027max_mileage\u0027, \u0027accum_dod\u0027, \u0027avg_bms_temp\u0027, \u0027discharge_rate\u0027,\r\n        \u0027energy_capacity\u0027, \u0027capa_pred\u0027, \u0027capa_2factor\u0027, \u0027dod_effect\u0027,\r\n        \u0027capa_decomposed\u0027, \u0027first_dod_est\u0027\r\n    ]\r\n    data_id[\u0027deviceId\u0027] \u003d device_id_str\r\n    result_id \u003d data_id[result_columns]\r\n    return result_id\r\n",
      "user": "anonymous",
      "dateUpdated": "2025-12-01 14:25:43.323",
      "progress": 0,
      "config": {
