    {
      "text": "%spark_user.pyspark\n\n\n# 누적 DoD 계산 함수\ndef cal_total_dod(df):\n    \"\"\"\n    누적 DoD 계산 함수\n    - 마일리지와 DoD 누적값 기반 회귀분석\n    - 효율성 기반 백업 계산 방법\n    \"\"\"\n\n    # id → deviceId 기준으로 사용\n    df1 \u003d df.select(\n        \"deviceId\", \"day_of_soh\", \"total_cycle\", \"total_dod\",\n        \"max_mileage\", \"avg_bms_temp\", \"discharge_rate\", \"energy_capacity\"\n    )\n\n    window_ordered \u003d Window.partitionBy(\"deviceId\").orderBy(\"day_of_soh\")\n    window_id      \u003d Window.partitionBy(\"deviceId\")\n\n    # 마일리지 차이 계산\n    df1 \u003d df1.withColumn(\"prev_max_mileage\", lag(\"max_mileage\").over(window_ordered))\n    df1 \u003d df1.withColumn(\"next_max_mileage\", lead(\"max_mileage\").over(window_ordered))\n    df1 \u003d df1.withColumn(\n        \"prev_max_mileage\",\n        when(col(\"prev_max_mileage\").isNull(), lit(0)).otherwise(col(\"prev_max_mileage\"))\n    )\n    df1 \u003d df1.withColumn(\"mileage_diff\", col(\"max_mileage\") - col(\"prev_max_mileage\"))\n\n    # DoD 효율성 계산\n    df1 \u003d df1.withColumn(\n        \"total_mileage_range\",\n        pyspark_max(\"max_mileage\").over(window_id) - pyspark_min(\"max_mileage\").over(window_id)\n    )\n    df1 \u003d df1.withColumn(\n        \"total_dod_range\",\n        pyspark_max(\"total_dod\").over(window_id) - pyspark_min(\"total_dod\").over(window_id)\n    )\n    df1 \u003d df1.withColumn(\n        \"dod_efficiency_km_per_dod\",\n        col(\"total_mileage_range\") / col(\"total_dod_range\")\n    )\n\n    df1 \u003d df1.withColumn(\"first_actual_max_mileage\", first(\"max_mileage\").over(window_id))\n\n    # 회귀분석용 데이터 필터\n    regression_df \u003d df1.filter(\n        ~(\n            (col(\"max_mileage\") \u003e col(\"prev_max_mileage\")) \u0026\n            (col(\"max_mileage\") \u003e col(\"next_max_mileage\"))\n        )\n    )\n\n    regression_df \u003d regression_df.withColumn(\n        \"accum_mileage\",\n        col(\"max_mileage\") - first(\"max_mileage\").over(window_ordered)\n    )\n    regression_df \u003d regression_df.withColumn(\n        \"accum_dod_change\",\n        col(\"total_dod\") - first(\"total_dod\").over(window_ordered)\n    )\n\n    regression_df \u003d regression_df.withColumn(\"mean_x\", avg(\"accum_dod_change\").over(window_id))\n    regression_df \u003d regression_df.withColumn(\"mean_y\", avg(\"accum_mileage\").over(window_id))\n    regression_df \u003d regression_df.withColumn(\"x_diff\", col(\"accum_dod_change\") - col(\"mean_x\"))\n    regression_df \u003d regression_df.withColumn(\"y_diff\", col(\"accum_mileage\") - col(\"mean_y\"))\n    regression_df \u003d regression_df.withColumn(\"xy_diff\", col(\"x_diff\") * col(\"y_diff\"))\n    regression_df \u003d regression_df.withColumn(\"x_diff_squared\", col(\"x_diff\") * col(\"x_diff\"))\n\n    regression_df \u003d regression_df.withColumn(\n        \"slope\",\n        sum(\"xy_diff\").over(window_id) / sum(\"x_diff_squared\").over(window_id)\n    )\n    regression_df \u003d regression_df.withColumn(\n        \"intercept\",\n        col(\"mean_y\") - col(\"slope\") * col(\"mean_x\")\n    )\n\n    # 초기 DoD 추정\n    regression_df \u003d regression_df.withColumn(\n        \"first_total_dod\",\n        first(\"total_dod\").over(window_ordered)\n    )\n    regression_df \u003d regression_df.withColumn(\n        \"numerator_check\",\n        col(\"first_actual_max_mileage\") - col(\"intercept\")\n    )\n    regression_df \u003d regression_df.withColumn(\n        \"first_dod_est_regression\",\n        when(\n            (col(\"slope\") \u003c\u003d 0) | (col(\"numerator_check\") \u003c\u003d 0),\n            lit(None).cast(IntegerType())\n        ).otherwise(\n            pyspark_round(col(\"numerator_check\") / col(\"slope\"), 0).cast(IntegerType())\n        )\n    )\n\n    # 효율성 기반 초기 DoD 추정\n    regression_df \u003d regression_df.withColumn(\n        \"first_dod_est_efficiency\",\n        pyspark_round(\n            col(\"first_actual_max_mileage\") / col(\"dod_efficiency_km_per_dod\"),\n            0\n        ).cast(IntegerType())\n    )\n\n    # 최종 first_dod_est 결정\n    regression_df \u003d regression_df.withColumn(\n        \"first_dod_est\",\n        when(\n            (col(\"first_dod_est_regression\").isNotNull()) \u0026\n            (col(\"first_dod_est_regression\") \u003e 0) \u0026\n            (col(\"first_dod_est_regression\") \u003e\u003d col(\"first_dod_est_efficiency\") / 10) \u0026\n            (col(\"first_dod_est_regression\") \u003c\u003d col(\"first_dod_est_efficiency\") * 10),\n            col(\"first_dod_est_regression\")\n        ).otherwise(col(\"first_dod_est_efficiency\"))\n    )\n\n    # deviceId 기준 first_dod_est 조인\n    first_dod_est_df \u003d regression_df.select(\"deviceId\", \"first_dod_est\").distinct()\n    df1 \u003d df1.join(first_dod_est_df, on\u003d\"deviceId\", how\u003d\"left\")\n\n    df1 \u003d df1.withColumn(\n        \"first_dod_est\",\n        when(\n            col(\"first_dod_est\") \u003c\u003d 0,\n            pyspark_round(\n                col(\"first_actual_max_mileage\") / col(\"dod_efficiency_km_per_dod\"),\n                0\n            ).cast(IntegerType())\n        ).otherwise(col(\"first_dod_est\"))\n    )\n\n    df1 \u003d df1.withColumn(\"accum_dod\", col(\"first_dod_est\") + col(\"total_dod\"))\n\n    return df1\n",
      "user": "anonymous",
      "dateUpdated": "2025-12-01 14:23:23.661",
