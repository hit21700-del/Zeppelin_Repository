      "text": "%spark_user.pyspark\nfrom pyspark.sql import SparkSession,DataFrame\nfrom pyspark.sql.types import StructType\nimport sys\nimport os\nsys.path.append(\"/home/kadap/QH/SOH_Model\")\n\n\n\"\"\"\nsoh forecst uing MLP algorithm_v4 (model version. v4.0)\n- accum_dod, mileage 회귀모델을 통해 초기 dod도출(보정)\n- 3개의 변수로 capacity 예측 후, temp, c-rate 소거법 적용으로 dod_effect 도출\n- dod effect,max_capacity로 capaciy_decomposed 도출 \n\"\"\"\n\n# 라이브러리 임포트\nimport torch\nimport torch.nn as nn\nimport torch.optim as optim\nimport pandas as pd\nimport numpy as np\nfrom kslab_soh_config import PRESOH_IO_CONFIG, MLP_IO_CONFIG, DB_QUERY_FROM_SOH_CAPA\nfrom kslab_soh_utils import setup_spark_session, load_data_from_csv, load_data_from_db, save_results_to_csv, save_results_to_db,load_data_from_parquet\nfrom pyspark.sql import Window, SparkSession\nfrom pyspark.sql.functions import lag, when, lit, col, avg, stddev, corr, sum, first, round as pyspark_round, cast, lead, max as pyspark_max, min as pyspark_min,date_format\nfrom pyspark.sql.types import IntegerType\nfrom sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score\nimport matplotlib.pyplot as plt\nimport os\nfrom sklearn.model_selection import train_test_split\nimport torch.utils.data as data_utils\nimport logging\nimport shutil\nfrom datetime import datetime\nfrom pyspark.sql import functions as F\n\n# ─────────────────────\n# 모델 저장 경로 설정 (config 기반)\n# ─────────────────────\nMODEL_CFG \u003d MLP_IO_CONFIG.get(\u0027model\u0027, {})\n\n# config 기반 경로 사용 (기본값 사용하지 않음)\nLOCAL_MODEL_DIR \u003d MODEL_CFG.get(\u0027local_base_dir\u0027)  # /home/kadap/QH/SOH_Model/models/discharge/mlp_model/\nHDFS_MODEL_DIR  \u003d MODEL_CFG.get(\u0027hdfs_base_dir\u0027)   # hdfs:///QH/SOH_Model/discharge/models/\nVERSION_BY_DATE \u003d MODEL_CFG.get(\u0027version_by_date\u0027, False)   # 날짜는 파일명에만 포함\n",
