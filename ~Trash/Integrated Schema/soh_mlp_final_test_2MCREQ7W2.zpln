    },
    {
      "text": "%spark_user.pyspark\n\n# MLP 기반 용량 예측\n# 특정 ID만 로드해서 처리하는 엔트리 함수\ndef mlp_decomposition(spark, id_value\u003dNone, day_of_soh\u003dNone, model_type\u003d\"MLP\", **model_params):\n\n    # 데이터 로드 (원래 로직 그대로)\n    if MLP_IO_CONFIG[\"input\"][\"source\"].lower() \u003d\u003d \"csv\":\n        if not id_value:\n            logger.error(\"ID가 입력되지 않았습니다. 프로그램을 종료합니다.\")\n            sys.exit(1)\n\n        capa_csv_path \u003d MLP_IO_CONFIG[\"input\"][\"csv_path\"]\n        csv_path \u003d capa_csv_path.replace(\"{id}\", id_value)\n\n        logger.info(f\"ID: {id_value} 의 CSV 파일을 로드합니다: {csv_path}\")\n        df \u003d load_data_from_csv(spark, csv_path)\n\n        if day_of_soh:\n            df \u003d df.filter(col(\"day_of_soh\") \u003c\u003d day_of_soh)\n            logger.info(f\"CSV 데이터에서 day_of_soh \u003c\u003d {day_of_soh} 로 필터링\")\n        else:\n            logger.info(\"날짜가 입력되지 않았습니다. 전체 데이터를 추출합니다.\")\n\n    else:  # \"db\"\n        if not id_value:\n            logger.info(\"ID가 입력되지 않았습니다. 프로그램을 종료합니다.\")\n            sys.exit(0)\n        else:\n            query \u003d DB_QUERY_FROM_SOH_CAPA.format(id_value\u003did_value)\n\n        df \u003d load_data_from_db(spark, query)\n\n    # id → deviceId 컬럼 정리\n    if \"deviceId\" not in df.columns and \"id\" in df.columns:\n        df \u003d df.withColumnRenamed(\"id\", \"deviceId\")\n    elif \"deviceId\" not in df.columns:\n        logger.error(\"[MLP] 입력 데이터에 deviceId/id 컬럼이 없습니다.\")\n        sys.exit(1)\n\n    # 누적 DoD 계산\n    df1 \u003d cal_total_dod(df)\n\n    # MLP 알고리즘으로 SOH 추정\n    df2 \u003d (\n        df1.select(\n            \"deviceId\", \"day_of_soh\", \"accum_dod\",\n            \"avg_bms_temp\", \"discharge_rate\",\n            \"energy_capacity\", \"first_dod_est\", \"max_mileage\"\n        )\n        .orderBy(\"deviceId\", \"day_of_soh\")\n    )\n    \n    # aggregate by id and day_of_soh (추가)\n    # 동일날짜 데이터 생성\n    df2 \u003d df2.groupBy(\u0027deviceId\u0027, \u0027day_of_soh\u0027).agg(\n        max(\u0027accum_dod\u0027).alias(\u0027accum_dod\u0027),\n        avg(\u0027avg_bms_temp\u0027).alias(\u0027avg_bms_temp\u0027),\n        avg(\u0027discharge_rate\u0027).alias(\u0027discharge_rate\u0027),\n        avg(\u0027energy_capacity\u0027).alias(\u0027energy_capacity\u0027),\n        avg(\u0027first_dod_est\u0027).alias(\u0027first_dod_est\u0027),\n        max(\u0027max_mileage\u0027).alias(\u0027max_mileage\u0027)\n    )\n    \n\n    data_list \u003d df2.rdd.collect()\n    data \u003d pd.DataFrame([row.asDict() for row in data_list])\n\n    if data.empty:\n        logger.info(\"[MLP] 처리할 데이터가 없습니다.\")\n        return pd.DataFrame()\n\n    device_list \u003d data[\"deviceId\"].unique()\n    result_list \u003d []\n\n    for device_id in device_list:\n        device_id_str \u003d str(device_id).zfill(11)\n        data_id \u003d data[data[\"deviceId\"] \u003d\u003d device_id].copy()\n        result_id \u003d process_single_id_data(data_id, device_id_str, model_type, **model_params)\n        result_list.append(result_id)\n\n    result \u003d pd.concat(result_list, ignore_index\u003dTrue)\n    return result\n",
      "user": "anonymous",
      "dateUpdated": "2025-12-01 14:23:23.763",
      "progress": 0,
