    },
    {
      "text": "%spark_user.pyspark\n# 현재 구조 (run_mlp_full_batch)\n# mlp_decomposition() 사용x \u003c-단일함수용\n#load_mlp_source(spark) 로 여러 단말기 ID의 전체 capa 데이터를 한 번에 로드하고,\n#cal_total_dod(capa_df) → process_single_id_data()를\n#deviceId별로 루프 돌면서 처리하는 방식\n# \n\ndef run_mlp_full_batch(spark, model_type\u003d\"MLP\", **model_params):\n    \"\"\"\n    증분 MLP 배치 (append 방식)\n    - cal_total_dod, 집계(df2)는 항상 capa 전체 기준\n    - MLP 학습/예측은 \u0027신규 day_of_soh가 있는 deviceId\u0027만 수행\n    - 결과는 \u0027신규 날짜 row만\u0027 soh_mlp 경로에 append\n    \"\"\"\n\n    # 0) 기존 soh_mlp에서 deviceId별 마지막 day_of_soh 조회\n    last_day_map \u003d get_last_processed_day_per_device(spark)  # {deviceId_str(11자리): last_day}\n\n    # 1) capa 전체 로드\n    capa_df \u003d load_mlp_source(spark)\n    \n    # 테스트용 하드코딩 (끝나면 꼭 지우기!)\n    capa_df \u003d capa_df.filter(F.col(\"day_of_soh\") \u003c\u003d F.lit(\"2025-05-02\"))\n    \n    \n    if capa_df.rdd.isEmpty():\n        logger.info(\"[MLP] capa 데이터가 없습니다. 종료합니다.\")\n        return\n\n    # 2) 누적 DoD 계산 (deviceId 기준)\n    df1 \u003d cal_total_dod(capa_df)\n\n    # 3) (deviceId, day_of_soh) 단위 집계\n    df2 \u003d (\n        df1\n        .groupBy(\"deviceId\", \"day_of_soh\")\n        .agg(\n            F.max(\"accum_dod\").alias(\"accum_dod\"),\n            F.avg(\"avg_bms_temp\").alias(\"avg_bms_temp\"),\n            F.avg(\"discharge_rate\").alias(\"discharge_rate\"),\n            F.avg(\"energy_capacity\").alias(\"energy_capacity\"),\n            F.avg(\"first_dod_est\").alias(\"first_dod_est\"),\n            F.max(\"max_mileage\").alias(\"max_mileage\"),\n        )\n        .orderBy(\"deviceId\", \"day_of_soh\")\n    )\n\n    # 4) Spark → pandas 변환\n    data_list \u003d df2.rdd.collect()\n    data \u003d pd.DataFrame([row.asDict() for row in data_list])\n\n    if data.empty:\n        logger.info(\"[MLP] 처리할 데이터가 없습니다.\")\n        return\n\n    device_list \u003d data[\"deviceId\"].unique()\n    result_list \u003d []\n\n    # 5) deviceId별 처리\n    for device_id in device_list:\n        device_id_str \u003d str(device_id).zfill(11)\n        logger.info(f\"[MLP] deviceId\u003d{device_id_str} 처리 시작\")\n\n        # 이 단말의 전체 히스토리\n        data_id \u003d data[data[\"deviceId\"] \u003d\u003d device_id_str].copy()\n        if data_id.empty:\n            continue\n\n        # 이 단말의 마지막 처리 날짜 (기존 soh_mlp 기준)\n        last_day \u003d last_day_map.get(device_id_str)\n\n        # 5-1) 신규 데이터 존재 여부 확인\n        if last_day is not None:\n            has_new \u003d (data_id[\"day_of_soh\"] \u003e last_day).any()\n            if not has_new:\n                logger.info(f\"[MLP] deviceId\u003d{device_id_str}: 신규 day_of_soh 없음 → 스킵\")\n                continue\n\n        # 5-2) 전체 히스토리로 MLP 학습/예측\n        #      (process_single_id_data는 전체 data_id 기준으로 학습/예측)\n        result_id_all \u003d process_single_id_data(\n            data_id, device_id_str, model_type, **model_params\n        )\n\n        # 5-3) 이 중에서 \u0027신규 날짜\u0027만 결과로 사용\n        if last_day is not None:\n            result_id_new \u003d result_id_all[result_id_all[\"day_of_soh\"] \u003e last_day]\n        else:\n            # 기존 soh_mlp에 이 단말이 없었던 경우 → 전체 저장\n            result_id_new \u003d result_id_all\n\n        if result_id_new.empty:\n            logger.info(f\"[MLP] deviceId\u003d{device_id_str}: 신규 결과 없음\")\n            continue\n\n        result_list.append(result_id_new)\n\n    if not result_list:\n        logger.info(\"[MLP] 이번 배치에서 추가할 신규 결과가 없습니다.\")\n        return\n\n    # 6) 신규 결과 합치기\n    incr_pd \u003d pd.concat(result_list, ignore_index\u003dTrue)\n    incr_spark \u003d spark.createDataFrame(incr_pd)\n\n    # 7) 신규 결과만 append 저장 (기존 soh_mlp는 건드리지 않음)\n    out_path \u003d MLP_IO_CONFIG[\u0027output\u0027][\u0027parquet_path\u0027]\n    (\n        incr_spark\n        .write\n        .mode(\"append\")          # append 모드로 쌓기\n        .partitionBy(\"deviceId\")\n        .parquet(out_path)\n    )\n\n    logger.info(f\"[MLP] 증분 배치 처리 완료 (append): {out_path}\")\n\n",
      "user": "anonymous",
