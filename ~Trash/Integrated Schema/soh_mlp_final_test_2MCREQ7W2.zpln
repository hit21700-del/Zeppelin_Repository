      "text": "%spark_user.pyspark\n# 로깅 설정\nlogging.basicConfig(\n    level\u003dlogging.INFO,\n    format\u003d\u0027%(asctime)s - %(levelname)s - %(message)s\u0027\n)\nlogger \u003d logging.getLogger(__name__)\n\n\"\"\"\nkslab_soh_mlp.py (full-batch 버전)\n- 입력  : soh_capa 전체 (parquet)\n- 출력  : soh_mlp 전체 (parquet, overwrite)\n- 연산로직(MLP, cal_total_dod, process_single_id_data)은 기존 코드 그대로 사용\n\"\"\"\n\n# 로깅 설정\nlogging.basicConfig(\n    level\u003dlogging.INFO,\n    format\u003d\u0027%(asctime)s - %(levelname)s - %(message)s\u0027\n)\nlogger \u003d logging.getLogger(\"mlp\")\nlogging.getLogger(\"py4j\").setLevel(logging.ERROR)\n\nprint(\"Logger initialized\")\n\n\n# Random seed 설정 함수 (기존 유지)\ndef set_random_seed(seed\u003d42):\n    \"\"\"\n    재현성을 위한 random seed 설정\n    \"\"\"\n    torch.manual_seed(seed)\n    torch.cuda.manual_seed_all(seed)\n    np.random.seed(seed)\n    torch.backends.cudnn.deterministic \u003d True\n    torch.backends.cudnn.benchmark \u003d False\n\n\n# MLP Model Class (기존 유지)\nclass MLP(nn.Module):\n\n    def __init__(self, input_size\u003d3, hidden_size\u003d6, output_size\u003d1):\n        super(MLP, self).__init__()\n        self.fc1 \u003d nn.Linear(input_size, hidden_size)\n        self.fc2 \u003d nn.Linear(hidden_size, output_size)\n        self.sigmoid \u003d nn.Sigmoid()\n\n    def forward(self, x):\n        x \u003d self.sigmoid(self.fc1(x))\n        x \u003d self.sigmoid(self.fc2(x))\n        return x\n\n\n# 모델 학습 및 검증 (기존 연산 로직 유지)\ndef train_model_with_validation(model, X_train, Y_train, X_val, Y_val, model_save_path,\n                               normalization_params, model_type\u003d\u0027MLP\u0027, **kwargs):\n\n    # 기본 하이퍼파라미터 설정\n    default_params \u003d {\n        \u0027learning_rate\u0027: 0.1,\n        \u0027batch_size\u0027: 1,\n        \u0027patience\u0027: 50,\n        \u0027max_epochs\u0027: 20000,\n        \u0027optimizer\u0027: \u0027SGD\u0027,\n        \u0027loss_function\u0027: \u0027MSE\u0027,\n        \u0027random_seed\u0027: 42\n    }\n\n    # 파라미터 업데이트\n    for key, value in kwargs.items():\n        default_params[key] \u003d value\n\n    # Random seed 설정\n    set_random_seed(default_params[\u0027random_seed\u0027])\n\n    # 데이터 로더 생성\n    train_dataset \u003d data_utils.TensorDataset(torch.tensor(X_train), torch.tensor(Y_train))\n    val_dataset \u003d data_utils.TensorDataset(torch.tensor(X_val), torch.tensor(Y_val))\n    train_loader \u003d data_utils.DataLoader(train_dataset, batch_size\u003ddefault_params[\u0027batch_size\u0027], shuffle\u003dTrue)\n    val_loader \u003d data_utils.DataLoader(val_dataset, batch_size\u003ddefault_params[\u0027batch_size\u0027], shuffle\u003dFalse)\n\n    # 옵티마이저 설정\n    criterion \u003d nn.MSELoss()\n    if default_params[\u0027optimizer\u0027] \u003d\u003d \u0027Adam\u0027:\n        optimizer \u003d optim.Adam(model.parameters(), lr\u003ddefault_params[\u0027learning_rate\u0027])\n    elif default_params[\u0027optimizer\u0027] \u003d\u003d \u0027SGD\u0027:\n        optimizer \u003d optim.SGD(model.parameters(), lr\u003ddefault_params[\u0027learning_rate\u0027])\n    else:\n        optimizer \u003d optim.Adam(model.parameters(), lr\u003ddefault_params[\u0027learning_rate\u0027])\n\n    # Early Stopping\n    patience \u003d default_params[\u0027patience\u0027]\n    best_val_loss \u003d float(\u0027inf\u0027)\n    patience_counter \u003d 0\n    best_state \u003d None\n\n    # 최대 epoch 조정 (기존 로직 유지)\n    if len(X_train) \u003c 10:\n        max_epochs \u003d 1000 if 1000 \u003c default_params[\u0027max_epochs\u0027] else default_params[\u0027max_epochs\u0027]\n    elif len(X_train) \u003e 32:\n        max_epochs \u003d default_params[\u0027max_epochs\u0027]\n    else:\n        max_epochs \u003d 20000\n\n    # 학습 루프\n    for epoch in range(max_epochs):\n        # 학습 단계\n        model.train()\n        for xb, yb in train_loader:\n            optimizer.zero_grad()\n            output \u003d model(xb)\n            loss \u003d criterion(output, yb)\n            loss.backward()\n            optimizer.step()\n\n        # 검증 단계\n        model.eval()\n        val_losses \u003d []\n        with torch.no_grad():\n            for xb, yb in val_loader:\n                output \u003d model(xb)\n                val_loss \u003d criterion(output, yb)\n                val_losses.append(val_loss.item())\n\n        avg_val_loss \u003d np.mean(val_losses)\n\n        # Early Stopping 체크\n        if avg_val_loss \u003c best_val_loss:\n            best_val_loss \u003d avg_val_loss\n            best_state \u003d model.state_dict()\n            patience_counter \u003d 0\n        else:\n            patience_counter +\u003d 1\n\n        if patience_counter \u003e\u003d patience:\n            break\n\n    # 최적 모델 복원\n    if best_state is not None:\n        model.load_state_dict(best_state)\n\n    # 성능 평가\n    model.eval()\n    val_predictions \u003d []\n    val_targets \u003d []\n    with torch.no_grad():\n        for xb, yb in val_loader:\n            output \u003d model(xb)\n            val_predictions.extend(output.numpy().flatten())\n            val_targets.extend(yb.numpy().flatten())\n\n    # 정확도 지표 계산\n    val_mse \u003d mean_squared_error(val_targets, val_predictions)\n    val_mae \u003d mean_absolute_error(val_targets, val_predictions)\n    val_r2 \u003d r2_score(val_targets, val_predictions)\n\n    training_info \u003d {\n        \u0027model_type\u0027: model_type,\n        \u0027epochs\u0027: epoch + 1,\n        \u0027learning_rate\u0027: default_params[\u0027learning_rate\u0027],\n        \u0027optimizer\u0027: default_params[\u0027optimizer\u0027],\n        \u0027loss_function\u0027: default_params[\u0027loss_function\u0027],\n        \u0027early_stopping_patience\u0027: patience,\n        \u0027batch_size\u0027: default_params[\u0027batch_size\u0027]\n    }\n\n    validation_metrics \u003d {\n        \u0027mse\u0027: val_mse,\n        \u0027mae\u0027: val_mae,\n        \u0027r2\u0027: val_r2\n    }\n\n    # 모델 저장 (기존 로직 유지)\n    try:\n        model_info \u003d {\n            \u0027model_state_dict\u0027: model.state_dict(),\n            \u0027model_architecture\u0027: {\n                \u0027input_size\u0027: X_train.shape[1],\n                \u0027hidden_size\u0027: 6,\n                \u0027output_size\u0027: 1\n            },\n            \u0027normalization_params\u0027: normalization_params,\n            \u0027training_info\u0027: training_info,\n            \u0027validation_metrics\u0027: validation_metrics\n        }\n        torch.save(model_info, model_save_path)\n        print(f\"Model trained and saved successfully to: {model_save_path}\")\n    except Exception as e:\n        pass\n\n    return model, training_info, validation_metrics\n\n\n# 모델 성능 평가 (기존 유지)\ndef evaluate_model_performance_v2(model, X, Y, normalization_params, actual_values):\n\n    model.eval()\n    with torch.no_grad():\n        pred \u003d model(torch.tensor(X)).numpy().flatten()\n        pred_real \u003d pred * (normalization_params[\u0027capa_max\u0027] - normalization_params[\u0027capa_min\u0027]) + normalization_params[\u0027capa_min\u0027]\n\n    mse \u003d mean_squared_error(actual_values, pred_real)\n    mae \u003d mean_absolute_error(actual_values, pred_real)\n    r2 \u003d r2_score(actual_values, pred_real)\n    rmse \u003d np.sqrt(mse)\n    mape \u003d np.mean(np.abs((actual_values - pred_real) / actual_values)) * 100\n\n    mean_actual \u003d np.mean(actual_values)\n    rmse_percentage \u003d (rmse / mean_actual) * 100\n\n    accuracy_score \u003d np.maximum(0.0, 100.0 - rmse_percentage)\n    accuracy_rmse_100 \u003d accuracy_score\n\n    performance_metrics \u003d {\n        \u0027mse\u0027: mse,\n        \u0027mae\u0027: mae,\n        \u0027r2\u0027: r2,\n        \u0027rmse\u0027: rmse,\n        \u0027mape\u0027: mape,\n        \u0027predictions\u0027: pred_real,\n        \u0027rmse_percentage\u0027: rmse_percentage,\n        \u0027accuracy_rmse_100\u0027: accuracy_rmse_100\n    }\n\n    return performance_metrics\n",
      "user": "anonymous",
