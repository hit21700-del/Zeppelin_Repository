    {
      "text": "%spark_user.pyspark\n# 기존 결과에서 deviceId별 마지막 day_of_soh 가져오기\ndef get_last_processed_day_per_device(spark):\n    \"\"\"\n    기존 soh_mlp 결과에서 deviceId별 마지막 day_of_soh 조회\n    - 결과가 없으면 빈 dict 리턴\n    - key: 11자리 zero-padding 된 deviceId (string)\n    \"\"\"\n    out_path \u003d MLP_IO_CONFIG[\u0027output\u0027][\u0027parquet_path\u0027]\n\n    try:\n        mlp_df \u003d spark.read.parquet(out_path)\n    except Exception:\n        logger.info(\"[MLP] 기존 soh_mlp 결과가 없어, 이번 배치는 신규(full)처럼 처리합니다.\")\n        return {}\n\n    last_df \u003d (\n        mlp_df\n        .groupBy(\"deviceId\")\n        .agg(F.max(\"day_of_soh\").alias(\"last_day_of_soh\"))\n    )\n\n    last_pd \u003d last_df.toPandas()\n\n    last_map \u003d {\n        str(row[\"deviceId\"]).zfill(11): row[\"last_day_of_soh\"]\n        for _, row in last_pd.iterrows()\n    }\n    return last_map\n",
      "user": "anonymous",
      "dateUpdated": "2025-12-01 14:23:23.868",
      "progress": 0,
      "config": {
        "editorSetting": {
