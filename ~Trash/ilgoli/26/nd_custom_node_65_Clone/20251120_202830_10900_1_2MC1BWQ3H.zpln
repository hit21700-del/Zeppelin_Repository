    {
      "title": "python_stock Execution",
      "text": "%python_stock\n\n# OUTPUT 데이터 저장 예제 (최종 데이터프레임: resultDf)\nimport os\nimport pandas as pd\nfrom datetime import datetime\n\ntry:\n    if not isinstance(resultDf, pd.DataFrame):\n        resultDf \u003d pd.DataFrame()\nexcept NameError:\n    resultDf \u003d pd.DataFrame()\n\nmakePath \u003d os.path.join(dockerBasePath, hdfsPath).replace(\"\\\\\", \"/\")\nos.makedirs(makePath, exist_ok\u003dTrue)\n\nbase \u003d os.path.join(makePath, \"result.csv\")\nproc \u003d base + \".proc\"\ntimestamp \u003d datetime.now().strftime(\"%Y%m%d%H%M%S\")\nsucc \u003d f\"{base}.succ.{timestamp}\"\n\n# 1) .proc 에 먼저 저장\nresultDf.to_csv(proc, index\u003dFalse)\nprint(\"Temporary written to:\", proc)\n\n# 2) 기존 파일이 있으면 .succ.TIMESTAMP 로 백업\nif os.path.exists(base):\n    os.rename(base, succ)\n    print(\"Backed up old result.csv to:\", succ)\n\n# 3) .proc 를 최종 result.csv 로 리네임\nos.rename(proc, base)\nprint(\"Final CSV saved at:\", base)\n",
