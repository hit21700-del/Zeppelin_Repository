    {
      "text": "%python_stock\n\n\n\nINTERPRETER_SETTING_ID \u003d \u0027python_stock\u0027 \n        \nrestart_url \u003d f\"{zeppelin_host}/api/interpreter/setting/restart/{INTERPRETER_SETTING_ID}\"\n\ntry:\n    restart_resp \u003d requests.put(restart_url, auth\u003d(auth_user, auth_pass), timeout\u003d(10, 3600))\n    \n    if restart_resp.ok:\n        print(f\"✅ 인터프리터 재시작 요청 성공 (Setting ID: {INTERPRETER_SETTING_ID}).\")\n        print(\"    잠시 후 PySpark 환경이 완전히 초기화됩니다.\")\n    else:\n        print(f\"❌ 인터프리터 재시작 요청 실패 (Status: {restart_resp.status_code}). Zeppelin 서버 로그를 확인하세요.\")\n        \nexcept requests.exceptions.RequestException as e:\n    print(f\"❌ 인터프리터 재시작 API 통신 실패: {e}\")",
