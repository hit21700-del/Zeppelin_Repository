    {
      "title": "python_stock Execution",
      "text": "%python_stock\n\nimport json\nimport pandas as pd\nimport os\n\ninput \u003d z.input(\u0027node_nm\u0027)\nconfigValue \u003d z.input(\u0027data_info\u0027)\ninput3 \u003d z.input(\u0027table_info\u0027)\n\nbeforeHdfsPath \u003d z.input(\u0027before_hdfs_path\u0027)\nschemaPath \u003d z.input(\u0027schema_path\u0027)\nhdfsPath \u003d z.input(\u0027hdfs_path\u0027)\n\nconfigValue \u003d configValue.replace(\"\u0027\", \u0027\"\u0027)\nconfigData \u003d json.loads(configValue)\n\n# 테스트 코드(임시)\nbeforeSchemaPath \u003d z.input(\u0027beforeSchemaPath\u0027)\nbeforeHdfsPath \u003d z.input(\u0027beforeHdfsPath\u0027)\n\ndockerBasePath \u003d \u0027/opt/zeppelin/result/\u0027\nif beforeHdfsPath.strip() !\u003d \"\":\n    csv_path \u003d os.path.join(\n        dockerBasePath,\n        beforeHdfsPath.replace(\"\\\\\", \"/\"),\n        \"result.csv\"\n    )\n    print(\"CSV 파일 경로:\", csv_path)\n    \n    if os.path.exists(csv_path):\n        try:\n            inputDf \u003d pd.read_csv(csv_path)\n            print(\"Read DataFrame from:\", csv_path)\n            print(inputDf)\n        except pd.errors.EmptyDataError:\n            print(\"이전 노드 파일에 데이터 없음\", csv_path)\n            inputDf \u003d pd.DataFrame()\n    else:\n        print(\"result.csv 파일없음:\", csv_path)",
