    {
      "title": "python_stock Execution",
      "text": "%python_stock\nimport requests\n\nzeppelin_host \u003d \u0027http://10.10.17.66:18080\u0027  \n\nurl \u003d f\"{zeppelin_host}/api/interpreter/setting/restart/{configData[\u0027interpreter_name\u0027]}\"\n\n# 요청 페이로드: 인터프리터 ID를 지정\npayload \u003d {\n    \"noteId\": configData[\u0027note_id\u0027]\n}\n\nheaders \u003d {\n    \"Content-Type\": \"application/json\"\n}\n\nauth_user \u003d \"admin\"    \nauth_pass \u003d \"admin\"     \n\n# 요청\nresponse \u003d requests.put(url, json\u003dpayload, headers\u003dheaders, auth\u003d(auth_user, auth_pass))\n\n\n# 결과 출력\nif response.ok:\n    print(\"인터프리터 초기화 성공:\")\n    print(response.json())\n    \n    try:\n        java_interpreter_context \u003d z.getInterpreterContext()\n        current_note_id \u003d java_interpreter_context.getNoteId()\n        \n        payload \u003d {\n            \"noteId\": current_note_id\n        }\n        \n        url \u003d f\"{zeppelin_host}/api/interpreter/setting/restart/python_stock\"\n        \n        response \u003d requests.put(url, json\u003dpayload, headers\u003dheaders, auth\u003d(auth_user, auth_pass))\n    \n    \n    except AttributeError as e:\n        print(f\"❌ 노트 ID 가져오기 실패: {e}\")\n        print(\"    현재 PySpark 환경에서는 z 객체의 내부 구조를 직접 접근해야 합니다.\")\n    \nelse:\n    print(\"인터프리터 초기화 실패:\")\n    print(response.status_code, response.text)\n",
      "user": "anonymous",
      "dateUpdated": "2025-11-21 09:47:09.946",
      "progress": 0,
      "config": {
        "tableHide": false,
