    {
      "title": "Config 변수 설정",
      "text": "%spark.pyspark\nimport os\n\nexport \u003d \u0027\u0027\u0027\n\"\"\"\nConfiguration file for KSLAB data preprocessing\n\n\"\"\"\n\n# Spark configuration\nSPARK_CONFIG \u003d {\n    \u0027app_name\u0027: \u0027kslab data preprocessing\u0027,\n    \u0027executor_memory\u0027: \u002716g\u0027,\n    \u0027driver_memory\u0027: \u002716g\u0027,\n    \u0027max_to_string_fields\u0027: 100\n}\n\n# Database configuration (PostgreSQL)\n\nDB_CONFIG \u003d {\n    \u0027dbname\u0027: \u0027KSLAB\u0027,\n    \u0027user\u0027: \u0027postgres\u0027,\n    \u0027password\u0027: \u0027!QAZ2wsx\u0027,\n    \u0027host\u0027: \u002759.6.99.131\u0027,\n    \u0027port\u0027: \u002715432\u0027\n}\n\n# Database configuration (MSSQL)\nDB_CONFIG_MSSQL \u003d {\n    \u0027server\u0027: \u002759.6.99.131:17934\u0027,\n    \u0027database\u0027: \u0027master\u0027,\n    \u0027username\u0027: \u0027sa\u0027,\n    \u0027password\u0027: \u0027!QAZ2wsx\u0027,\n    \u0027driver\u0027: \u0027ODBC+Driver+18+for+SQL+Server\u0027,\n    \u0027encrypt\u0027: \u0027no\u0027,\n    \u0027trust_server_certificate\u0027: \u0027yes\u0027\n}\n\n# Preprocessing Input/Output configuration\n# db : postgreSQL로 변경(\u002724.5)\nPP_IO_CONFIG \u003d {\n    \u0027input\u0027: {\n        \u0027source\u0027: \u0027csv\u0027,                         # \u0027csv\u0027 고정\n        \u0027csv_path\u0027: \u0027hdfs:///QH/TEST_DATA/*\u0027,   # ← 전체/증분은 글로빙으로 조절\n        \u0027db_table\u0027: \u0027\"KSLAB_DATA\".kmon_data\u0027    # (보관)\n    },\n    \u0027output\u0027: {\n        \u0027format\u0027: \u0027parquet\u0027,                         # \u0027csv\u0027 또는 \u0027parquet\u0027 권장\n        \u0027csv_path\u0027: \u0027hdfs:///QH/PP_OUTPUT/pp_result\u0027,  # ← HDFS 출력 디렉터리(폴더)\n        \u0027db_table\u0027: \u0027\"KSLAB_DATA\".kslab_pp_set\u0027        # (보관)\n    }\n}\n\n# Cycle setting Input/Output configuration\nCYCLE_IO_CONFIG \u003d {\n    \u0027input\u0027: {\n        \u0027source\u0027: \u0027db\u0027,  # \u0027csv\u0027 or \u0027db\u0027\n        \u0027csv_path\u0027: \u0027./output_data/pp_output/pp_result_01229848911_2503_2504.csv\u0027,  # Use preprocessing output as input\n        \u0027db_table\u0027: \u0027\"KSLAB_DATA\".kslab_pp_set\u0027\n    },\n    \u0027output\u0027: {\n        \u0027format\u0027: \u0027db\u0027,  # \u0027csv\u0027 or \u0027db\u0027\n        \u0027csv_path\u0027: \u0027./output_data/cycle_output/cycle_result_01229848911_2503_2504.csv\u0027,\n        \u0027db_table\u0027: \u0027\"KSLAB_DATA\".kslab_cycle_set\u0027,\n        \u0027include_raw_data\u0027: False  # 원본 데이터도 함께 저장할지 여부\n    }\n}\n\n# select columns for preprocessing\nSELECTED_COLUMNS \u003d [\n    \"sourceCode\", \"deviceId\", \"vehicleCode\", \"createdAt\", \"indate\",\n    \"messageCode\", \"longitude\", \"latitude\", \"isEVReady\", \"totalMileage\",\n    \"isBreak\", \"accelPedalDepth\", \"speed\", \"SOC\", \"displaySoc\",\n    \"totalSlowChargeCount\", \"totalSlowChargeDuration\",\n\n    \"isMotorPulseWidthModulationOn\", \"inverterDcInputVoltage\",\n    \"motorPhaseCurrentRms\", \"mcuMotorRpm\", \"motorTorqueActual\",\n    \"SOH\", \"totalActiveTime\", \"batteryPackVoltages\", \"batteryPackCurrents\",\n    \"inverterCapacitorVoltage\", \"batteryTotalChargedCapacity\",\n    \"batteryTotalDischargedCapacity\", \"batteryTotalChargedEnergy\",\n\n    \"batteryTotalDischargedEnergy\", \"batteryMaxChargePower\",\n    \"batteryMaxDischargePower\", \"batteryCellVolatageDiff\", \"maxCellVoltageNum\",\n    \"maxCellVoltages\", \"minCellVoltageNum\", \"minCellVoltages\", \"cellVoltages\",\n    \"isBatteryHeaterRelayOn\", \"airconditionCompressorRpm\",\n\n    \"BMSmcuMotorRpm\", \"insulationResistance\",\n    \"obcOutputVoltage\", \"obcOutputCurrent\", \"acInputVoltage\",\n    \"ldcOutputVoltage\", \"ldcOutputCurrent\", \"auxiliaryBatteryVoltage\",\n    \"auxiliaryBatteryCurrent\", \"auxiliaryBatterySoC\",\n\n    \"auxiliaryBatteryTemperature\", \"motorTemperature\", \"inverterTemperature\",\n    \"heatSinkTemperature\", \"igbtTemperature\", \"heater1Temperature\",\n    \"maxModuleTemperatures\", \"minModuleTemperatures\", \"bmt_1\", \"bmt_2\",\n    \"bmt_3\", \"bmt_4\", \"bmt\", \"batteryCoolantInletTemperature\",\n    \"batteryPraBusbarTemperature\", \"ltrOutletTemperature\",\n    \"internalTemperatureFront\", \"externalTemperature\",\n\n    # 비트연산된 컬럼\n    \"car_num\", \"isMcuFault\", \"isMcuTorqueLimited\", \"isMcuMotorControllable\",\n    \"isBmsMainRelayOn\", \"isBmsBatteryUsable\", \"isBmsWarning\", \"isBmsFault\",\n    \"isBmsFused\", \"isWinterModeActive\", \"isCharge\", \"isSlowChargeConnected\",\n    \"isFastChargeConnected\", \"isMcuMainRelayOffRequest\", \"isMcuReady\",\n    \"isHvptcDrive\", \"isObcFault\", \"isObcChargeComplete\", \"cc_sts\",\n    \"paddleShiftUp\", \"paddleShiftDown\",\n\n    # 전처리 생성된 컬럼\n    \"status\"\n]\n\n\n\n# selct final(monitoring) comlums\nSELECTED_COLUMNS_FINAL \u003d [\n    \u0027deviceId\u0027, \u0027vehicleCode\u0027, \u0027createdAt\u0027, \u0027indate\u0027, \u0027status\u0027, \u0027totalMileage\u0027, \u0027speed\u0027, \u0027mcuMotorRpm\u0027, \u0027paddleShiftUp\u0027,\u0027paddleShiftDown\u0027,\n    \u0027SOC\u0027, \u0027displaySoc\u0027, \u0027SOH\u0027, \u0027batteryPackVoltages\u0027, \u0027batteryPackCurrents\u0027, \u0027batteryTotalDischargedCapacity\u0027, \u0027batteryTotalChargedCapacity\u0027, \u0027batteryTotalDischargedEnergy\u0027\n    , \u0027batteryTotalChargedEnergy\u0027, \u0027totalSlowChargeCount\u0027, \n    \u0027maxCellVoltages\u0027, \u0027maxCellVoltageNum\u0027, \u0027minCellVoltages\u0027, \u0027minCellVoltageNum\u0027, \u0027insulationResistance\u0027,\n    \u0027bmt_1\u0027, \u0027bmt_2\u0027, \u0027bmt_3\u0027, \u0027bmt_4\u0027, \u0027maxModuleTemperatures\u0027, \u0027minModuleTemperatures\u0027, \n    \u0027heater1Temperature\u0027, \u0027batteryCoolantInletTemperature\u0027, \u0027batteryPraBusbarTemperature\u0027, \u0027motorTemperature\u0027, \u0027inverterTemperature\u0027, \u0027heatSinkTemperature\u0027\n    , \u0027igbtTemperature\u0027, \u0027internalTemperatureFront\u0027, \u0027externalTemperature\u0027, \u0027bmt\u0027, \u0027ltrOutletTemperature\u0027,\n    \u0027c_date1\u0027, \u0027cvdiff\u0027, \u0027ctdiff\u0027, \u0027mean_ct\u0027, \u0027socdiff\u0027 #, \u0027sop\u0027, \u0027sob\u0027\n    , \u0027anomaly\u0027, \u0027anomaly_type\u0027, \u0027anomaly_level\u0027, \u0027anomaly_desc\u0027 \n    #,\u0027evr\u0027,\u0027c_state\u0027,\u0027c_state_bit0\u0027,\u0027fcco\u0027,\u0027scco\u0027\n]\n\n# Data processing parameters\nPROCESSING_PARAMS \u003d {\n    \u0027status_duration_threshold\u0027: 60,  # seconds\n    \u0027zscore_threshold\u0027: 3,\n    \u0027outlier\u0027: {\n        \u0027SOC\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 127.5},\n        \u0027displaySoc\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 127.5},\n        \u0027SOH\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 127.5},\n        \u0027batteryPackCurrents\u0027: {\u0027min\u0027: -3276.8, \u0027max\u0027: 3276.7},\n        \u0027batteryPackVoltages\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 960},\n        \u0027maxCellVoltages\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 5.1},\n        \u0027minCellVoltages\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 5.1},\n        \u0027batteryMaxChargePower\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 655.35},\n        \u0027batteryMaxDischargePower\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 655.35},\n        \u0027inverterCapacitorVoltage\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 5000},\n        \u0027insulationResistance\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 65535},\n        \u0027speed\u0027: {\u0027min\u0027: -512, \u0027max\u0027: 512},\n        \u0027mcuMotorRpm\u0027: {\u0027min\u0027: -32768, \u0027max\u0027: 32767},\n        #온도변수\n        \u0027bmt_1\u0027: {\u0027min\u0027: -128, \u0027max\u0027: 127},\n        \u0027bmt_2\u0027: {\u0027min\u0027: -128, \u0027max\u0027: 127},\n        \u0027bmt_3\u0027: {\u0027min\u0027: -128, \u0027max\u0027: 127},\n        \u0027bmt_4\u0027: {\u0027min\u0027: -128, \u0027max\u0027: 127},\n        \u0027maxModuleTemperatures\u0027: {\u0027min\u0027: -128, \u0027max\u0027: 127},\n        \u0027minModuleTemperatures\u0027: {\u0027min\u0027: -128, \u0027max\u0027: 127},\n        \u0027batteryCoolantInletTemperature\u0027: {\u0027min\u0027: -128, \u0027max\u0027: 127},\n        \u0027heater1Temperature\u0027: {\u0027min\u0027: -128, \u0027max\u0027: 127},\n        \u0027batteryPraBusbarTemperature\u0027: {\u0027min\u0027: -256, \u0027max\u0027: 254},\n        \u0027motorTemperature\u0027: {\u0027min\u0027: -327.68, \u0027max\u0027: 327.67},\n        \u0027inverterTemperature\u0027: {\u0027min\u0027: -327.68, \u0027max\u0027: 327.67},\n        \u0027heatSinkTemperature\u0027: {\u0027min\u0027: -327.68, \u0027max\u0027: 327.67},\n        \u0027igbtTemperature\u0027: {\u0027min\u0027: -327.68, \u0027max\u0027: 327.67},\n        \u0027internalTemperatureFront\u0027: {\u0027min\u0027: -40, \u0027max\u0027: 88},\n        \u0027externalTemperature\u0027: {\u0027min\u0027: -40, \u0027max\u0027: 88},\n        \u0027ltrOutletTemperature\u0027: {\u0027min\u0027: -128, \u0027max\u0027: 127},  # LTR 온도 센서\n        #누적변수\n        \u0027batteryTotalChargedCapacity\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 500000}, #429496729.5\n        \u0027batteryTotalDischargedCapacity\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 500000},\n        \u0027batteryTotalChargedEnergy\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 500000},\n        \u0027batteryTotalDischargedEnergy\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 500000},\n        \u0027totalMileage\u0027: {\u0027min\u0027: 0, \u0027max\u0027: 500000}\n    }\n}\n\nANOMALY_DETECTION_PARAMS \u003d {\n    # 상태 지속 시간 임계값 (초)\n    \u0027status_duration_threshold\u0027: 60,\n    \n    # Z-score 이상치 감지 임계값\n    \u0027zscore_threshold\u0027: 3,\n    \n    # 배터리 파라미터\n    \u0027battery\u0027: {\n        # 온도 관련 임계값\n        \u0027module_temp_danger\u0027: 60.0,  # 모듈 최대온도 위험 임계값\n        \u0027module_temp_warn\u0027: 50.0,  # 모듈 최대온도 경고 임계값\n        \u0027module_temp_min_danger\u0027: -10.0,  # 모듈 최소온도 위험 임계값 \n        \u0027module_temp_min_warn\u0027: 0.0,  # 모듈 최소온도 경고 임계값\n\n        \u0027module_temp_diff_danger\u0027: 8.0,  # 모듈 간 온도차 위험 임계값\n        \u0027module_temp_diff_warn\u0027: 5.0,  # 모듈 간 온도차 경고 임계값\n\n        \u0027inlt_danger\u0027: 50.0,  # 냉각수 인렛 온도 위험 임계값\n        \u0027inlt_warn\u0027: 45.0,  # 냉각수 인렛 온도 경고 임계값\n        \u0027inlt_min_warn\u0027: 0.0,  # 냉각수 인렛 온도(최소) 경고 임계값\n\n        \u0027ltrt_danger\u0027: 55.0,  # 냉각수 OUTLET 온도 위험 임계값(신규)\n        \u0027ltrt_warn\u0027: 45.0,  # 냉각수 OUTLET 온도 경고 임계값(신규)\n        \u0027ltrt_min_warn\u0027: 0.0,  # 냉각수 OUTLET 온도(최소) 경고 임계값(신규)\n\n        \u0027igbt_danger\u0027: 95.0,  # IGBT 온도 위험 임계값\n        \u0027igbt_warn\u0027: 83.0,  # IGBT 온도 경고 임계값\n        \u0027igbt_min_warn\u0027: -10.0,  # IGBT 온도 경고 임계값\n\n        \u0027busbar_danger\u0027: 66.0,  # 버스바 온도 위험 임계값\n        \u0027busbar_warn\u0027: 61.0,  # 버스바 온도 경고 임계값\n\n        \u0027mtt_danger\u0027: 95.0,  # 구동모터 온도 위험 임계값\n        \u0027mtt_warn\u0027: 71.0,  #  구동모터 온도 경고 임계값\n        \u0027mtt_min_warn\u0027: -20.0,  # 구동모터 온도(최소) 경고 임계값\n\n        \u0027ivtt_danger\u0027: 96.0,  # 인버터 온도 위험 임계값\n        \u0027ivtt_warn\u0027: 85.0,  # 인버터 온도 경고 임계값\n        \u0027ivtt_min_warn\u0027: -10.0,  # 인버터 온도(최소) 경고 임계값\n\n        \u0027hst_danger\u0027: 81.0,  # 방열판 온도 위험 임계값\n        \u0027hst_warn\u0027: 57.0,  # 방열판 온도 경고 임계값\n\n        \u0027heater_danger\u0027: 76.0,  # 히터 온도 위험 임계값\n        \u0027heater_warn\u0027: 66.0,  # 히터 온도 경고 임계값\n\n        \u0027temp_rate_danger\u0027: 5.0,  # 온도 상승률 위험 임계값 (1분당)\n        \u0027temp_rate_warn\u0027: 3.0,  # 온도 상승률 경고 임계값 (1분당)\n        \u0027max_time_gap\u0027: 3600,  # 최대 시간 간격 (초)\n        \n        # 전압 관련 임계값\n        \u0027cell_volt_max_warn\u0027: 4.2,  # 셀전압(최대) 경고 임계치\n        \u0027cell_volt_max_danger\u0027: 4.25,  # 셀전압(최대) 위험 임계치\n        \u0027cell_volt_min_warn\u0027: 2.8,  # 셀전압(최소) 경고 임계치\n        \u0027cell_volt_min_danger\u0027: 2.5,  # 셀전압(최소) 위험 임계치\n        \u0027cvdiff_danger\u0027: 0.08,  # 전압 차이 위험 임계치\n        \u0027cvdiff_warn\u0027: 0.05,  # 전압 차이 경고 임계치\n        \n        \n        # 상태별 전류/전압 변화율 임계값\n        \u0027CHARG\u0027: {\n            \u0027current_rate_threshold\u0027: 10.0,  # 1초당 전류 변화율 임계값 (A/s)\n            \u0027voltage_rate_threshold\u0027: 0.2,  # 1초당 전압 변화율 임계값 (V/s)\n            \u0027duration_threshold\u0027: 3,  # 연속 이상 감지 시간 (초)\n            \u0027voltage_direction\u0027: \u0027decrease\u0027  # 전압 변화 방향\n        },\n        \u0027DRIVING\u0027: {\n            \u0027current_rate_threshold\u0027: 100.0,  # 1초당 전류 변화율 임계값 (A/s)\n            \u0027voltage_rate_threshold\u0027: 0.2,  # 1초당 전압 변화율 임계값 (V/s)\n            \u0027duration_threshold\u0027: 3,  # 연속 이상 감지 시간 (초)\n            \u0027voltage_direction\u0027: \u0027increase\u0027  # 전압 변화 방향\n        },\n        \u0027STOP\u0027: {\n            \u0027current_rate_threshold\u0027: 50.0,  # 1초당 전류 변화율 임계값 (A/s)\n            \u0027voltage_rate_threshold\u0027: 0.1,  # 1초당 전압 변화율 임계값 (V/s)\n            \u0027duration_threshold\u0027: 3,  # 연속 이상 감지 시간 (초)\n            \u0027voltage_direction\u0027: \u0027both\u0027  # 전압 변화 방향\n        }\n    }\n}\n\n# SQL query for database input (kmon raw data) \n# id\u003d\u002701229848911\u0027(현대코나 54러6894) ,\u002701229898935\u0027(니로 제주60바2049)\n\nDB_QUERY_KMON_DATA \u003d \"\"\"\nSELECT * FROM \"KSLAB_DATA\".kmon_data \nWHERE table_type\u003d\u0027kmon_new\u0027 and id\u003d\u002701229848911\u0027 \n-- AND c_date \u003e\u003d\u002720250301\u0027::timestamp and c_date \u003c\u003d\u002720250430\u0027::timestamp\nAND c_date \u003e\u003d\u002720250301\u0027::timestamp and c_date \u003c\u003d\u002720250301 145959\u0027::timestamp\n\"\"\"\n\n\n# SQL query for database input (Master data)\nDB_QUERY_MASTER_DATA \u003d \"\"\"\nSELECT * FROM \"KSLAB_DATA\".kslab_data_info_car_view\n\"\"\"\n\n# SQL query for database input (pp_result data) #01229848911\nDB_QUERY_PP_DATA \u003d \"\"\"\nSELECT * FROM \"KSLAB_DATA\".kslab_pp_set\nWHERE id \u003d\u002701229848911\u0027\nAND c_date \u003e\u003d\u002720250101\u0027::timestamp and c_date \u003c\u003d\u002720250430\u0027::timestamp;\n\"\"\"\n\n# SQL query for database input (cycle_result data)\nDB_QUERY_CYCLE_CC_DATA \u003d \"\"\"\nSELECT id, \nCOALESCE(MAX(acc_dch_cnt),0) as last_acc_dch_cnt, \nCOALESCE(MAX(acc_ch_cnt),0) as last_acc_ch_cnt, \nCOALESCE(MAX(acc_dch_cyc_cnt),0) as last_acc_dch_cyc_cnt, \nCOALESCE(MAX(acc_ch_cyc_cnt),0) as last_acc_ch_cyc_cnt \nFROM \"KSLAB_DATA\".kslab_cycle_set\nWHERE id \u003d\u002701229848911\u0027 \nGROUP BY id;\n\"\"\"\n\u0027\u0027\u0027",
