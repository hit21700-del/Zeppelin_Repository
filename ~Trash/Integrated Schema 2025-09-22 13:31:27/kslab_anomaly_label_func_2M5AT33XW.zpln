{
  "paragraphs": [
    {
      "text": "%spark.pyspark\r\nimport os\r\n\r\nexport \u003d \u0027\u0027\u0027\r\n\"\"\"\r\nKSLAB Anomaly Detection Labeling fuction\r\nThis script labels anomaly detection results based on predefined thresholds and apply on pre-processing code\r\n\r\n\"\"\"\r\nimport os\r\nimport pandas as pd\r\nimport numpy as np\r\nfrom datetime import datetime\r\nimport logging\r\nfrom pyspark.sql import functions as F\r\nfrom kslab_config import ANOMALY_DETECTION_PARAMS\r\nfrom pyspark.sql import Window\r\n\r\n\r\nclass AnomalyLabeler:\r\n    \"\"\"\r\n    Class for labeling anomaly detection results and saving them to a file.\r\n    \"\"\"\r\n    def __init__(self):\r\n        self.battery_params \u003d ANOMALY_DETECTION_PARAMS[\u0027battery\u0027]\r\n        \r\n\r\n    def label_anomalies_spark(self, data: pd.DataFrame) -\u003e pd.DataFrame:\r\n        # Initialize anomaly labels\r\n\r\n        data \u003d data.withColumn(\u0027anomaly\u0027, F.lit(0)) \\\r\n                .withColumn(\u0027temp_anomaly_level\u0027, F.lit(\u0027\u0027)) \\\r\n                .withColumn(\u0027temp_anomaly_type\u0027, F.lit(\u0027\u0027)) \\\r\n                .withColumn(\u0027anomaly_desc\u0027, F.lit(\u0027\u0027)) \\\r\n                .withColumn(\u0027temp_anomaly_desc\u0027, F.lit(\u0027\u0027))\r\n        \r\n        # \u0027createdAt\u0027 컬럼이 존재하는지 확인 (PySpark에서는 schema로 확인)\r\n        if \u0027createdAt\u0027 in data.columns:\r\n            # 시간 기준으로 정렬 (PySpark는 orderBy)\r\n            data \u003d data.orderBy(\u0027createdAt\u0027)\r\n            # 시간 간격 계산 (초 단위)\r\n            diff_window \u003d Window.orderBy(\u0027createdAt\u0027)\r\n            data \u003d data.withColumn(\r\n                \u0027time_diff\u0027,\r\n                (F.col(\u0027createdAt\u0027).cast(\u0027timestamp\u0027).cast(\u0027long\u0027) - F.lag(F.col(\u0027createdAt\u0027).cast(\u0027timestamp\u0027).cast(\u0027long\u0027), 1).over(diff_window))\r\n            )\r\n            # 1시간(3600초) 이상 간격 마스크\r\n            gap_mask \u003d F.col(\u0027time_diff\u0027) \u003e 3600\r\n        \r\n        # 온도 파라미터 리스트\r\n        temp_params \u003d [\r\n            \u0027maxModuleTemperatures\u0027, \u0027minModuleTemperatures\u0027, \u0027bmt_1\u0027, \u0027bmt_2\u0027, \u0027bmt_3\u0027, \u0027bmt_4\u0027,\r\n            \u0027batteryCoolantInletTemperature\u0027, \u0027igbtTemperature\u0027, \u0027batteryPraBusbarTemperature\u0027, \u0027motorTemperature\u0027, \u0027inverterTemperature\u0027,\u0027heatSinkTemperature\u0027,\u0027heater1Temperature\u0027\r\n        ]\r\n        \r\n        # 각 온도 파라미터에 대해 이상 감지 수행\r\n        for param in temp_params:\r\n            if param in data.columns:\r\n                # DANGER 임계치 초과\r\n                danger_mask \u003d F.col(param) \u003e\u003d F.lit(self.battery_params[\u0027module_temp_danger\u0027])\r\n                data \u003d data.withColumn(\r\n                    \u0027anomaly\u0027,\r\n                    F.when(danger_mask, 1).otherwise(F.col(\u0027anomaly\u0027))\r\n                ).withColumn(\r\n                    \u0027temp_anomaly_level\u0027,\r\n                    F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_level\u0027), F.lit(\u0027DANGER; \u0027))).otherwise(F.col(\u0027temp_anomaly_level\u0027))\r\n                ).withColumn(\r\n                    \u0027temp_anomaly_type\u0027,\r\n                    F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_type\u0027), F.lit(\u0027TEMP_ERR; \u0027))).otherwise(F.col(\u0027temp_anomaly_type\u0027))\r\n                ).withColumn(\r\n                    \u0027temp_anomaly_desc\u0027,\r\n                    F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_desc\u0027), F.lit(param + \u0027 OVER DANGER LIMIT; \u0027))).otherwise(F.col(\u0027temp_anomaly_desc\u0027))\r\n                )\r\n\r\n                # WARNING 임계치 초과\r\n                warning_mask \u003d (F.col(param) \u003e\u003d F.lit(self.battery_params[\u0027module_temp_warn\u0027])) \u0026 (F.col(param) \u003c F.lit(self.battery_params[\u0027module_temp_danger\u0027]))\r\n                data \u003d data.withColumn(\r\n                    \u0027anomaly\u0027,\r\n                    F.when(warning_mask, 1).otherwise(F.col(\u0027anomaly\u0027))\r\n                ).withColumn(\r\n                    \u0027temp_anomaly_level\u0027,\r\n                    F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_level\u0027), F.lit(\u0027WARNING; \u0027))).otherwise(F.col(\u0027temp_anomaly_level\u0027))\r\n                ).withColumn(\r\n                    \u0027temp_anomaly_type\u0027,\r\n                    F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_type\u0027), F.lit(\u0027TEMP_ERR; \u0027))).otherwise(F.col(\u0027temp_anomaly_type\u0027))\r\n                ).withColumn(\r\n                    \u0027temp_anomaly_desc\u0027,\r\n                    F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_desc\u0027), F.lit(param + \u0027 OVER WARN LIMIT; \u0027))).otherwise(F.col(\u0027temp_anomaly_desc\u0027))\r\n                )\r\n        \r\n        # 최대-최소 온도차 (CTDIFF) 계산 (PySpark 변환)\r\n        if \u0027ctdiff\u0027 in data.columns:\r\n            # danger 임계치 초과 체크\r\n            danger_mask \u003d F.col(\u0027ctdiff\u0027) \u003e F.lit(self.battery_params[\u0027module_temp_diff_danger\u0027])\r\n            data \u003d data.withColumn(\r\n                \u0027anomaly\u0027,\r\n                F.when(danger_mask, 1).otherwise(F.col(\u0027anomaly\u0027))\r\n            ).withColumn(\r\n                \u0027temp_anomaly_level\u0027,\r\n                F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_level\u0027), F.lit(\u0027DANGER; \u0027))).otherwise(F.col(\u0027temp_anomaly_level\u0027))\r\n            ).withColumn(\r\n                \u0027temp_anomaly_type\u0027,\r\n                F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_type\u0027), F.lit(\u0027TEMP_ERR; \u0027))).otherwise(F.col(\u0027temp_anomaly_type\u0027))\r\n            ).withColumn(\r\n                \u0027temp_anomaly_desc\u0027,\r\n                F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_desc\u0027), F.lit(\u0027CTDIFF OVER DANGER LIMIT; \u0027))).otherwise(F.col(\u0027temp_anomaly_desc\u0027))\r\n            )\r\n\r\n            # warning 임계치 초과 체크 (danger 미만인 경우만)\r\n            warning_mask \u003d (F.col(\u0027ctdiff\u0027) \u003e F.lit(self.battery_params[\u0027module_temp_diff_warn\u0027])) \u0026 \\\r\n                           (F.col(\u0027ctdiff\u0027) \u003c\u003d F.lit(self.battery_params[\u0027module_temp_diff_danger\u0027]))\r\n            data \u003d data.withColumn(\r\n                \u0027anomaly\u0027,\r\n                F.when(warning_mask, 1).otherwise(F.col(\u0027anomaly\u0027))\r\n            ).withColumn(\r\n                \u0027temp_anomaly_level\u0027,\r\n                F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_level\u0027), F.lit(\u0027WARNING; \u0027))).otherwise(F.col(\u0027temp_anomaly_level\u0027))\r\n            ).withColumn(\r\n                \u0027temp_anomaly_type\u0027,\r\n                F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_type\u0027), F.lit(\u0027TEMP_ERR; \u0027))).otherwise(F.col(\u0027temp_anomaly_type\u0027))\r\n            ).withColumn(\r\n                \u0027temp_anomaly_desc\u0027,\r\n                F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_desc\u0027), F.lit(\u0027CTDIFF OVER WARN LIMIT; \u0027))).otherwise(F.col(\u0027temp_anomaly_desc\u0027))\r\n            )\r\n        \r\n        # 전압 이상 감지 (PySpark 변환)\r\n        voltage_cols \u003d [\u0027maxCellVoltages\u0027, \u0027minCellVoltages\u0027, \u0027cvdiff\u0027]\r\n        for col in voltage_cols:\r\n            if col in data.columns:\r\n                if col \u003d\u003d \u0027maxCellVoltages\u0027:\r\n                    # MAXCV: 4.25 초과이면 danger, 4.2 초과이면 warning\r\n                    danger_mask \u003d F.col(col) \u003e F.lit(self.battery_params[\u0027cell_volt_max_danger\u0027])\r\n                    data \u003d data.withColumn(\r\n                        \u0027anomaly\u0027,\r\n                        F.when(danger_mask, 1).otherwise(F.col(\u0027anomaly\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_level\u0027,\r\n                        F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_level\u0027), F.lit(\u0027DANGER; \u0027))).otherwise(F.col(\u0027temp_anomaly_level\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_type\u0027,\r\n                        F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_type\u0027), F.lit(\u0027VOLT_ERR; \u0027))).otherwise(F.col(\u0027temp_anomaly_type\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_desc\u0027,\r\n                        F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_desc\u0027), F.lit(col + \u0027 OVER DANGER LIMIT; \u0027))).otherwise(F.col(\u0027temp_anomaly_desc\u0027))\r\n                    )\r\n\r\n                    warning_mask \u003d (F.col(col) \u003e F.lit(self.battery_params[\u0027cell_volt_max_warn\u0027])) \u0026 \\\r\n                                   (F.col(col) \u003c\u003d F.lit(self.battery_params[\u0027cell_volt_max_danger\u0027]))\r\n                    data \u003d data.withColumn(\r\n                        \u0027anomaly\u0027,\r\n                        F.when(warning_mask, 1).otherwise(F.col(\u0027anomaly\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_level\u0027,\r\n                        F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_level\u0027), F.lit(\u0027WARNING; \u0027))).otherwise(F.col(\u0027temp_anomaly_level\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_type\u0027,\r\n                        F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_type\u0027), F.lit(\u0027VOLT_ERR; \u0027))).otherwise(F.col(\u0027temp_anomaly_type\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_desc\u0027,\r\n                        F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_desc\u0027), F.lit(col + \u0027 OVER WARN LIMIT; \u0027))).otherwise(F.col(\u0027temp_anomaly_desc\u0027))\r\n                    )\r\n                elif col \u003d\u003d \u0027minCellVoltages\u0027:\r\n                    # MINCV: 2.5 미만이면 danger, 2.8 미만이면 warning\r\n                    danger_mask \u003d F.col(col) \u003c F.lit(self.battery_params[\u0027cell_volt_min_danger\u0027])\r\n                    data \u003d data.withColumn(\r\n                        \u0027anomaly\u0027,\r\n                        F.when(danger_mask, 1).otherwise(F.col(\u0027anomaly\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_level\u0027,\r\n                        F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_level\u0027), F.lit(\u0027DANGER; \u0027))).otherwise(F.col(\u0027temp_anomaly_level\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_type\u0027,\r\n                        F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_type\u0027), F.lit(\u0027VOLT_ERR; \u0027))).otherwise(F.col(\u0027temp_anomaly_type\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_desc\u0027,\r\n                        F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_desc\u0027), F.lit(col + \u0027 UNDER DANGER LIMIT; \u0027))).otherwise(F.col(\u0027temp_anomaly_desc\u0027))\r\n                    )\r\n\r\n                    warning_mask \u003d (F.col(col) \u003c F.lit(self.battery_params[\u0027cell_volt_min_warn\u0027])) \u0026 \\\r\n                                   (F.col(col) \u003e\u003d F.lit(self.battery_params[\u0027cell_volt_min_danger\u0027]))\r\n                    data \u003d data.withColumn(\r\n                        \u0027anomaly\u0027,\r\n                        F.when(warning_mask, 1).otherwise(F.col(\u0027anomaly\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_level\u0027,\r\n                        F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_level\u0027), F.lit(\u0027WARNING; \u0027))).otherwise(F.col(\u0027temp_anomaly_level\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_type\u0027,\r\n                        F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_type\u0027), F.lit(\u0027VOLT_ERR; \u0027))).otherwise(F.col(\u0027temp_anomaly_type\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_desc\u0027,\r\n                        F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_desc\u0027), F.lit(col + \u0027 UNDER WARN LIMIT; \u0027))).otherwise(F.col(\u0027temp_anomaly_desc\u0027))\r\n                    )\r\n                elif col \u003d\u003d \u0027cvdiff\u0027:\r\n                    # CVDIFF: 0.05 이상이면 danger, 0.03 이상이면 warning\r\n                    danger_mask \u003d F.col(col) \u003e\u003d F.lit(self.battery_params[\u0027cvdiff_danger\u0027])\r\n                    data \u003d data.withColumn(\r\n                        \u0027anomaly\u0027,\r\n                        F.when(danger_mask, 1).otherwise(F.col(\u0027anomaly\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_level\u0027,\r\n                        F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_level\u0027), F.lit(\u0027DANGER; \u0027))).otherwise(F.col(\u0027temp_anomaly_level\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_type\u0027,\r\n                        F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_type\u0027), F.lit(\u0027VOLT_ERR; \u0027))).otherwise(F.col(\u0027temp_anomaly_type\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_desc\u0027,\r\n                        F.when(danger_mask, F.concat(F.col(\u0027temp_anomaly_desc\u0027), F.lit(col + \u0027 OVER DANGER LIMIT; \u0027))).otherwise(F.col(\u0027temp_anomaly_desc\u0027))\r\n                    )\r\n\r\n                    warning_mask \u003d (F.col(col) \u003e\u003d F.lit(self.battery_params[\u0027cvdiff_warn\u0027])) \u0026 \\\r\n                                   (F.col(col) \u003c F.lit(self.battery_params[\u0027cvdiff_danger\u0027]))\r\n                    data \u003d data.withColumn(\r\n                        \u0027anomaly\u0027,\r\n                        F.when(warning_mask, 1).otherwise(F.col(\u0027anomaly\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_level\u0027,\r\n                        F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_level\u0027), F.lit(\u0027WARNING; \u0027))).otherwise(F.col(\u0027temp_anomaly_level\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_type\u0027,\r\n                        F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_type\u0027), F.lit(\u0027VOLT_ERR; \u0027))).otherwise(F.col(\u0027temp_anomaly_type\u0027))\r\n                    ).withColumn(\r\n                        \u0027temp_anomaly_desc\u0027,\r\n                        F.when(warning_mask, F.concat(F.col(\u0027temp_anomaly_desc\u0027), F.lit(col + \u0027 OVER WARN LIMIT; \u0027))).otherwise(F.col(\u0027temp_anomaly_desc\u0027))\r\n                    )\r\n        \r\n        \r\n        # 상태별 전류/전압 변화율 감지\r\n        if \u0027batteryPackCurrents\u0027 in data.columns and \u0027batteryPackVoltages\u0027 in data.columns and \u0027status\u0027 in data.columns:\r\n            # winter_mode가 0일때만 실행\r\n            winter_mode_off \u003d F.col(\u0027isWinterModeActive\u0027) \u003d\u003d 0\r\n            \r\n            # 시간 기준으로 정렬\r\n            data \u003d data.orderBy(\u0027createdAt\u0027)\r\n            \r\n            # createdAt 기준 정렬 윈도우\r\n            diff_window \u003d Window.orderBy(\u0027createdAt\u0027)\r\n\r\n            # 전류/전압 diff\r\n            data \u003d data.withColumn(\r\n                \u0027bpc_a_diff\u0027,\r\n                F.col(\u0027batteryPackCurrents\u0027) - F.lag(\u0027batteryPackCurrents\u0027, 1).over(diff_window)\r\n            ).withColumn(\r\n                \u0027bpc_v_diff\u0027,\r\n                F.col(\u0027batteryPackVoltages\u0027) - F.lag(\u0027batteryPackVoltages\u0027, 1).over(diff_window)\r\n            )\r\n\r\n            # 시간차 diff (초 단위)\r\n            data \u003d data.withColumn(\r\n                \u0027time_diff\u0027,\r\n                (F.col(\u0027createdAt\u0027).cast(\u0027timestamp\u0027).cast(\u0027long\u0027) - F.lag(F.col(\u0027createdAt\u0027).cast(\u0027timestamp\u0027).cast(\u0027long\u0027), 1).over(diff_window))\r\n            )\r\n\r\n            # 1초당 변화율 계산 (time_diff가 0 또는 null인 경우 0으로 처리)\r\n            data \u003d data.withColumn(\r\n                \u0027bpc_a_rate\u0027,\r\n                F.when(F.col(\u0027time_diff\u0027).isNull() | (F.col(\u0027time_diff\u0027) \u003d\u003d 0), F.lit(0))\r\n                 .otherwise(F.col(\u0027bpc_a_diff\u0027) / F.col(\u0027time_diff\u0027))\r\n            ).withColumn(\r\n                \u0027bpc_v_rate\u0027,\r\n                F.when(F.col(\u0027time_diff\u0027).isNull() | (F.col(\u0027time_diff\u0027) \u003d\u003d 0), F.lit(0))\r\n                 .otherwise(F.col(\u0027bpc_v_diff\u0027) / F.col(\u0027time_diff\u0027))\r\n            )\r\n            \r\n            # 상태별 이상 감지 (PySpark 변환)\r\n            for status in [\u0027CHARG\u0027, \u0027DRIVING\u0027, \u0027STOP\u0027]:\r\n                status_mask \u003d F.col(\u0027status\u0027).startswith(status)\r\n                if status not in self.battery_params:\r\n                    continue\r\n                params \u003d self.battery_params[status]\r\n\r\n                # 전류 변화율 체크\r\n                current_anomaly \u003d F.abs(F.col(\u0027bpc_a_rate\u0027)) \u003e\u003d F.lit(params[\u0027current_rate_threshold\u0027])\r\n\r\n                # 전압 변화율 체크\r\n                if params[\u0027voltage_direction\u0027] \u003d\u003d \u0027increase\u0027:\r\n                    voltage_anomaly \u003d F.col(\u0027bpc_v_rate\u0027) \u003e\u003d F.lit(params[\u0027voltage_rate_threshold\u0027])\r\n                elif params[\u0027voltage_direction\u0027] \u003d\u003d \u0027decrease\u0027:\r\n                    voltage_anomaly \u003d F.col(\u0027bpc_v_rate\u0027) \u003c\u003d -F.lit(params[\u0027voltage_rate_threshold\u0027])\r\n                else:  # both\r\n                    voltage_anomaly \u003d F.abs(F.col(\u0027bpc_v_rate\u0027)) \u003e\u003d F.lit(params[\u0027voltage_rate_threshold\u0027])\r\n\r\n                # winter_mode가 0일 때만 적용\r\n                winter_mode_off \u003d F.col(\u0027isWinterModeActive\u0027) \u003d\u003d 0\r\n\r\n                # rolling window 적용\r\n                anomaly_base \u003d status_mask \u0026 current_anomaly \u0026 voltage_anomaly \u0026 winter_mode_off\r\n                anomaly_window \u003d Window.orderBy(\u0027createdAt\u0027).rowsBetween(-(params[\u0027duration_threshold\u0027]-1), 0)\r\n                anomaly_rolling \u003d F.sum(anomaly_base.cast(\u0027int\u0027)).over(anomaly_window) \u003e\u003d params[\u0027duration_threshold\u0027]\r\n\r\n                # 최종 mask\r\n                anomaly_mask \u003d anomaly_rolling \u0026 anomaly_base\r\n\r\n                # 조건부 컬럼 업데이트\r\n                data \u003d data.withColumn(\r\n                    \u0027anomaly\u0027,\r\n                    F.when(anomaly_mask, 1).otherwise(F.col(\u0027anomaly\u0027))\r\n                ).withColumn(\r\n                    \u0027temp_anomaly_level\u0027,\r\n                    F.when(anomaly_mask, F.concat(F.col(\u0027temp_anomaly_level\u0027), F.lit(\u0027WARNING; \u0027))).otherwise(F.col(\u0027temp_anomaly_level\u0027))\r\n                ).withColumn(\r\n                    \u0027temp_anomaly_type\u0027,\r\n                    F.when(anomaly_mask, F.concat(F.col(\u0027temp_anomaly_type\u0027), F.lit(\u0027VI_ERR; \u0027))).otherwise(F.col(\u0027temp_anomaly_type\u0027))\r\n                ).withColumn(\r\n                    \u0027temp_anomaly_desc\u0027,\r\n                    F.when(anomaly_mask, F.concat(F.col(\u0027temp_anomaly_desc\u0027), F.lit(\u0027RAPID \u0027 + status + \u0027 VI CHANGE DETECTED; \u0027))).otherwise(F.col(\u0027temp_anomaly_desc\u0027))\r\n                )\r\n        \r\n        \r\n        # 최종적으로 anomaly_desc, anomaly_type, anomaly_level 처리 (PySpark)\r\n        data \u003d (\r\n            data\r\n            .withColumn(\r\n                \"anomaly_desc\",\r\n                F.regexp_replace(F.coalesce(F.col(\"temp_anomaly_desc\"), F.lit(\"\")), r\";\\\\s*$\", \"\")\r\n            )\r\n            .withColumn(\r\n                \"anomaly_type\",\r\n                F.regexp_replace(F.coalesce(F.col(\"temp_anomaly_type\"), F.lit(\"\")), r\";\\\\s*$\", \"\")\r\n            )\r\n            .withColumn(\r\n                \"anomaly_level\",\r\n                F.regexp_replace(F.coalesce(F.col(\"temp_anomaly_level\"), F.lit(\"\")), r\";\\\\s*$\", \"\")\r\n            )\r\n        )\r\n\r\n         # 정상 행 보정\r\n        data \u003d (\r\n            data\r\n            .withColumn(\r\n                \"anomaly_type\",\r\n                F.when(F.col(\"anomaly\") \u003d\u003d 0, F.lit(\"normal\")).otherwise(F.col(\"anomaly_type\"))\r\n            )\r\n            .withColumn(\r\n                \"anomaly_desc\",\r\n                F.when(F.col(\"anomaly\") \u003d\u003d 0, F.lit(\"\")).otherwise(F.col(\"anomaly_desc\"))\r\n            )\r\n            .withColumn(\r\n                \"anomaly_level\",\r\n                F.when(F.col(\"anomaly_level\") \u003d\u003d \"\", F.lit(\"normal\")).otherwise(F.col(\"anomaly_level\"))\r\n            )\r\n        )\r\n\r\n        # 임시 계산 컬럼 제거 (PySpark)\r\n        temp_columns \u003d [\r\n            \u0027time_diff\u0027, \u0027ht_1_diff\u0027, \u0027ht_1_rate\u0027,\r\n            \u0027bpc_a_diff\u0027, \u0027bpc_v_diff\u0027, \u0027bpc_a_rate\u0027, \u0027bpc_v_rate\u0027,\r\n            \u0027temp_anomaly_desc\u0027, \u0027temp_anomaly_type\u0027, \u0027temp_anomaly_level\u0027\r\n        ]\r\n        for col in temp_columns:\r\n            if col in data.columns:\r\n                data \u003d data.drop(col)\r\n\r\n        return data\r\n    \r\n        \r\n    # 충방전상태별 그룹핑 및 이상데이터 추가 처리\r\n    def preprocess_status_groups(self, data):\r\n        from pyspark.sql import Window\r\n        from pyspark.sql import functions as F\r\n\r\n        if \u0027createdAt\u0027 not in data.columns or \u0027status\u0027 not in data.columns:\r\n            print(\"Required columns (createdAt, status) not found. Skipping preprocessing.\")\r\n            return data\r\n\r\n        # 시간 기준으로 정렬\r\n        data \u003d data.orderBy(\u0027createdAt\u0027)\r\n\r\n        # 1. STATUS로 그룹 나누기 (STATUS가 변경되거나 1시간 이상 차이가 나는 경우)\r\n        # 시간 차이 계산 (첫 번째 행은 0으로 설정)\r\n        diff_window \u003d Window.orderBy(\u0027createdAt\u0027)\r\n        data \u003d data.withColumn(\u0027time_diff\u0027,\r\n            (F.col(\u0027createdAt\u0027).cast(\u0027timestamp\u0027).cast(\u0027long\u0027) - F.lag(F.col(\u0027createdAt\u0027).cast(\u0027timestamp\u0027).cast(\u0027long\u0027), 1).over(diff_window))\r\n        )\r\n        data \u003d data.withColumn(\u0027time_diff\u0027, F.when(F.col(\u0027time_diff\u0027).isNull(), 0).otherwise(F.col(\u0027time_diff\u0027)))\r\n\r\n        # 그룹 ID 생성 (STATUS 변경 또는 1시간 이상 차이)\r\n        data \u003d data.withColumn(\u0027prev_status\u0027, F.lag(\u0027status\u0027, 1).over(diff_window))\r\n        data \u003d data.withColumn(\u0027group_break\u0027,\r\n            (F.col(\u0027status\u0027) !\u003d F.col(\u0027prev_status\u0027)) | (F.col(\u0027time_diff\u0027) \u003e 3600)\r\n        )\r\n        data \u003d data.withColumn(\u0027group_id\u0027, F.sum(F.col(\u0027group_break\u0027).cast(\u0027int\u0027)).over(diff_window))\r\n\r\n        # 각 그룹별로 row_number 부여\r\n        group_window \u003d Window.partitionBy(\u0027group_id\u0027).orderBy(\u0027createdAt\u0027)\r\n        data \u003d data.withColumn(\u0027row_num\u0027, F.row_number().over(group_window))\r\n        data \u003d data.withColumn(\u0027group_size\u0027, F.count(\u0027*\u0027).over(group_window))\r\n\r\n        # 2-1. 그룹의 행 수가 5개 이하인 경우 제거\r\n        data \u003d data.filter(F.col(\u0027group_size\u0027) \u003e 5)\r\n\r\n        # 2-2. 그룹의 첫 번째 행이 anomaly\u003d1인 경우 제거\r\n        data \u003d data.withColumn(\u0027first_anomaly\u0027, F.first(\u0027anomaly\u0027).over(group_window))\r\n        data \u003d data.withColumn(\u0027is_first\u0027, F.col(\u0027row_num\u0027) \u003d\u003d 1)\r\n        data \u003d data.filter(~((F.col(\u0027is_first\u0027)) \u0026 (F.col(\u0027first_anomaly\u0027) \u003d\u003d 1)))\r\n\r\n        # 2-3. 그룹의 마지막 행이 anomaly\u003d1인 경우 제거\r\n        data \u003d data.withColumn(\u0027last_anomaly\u0027, F.last(\u0027anomaly\u0027).over(group_window))\r\n        data \u003d data.withColumn(\u0027is_last\u0027, F.col(\u0027row_num\u0027) \u003d\u003d F.col(\u0027group_size\u0027))\r\n        data \u003d data.filter(~((F.col(\u0027is_last\u0027)) \u0026 (F.col(\u0027last_anomaly\u0027) \u003d\u003d 1)))\r\n\r\n        # 임시 컬럼 제거\r\n        drop_cols \u003d [\u0027group_id\u0027, \u0027time_diff\u0027, \u0027prev_status\u0027, \u0027group_break\u0027, \u0027row_num\u0027, \u0027group_size\u0027, \u0027first_anomaly\u0027, \u0027is_first\u0027, \u0027last_anomaly\u0027, \u0027is_last\u0027]\r\n        for col in drop_cols:\r\n            if col in data.columns:\r\n                data \u003d data.drop(col)\r\n\r\n        return data\r\n    \r\n\r\n    # 파일로 저장 (전처리 로직과 별도로 적용 시)\r\n    def save_results(self, data, output_path: str \u003d None):\r\n        \"\"\"\r\n        Save labeled anomaly detection results to a file (PySpark version only).\r\n        Args:\r\n            data: PySpark DataFrame with anomaly labels\r\n            output_path: Path to save the results\r\n        \"\"\"\r\n        import os\r\n        from datetime import datetime\r\n        if output_path is None:\r\n            output_path \u003d os.path.join(\r\n                \u0027output_data\u0027,\r\n                f\u0027anomaly_labels_{datetime.now().strftime(\"%Y%m%d_%H%M%S\")}\u0027\r\n            )\r\n\r\n        # 필요한 컬럼만 선택\r\n        columns_to_save \u003d [\r\n            \u0027deviceId\u0027,\u0027createdAt\u0027, \u0027status\u0027,\u0027anomaly\u0027, \u0027anomaly_level\u0027, \u0027anomaly_type\u0027,\u0027anomaly_desc\u0027,\r\n            \u0027maxModuleTemperatures\u0027, \u0027minModuleTemperatures\u0027, \u0027bmt_1\u0027, \u0027bmt_2\u0027, \u0027bmt_3\u0027, \u0027bmt_4\u0027, \u0027ctdiff\u0027, \r\n            \u0027batteryCoolantInletTemperature\u0027, \u0027igbtTemperature\u0027, \u0027batteryPraBusbarTemperature\u0027, \u0027motorTemperature\u0027, \u0027inverterTemperature\u0027,\u0027heatSinkTemperature\u0027,\u0027heater1Temperature\u0027,\r\n            \u0027maxCellVoltages\u0027, \u0027minCellVoltages\u0027, \u0027cvdiff\u0027,\r\n            \u0027bcs\u0027,\u0027socdiff\u0027,\u0027batteryPackCurrents\u0027, \u0027batteryPackVoltages\u0027\r\n        ]\r\n        columns_to_save \u003d [col for col in columns_to_save if col in data.columns]\r\n\r\n        # PySpark DataFrame을 바로 CSV로 저장 (overwrite 모드, header 포함)\r\n        data.select(*columns_to_save) \\\r\n            .write \\\r\n            .mode(\u0027overwrite\u0027) \\\r\n            .option(\u0027header\u0027, True) \\\r\n            .csv(output_path)\r\n        print(f\"Anomaly detection results saved to {output_path}\")\r\n        \u0027\u0027\u0027",
      "user": "anonymous",
      "dateUpdated": "2025-09-17 14:23:38.925",
