{
  "paragraphs": [
    {
      "text": "%spark.pyspark\r\nimport os\r\n\r\nexport \u003d \u0027\u0027\u0027\r\n\r\n\"\"\"\r\nData processing functions for KSLAB data preprocessing\r\n\"\"\"\r\n\r\nfrom typing import Dict, List, Tuple\r\n\r\nfrom pyspark.sql import DataFrame\r\nfrom pyspark.sql.functions import (\r\n    col, avg, max, min, count, to_date, when, mean, stddev, abs, \r\n    date_format, round, split, explode, avg, lit, format_number, \r\n    pandas_udf, lag, lead, expr, array, to_timestamp, unix_timestamp, \r\n    from_unixtime, row_number, last, first, percentile_approx, least, sum as sum_\r\n)\r\nfrom pyspark.sql.window import Window\r\nfrom pyspark.sql.types import DoubleType, IntegerType\r\n\r\nfrom kslab_config import PROCESSING_PARAMS, SELECTED_COLUMNS\r\nfrom kslab_utils import (\r\n    print_timestamp, print_dfcount, create_spark_session,\r\n    load_data_from_db, load_data_from_csv, save_to_csv, save_to_db\r\n)\r\n\r\n# kmon_new 단말 데이터 변환 \r\ndef convert_df_new(df: DataFrame) -\u003e DataFrame:\r\n\r\n    # Column name and data type mapping\r\n    columns_to_rename_and_cast \u003d {\r\n        \u0027table_type\u0027: (\u0027sourceCode\u0027, \u0027string\u0027), #테이블타입\r\n        \u0027id\u0027: (\u0027deviceId\u0027, \u0027string\u0027), # 단말기번호 (id)\r\n        \u0027idx\u0027: (\u0027vehicleCode\u0027, \u0027integer\u0027), #차량type(idx)\r\n        \u0027indate\u0027: (\u0027indate\u0027, \u0027timestamp\u0027), #서버입력시간 (신규)\r\n        \u0027c_date\u0027: (\u0027createdAt\u0027, \u0027timestamp\u0027), #정보발생일시\r\n        \u0027p_status\u0027: (\u0027messageCode\u0027, \u0027integer\u0027),#기기 및 통신상태코드(정상:0, 비정상:11)\r\n        \u0027gps_x\u0027: (\u0027longitude\u0027, \u0027double\u0027),#위도 (신규)\r\n        \u0027gps_y\u0027: (\u0027latitude\u0027, \u0027double\u0027),#경도 \r\n        \u0027evr\u0027: (\u0027isEVReady\u0027, \u0027integer\u0027), #차량준비상태(정상:0, 준비중:1)\r\n        \u0027t_dist\u0027: (\u0027totalMileage\u0027, \u0027integer\u0027),#총주행거리(Km)\r\n        \u0027brk\u0027: (\u0027isBreak\u0027, \u0027integer\u0027),#브레이크 스위치(정상:0, 브레이크:1)\r\n        \u0027epd\u0027: (\u0027accelPedalDepth\u0027, \u0027double\u0027),#엑셀페달 깊이(%)\r\n        \u0027km\u0027: (\u0027speed\u0027, \u0027integer\u0027),#차량속도(km/h)\r\n        \u0027c_state\u0027: (\u0027c_state\u0027, \u0027integer\u0027),#충전 상태 : 충전 정상 진행 상태(bit0), 완속충전 커넥터 ON(bit6), 급속충전 커넥터 ON(bit7)\r\n        \u0027bcs\u0027: (\u0027SOC\u0027, \u0027double\u0027),#배터리 충전상태(%) BMS SOC\r\n        \u0027bsoc\u0027: (\u0027displaySoc\u0027, \u0027double\u0027),#SOC DSIPLAY(%)\r\n        \u0027occ\u0027: (\u0027totalSlowChargeCount\u0027, \u0027integer\u0027),#완속충전 수행 적산횟수\r\n        \u0027o_ctime\u0027: (\u0027totalSlowChargeDuration\u0027, \u0027integer\u0027),#완속충전 수행 적산시간,OBC충전동작 누적시간(min)(아이오닉5, EV6)\r\n        \u0027mcu_state\u0027: (\u0027mcu_state\u0027, \u0027integer\u0027),#MCU 상태 : MCU 고장상태(bit0), MCU 토크제한 운전상태(bit1), 구동모터 제어가능 상태(bit2)\r\n        \u0027pwm\u0027 : (\u0027isMotorPulseWidthModulationOn\u0027, \u0027integer\u0027),#모터PWM ON/OFF상태(ON:1, OFF:0)\r\n        \u0027idiv\u0027: (\u0027inverterDcInputVoltage\u0027, \u0027double\u0027),#인버터 DC입력전압(V)\r\n        \u0027arms\u0027: (\u0027motorPhaseCurrentRms\u0027, \u0027double\u0027),#구동모터 상전류(실효치(Arms)\r\n        \u0027rpm\u0027: (\u0027mcuMotorRpm\u0027, \u0027double\u0027),#구동 모터 속도(MCU) ######################################################## 컬럼명 중복 \r\n        \u0027nm\u0027: (\u0027motorTorqueActual\u0027, \u0027double\u0027),#구동 모터 출력 토크(NM)\r\n        \u0027bms_state\u0027: (\u0027bms_state\u0027, \u0027integer\u0027),#BMS 상태 : BMS 메인릴레이 ON(bit0), 배터리 사용가능상태(bit1), BMS경고(bit2), BMS고장(bit3), BMS융착상태(bit4), 윈터모드 활성화(bit7)\r\n        \u0027bsoh\u0027: (\u0027SOH\u0027, \u0027double\u0027),# BMS SOH (%)\r\n        \u0027t_atime\u0027: (\u0027totalActiveTime\u0027, \u0027integer\u0027),#총동작시간(sec)\r\n        \u0027bpc_v\u0027: (\u0027batteryPackVoltages\u0027, \u0027double\u0027),#배터리 팩 전압(V)\r\n        \u0027bpc_a\u0027: (\u0027batteryPackCurrents\u0027, \u0027double\u0027),#배터리 팩 전류(A)\r\n        \u0027icv\u0027: (\u0027inverterCapacitorVoltage\u0027, \u0027double\u0027),#인버터 캐퍼시터 전압(V)\r\n        \u0027bacc\u0027: (\u0027batteryTotalChargedCapacity\u0027, \u0027double\u0027),#누적충전전류량(Ah)\r\n        \u0027badc\u0027: (\u0027batteryTotalDischargedCapacity\u0027, \u0027double\u0027),#누적방전전류량(Ah)\r\n        \u0027bacp\u0027: (\u0027batteryTotalChargedEnergy\u0027, \u0027double\u0027),#누적충전전력량(kWh)\r\n        \u0027badp\u0027: (\u0027batteryTotalDischargedEnergy\u0027, \u0027double\u0027),#누적방전전력량(kWh)\r\n        \u0027bmcpp\u0027: (\u0027batteryMaxChargePower\u0027, \u0027double\u0027),#배터리최대충전가능파워(kwh)\r\n        \u0027bmdpp\u0027: (\u0027batteryMaxDischargePower\u0027, \u0027double\u0027),#배터리최대충전가능파워(kwh)\r\n        \u0027bcvd\u0027: (\u0027batteryCellVolatageDiff\u0027, \u0027double\u0027),#셀간전압편차(v)(신규)\r\n        \u0027maxcvn\u0027: (\u0027maxCellVoltageNum\u0027, \u0027integer\u0027),#최대셀전압번호\r\n        \u0027maxcv\u0027: (\u0027maxCellVoltages\u0027, \u0027double\u0027),#최대셀전압(v)\r\n        \u0027mincvn\u0027: (\u0027minCellVoltageNum\u0027, \u0027integer\u0027),#최소셀전압번호\r\n        \u0027mincv\u0027: (\u0027minCellVoltages\u0027, \u0027double\u0027),#최소셀전압(v)\r\n        \u0027cv\u0027: (\u0027cellVoltages\u0027, \u0027string\u0027),#셀전압리스트(v)\r\n        \u0027bhr_state\u0027: (\u0027isBatteryHeaterRelayOn\u0027, \u0027integer\u0027),#배터리히터릴레이상태(bit3)\r\n        \u0027acrpm\u0027: (\u0027airconditionCompressorRpm\u0027, \u0027integer\u0027),#에어컨 컴프레셔 동작 RPM\r\n        \u0027mcurr\u0027: (\u0027m_curr\u0027, \u0027integer\u0027),#MCU메인릴레이: MCU메인릴레이 OFF요청(bit1), MCU준비상태(bit2)\r\n        \u0027m_rpm\u0027: (\u0027BMSmcuMotorRpm\u0027, \u0027integer\u0027),#모터 회전수(구동모터속도) rpm) -\u003e RPM과 차이점??!\r\n        \u0027ir\u0027: (\u0027insulationResistance\u0027, \u0027integer\u0027),#절연저항(MΩ)\r\n        \u0027o_state\u0027: (\u0027o_state\u0027, \u0027integer\u0027),#OBC 고장상태 (정상:0, 고장:1)\r\n        \u0027oce\u0027: (\u0027oce\u0027, \u0027integer\u0027),#OBC 충전완료\r\n        \u0027oov\u0027: (\u0027obcOutputVoltage\u0027, \u0027double\u0027),#OBC 출력전압(V), BMS고전압 배터리 전압(아이오닉5, EV6)\r\n        \u0027ooc\u0027: (\u0027obcOutputCurrent\u0027, \u0027double\u0027),#OBC 출력전류(A), BMS고전류 배터리 전류(아이오닉5, EV6)\r\n        \u0027aciv\u0027: (\u0027acInputVoltage\u0027, \u0027double\u0027),#AC 입력전류(충전시), OBC AC전압 A(RMS)(아이오닉5, EV6)\r\n        \u0027lov\u0027: (\u0027ldcOutputVoltage\u0027, \u0027double\u0027),#LCD 출력전압(V)\r\n        \u0027loc\u0027: (\u0027ldcOutputCurrent\u0027, \u0027double\u0027),#LCD 출력전류(A)\r\n        \u0027pss\u0027: (\u0027pss\u0027, \u0027integer\u0027),#패들시프트 스위치 (명칭변경)\r\n        \u0027sbv\u0027: (\u0027auxiliaryBatteryVoltage\u0027, \u0027double\u0027),#보조배터리 전압(V)\r\n        \u0027sbc\u0027: (\u0027auxiliaryBatteryCurrent\u0027, \u0027double\u0027),#보조배터리 전류(A)\r\n        \u0027sbsoc\u0027: (\u0027auxiliaryBatterySoC\u0027, \u0027double\u0027),#보조배터리 SOC(%) #################################################컬럼명 틀림\r\n        \u0027sbt\u0027: (\u0027auxiliaryBatteryTemperature\u0027, \u0027double\u0027),#보조배터리 온도(℃)\r\n        \u0027mtt\u0027: (\u0027motorTemperature\u0027, \u0027double\u0027),#구동모터 온도(℃)\r\n        \u0027ivtt\u0027: (\u0027inverterTemperature\u0027, \u0027double\u0027),#인버터 온도(℃)\r\n        \u0027hst\u0027: (\u0027heatSinkTemperature\u0027, \u0027double\u0027),#히터 온도(℃)\r\n        \u0027igbtt\u0027: (\u0027igbtTemperature\u0027, \u0027double\u0027), #IGBT 온도(℃)\r\n        \u0027ht_1\u0027 : (\u0027heater1Temperature\u0027, \u0027double\u0027),#히터1 온도(℃)\r\n        \u0027maxct\u0027: (\u0027maxModuleTemperatures\u0027, \u0027double\u0027),#배터리 최대온도(℃)\r\n        \u0027minct\u0027: (\u0027minModuleTemperatures\u0027, \u0027double\u0027),#배터리 최소온도(℃)\r\n        \u0027bmt_1\u0027: (\u0027bmt_1\u0027, \u0027double\u0027),#배터리 모듈 온도1(℃)\r\n        \u0027bmt_2\u0027: (\u0027bmt_2\u0027, \u0027double\u0027),#배터리 모듈 온도2(℃)\r\n        \u0027bmt_3\u0027: (\u0027bmt_3\u0027, \u0027double\u0027),#배터리 모듈 온도3(℃)\r\n        \u0027bmt_4\u0027: (\u0027bmt_4\u0027, \u0027double\u0027),#배터리 모듈 온도4(℃)\r\n        \u0027bmt\u0027: (\u0027bmt\u0027, \u0027string\u0027),#배터리 외기온도 + 배터리 모듈온도 리스트 (5~)\r\n        \u0027inlt\u0027: (\u0027batteryCoolantInletTemperature\u0027, \u0027double\u0027),#배터리 냉각수 인렛온도(℃)\r\n        \u0027bbt\u0027: (\u0027batteryPraBusbarTemperature\u0027, \u0027double\u0027),#배터리 PRA 버스바온도℃)\r\n        \u0027ltrt\u0027: (\u0027ltrOutletTemperature\u0027, \u0027double\u0027),#LTR온도(℃) -\u003e 신규\r\n        \u0027itsf\u0027: (\u0027internalTemperatureFront\u0027, \u0027double\u0027),#실내온도센서-front(℃)\r\n        \u0027ets\u0027: (\u0027externalTemperature\u0027, \u0027double\u0027),#외기온도센서(℃)\r\n        #\u0027bet\u0027: (\u0027batteryExternalTemperature\u0027, \u0027double\u0027),#배터리 외기온도(℃) -\u003e신규 -\u003e posgreSQL에서만 빠졌는지 체크 필요\r\n        \u0027hvptc\u0027: (\u0027hvptc\u0027, \u0027integer\u0027),#HVPTC작동상태\r\n        \u0027seq\u0027: (\u0027seq\u0027, \u0027integer\u0027), #데이터 시퀀스\r\n        \u0027group_cd\u0027: (\u0027group_code\u0027, \u0027integer\u0027) #차종그룹코드 -\u003e bit연산을 위한 추가 \r\n    }\r\n\r\n    # Rename columns and cast data types\r\n    for old_name, (new_name, new_type) in columns_to_rename_and_cast.items():\r\n        df \u003d df.withColumnRenamed(old_name, new_name)\r\n        df \u003d df.withColumn(new_name, col(new_name).cast(new_type))\r\n\r\n    return df\r\n\r\n#비트연산 추가 (25.05.07)\r\ndef bit_process(df: DataFrame) -\u003e DataFrame:\r\n\r\n    # group_cd: 1 -\u003e 아이오닉_T1(~19)\r\n    # groupb_cd: 2 -\u003e 코나, 니로, 아이오닉_T2, 니로플러스\r\n    # group_cd: 3 -\u003e 아이오닉5, 아이오닉6, 아이오닉5N, EV6, GV70, GV60, G80 \r\n      \r\n    # MCU_STATE processing\r\n    # 구동모터제어가능상태(bit2): group_code\u003d3(아이오닉5,6,N,EV6, GV70, G80)은 bit(6) \r\n    df \u003d df.withColumn(\r\n        \"isMcuFault\", #MCU고장상태(bit0)\r\n        when(expr(\"CAST(CONV(CAST(mcu_state AS STRING), 16, 10) AS INT) \u0026 1\") !\u003d 0, 1).otherwise(0)\r\n    ).withColumn(\r\n        \"isMcuTorqueLimited\", #MCu토크제한운전상태(bit1)\r\n        when(expr(\"CAST(CONV(CAST(mcu_state AS STRING), 16, 10) AS INT) \u0026 2\") !\u003d 0, 1).otherwise(0)\r\n    ).withColumn(\r\n        \"isMcuMotorControllable\", #구동모터제어가능상태\r\n        when(col(\"group_code\")\u003d\u003d3, \r\n             when(expr(\"CAST(CONV(CAST(mcu_state AS STRING), 16, 10) AS INT) \u0026 64\") !\u003d 0, 1).otherwise(0)\r\n        ).otherwise(\r\n             when(expr(\"CAST(CONV(CAST(mcu_state AS STRING), 16, 10) AS INT) \u0026 4\") !\u003d 0, 1).otherwise(0)\r\n        )\r\n    )\r\n\r\n    # BMS_STATE processing\r\n    df \u003d df.withColumn(\r\n        \"isBmsMainRelayOn\", #BMS메인릴레이ON(bit0)\r\n        when(expr(\"CAST(CONV(CAST(bms_state AS STRING), 16, 10) AS INT) \u0026 1\") !\u003d 0, 1).otherwise(0) # 2^0\r\n    ).withColumn(\r\n        \"isBmsBatteryUsable\", #배터리사용가능상태(bit1)\r\n        when(expr(\"CAST(CONV(CAST(bms_state AS STRING), 16, 10) AS INT) \u0026 2\") !\u003d 0, 1).otherwise(0)  # 2^1\r\n    ).withColumn(\r\n        \"isBmsWarning\", #BMS경고(bit2)\r\n        when(expr(\"CAST(CONV(CAST(bms_state AS STRING), 16, 10) AS INT) \u0026 4\") !\u003d 0, 1).otherwise(0)  # 2^2\r\n    ).withColumn(\r\n        \"isBmsFault\", #BMS고장(bit3)\r\n        when(expr(\"CAST(CONV(CAST(bms_state AS STRING), 16, 10) AS INT) \u0026 8\") !\u003d 0, 1).otherwise(0)  #  2^3\r\n    ).withColumn(\r\n        \"isBmsFused\", #BMS융착상태(bit4)\r\n        when(expr(\"CAST(CONV(CAST(bms_state AS STRING), 16, 10) AS INT) \u0026 16\") !\u003d 0, 1).otherwise(0)  # 2^4\r\n    ).withColumn(\r\n        \"isWinterModeActive\", #윈터모드활성화(bit7)\r\n        when(expr(\"CAST(CONV(CAST(bms_state AS STRING), 16, 10) AS INT) \u0026 128\") !\u003d 0, 1).otherwise(0) # 2^7 \r\n    )\r\n\r\n    # C_STATE processing\r\n    df \u003d df.withColumn(\r\n        \"isCharge\", #충전정상진행상태(bit0)\r\n        when(expr(\"CAST(CONV(CAST(c_state AS STRING), 16, 10) AS INT) \u0026 1\") !\u003d 0, 1).otherwise(0)     # 2^0\r\n    ).withColumn(\r\n        \"isSlowChargeConnected\", #완속충전커넥터ON(bit6)\r\n        when(expr(\"CAST(CONV(CAST(c_state AS STRING), 16, 10) AS INT) \u0026 64\") !\u003d 0, 1).otherwise(0)    # 2^6\r\n    ).withColumn(\r\n        \"isFastChargeConnected\", #급속충전커넥터ON(bit7)\r\n        when(expr(\"CAST(CONV(CAST(c_state AS STRING), 16, 10) AS INT) \u0026 128\") !\u003d 0, 1).otherwise(0)    # 2^7\r\n    )\r\n\r\n    # MCURR processing\r\n    # MCU메인릴레이OFf요청(bit1) : GROUP_CODE\u003d3(아이오닉5,6,N,EV6, GV70, G80) : bit(2)\r\n    # MCU준비상태(bit0): 코나, 니로, 아이오닉, 니로플러스 : bit(2) \r\n    df \u003d df.withColumn(\r\n        \"isMcuMainRelayOffRequest\", #MCU메인릴레이OFF요청(bit1)\r\n        when(col(\"group_code\")\u003d\u003d3, \r\n             when(expr(\"CAST(CONV(CAST(m_curr AS STRING), 16, 10) AS INT) \u0026 4\") !\u003d 0, 1).otherwise(0) # 2^2\r\n        ).otherwise(\r\n             when(expr(\"CAST(CONV(CAST(m_curr AS STRING), 16, 10) AS INT) \u0026 2\") !\u003d 0, 1).otherwise(0)\r\n        )        \r\n        ).withColumn(\r\n        \"isMcuReady\",  # MCU준비상태(bit2)\r\n        when(\r\n            col(\"group_code\") \u003d\u003d 2,\r\n            when(expr(\"CAST(CONV(CAST(m_curr AS STRING), 16, 10) AS INT) \u0026 4\") !\u003d 0, 1).otherwise(0)  # 2^2   ############ 추가\r\n        ).otherwise(\r\n            when(expr(\"CAST(CONV(CAST(m_curr AS STRING), 16, 10) AS INT) \u0026 1\") !\u003d 0, 1).otherwise(0)  # 2^0 ############ 추가\r\n        )\r\n    )  \r\n\r\n    # HVPTC processing\r\n    df \u003d df.withColumn(\r\n        \"isHvptcDrive\", #HVPTC작동상태(bit0)\r\n        when(expr(\"CAST(CONV(CAST(hvptc AS STRING), 16, 10) AS INT) \u0026 1\") !\u003d 0, 1).otherwise(0) # 2^0\r\n    )\r\n\r\n    # O_STATE processing\r\n    df \u003d df.withColumn(\r\n        \"isObcFault\", #OBC고장상태(bit0)\r\n        when(expr(\"CAST(CONV(CAST(o_state AS STRING), 16, 10) AS INT) \u0026 1\") !\u003d 0, 1).otherwise(0) ############# 비트번호수정\r\n    ) \r\n\r\n    # OCE processing\r\n    #obc충전완료(bit3) : 아이오닉5,6, N, EV6, GV70,60, G80은 bit4\r\n    #충전커넥터체결상태(bit4) : 아이오닉5,6, N, EV6, GV70,60, G80은 bit3\r\n    df \u003d df.withColumn(\r\n        \"isObcChargeComplete\", #OBC충전완료(bit3)\r\n        when(col(\"group_code\")\u003d\u003d3,\r\n             when(expr(\"CAST(CONV(CAST(oce AS STRING), 16, 10) AS INT) \u0026 16\") !\u003d 0, 1).otherwise(0)\r\n        ).otherwise(\r\n        when(expr(\"CAST(CONV(CAST(oce AS STRING), 16, 10) AS INT) \u0026 8\") !\u003d 0, 1).otherwise(0))\r\n    ).withColumn(\r\n        \"cc_sts\", #충전커넥터상태(bit4)\r\n        when(col(\"group_code\")\u003d\u003d3,\r\n             when(expr(\"CAST(CONV(CAST(oce AS STRING), 16, 10) AS INT) \u0026 8\") !\u003d 0, 1).otherwise(0)\r\n        ).otherwise(\r\n        when(expr(\"CAST(CONV(CAST(oce AS STRING), 16, 10) AS INT) \u0026 16\") !\u003d 0, 1).otherwise(0))\r\n        )\r\n    \r\n    # bhr_state processing\r\n    df \u003d df.withColumn(\r\n        \"isBatteryHeaterRelayOn\", #배터리 히터 릴레이 상태(bit3)\r\n        when(expr(\"CAST(CONV(CAST(o_state AS STRING), 16, 10) AS INT) \u0026 8\") !\u003d 0, 1).otherwise(0) ############# 추가\r\n    ) \r\n\r\n    # pss processing\r\n    df \u003d df.withColumn(\r\n        \"paddleShiftUp\", #패들시프트1(bit0) 패들시프트 up\r\n        when(expr(\"CAST(CONV(CAST(pss AS STRING), 16, 10) AS INT) \u0026 1\") !\u003d 0, 1).otherwise(0) ############# 추가 2^0\r\n    ).withColumn(\r\n        \"paddleShiftDown\", #패들시프트2(bit1) 패들시프트 down\r\n        when(expr(\"CAST(CONV(CAST(pss AS STRING), 16, 10) AS INT) \u0026 2\") !\u003d 0, 1).otherwise(0)  ############# 추가 2^1\r\n    )\r\n\r\n    return df\r\n\r\n\r\n# Add status column based on vehicle state\r\ndef add_status(df: DataFrame) -\u003e DataFrame:\r\n\r\n    df \u003d df.withColumn(\r\n        \"status\",\r\n        when(col(\"isEVReady\") \u003d\u003d 1, \u0027DRIVING\u0027)\r\n        .when((col(\"isSlowChargeConnected\") \u003d\u003d 1) \u0026 (col(\"isFastChargeConnected\") \u003d\u003d 0), \u0027CHARGE_S\u0027)\r\n        .when((col(\"isSlowChargeConnected\") \u003d\u003d 0) \u0026 (col(\"isFastChargeConnected\") \u003d\u003d 1), \u0027CHARGE_F\u0027)\r\n        .when((col(\"isSlowChargeConnected\") \u003d\u003d 1) \u0026 (col(\"isFastChargeConnected\") \u003d\u003d 1), \u0027ERROR\u0027) \r\n        .otherwise(\u0027STOP\u0027)\r\n    )\r\n    \r\n    df \u003d df.filter(col(\"status\") !\u003d \u0027ERROR\u0027)\r\n\r\n    return df\r\n\r\n# Select only the required columns -\u003e 신규단말 적용\r\ndef select_columns(df: DataFrame, filtered_cols: List[str] \u003d None) -\u003e DataFrame:\r\n    cols \u003d filtered_cols or SELECTED_COLUMNS\r\n    return df.select(*cols)\r\n\r\n\r\n# 이상치 제거 -\u003e 1,과 2로 나눠서 진행\r\n# 스파이크 데이터 제거 -\u003e 주행 on/off 파악을 위한 이상치 제거  \r\n# 이벤트 신뢰성 확보\r\ndef remove_outlier1(df: DataFrame) -\u003e DataFrame:\r\n    from pyspark.sql.functions import col, lag, sum as sum_, when, first, count\r\n    from pyspark.sql.window import Window\r\n\r\n    w \u003d Window.partitionBy(\"deviceId\").orderBy(\"createdAt\")  # 단말기별 시간 정렬 기준\r\n\r\n    df \u003d df.withColumn(\"evr_prev\", lag(\"isEVReady\").over(w))\r\n    df \u003d df.withColumn(\"evr_change\", when(col(\"isEVReady\") !\u003d col(\"evr_prev\"), 1).otherwise(0))\r\n    df \u003d df.withColumn(\"evr_group\", sum_(\"evr_change\").over(w))\r\n\r\n    df_grouped \u003d df.groupBy(\"evr_group\").agg(\r\n        first(\"isEVReady\").alias(\"evr_value\"),\r\n        count(\"*\").alias(\"group_size\")\r\n    )\r\n\r\n    df_grouped \u003d df_grouped.withColumn(\"is_anomaly_group\", when(\r\n        (col(\"evr_value\") \u003d\u003d 0) \u0026 (col(\"group_size\") \u003c\u003d 5), 1\r\n    ).otherwise(0))\r\n\r\n    df \u003d df.join(df_grouped.select(\"evr_group\", \"is_anomaly_group\"), on\u003d\"evr_group\", how\u003d\"left\")\r\n    df \u003d df.filter(col(\"is_anomaly_group\") !\u003d 1)\r\n\r\n    return df.drop(\"evr_group\", \"evr_prev\", \"evr_change\", \"is_anomaly_group\")\r\n\r\n\r\n\r\n# 수치형 컬럼에 대해 값의 범위 이상, 급변 등을 기준으로 이상치 파악 및 보정(제거x)\r\n# remove_outlier2(df)\r\n# ├─ 누적형/일반형/온도형 컬럼 분리\r\n# ├─ 온도 컬럼 모두 0인 행 제거\r\n# ├─ 각 컬럼별로\r\n# │   ├─ 이상치 여부 판별\r\n# │   ├─ noise 그룹 deviceId 계산\r\n# │   ├─ 앞뒤 정상값 탐색\r\n# │   ├─ 해당 값 보정 (누적형/일반/온도 방식 다름)\r\n# ├─ 임시 컬럼 제거\r\n# └─ batch 처리로 메모리 관리\r\n\r\ndef remove_outlier2(df: DataFrame) -\u003e DataFrame:\r\n    # Columns to process for outlier removal\r\n    acc_outlier_columns \u003d [ #누적형\r\n        \u0027batteryTotalDischargedCapacity\u0027, \u0027batteryTotalChargedCapacity\u0027, \u0027batteryTotalChargedEnergy\u0027, \u0027batteryTotalDischargedEnergy\u0027, \u0027totalMileage\u0027\r\n    ]\r\n\r\n    regular_outlier_columns \u003d [ # 일반\r\n        \u0027SOC\u0027, \u0027displaySoc\u0027, \u0027SOH\u0027, \u0027batteryPackCurrents\u0027, \u0027batteryPackVoltages\u0027, \u0027maxCellVoltages\u0027\r\n        , \u0027minCellVoltages\u0027, \u0027batteryMaxChargePower\u0027, \u0027batteryMaxDischargePower\u0027, \u0027insulationResistance\u0027, \u0027speed\u0027, \u0027mcuMotorRpm\u0027\r\n    ]\r\n    \r\n    temp_outlier_columns \u003d [ # 온도\r\n        \u0027bmt_1\u0027, \u0027bmt_2\u0027, \u0027bmt_3\u0027, \u0027bmt_4\u0027, \u0027maxModuleTemperatures\u0027, \u0027minModuleTemperatures\u0027, \u0027batteryCoolantInletTemperature\u0027, \u0027heater1Temperature\u0027, \u0027batteryPraBusbarTemperature\u0027\r\n        , \u0027motorTemperature\u0027, \u0027inverterTemperature\u0027, \u0027heatSinkTemperature\u0027, \u0027igbtTemperature\u0027, \u0027internalTemperatureFront\u0027, \u0027externalTemperature\u0027, \u0027ltrOutletTemperature\u0027 #신규추가 \u0027BET\u0027체크\r\n    ]\r\n    \r\n    # Calculate sum of outlier columns\r\n    # 온도계열 컬럼 모두 0인 행 제거\r\n    temp_outlier_columns_0 \u003d [f\"coalesce({col}, 0)\" for col in temp_outlier_columns]\r\n    sum_expr \u003d \" + \".join(temp_outlier_columns_0) # columns_to_process\r\n    df \u003d df.withColumn(\"zero_chk\", expr(sum_expr)) #모든 온도컬럼을 더한 값이 0이면 센서오류 등으로 인한 이상값이라 판단\r\n    df \u003d df.filter(col(\"zero_chk\") !\u003d 0)\r\n    df \u003d df.drop(\"zero_chk\")\r\n    \r\n    \r\n    # Define window for calculating statistics and detecting consecutive outliers\r\n    window \u003d Window.partitionBy(\"deviceId\").orderBy(\"createdAt\")\r\n    \r\n    # 컬럼별로 이상치 탐지 및 보정 함수 정의\r\n    def process_column(df: DataFrame, column: str, var_type: str) -\u003e DataFrame:\r\n        \"\"\"Process a single column for outlier removal based on variable type\"\"\"\r\n        # Replace NULL values with 0\r\n        df \u003d df.withColumn(column, when(col(column).isNull(), 0).otherwise(col(column)))\r\n        \r\n        # Get min and max values from config\r\n        #min_val \u003d PROCESSING_PARAMS[\u0027outlier\u0027][column.lower()][\u0027min\u0027]\r\n        #max_val \u003d PROCESSING_PARAMS[\u0027outlier\u0027][column.lower()][\u0027max\u0027]\r\n        \r\n        # 통합스키마 컬러명은 카멜표기법을 사용했기 때문에 대소문자를 함께 사용\r\n        min_val \u003d PROCESSING_PARAMS[\u0027outlier\u0027][column][\u0027min\u0027] \r\n        max_val \u003d PROCESSING_PARAMS[\u0027outlier\u0027][column][\u0027max\u0027] \r\n        \r\n        # Step 1: 이전값/다음값/시간차 계산\r\n        # 아래에서 함수 사용시 전체 컬럼을 반복문으로 돌리기 때문에 아래 코드 적용가능\r\n        df \u003d df.withColumn(\r\n            f\"{column}_prev\",\r\n            lag(col(column)).over(window)\r\n        ).withColumn(\r\n            f\"{column}_next\",\r\n            lead(col(column)).over(window)\r\n        ).withColumn(\r\n            \"time_diff\",\r\n            (unix_timestamp(col(\"createdAt\")) - unix_timestamp(lag(col(\"createdAt\")).over(window)))\r\n        )\r\n        \r\n        # Step 2: 이상치 설정 기준 컬럼 생성 \r\n        # \"컬럼명_is_noise\" 형태로 해당로우가 이상인지 확인 \r\n        # 누적값 그리고 일반/온도로 묶어서 분기처리, var_type은 아래서 정의\r\n        if var_type \u003d\u003d \u0027accumulated\u0027:\r\n            # For accumulated variables\r\n            df \u003d df.withColumn(\r\n                f\"{column}_is_noise\",\r\n                when(\r\n                    # Case 1: Value outside min/max range or zero\r\n                    ((col(column) \u003e\u003d max_val) | (col(column) \u003c\u003d min_val) | (col(column) \u003d\u003d 0)) |\r\n                    # Case 2: Value differs by 10 or more from both previous and next\r\n                    ((col(column) \u003e\u003d col(f\"{column}_prev\") + 10) \u0026 \r\n                     (col(column) \u003e\u003d col(f\"{column}_next\") + 10)) |\r\n                    ((col(column) \u003c\u003d col(f\"{column}_prev\") - 10) \u0026 \r\n                     (col(column) \u003c\u003d col(f\"{column}_next\") - 10)),\r\n                    1\r\n                ).otherwise(0)\r\n            )\r\n        else:\r\n            # For regular and temperature variables\r\n            df \u003d df.withColumn(\r\n                f\"{column}_is_noise\",\r\n                when(\r\n                    # Case 1: Value outside min/max range\r\n                    ((col(column) \u003e\u003d max_val) | (col(column) \u003c\u003d min_val)) |\r\n                    # Case 2: Sudden increase/decrease\r\n                    ((col(column) \u003e col(f\"{column}_prev\") * 2) \u0026 \r\n                     (col(column) \u003e col(f\"{column}_next\") * 2)) |\r\n                    ((col(column) \u003c col(f\"{column}_prev\") * 0.5) \u0026 \r\n                     (col(column) \u003c col(f\"{column}_next\") * 0.5)),\r\n                    1\r\n                ).otherwise(0)\r\n            )\r\n        \r\n        # Step 3: 이상치 그룹 시작 지점 찾기\r\n        # 정상값이거나, 10분 이상 시간간격 생기면 그룹 새로 시작\r\n        # 이상치의 그룹을 나누는 것이고 주행은 구분하지 않는다.\r\n        # is_noise \u003d\u003d 1인 이상치들이 연속으로 존재하는 경우 → 하나의 이상치 그룹으로 묶어서 처리\r\n        df \u003d df.withColumn(\r\n            f\"{column}_group_start\",\r\n            when(\r\n                (col(f\"{column}_is_noise\") \u003d\u003d 0) | # 이상치가 끊겼다는 의미\r\n                (col(\"time_diff\") \u003e 600),  # 센서가 끊겼다가 다시 연결됐다는 의미\r\n                1\r\n            ).otherwise(0)\r\n        )\r\n        \r\n        # Step 4: 이상치 그룹 ID 생성\r\n        # 그룹 시작마다 sum을 증가시키므로 → noise group 번호 부여\r\n        df \u003d df.withColumn(\r\n            f\"{column}_noise_group\",\r\n            expr(f\"sum({column}_group_start)\").over(\r\n                Window.partitionBy(\"deviceId\").orderBy(\"createdAt\")\r\n            )\r\n        )\r\n        \r\n        # Step 5: 정상값 탐색\r\n        # 이전/이후 정상겂을 구해서 추후 보정값으로 사용\r\n        df \u003d df.withColumn(\r\n            f\"{column}_next_normal\",\r\n            first(when(col(f\"{column}_is_noise\") \u003d\u003d 0, col(column)), ignorenulls\u003dTrue).over(\r\n                Window.partitionBy(\"deviceId\", f\"{column}_noise_group\").orderBy(\"createdAt\")\r\n            )\r\n        ).withColumn(\r\n            f\"{column}_prev_normal\",\r\n            last(when(col(f\"{column}_is_noise\") \u003d\u003d 0, col(column)), ignorenulls\u003dTrue).over(\r\n                Window.partitionBy(\"deviceId\", f\"{column}_noise_group\").orderBy(\"createdAt\")\r\n            )\r\n        )\r\n        \r\n        # Step 6: 이상치 보정\r\n        if var_type \u003d\u003d \u0027accumulated\u0027:\r\n            # 누적형: 그룹 첫 행이 노이즈면 뒤의 첫 정상값, 그 외 노이즈는 이전 정상값\r\n            df \u003d df.withColumn(\r\n                column,\r\n                when(\r\n                    (col(f\"{column}_group_start\") \u003d\u003d 1) \u0026 (col(f\"{column}_is_noise\") \u003d\u003d 1),\r\n                    col(f\"{column}_next_normal\")\r\n                ).when(\r\n                    col(f\"{column}_is_noise\") \u003d\u003d 1,\r\n                    col(f\"{column}_prev_normal\")\r\n                ).otherwise(col(column))\r\n            )\r\n        elif var_type \u003d\u003d \u0027temperature\u0027:\r\n\r\n            # 온도: 3초 이하인 경우에만 노이즈로 간주\r\n            df \u003d df.withColumn(\r\n                column,\r\n                when(\r\n                    (col(f\"{column}_group_start\") \u003d\u003d 1) \u0026 (col(f\"{column}_is_noise\") \u003d\u003d 1),\r\n                    col(f\"{column}_next_normal\")\r\n                ).when(\r\n                    (col(f\"{column}_is_noise\") \u003d\u003d 1) \u0026 (col(\"time_diff\") \u003c\u003d 3),\r\n                    (col(f\"{column}_prev_normal\") + col(f\"{column}_next_normal\")) / 2\r\n                ).otherwise(col(column))\r\n            )\r\n        else:\r\n            # 일반: 그룹 첫 행이 노이즈면 뒤의 첫 정상값, 그 외 노이즈는 앞뒤 정상값의 평균\r\n            df \u003d df.withColumn(\r\n                column,\r\n                when(\r\n                    (col(f\"{column}_group_start\") \u003d\u003d 1) \u0026 (col(f\"{column}_is_noise\") \u003d\u003d 1),\r\n                    col(f\"{column}_next_normal\")\r\n                ).when(\r\n                    col(f\"{column}_is_noise\") \u003d\u003d 1,\r\n                    (col(f\"{column}_prev_normal\") + col(f\"{column}_next_normal\")) / 2\r\n                ).otherwise(col(column))\r\n            )\r\n\r\n        # 임시 컬럼 정리\r\n        df \u003d df.drop(\r\n            f\"{column}_prev\", f\"{column}_next\", f\"{column}_is_noise\",\r\n            f\"{column}_group_start\", f\"{column}_noise_group\",\r\n            f\"{column}_next_normal\", f\"{column}_prev_normal\",\r\n            \"TIME_DIFF\"\r\n        )\r\n        \r\n        return df\r\n    \r\n    # 컬럼을 묶어서 batch 단위 처리\r\n    batch_size \u003d 3  # Reduced batch size\r\n    columns_to_process \u003d acc_outlier_columns + regular_outlier_columns + temp_outlier_columns\r\n    var_types \u003d ([\u0027accumulated\u0027] * len(acc_outlier_columns) + \r\n                [\u0027regular\u0027] * len(regular_outlier_columns) + \r\n                [\u0027temperature\u0027] * len(temp_outlier_columns))\r\n    \r\n    \r\n    for i in range(0, len(columns_to_process), batch_size):\r\n        batch_columns \u003d columns_to_process[i:i+batch_size]\r\n        batch_types \u003d var_types[i:i+batch_size]\r\n        \r\n        for column, var_type in zip(batch_columns, batch_types):\r\n            df \u003d process_column(df, column, var_type)\r\n            df \u003d df.cache()  # Cache after each column to prevent memory issues\r\n        \r\n        # Clear cache after each batch\r\n        df.unpersist()\r\n    \r\n    return df\r\n\r\n# add analysis columns\r\n# 온도변수 추가(BMT) 시, MEAN_CT, CTDIFF 변경 필요\r\ndef add_columns(df: DataFrame) -\u003e DataFrame:\r\n    df \u003d df.withColumn(\u0027c_date1\u0027, date_format(col(\u0027createdAt\u0027), \u0027yyyy-MM-dd\u0027))\r\n    df \u003d df.withColumn(\u0027c_date2\u0027, date_format(col(\u0027createdAt\u0027), \u0027yyyy-MM\u0027))\r\n    df \u003d df.withColumn(\u0027cvdiff\u0027, round(col(\u0027maxCellVoltages\u0027) - col(\u0027minCellVoltages\u0027), 3))\r\n    df \u003d df.withColumn(\u0027ctdiff\u0027, round(\r\n        expr(\u0027greatest(bmt_1, bmt_2, bmt_3, bmt_4) - least(bmt_1, bmt_2, bmt_3, bmt_4)\u0027), 2))\r\n    df \u003d df.withColumn(\"mean_ct\", round(((col(\u0027bmt_1\u0027) + col(\u0027bmt_2\u0027) + col(\u0027bmt_3\u0027) + col(\u0027bmt_4\u0027)) / 4), 2))\r\n    df \u003d df.withColumn(\u0027socdiff\u0027, round(abs(col(\u0027SOC\u0027) - col(\u0027displaySoc\u0027)), 2))\r\n    \r\n    return df\r\n\r\n# add SOB and SOP columns \r\ndef add_sox(df: DataFrame) -\u003e DataFrame:\r\n    \"\"\"\r\n    Add SOB and SOP columns using percentile with simplified conditions\r\n    \"\"\"\r\n    # Calculate percentiles for BMDPP and BMCPP\r\n    #df_cond \u003d df.filter(\r\n    #    (col(\"BCS\").between(10, 95)) \u0026 \r\n    #    (col(\"MEAN_CT\").between(0, 45))\r\n    #)\r\n    \r\n    #bmdpp_max \u003d df_cond.selectExpr(\"percentile_approx(BMDPP, 0.95)\").collect()[0][0] or 1\r\n    #bmcpp_max \u003d df_cond.selectExpr(\"percentile_approx(BMCPP, 0.95)\").collect()[0][0] or 1\r\n\r\n    # Get Z-score threshold from config\r\n    zscore_threshold \u003d PROCESSING_PARAMS[\u0027zscore_threshold\u0027]\r\n    \r\n    # Calculate statistics for BMCPP\r\n    stats_c \u003d df.select(\r\n        mean(col(\"batteryMaxChargePower\")).alias(\"mean\"), # bmcpp\r\n        stddev(col(\"batteryMaxChargePower\")).alias(\"std\"),\r\n        max(col(\"batteryMaxChargePower\")).alias(\"max\")\r\n    ).collect()[0]\r\n    mean_val_c \u003d stats_c[\"mean\"] or 0\r\n    std_val_c \u003d stats_c[\"std\"] or 0\r\n    bmcpp_max \u003d stats_c[\"max\"] or 1\r\n    \r\n    # Calculate statistics for BMDPP\r\n    stats_d \u003d df.select(\r\n        mean(col(\"batteryMaxDischargePower\")).alias(\"mean\"), # bmdpp\r\n        stddev(col(\"batteryMaxDischargePower\")).alias(\"std\"),\r\n        max(col(\"batteryMaxDischargePower\")).alias(\"max\")\r\n    ).collect()[0]\r\n    mean_val_d \u003d stats_d[\"mean\"] or 0\r\n    std_val_d \u003d stats_d[\"std\"] or 0\r\n    bmdpp_max \u003d stats_d[\"max\"] or 1\r\n\r\n    #print(\"bmcpp_max, bmdpp_max: \", bmcpp_max, bmdpp_max)\r\n\r\n    # 이상치 제거 (Z-score 기반)\r\n    if std_val_c \u003e 0 and std_val_d \u003e 0:\r\n        df_filtered \u003d df.filter(\r\n            (col(\"batteryMaxChargePower\") \u003e\u003d mean_val_c - zscore_threshold * std_val_c) \u0026\r\n            (col(\"batteryMaxChargePower\") \u003c\u003d mean_val_c + zscore_threshold * std_val_c) \u0026\r\n            (col(\"batteryMaxDischargePower\") \u003e\u003d mean_val_d - zscore_threshold * std_val_d) \u0026\r\n            (col(\"batteryMaxDischargePower\") \u003c\u003d mean_val_d + zscore_threshold * std_val_d)\r\n        )\r\n    else:\r\n        df_filtered \u003d df\r\n    \r\n    # SOP 계산 - expr() 대신 withColumn + when\r\n    df_s \u003d df_filtered.withColumn(\r\n        \"sop\",\r\n        when(\r\n            col(\"status\") \u003d\u003d \"DRIVING\",\r\n            least(round((col(\"batteryMaxDischargePower\") / lit(bmdpp_max)) * 100, 2), lit(100))\r\n        ).when(\r\n            col(\"status\").startswith(\"CHARGE\"),\r\n            least(round((col(\"batteryMaxDischargePower\") / lit(bmcpp_max)) * 100, 2), lit(100))\r\n        ).otherwise(\r\n            least(\r\n                round(((col(\"batteryMaxChargePower\") + col(\"batteryMaxDischargePower\")) / 2) / ((bmcpp_max + bmdpp_max) / 2) * 100, 2),\r\n                lit(100)\r\n            )\r\n        )\r\n    )\r\n\r\n    # SOB 계산\r\n    df_s \u003d df_s.withColumn(\r\n        \"sob\",\r\n        when(\r\n            col(\"maxCellVoltages\").isNull() | col(\"minCellVoltages\").isNull() | (col(\"maxCellVoltages\") \u003d\u003d 0),\r\n            lit(0)\r\n        ).otherwise(\r\n            round((1 - (abs(col(\"maxCellVoltages\") - col(\"minCellVoltages\")) / col(\"maxCellVoltages\"))) * 100, 2)\r\n        )\r\n    )\r\n\r\n    return df_s\r\n    \r\n    \u0027\u0027\u0027\r\n    \r\n\r\n",
      "user": "anonymous",
      "dateUpdated": "2025-09-17 14:28:06.548",
