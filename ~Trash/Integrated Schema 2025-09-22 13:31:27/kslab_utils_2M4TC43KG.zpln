{
  "paragraphs": [
    {
      "text": "%spark.pyspark\r\nimport os\r\n\r\nexport \u003d \u0027\u0027\u0027\r\n\r\n\"\"\"\r\nUtility functions for KSLAB data preprocessing\r\nfuctions : print_timestamp, print_dfcount, create_spark_session, load_data_from_db, load_data_from_csv, save_to_csv, save_to_db\r\n\"\"\"\r\n\r\nimport os\r\nimport sys\r\nfrom datetime import datetime\r\nimport os\r\nfrom typing import Optional\r\nimport pandas as pd\r\nimport gc  # Add garbage collector import\r\n\r\n# HDFS를 위한 추가 \r\nfrom typing import Optional\r\nfrom pyspark.sql import SparkSession, DataFrame\r\nfrom pyspark.sql.functions import input_file_name\r\nfrom pyspark.sql.types import StructType\r\n\r\nfrom pyspark.sql import SparkSession, DataFrame\r\nfrom sqlalchemy import create_engine, text\r\nfrom pyspark.sql.functions import col, to_timestamp, date_format\r\nimport psycopg2\r\nfrom psycopg2 import sql\r\nfrom pyspark.sql.types import IntegerType, DoubleType\r\n\r\nfrom kslab_config import DB_CONFIG, SPARK_CONFIG, PP_IO_CONFIG, CYCLE_IO_CONFIG, DB_QUERY_KMON_DATA, DB_QUERY_MASTER_DATA, DB_QUERY_CYCLE_CC_DATA\r\n\r\ndef print_timestamp(message: str) -\u003e None:\r\n    \"\"\"Print message with current timestamp\"\"\"\r\n    print(f\"[{datetime.now().strftime(\u0027%Y-%m-%d %H:%M:%S\u0027)}] {message}\")\r\n\r\ndef print_dfcount(df: DataFrame, message: str) -\u003e None:\r\n    \"\"\"Print DataFrame count with message\"\"\"\r\n    count \u003d df.count()\r\n    print_timestamp(f\"{message}: {count:,} rows\")\r\n\r\n# Create and configure a Spark session\r\ndef create_spark_session() -\u003e SparkSession:\r\n    \"\"\"Create and configure a Spark session.\"\"\"\r\n    # Stop any existing Spark session\r\n    spark \u003d SparkSession.getActiveSession()\r\n    if spark:\r\n        spark.stop()\r\n    \r\n    # Create new session with enhanced configuration for large datasets\r\n    spark \u003d SparkSession.builder \\\r\n        .appName(SPARK_CONFIG[\u0027app_name\u0027]) \\\r\n        .master(\"local[*]\") \\\r\n        .config(\"spark.executor.memory\", SPARK_CONFIG[\u0027executor_memory\u0027]) \\\r\n        .config(\"spark.driver.memory\", SPARK_CONFIG[\u0027driver_memory\u0027]) \\\r\n        .config(\"spark.sql.debug.maxToStringFields\", SPARK_CONFIG[\u0027max_to_string_fields\u0027]) \\\r\n        .config(\"spark.ui.port\", \"0\") \\\r\n        .config(\"spark.local.dir\", \"C:/10.kevin/namdsqh/80.temp\") \\\r\n        .config(\"spark.network.timeout\", \"800s\") \\\r\n        .config(\"spark.executor.heartbeatInterval\", \"400s\") \\\r\n        .config(\"spark.python.worker.timeout\", \"800\") \\\r\n        .config(\"spark.python.worker.memory\", \"16g\") \\\r\n        .config(\"spark.python.worker.reuse\", \"true\") \\\r\n        .config(\"spark.python.worker.keepalive\", \"true\") \\\r\n        .config(\"spark.python.worker.connection.timeout\", \"600\") \\\r\n        .config(\"spark.python.worker.connection.retries\", \"3\") \\\r\n        .config(\"spark.cleaner.referenceTracking.cleanCheckpoints\", \"false\") \\\r\n        .config(\"spark.cleaner.referenceTracking.blocking\", \"false\") \\\r\n        .config(\"spark.sql.execution.arrow.pyspark.enabled\", \"true\") \\\r\n        .config(\"spark.sql.execution.arrow.pyspark.fallback.enabled\", \"true\") \\\r\n        .config(\"spark.sql.execution.pythonUDF.arrow.enabled\", \"true\") \\\r\n        .config(\"spark.sql.execution.pythonUDF.arrow.fallback.enabled\", \"true\") \\\r\n        .config(\"spark.sql.shuffle.partitions\", \"200\") \\\r\n        .config(\"spark.default.parallelism\", \"200\") \\\r\n        .config(\"spark.memory.fraction\", \"0.8\") \\\r\n        .config(\"spark.memory.storageFraction\", \"0.3\") \\\r\n        .config(\"spark.jars.packages\", \"org.postgresql:postgresql:42.7.4\") \\\r\n        .config(\"spark.executor.extraJavaOptions\", \"-XX:+UseG1GC -XX:+UnlockDiagnosticVMOptions -XX:+G1SummarizeConcMark -XX:InitiatingHeapOccupancyPercent\u003d35 -XX:+UseStringDeduplication\") \\\r\n        .config(\"spark.driver.extraJavaOptions\", \"-XX:+UseG1GC -XX:+UnlockDiagnosticVMOptions -XX:+G1SummarizeConcMark -XX:InitiatingHeapOccupancyPercent\u003d35 -XX:+UseStringDeduplication\") \\\r\n        .getOrCreate()\r\n    \r\n    # Set log level to WARN to reduce console output\r\n    spark.sparkContext.setLogLevel(\"WARN\")\r\n    \r\n    return spark\r\n\r\n\r\n# HDFS 읽도록 수정\r\ndef load_data_from_csv(\r\n        spark: SparkSession,\r\n        file_path: Optional[str] \u003d None,\r\n        recursive: bool \u003d False\r\n    ) -\u003e DataFrame:\r\n        \"\"\"\r\n        HDFS/로컬 모두 지원. inferSchema\u003dTrue 로 빠른 테스트 로드.\r\n        - recursive\u003dTrue 시 하위 폴더까지 읽기\r\n        - 불량 레코드는 _corrupt_record 컬럼으로 구분\r\n        - 원본 파일 경로를 _src_file 로 남김\r\n        \"\"\"\r\n        # 1) 경로 결정: 인자 \u003e PP_IO_CONFIG \u003e CYCLE_IO_CONFIG\r\n        if file_path is not None:\r\n            csv_path \u003d file_path\r\n        elif \u0027PP_IO_CONFIG\u0027 in globals():\r\n            csv_path \u003d PP_IO_CONFIG[\u0027input\u0027][\u0027csv_path\u0027]\r\n        else:\r\n            csv_path \u003d CYCLE_IO_CONFIG[\u0027input\u0027][\u0027csv_path\u0027]\r\n    \r\n        # 2) 리더 옵션 (HDFS 가능)\r\n        reader \u003d (spark.read\r\n            .option(\"header\", \"true\")\r\n            .option(\"inferSchema\", \"true\")                  # 지금은 스키마 추론\r\n            .option(\"mode\", \"PERMISSIVE\")\r\n            .option(\"columnNameOfCorruptRecord\", \"_corrupt_record\"))\r\n        if recursive:\r\n            reader \u003d reader.option(\"recursiveFileLookup\", \"true\")\r\n    \r\n        # 3) 로드 \u0026 파일출처 컬럼\r\n        try:\r\n            df \u003d reader.csv(csv_path).withColumn(\"_src_file\", input_file_name())\r\n            # 빈 로드 경고 (필수 아님)\r\n            if df.rdd.isEmpty():\r\n                print(f\"[WARN] No rows loaded from: {csv_path}\")\r\n            return df\r\n        except Exception as e:\r\n            print(f\"[ERROR] Failed to read CSV from {csv_path}: {e}\")\r\n            # 빈 DataFrame 반환(스키마 없음)\r\n            return spark.createDataFrame([], StructType([]))\r\n\r\n\r\n\r\ndef save_to_csv(df: DataFrame, output_path: Optional[str] \u003d None) -\u003e str:\r\n    \"\"\"Save DataFrame to a CSV file.\"\"\"\r\n    # Use the provided output path or get from appropriate config based on context\r\n    if output_path is None:\r\n        # Check if we\u0027re in preprocessing or cycle setting context\r\n        if \u0027PP_IO_CONFIG\u0027 in globals():\r\n            output_path \u003d PP_IO_CONFIG[\u0027output\u0027][\u0027csv_path\u0027]\r\n        else:\r\n            output_path \u003d CYCLE_IO_CONFIG[\u0027output\u0027][\u0027csv_path\u0027]\r\n    \r\n    # Ensure directory exists\r\n    os.makedirs(os.path.dirname(output_path), exist_ok\u003dTrue)\r\n    \r\n    # Collect data into a list of Row objects\r\n    rows \u003d df.collect()\r\n    \r\n    # Construct Pandas DataFrame from collected rows\r\n    pdf \u003d pd.DataFrame([row.asDict() for row in rows])\r\n    \r\n    # Get column types from DataFrame schema\r\n    column_types \u003d {field.name: field.dataType for field in df.schema.fields}\r\n    \r\n    # Replace NULL/None values based on column type\r\n    for column in pdf.columns:\r\n        col_type \u003d column_types[column]\r\n        if isinstance(col_type, (IntegerType, DoubleType)):\r\n            # For numeric types, replace NULL/None with 0\r\n            pdf[column] \u003d pdf[column].apply(lambda x: 0 if pd.isna(x) or x \u003d\u003d \u0027None\u0027 or x \u003d\u003d \u0027\u0027 else x)\r\n        else:\r\n            # For non-numeric types, replace NULL/None with empty string\r\n            pdf[column] \u003d pdf[column].apply(lambda x: \u0027\u0027 if pd.isna(x) or x \u003d\u003d \u0027None\u0027 or x \u003d\u003d \u0027\u0027 else x)\r\n    \r\n    # Ensure C_DATE is in datetime64[ns] format\r\n    if \u0027C_DATE\u0027 in pdf.columns:\r\n        pdf[\u0027C_DATE\u0027] \u003d pd.to_datetime(pdf[\u0027C_DATE\u0027], errors\u003d\u0027coerce\u0027)\r\n    \r\n    # Save to CSV\r\n    pdf.to_csv(output_path, index\u003dFalse, encoding\u003d\u0027utf-8-sig\u0027)\r\n    \r\n    return output_path\r\n\r\n# load data from the database using the configuration\r\n# utils.py\r\n\r\ndef load_data_from_db(spark, db_query):\r\n    jdbc_url \u003d f\"jdbc:postgresql://{DB_CONFIG[\u0027host\u0027]}:{DB_CONFIG[\u0027port\u0027]}/{DB_CONFIG[\u0027dbname\u0027]}\"\r\n    reader \u003d (\r\n        spark.read.format(\"jdbc\")\r\n            .option(\"url\", jdbc_url)\r\n            .option(\"user\", DB_CONFIG[\"user\"])\r\n            .option(\"password\", DB_CONFIG[\"password\"])\r\n            .option(\"driver\", \"org.postgresql.Driver\")\r\n    )\r\n\r\n    # SELECT 문이면 그대로 query 옵션으로만 넘긴다\r\n    if any(tok in db_query.lower() for tok in (\"select\", \"join\", \"where\", \"limit\")):\r\n        clean_sql \u003d db_query.strip().rstrip(\";\")       # 세미콜론 제거\r\n        #print(\"최종 전달 쿼리 \u003e\u003e\u003e\\n\", clean_sql)        # 확인용\r\n        return reader.option(\"query\", clean_sql).load()   #  ‘( … ) AS …’ 붙이지 않음\r\n    else:\r\n        return reader.option(\"dbtable\", db_query.strip()).load()\r\n\r\n\r\n\r\n\r\n\r\ndef save_to_db(df: DataFrame, table_name: str, spark: SparkSession) -\u003e None:\r\n    \"\"\"Save DataFrame to a database table using batch processing.\"\"\"\r\n    try:\r\n        # Parse schema and table name\r\n        if \u0027.\u0027 in table_name:\r\n            schema, table \u003d table_name.split(\u0027.\u0027)\r\n            schema \u003d schema.strip(\u0027\"\u0027)  # Remove quotes if present\r\n            table \u003d table.strip(\u0027\"\u0027)    # Remove quotes if present\r\n        else:\r\n            schema \u003d \u0027KSLAB_DATA\u0027  # Default schema\r\n            table \u003d table_name.strip(\u0027\"\u0027)\r\n        \r\n        print_timestamp(f\"Using schema: {schema}, table: {table}\")\r\n        \r\n        # Get total number of rows\r\n        total_rows \u003d df.count()\r\n        batch_size \u003d 10000  # Reduced batch size for better performance\r\n        chunk_size \u003d 1000   # Increased chunk size for database operations\r\n        \r\n        # Calculate number of batches\r\n        num_batches \u003d (total_rows + batch_size - 1) // batch_size\r\n        \r\n        print_timestamp(f\"Total rows: {total_rows}, Processing in {num_batches} batches\")\r\n        \r\n        # Get column types from DataFrame schema\r\n        column_types \u003d {field.name: field.dataType for field in df.schema.fields}\r\n        \r\n        # Connect to PostgreSQL\r\n        conn \u003d psycopg2.connect(\r\n            host\u003dDB_CONFIG[\u0027host\u0027],\r\n            port\u003dDB_CONFIG[\u0027port\u0027],\r\n            database\u003dDB_CONFIG[\u0027dbname\u0027],\r\n            user\u003dDB_CONFIG[\u0027user\u0027],\r\n            password\u003dDB_CONFIG[\u0027password\u0027]\r\n        )\r\n        conn.autocommit \u003d False  # Enable transactions\r\n        cur \u003d conn.cursor()\r\n        \r\n        try:\r\n            # Add row number to DataFrame for batch processing\r\n            from pyspark.sql.functions import monotonically_increasing_id\r\n            df_with_id \u003d df.withColumn(\"row_id\", monotonically_increasing_id())\r\n            \r\n            # Process each batch\r\n            for i in range(num_batches):\r\n                start_idx \u003d i * batch_size\r\n                end_idx \u003d min((i + 1) * batch_size, total_rows)\r\n                \r\n                print_timestamp(f\"Processing batch {i+1}/{num_batches} (rows {start_idx+1}-{end_idx})\")\r\n                \r\n                try:\r\n                    # Get batch of data using row_id\r\n                    batch_df \u003d df_with_id.filter(f\"row_id \u003e\u003d {start_idx} AND row_id \u003c {end_idx}\")\r\n                    \r\n                    # Check if batch is empty\r\n                    batch_count \u003d batch_df.count()\r\n                    if batch_count \u003d\u003d 0:\r\n                        print_timestamp(f\"Batch {i+1} is empty, skipping...\")\r\n                        continue\r\n                    \r\n                    print_timestamp(f\"Batch {i+1} contains {batch_count} rows\")\r\n                    \r\n                    # Convert to list of rows\r\n                    rows \u003d batch_df.drop(\"row_id\").collect()\r\n                    \r\n                    if not rows:\r\n                        print_timestamp(f\"No rows collected for batch {i+1}, skipping...\")\r\n                        continue\r\n                    \r\n                    # Get column names from first row\r\n                    columns \u003d rows[0].asDict().keys()\r\n                    \r\n                    # Create table if not exists\r\n                    create_table_sql \u003d f\u0027\u0027\u0027\r\n                        CREATE TABLE IF NOT EXISTS \"{schema}\".\"{table}\" (\r\n                            {\u0027, \u0027.join(f\u0027\"{col}\" TEXT\u0027 for col in columns)}\r\n                        )\r\n                    \u0027\u0027\u0027\r\n                    cur.execute(create_table_sql)\r\n                    \r\n                    # Prepare insert statement\r\n                    placeholders \u003d \u0027, \u0027.join([\u0027%s\u0027] * len(columns))\r\n                    insert_sql \u003d f\u0027\u0027\u0027\r\n                        INSERT INTO \"{schema}\".\"{table}\" \r\n                        ({\u0027, \u0027.join(f\u0027\"{col}\"\u0027 for col in columns)})\r\n                        VALUES ({placeholders})\r\n                    \u0027\u0027\u0027\r\n                    \r\n                    # Process data in chunks\r\n                    for chunk_start in range(0, len(rows), chunk_size):\r\n                        chunk_end \u003d min(chunk_start + chunk_size, len(rows))\r\n                        chunk_rows \u003d rows[chunk_start:chunk_end]\r\n                        \r\n                        if not chunk_rows:\r\n                            continue\r\n                        \r\n                        # Convert rows to list of values, handling NULL values based on type\r\n                        values \u003d []\r\n                        for row in chunk_rows:\r\n                            row_dict \u003d row.asDict()\r\n                            row_values \u003d []\r\n                            for col in columns:\r\n                                val \u003d row_dict[col]\r\n                                col_type \u003d column_types[col]\r\n                                \r\n                                if val is None or val \u003d\u003d \u0027None\u0027 or val \u003d\u003d \u0027\u0027:\r\n                                    # Handle NULL based on column type\r\n                                    if isinstance(col_type, (IntegerType, DoubleType)):\r\n                                        row_values.append(\u00270\u0027)  # 숫자형인 경우 0으로 처리\r\n                                    else:\r\n                                        row_values.append(\u0027\u0027)   # 그 외의 경우 빈 문자열로 처리\r\n                                else:\r\n                                    try:\r\n                                        if isinstance(col_type, (IntegerType, DoubleType)):\r\n                                            # Convert to float for numeric types\r\n                                            float_val \u003d float(val)\r\n                                            row_values.append(str(float_val))\r\n                                        else:\r\n                                            # Keep original value for non-numeric types\r\n                                            row_values.append(str(val))\r\n                                    except (ValueError, TypeError):\r\n                                        # If conversion fails, use appropriate default\r\n                                        if isinstance(col_type, (IntegerType, DoubleType)):\r\n                                            row_values.append(\u00270\u0027)\r\n                                        else:\r\n                                            row_values.append(\u0027\u0027)\r\n                            values.append(row_values)\r\n                        \r\n                        if values:\r\n                            try:\r\n                                # Try to insert data\r\n                                cur.executemany(insert_sql, values)\r\n                                conn.commit()\r\n                                print_timestamp(f\u0027Appended {len(values)} rows to table \"{schema}\".\"{table}\"\u0027)\r\n                            except psycopg2.errors.UniqueViolation as e:\r\n                                conn.rollback()\r\n                                print_timestamp(f\"Duplicate key found, attempting to update existing records...\")\r\n                                \r\n                                # Prepare update statement\r\n                                update_cols \u003d [col for col in columns if col not in [\u0027ID\u0027, \u0027OP_DATE\u0027, \u0027START_C_DATE\u0027]]\r\n                                update_sql \u003d f\u0027\u0027\u0027\r\n                                    UPDATE \"{schema}\".\"{table}\"\r\n                                    SET {\u0027, \u0027.join(f\u0027\"{col}\" \u003d EXCLUDED.\"{col}\"\u0027 for col in update_cols)}\r\n                                    FROM (VALUES {\u0027, \u0027.join([\u0027%s\u0027] * len(columns))}) AS EXCLUDED ({\u0027, \u0027.join(f\u0027\"{col}\"\u0027 for col in columns)})\r\n                                    WHERE \"{schema}\".\"{table}\".\"ID\" \u003d EXCLUDED.\"ID\"\r\n                                    AND \"{schema}\".\"{table}\".\"OP_DATE\" \u003d EXCLUDED.\"OP_DATE\"\r\n                                    AND \"{schema}\".\"{table}\".\"START_C_DATE\" \u003d EXCLUDED.\"START_C_DATE\"\r\n                                \u0027\u0027\u0027\r\n                                \r\n                                # Execute update\r\n                                cur.executemany(update_sql, values)\r\n                                conn.commit()\r\n                                print_timestamp(f\u0027Updated {len(values)} existing rows in table \"{schema}\".\"{table}\"\u0027)\r\n                            \r\n                            # Clear memory\r\n                            del values\r\n                            gc.collect()\r\n                    \r\n                    # Verify the save\r\n                    cur.execute(f\u0027SELECT COUNT(*) FROM \"{schema}\".\"{table}\"\u0027)\r\n                    saved_count \u003d cur.fetchone()[0]\r\n                    print_timestamp(f\"Immediate verification: {saved_count} rows in database\")\r\n                    \r\n                except Exception as batch_error:\r\n                    conn.rollback()\r\n                    print_timestamp(f\"Error processing batch {i+1}: {str(batch_error)}\")\r\n                    raise\r\n            \r\n            print_timestamp(f\u0027Successfully saved all data to \"{schema}\".\"{table}\"\u0027)\r\n            \r\n        finally:\r\n            # Close cursor and connection\r\n            cur.close()\r\n            conn.close()\r\n        \r\n    except Exception as e:\r\n        print_timestamp(f\"Error saving to database: {str(e)}\")\r\n        raise\r\n\u0027\u0027\u0027\r\n",
      "user": "anonymous",
