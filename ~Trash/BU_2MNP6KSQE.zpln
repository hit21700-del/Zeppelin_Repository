  "paragraphs": [
    {
      "text": "%python\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n# Battery Feature Engineering Pipeline \n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n\n\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n# PARAGRAPH 1 — Imports \u0026 Config\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n%python\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\nimport warnings\nimport re\nimport os\nimport gc\nimport time\nimport psutil\nimport s3fs\nfrom numba import jit\nfrom multiprocessing import Pool, cpu_count\nwarnings.filterwarnings(\u0027ignore\u0027)\n\n# S3 Configuration\nBUCKET_NAME   \u003d \"quantum\"\nINPUT_FOLDER  \u003d \"data_folder\"\nOUTPUT_FOLDER \u003d \"output_folder\"\n\n# dtype map — float32 saves ~50% RAM vs default float64\nDTYPE_MAP \u003d {\n    \u0027vehicle_id\u0027:           \u0027int16\u0027,\n    \u0027bus_speed\u0027:            \u0027float32\u0027,\n    \u0027is_key_on\u0027:            \u0027int8\u0027,\n    \u0027is_charger_connected\u0027: \u0027int8\u0027,\n    \u0027is_parking_brake_on\u0027:  \u0027int8\u0027,\n    \u0027mileage\u0027:              \u0027float32\u0027,\n}\nfor _prefix in [\u0027cell_max_t\u0027, \u0027cell_min_t\u0027, \u0027cell_max_v\u0027, \u0027cell_min_v\u0027,\n                 \u0027voltage\u0027, \u0027current\u0027, \u0027soc\u0027, \u0027soh\u0027]:\n    for _j in range(1, 9):\n        DTYPE_MAP[f\u0027{_prefix}_P{_j}\u0027] \u003d \u0027float32\u0027\n\nprint(\"✅ P1 done — imports \u0026 config ready\")\n\n",
      "user": "anonymous",
      "dateUpdated": "2026-04-13 04:04:21.484",
