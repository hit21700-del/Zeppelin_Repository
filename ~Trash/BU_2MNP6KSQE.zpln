    {
      "text": "%python\n\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n# PARAGRAPH 7 — Evaluate on Vehicle 95\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n%python\nlog_mem(\"before evaluation\")\n\n# FIX 8: .query() — no .copy()\nv95      \u003d df.query(\u0027vehicle_id \u003d\u003d 95\u0027)\nprint(f\"Vehicle 95 rows: {len(v95):,}\")\n\nv95_seqs, _ \u003d create_sequences_fast(v95, OPTIMAL_FEATURES, OPTIMAL_SEQ_LEN)\nv95_eval    \u003d v95.iloc[OPTIMAL_SEQ_LEN - 1:].reset_index(drop\u003dTrue).copy()\n\nprint(f\"Sequences : {len(v95_seqs):,}\")\nprint(f\"Eval rows : {len(v95_eval):,}\")\n\nfor col in [\u0027L3_main_anomaly\u0027, \u0027L3_aux_anomaly\u0027, \u0027L3_combined_anomaly\u0027]:\n    v95_eval[col] \u003d np.int8(0)\n\n# FIX 9: run predict() ONCE per model — cache all errors upfront\n# Original called predict() inside a per-state loop → N× redundant inference\nprint(\"\\nRunning inference (predict once per model)...\")\ncached_errors \u003d {\n    state: reconstruction_errors(v95_seqs, model)\n    for state, model in main_models.items()\n}\naux_errors_v95 \u003d reconstruction_errors(v95_seqs, aux_model)\nprint(f\"  ✓ {len(cached_errors)} main + 1 aux error arrays cached\")\nlog_mem(\"after predictions\")\n\n# Apply thresholds\nfor state in [\u0027charging\u0027, \u0027driving\u0027, \u0027idling\u0027, \u0027resting\u0027]:\n    if state not in cached_errors:\n        continue\n    mask \u003d v95_eval[\u0027state\u0027] \u003d\u003d state\n    idx  \u003d np.where(mask.values)[0]\n    if len(idx) \u003d\u003d 0:\n        continue\n\n    m_anom \u003d (cached_errors[state] \u003e main_thresholds[state]).astype(np.int8)\n    v95_eval.loc[mask, \u0027L3_main_anomaly\u0027] \u003d m_anom[idx]\n\n    if state \u003d\u003d \u0027driving\u0027:\n        a_anom \u003d (aux_errors_v95 \u003e aux_threshold).astype(np.int8)\n        v95_eval.loc[mask, \u0027L3_aux_anomaly\u0027]      \u003d a_anom[idx]\n        v95_eval.loc[mask, \u0027L3_combined_anomaly\u0027] \u003d (m_anom | a_anom)[idx]\n    else:\n        v95_eval.loc[mask, \u0027L3_combined_anomaly\u0027] \u003d m_anom[idx]\n\ndel v95_seqs, cached_errors, aux_errors_v95; gc.collect()\nlog_mem(\"after eval cleanup\")\nprint(\"\\n✅ P7 done — evaluation complete\")\n\n",
      "user": "anonymous",
      "dateUpdated": "2026-04-13 04:02:31.623",
      "progress": 0,
