      "text": "%python\n\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n# PARAGRAPH 6 — Run Pipeline\r\n# Start with single process (Option A), switch to parallel (Option B)\r\n# once Option A confirms it works correctly\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n%python\r\ntotal_start \u003d time.time()\r\n\r\n# ── Option A: single process — run this first ──────────────────────────────\r\nresults \u003d []\r\nfor f in cleaned_files:\r\n    result \u003d process_single_file(f)\r\n    results.append(result)\r\n    log_memory(f\"after {os.path.basename(f)}\")\r\n\r\n# ── Option B: parallel — uncomment after Option A succeeds ─────────────────\r\n# n_cores \u003d min(cpu_count() - 1, len(cleaned_files), 8)\r\n# print(f\"Running parallel with {n_cores} cores...\")\r\n# with Pool(n_cores) as pool:\r\n#     results \u003d pool.map(process_single_file, cleaned_files)\r\n\r\nprint(f\"\\n✅ Stage 1 done: {(time.time()-total_start)/60:.1f} min\")\r\nprint(f\"Results: {len(results)} files processed\")\r\n\r\n",
