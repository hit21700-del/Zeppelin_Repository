    {
      "text": "%python\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n# Level 3 Phase 2 — Memory-Optimized \n# Memory optimizations applied:\n#   1. float32 dtype on CSV load              → ~50% less RAM\n#   2. .transform() replaces .rolling().values → no intermediate copies\n#   3. .query() replaces .copy()              → no DataFrame copy\n#   4. numpy stride trick for sequences       → 10x faster, no Python loop\n#   5. Scaler stored per state                → reproducible inference\n#   6. model.predict() called ONCE per model  → no redundant inference\n#   7. del + gc.collect() after heavy ops     → memory released promptly\n#   8. Results saved as Parquet               → 80% smaller than CSV\n#   9. psutil memory logging per step         → easy OOM diagnosis\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n\n\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n# PARAGRAPH 1 — Imports \u0026 Config\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n%python\nimport gc\nimport json\nimport warnings\n\nimport numpy as np\nimport pandas as pd\nimport psutil\nimport s3fs\nfrom sklearn.preprocessing import StandardScaler\nfrom tensorflow.keras.layers import (\n    GRU, Dense, Dropout, RepeatVector, TimeDistributed\n)\nfrom tensorflow.keras.models import Sequential\n\nwarnings.filterwarnings(\u0027ignore\u0027)\n\n# S3\nBUCKET_NAME   \u003d \"quantum\"\nINPUT_FOLDER  \u003d \"data_folder\"\nOUTPUT_FOLDER \u003d \"output_folder\"\n\nALL_VEHICLES \u003d [93, 95, 97, 100, 103, 104, 111, 125, 170]\n\n# FIX 1: explicit dtype map — float32 saves ~50% RAM vs default float64\nDTYPE_MAP \u003d {\n    \u0027vehicle_id\u0027:         \u0027int16\u0027,\n    \u0027alarm_level\u0027:        \u0027int8\u0027,\n    \u0027time_1min\u0027:          \u0027str\u0027,\n    \u0027state\u0027:              \u0027str\u0027,\n    \u0027max_temp\u0027:           \u0027float32\u0027,\n    \u0027max_cell_t_diff\u0027:    \u0027float32\u0027,\n    \u0027joule_heat\u0027:         \u0027float32\u0027,\n    \u0027c_rate\u0027:             \u0027float32\u0027,\n    \u0027cooling_efficiency\u0027: \u0027float32\u0027,\n    \u0027pack_soc_std\u0027:       \u0027float32\u0027,\n    \u0027max_cell_v_diff\u0027:    \u0027float32\u0027,\n    \u0027voltage_volatility\u0027: \u0027float32\u0027,\n}\nfor _i in range(1, 9):\n    DTYPE_MAP[f\u0027current_P{_i}\u0027] \u003d \u0027float32\u0027\n\nfs \u003d s3fs.S3FileSystem(anon\u003dFalse)\n\ndef log_mem(label: str) -\u003e None:\n    \"\"\"Print available memory — helps locate OOM source.\"\"\"\n    vm \u003d psutil.virtual_memory()\n    print(f\"  [MEM] {label:35s} | avail\u003d{vm.available/1e9:.1f}GB  used\u003d{vm.percent}%\")\n\nprint(\"\u003d\" * 60)\nprint(\"Level 3 Phase 2 — Memory-Optimized (S3)\")\nprint(\"\u003d\" * 60)\nprint(f\"  Bucket : {BUCKET_NAME}\")\nprint(f\"  Input  : {INPUT_FOLDER}/\")\nprint(f\"  Output : {OUTPUT_FOLDER}/\")\nprint(\"P1 done\")",
      "user": "anonymous",
      "dateUpdated": "2026-04-13 04:02:31.622",
