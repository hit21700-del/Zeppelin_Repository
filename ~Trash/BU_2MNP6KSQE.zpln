    {
      "text": "%python\n\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n# PARAGRAPH 8 — Performance Report\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n%python\nL1_anom      \u003d v95_eval[\u0027alarm_level\u0027] \u003e\u003d 1\nL2_anom      \u003d v95_eval[\u0027if_anomaly_state\u0027].fillna(0) \u003d\u003d 1\nL3_anom      \u003d v95_eval[\u0027L3_combined_anomaly\u0027] \u003d\u003d 1\nn            \u003d len(v95_eval)\n\nL1_tpr       \u003d L1_anom.sum() / n * 100\nL2_tpr       \u003d L2_anom.sum() / n * 100\nL3_tpr       \u003d L3_anom.sum() / n * 100\nL1_L2_OR     \u003d (L1_anom | L2_anom).sum() / n * 100\nL1_L2_L3_OR  \u003d (L1_anom | L2_anom | L3_anom).sum() / n * 100\nprev_or      \u003d 51.78\n\nprint(\"\u003d\" * 60)\nprint(\"Individual TPR\")\nprint(f\"  L1 : {L1_tpr:.2f}%\")\nprint(f\"  L2 : {L2_tpr:.2f}%\")\nprint(f\"  L3 : {L3_tpr:.2f}%\")\n\nprint(\"\\nOR Integration\")\nprint(f\"  L1 + L2        : {L1_L2_OR:.2f}%\")\nprint(f\"  L1 + L2 + L3   : {L1_L2_L3_OR:.2f}%\")\nprint(f\"  L3 contribution: +{L1_L2_L3_OR - L1_L2_OR:.2f}%p\")\n\nprint(\"\\nPer-state breakdown\")\nstate_results \u003d []\nfor state in [\u0027charging\u0027, \u0027driving\u0027, \u0027idling\u0027, \u0027resting\u0027]:\n    smask  \u003d v95_eval[\u0027state\u0027] \u003d\u003d state\n    stotal \u003d smask.sum()\n    if stotal \u003d\u003d 0:\n        continue\n    l1s \u003d (L1_anom \u0026 smask).sum() / stotal * 100\n    l2s \u003d (L2_anom \u0026 smask).sum() / stotal * 100\n    l3s \u003d (L3_anom \u0026 smask).sum() / stotal * 100\n    ors \u003d ((L1_anom | L2_anom | L3_anom) \u0026 smask).sum() / stotal * 100\n    tag \u003d \" 🆕\" if state \u003d\u003d \u0027resting\u0027 else \"\"\n    print(f\"\\n  [{state}]{tag}  ({stotal:,} rows)\")\n    print(f\"    L1\u003d{l1s:.2f}%  L2\u003d{l2s:.2f}%  L3\u003d{l3s:.2f}%  OR\u003d{ors:.2f}%\")\n    state_results.append(dict(state\u003dstate, total\u003dstotal,\n                               L1\u003dl1s, L2\u003dl2s, L3\u003dl3s, OR\u003dors))\n\nprint(\"\\nGoal check (target: 60%)\")\nif L1_L2_L3_OR \u003e\u003d 60:\n    print(f\"  ✅ Reached!  {L1_L2_L3_OR:.2f}%  (+{L1_L2_L3_OR - prev_or:.2f}%p)\")\nelif L1_L2_L3_OR \u003e\u003d 55:\n    print(f\"  ⚠️  Near     {L1_L2_L3_OR:.2f}%  (+{L1_L2_L3_OR - prev_or:.2f}%p)\")\nelse:\n    print(f\"  ❌ Below    {L1_L2_L3_OR:.2f}%  (need +{60 - L1_L2_L3_OR:.2f}%p)\")\n\nprint(\"\\n✅ P8 done\")\n\n",
      "user": "anonymous",
