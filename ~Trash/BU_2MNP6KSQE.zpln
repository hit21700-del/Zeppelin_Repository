    {
      "text": "%python\n\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n# PARAGRAPH 7 — Merge Shards \u0026 Save Final Output\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n%python\r\nmerged_paths \u003d {}\r\nfor res in [\u002710s\u0027, \u00271min\u0027, \u00275min\u0027]:\r\n    shards \u003d [r[res] for r in results if res in r]\r\n    merged_paths[res] \u003d merge_and_save(fs, res, shards)\r\n\r\ntotal_elapsed \u003d time.time() - total_start\r\nprint(f\"\\n✅ Pipeline complete: {total_elapsed/60:.1f} min\")\r\nprint(f\"Per-file average  : {total_elapsed/len(cleaned_files)/60:.1f} min\")\r\nprint(\"\\nOutput files (Parquet / snappy):\")\r\nfor res, path in merged_paths.items():\r\n    print(f\"  ✓ {path}\")",
