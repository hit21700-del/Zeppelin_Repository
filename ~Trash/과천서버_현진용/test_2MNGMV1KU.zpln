    {
      "text": "%spark.pyspark\nfrom pyspark.sql import functions as F\nfrom pyspark.sql.window import Window\n\ndf \u003d spark.read.option(\"basePath\", \"s3a://parquet/kslab_kmon\") \\\n    .parquet(\"s3a://parquet/kslab_kmon/_deviceId\u003d01229898903/\") \\\n    .filter(\n        (F.col(\"_date\") \u003e\u003d \"2022-01-01\") \u0026\n        (F.col(\"_date\") \u003c\u003d \"2024-12-31\")\n    ) \\\n    .drop(\"_deviceId\", \"_date\")\n\nw \u003d Window.partitionBy(\"deviceId\").orderBy(\"createdAt\")\n\ndf \u003d df.withColumn(\"maxCellTemperature_prev\", F.lag(\"maxCellTemperature\").over(w)) \\\n       .withColumn(\"maxCellTemperature_next\", F.lead(\"maxCellTemperature\").over(w)) \\\n       .withColumn(\"minCellTemperature_prev\", F.lag(\"minCellTemperature\").over(w)) \\\n       .withColumn(\"minCellTemperature_next\", F.lead(\"minCellTemperature\").over(w))\n\ndf_result \u003d df.filter(\n    (F.col(\"maxCellTemperature\") \u003e 127) | (F.col(\"maxCellTemperature\") \u003c -128) |\n    (F.col(\"minCellTemperature\") \u003e 127) | (F.col(\"minCellTemperature\") \u003c -128)\n)\n\ndf_result.select(\n    \"deviceId\", \"createdAt\",\n    \"maxCellTemperature_prev\", \"maxCellTemperature\", \"maxCellTemperature_next\",\n    \"minCellTemperature_prev\", \"minCellTemperature\", \"minCellTemperature_next\"\n).orderBy(\"createdAt\").show(100)",
