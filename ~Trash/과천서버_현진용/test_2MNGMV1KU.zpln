    {
      "text": "%spark.pyspark\r\nfrom pyspark.sql import functions as F\r\nfrom pyspark.sql.types import BooleanType\r\n\r\ndef is_cv_anomaly(cv_str, threshold\u003d0.3):\r\n    if not cv_str:\r\n        return None\r\n    try:\r\n        cells \u003d [float(x.strip()) for x in cv_str.split(\",\")]\r\n        total \u003d len(cells)\r\n        if total \u003d\u003d 0:\r\n            return None\r\n        low_count \u003d sum(1 for v in cells if v \u003c 1.0)\r\n        return (low_count / total) \u003e\u003d threshold\r\n    except:\r\n        return None\r\n\r\nis_cv_anomaly_udf \u003d F.udf(is_cv_anomaly, BooleanType())\r\n\r\ndf \u003d spark.read.option(\"basePath\", \"s3a://parquet/kslab_kmon\") \\\r\n    .parquet(\"s3a://parquet/kslab_kmon/_deviceId\u003d01229518902/\") \\\r\n    .filter(F.col(\"cellVoltages\").isNotNull())\r\n\r\ndf \u003d df.withColumn(\"cv_anomaly\", is_cv_anomaly_udf(F.col(\"cellVoltages\")))\r\n\r\ntotal \u003d df.count()\r\nanomaly \u003d df.filter(F.col(\"cv_anomaly\") \u003d\u003d True).count()\r\nprint(f\"전체: {total}, 이상: {anomaly}, 비율: {anomaly/total:.4f}\")\r\n\r\n# 이상 샘플 확인 — 몇 개짜리 셀인지, 어떤 패턴인지\r\ndf.filter(F.col(\"cv_anomaly\") \u003d\u003d True) \\\r\n  .select(\"createdAt\", \"cellVoltages\", \"batteryPackVoltages\", \"maxCellVoltages\", \"minCellVoltages\") \\\r\n  .show(10, truncate\u003d80)",
