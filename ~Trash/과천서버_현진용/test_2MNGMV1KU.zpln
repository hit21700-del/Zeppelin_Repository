      "text": "%spark.pyspark\r\nfrom pyspark.sql import functions as F\r\nfrom pyspark.sql.window import Window\r\n\r\ndf \u003d spark.read.option(\"basePath\", \"s3a://parquet/kslab_kmon\") \\\r\n    .parquet(\"s3a://parquet/kslab_kmon/_deviceId\u003d01229968996/\") \\\r\n    .filter(\r\n        (F.col(\"_date\") \u003e\u003d \"2022-01-01\") \u0026\r\n        (F.col(\"_date\") \u003c\u003d \"2024-12-31\")\r\n    ) \\\r\n    .drop(\"_deviceId\", \"_date\")\r\n\r\nw \u003d Window.partitionBy(\"deviceId\").orderBy(\"createdAt\")\r\n\r\ndf \u003d df.withColumn(\"SOC_prev\",                F.lag(\"SOC\").over(w)) \\\r\n       .withColumn(\"SOC_next\",                F.lead(\"SOC\").over(w)) \\\r\n       .withColumn(\"speed_prev\",              F.lag(\"speed\").over(w)) \\\r\n       .withColumn(\"speed_next\",              F.lead(\"speed\").over(w)) \\\r\n       .withColumn(\"batteryPackCurrent_prev\", F.lag(\"batteryPackCurrent\").over(w)) \\\r\n       .withColumn(\"batteryPackCurrent_next\", F.lead(\"batteryPackCurrent\").over(w)) \\\r\n       .withColumn(\"mcuMotorRpm_prev\",        F.lag(\"mcuMotorRpm\").over(w)) \\\r\n       .withColumn(\"mcuMotorRpm_next\",        F.lead(\"mcuMotorRpm\").over(w))\r\n\r\ndf_result \u003d df.filter(\r\n    ((F.col(\"SOC\") \u003e F.col(\"SOC_prev\") * 2) \u0026 (F.col(\"SOC\") \u003e F.col(\"SOC_next\") * 2)) |\r\n    ((F.col(\"SOC\") \u003c F.col(\"SOC_prev\") * 0.5) \u0026 (F.col(\"SOC\") \u003c F.col(\"SOC_next\") * 0.5)) |\r\n    ((F.col(\"speed\") \u003e F.col(\"speed_prev\") * 2) \u0026 (F.col(\"speed\") \u003e F.col(\"speed_next\") * 2)) |\r\n    ((F.col(\"speed\") \u003c F.col(\"speed_prev\") * 0.5) \u0026 (F.col(\"speed\") \u003c F.col(\"speed_next\") * 0.5)) |\r\n    ((F.col(\"batteryPackCurrent\") \u003e F.col(\"batteryPackCurrent_prev\") * 2) \u0026 (F.col(\"batteryPackCurrent\") \u003e F.col(\"batteryPackCurrent_next\") * 2)) |\r\n    ((F.col(\"batteryPackCurrent\") \u003c F.col(\"batteryPackCurrent_prev\") * 0.5) \u0026 (F.col(\"batteryPackCurrent\") \u003c F.col(\"batteryPackCurrent_next\") * 0.5)) |\r\n    ((F.col(\"mcuMotorRpm\") \u003e F.col(\"mcuMotorRpm_prev\") * 2) \u0026 (F.col(\"mcuMotorRpm\") \u003e F.col(\"mcuMotorRpm_next\") * 2)) |\r\n    ((F.col(\"mcuMotorRpm\") \u003c F.col(\"mcuMotorRpm_prev\") * 0.5) \u0026 (F.col(\"mcuMotorRpm\") \u003c F.col(\"mcuMotorRpm_next\") * 0.5))\r\n)\r\n\r\ndf_result.select(\r\n    \"deviceId\", \"createdAt\",\r\n    \"SOC_prev\", \"SOC\", \"SOC_next\",\r\n    \"speed_prev\", \"speed\", \"speed_next\",\r\n    \"batteryPackCurrent_prev\", \"batteryPackCurrent\", \"batteryPackCurrent_next\",\r\n    \"mcuMotorRpm_prev\", \"mcuMotorRpm\", \"mcuMotorRpm_next\"\r\n).orderBy(\"createdAt\").show(100)",
