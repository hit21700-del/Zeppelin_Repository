    {
      "text": "%spark.pyspark\r\nfrom pyspark.sql import functions as F\r\nfrom pyspark.sql.window import Window\r\n\r\ndf \u003d spark.read.option(\"basePath\", \"s3a://parquet/kslab_kmon\") \\\r\n    .parquet(\"s3a://parquet/kslab_kmon/_deviceId\u003d01229898903/\") \\\r\n    .filter(\r\n        (F.col(\"_date\") \u003e\u003d \"2022-01-01\") \u0026\r\n        (F.col(\"_date\") \u003c\u003d \"2024-12-31\")\r\n    ) \\\r\n    .drop(\"_deviceId\", \"_date\")\r\n\r\nw \u003d Window.partitionBy(\"deviceId\").orderBy(\"createdAt\")\r\n\r\ndf \u003d df.withColumn(\"totalMileage_prev\",                   F.lag(\"totalMileage\").over(w)) \\\r\n       .withColumn(\"totalMileage_next\",                   F.lead(\"totalMileage\").over(w)) \\\r\n       .withColumn(\"batteryTotalChargedCapacity_prev\",    F.lag(\"batteryTotalChargedCapacity\").over(w)) \\\r\n       .withColumn(\"batteryTotalChargedCapacity_next\",    F.lead(\"batteryTotalChargedCapacity\").over(w)) \\\r\n       .withColumn(\"batteryTotalDischargedCapacity_prev\", F.lag(\"batteryTotalDischargedCapacity\").over(w)) \\\r\n       .withColumn(\"batteryTotalDischargedCapacity_next\", F.lead(\"batteryTotalDischargedCapacity\").over(w))\r\n\r\ndf_result \u003d df.filter(\r\n    # totalMileage 순간 스파이크 (올라갔다 내려오는)\r\n    ((F.col(\"totalMileage\") \u003e F.col(\"totalMileage_prev\") + 10) \u0026\r\n     (F.col(\"totalMileage\") \u003e F.col(\"totalMileage_next\") + 10)) |\r\n    # batteryTotalChargedCapacity 순간 스파이크\r\n    ((F.col(\"batteryTotalChargedCapacity\") \u003e F.col(\"batteryTotalChargedCapacity_prev\") + 10) \u0026\r\n     (F.col(\"batteryTotalChargedCapacity\") \u003e F.col(\"batteryTotalChargedCapacity_next\") + 10)) |\r\n    # batteryTotalDischargedCapacity 순간 스파이크\r\n    ((F.col(\"batteryTotalDischargedCapacity\") \u003e F.col(\"batteryTotalDischargedCapacity_prev\") + 10) \u0026\r\n     (F.col(\"batteryTotalDischargedCapacity\") \u003e F.col(\"batteryTotalDischargedCapacity_next\") + 10))\r\n)\r\n\r\ndf_result.select(\r\n    \"deviceId\", \"createdAt\",\r\n    \"totalMileage_prev\", \"totalMileage\", \"totalMileage_next\",\r\n    \"batteryTotalChargedCapacity_prev\", \"batteryTotalChargedCapacity\", \"batteryTotalChargedCapacity_next\",\r\n    \"batteryTotalDischargedCapacity_prev\", \"batteryTotalDischargedCapacity\", \"batteryTotalDischargedCapacity_next\"\r\n).orderBy(\"createdAt\").show(100)",
