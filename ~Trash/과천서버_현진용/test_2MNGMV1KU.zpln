    {
      "text": "%spark.pyspark\r\nfrom pyspark.sql import functions as F\r\nfrom pyspark.sql.window import Window\r\n\r\nw \u003d Window.partitionBy(\"deviceId\").orderBy(\"createdAt\")\r\n\r\ndf \u003d spark.read.option(\"basePath\", \"s3a://parquet/kslab_kmon\") \\\r\n    .parquet(\"s3a://parquet/kslab_kmon/_deviceId\u003d01229898903/\") \\\r\n    .filter(F.col(\"SOC\").isNotNull())\r\n\r\ndf \u003d df.withColumn(\"soc_prev\", F.lag(\"SOC\").over(w)) \\\r\n       .withColumn(\"time_prev\", F.lag(\"createdAt\").over(w)) \\\r\n       .withColumn(\"soc_delta\", F.abs(F.col(\"SOC\") - F.col(\"soc_prev\"))) \\\r\n       .withColumn(\"time_diff_sec\",\r\n           F.unix_timestamp(\"createdAt\") - F.unix_timestamp(\"time_prev\")\r\n       )\r\n\r\ndf_anomaly \u003d df.filter(\r\n    (F.col(\"soc_delta\") \u003e\u003d 3) \u0026\r\n    (F.col(\"time_diff_sec\") \u003c\u003d 2) \u0026\r\n    (F.col(\"SOC\") !\u003d 0) \u0026\r\n    (F.col(\"soc_prev\") !\u003d 0)\r\n)\r\n\r\nprint(f\"이상 건수: {df_anomaly.count()}\")\r\n\r\ndf_anomaly.select(\r\n    \"deviceId\", \"createdAt\", \"SOC\", \"soc_prev\",\r\n    \"soc_delta\", \"time_diff_sec\", \"isEVReady\", \"speed\"\r\n).show(20, truncate\u003dFalse)",
