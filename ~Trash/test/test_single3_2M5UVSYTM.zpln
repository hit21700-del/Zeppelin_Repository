      "text": "%spark_single.pyspark\ndef process_data(spark: SparkSession) -\u003e DataFrame: # DataFrame 대신에 None을 입력하고 return값을 없앤뒤 main() 사용\n\n    # Step 1: Load data (csv or db) \n    print_timestamp(\"Step 1\u003e Loading data\")\n    if PP_IO_CONFIG[\u0027input\u0027][\u0027source\u0027].lower() \u003d\u003d \u0027csv\u0027: \n        df \u003d load_data_from_csv(spark, PP_IO_CONFIG[\u0027input\u0027][\u0027csv_path\u0027])\n    else:  # \u0027db\u0027\n        df \u003d load_data_from_db(spark,DB_QUERY_KMON_DATA)\n\n\n    #step 2: Load master data and add group_code \n    # df_master \u003d load_data_from_db(spark,DB_QUERY_MASTER_DATA)\n    \n    # df \u003d df.join(\n    #     df_master.select(\"sensor_num\", \"group_cd\", \"car_num\"),\n    #     df.id \u003d\u003d df_master.sensor_num,\n    #     \"left\"\n    # ).drop(\"sensor_num\").fillna({\"group_cd\": 0, \"car_num\": \"\"})\n    \n   \n    # Step 6-1: 이상치 제거 1\n    print_timestamp(\"Step 6-1\u003e remove_short_evr_anomalies\")\n    df\u003dremove_outlier1(df)\n\n    # Step 6-2: Remove outliers 2\n    print_timestamp(\"Step 6-2\u003e Removing outliers\")\n    df \u003d remove_outlier2(df)\n\n    # Step 7: 분석 컬럼(관제용) 추가\n    print_timestamp(\"Step 7\u003e Adding analysis columns\")\n    df \u003d add_columns(df)\n\n    # Step 8:  SOB / SOP 변수 추가\n    #print_timestamp(\"Step 8\u003e Adding SOB and SOP\")\n    #df \u003d add_sox(df)\n\n    # Step 9: Add anomaly labels (PySpark 기반)\n    #print_timestamp(\"Step 9\u003e Adding anomaly labels\")\n    #labeler \u003d AnomalyLabeler()\n    #df \u003d labeler.label_anomalies_spark(df)\n    #df \u003d labeler.preprocess_status_groups(df)\n    #print_timestamp(f\"After adding anomaly labels: {df.count():,} rows\")\n\n    # Step 10: Select final columns \n    print_timestamp(\"Step 10\u003e Selecting final columns\")\n    result_df \u003d df.select(*SELECTED_COLUMNS_FINAL)\n    \n    # Step 11: Save results\n    # print_timestamp(\"Step 11\u003e Saving results (HDFS overwrite)\")\n    # output_path \u003d \"hdfs:///QH/PP_SET/latest\"   # 항상 같은 경로\n\n    # # 단일 CSV 파일만 원하면 True, 여러 part로 빠르게 저장하려면 False\n    # SINGLE_FILE \u003d True\n\n    # writer \u003d (result_df\n    #           .write\n    #           .mode(\"overwrite\")\n    #           .option(\"header\", True))\n\n    # if SINGLE_FILE:\n    #     # 대용량에서는 병목 가능. 필요 시만 사용하세요.\n    #     (result_df\n    #         #.coalesce(1)\n    #         .write\n    #         .mode(\"overwrite\")\n    #         .option(\"header\", True)\n    #         .csv(output_path))\n    # else:\n    #     writer.csv(output_path)\n\n    # print(f\"[OK] Results saved to: {output_path}\")\n    \n    # print_timestamp(\"Processing complete.\")\n    return result_df\n",
