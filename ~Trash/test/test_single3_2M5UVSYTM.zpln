      "text": "%spark_single.pyspark\nfrom pyspark.sql.functions import input_file_name\n\n# 단일 CSV 파일 경로\nFILE_PATH \u003d \"/QH/TEST_DATA/small.csv\"\n\nREAD_OPTS \u003d {\n    \"header\": \"true\",\n    \"inferSchema\": \"true\",\n    \"mode\": \"PERMISSIVE\",\n    \"columnNameOfCorruptRecord\": \"_corrupt_record\",\n    \"badRecordsPath\": \"/QH/_bad_records_raw\",\n    \"multiLine\": \"false\",\n    \"escape\": \"\\\\\",\n    \"quote\": \"\\\"\",\n}\n\n# 단일 파일만 읽기\ndf \u003d (spark.read\n      .options(**READ_OPTS)\n      .csv(FILE_PATH)                      # ← 단일 파일 지정\n      .withColumn(\"_src_file\", input_file_name()))\n",
      "user": "anonymous",
