    {
      "text": "%python\r\nimport os\r\n\r\n# CPU 코어 수\r\nprint(f\"CPU 코어 수: {os.cpu_count()}\")\r\n\r\n# 메모리\r\nwith open(\u0027/proc/meminfo\u0027) as f:\r\n    meminfo \u003d {}\r\n    for line in f:\r\n        key, val \u003d line.split(\u0027:\u0027)\r\n        meminfo[key.strip()] \u003d val.strip()\r\n\r\ntotal \u003d int(meminfo[\u0027MemTotal\u0027].split()[0]) / 1024\r\navailable \u003d int(meminfo[\u0027MemAvailable\u0027].split()[0]) / 1024\r\nused \u003d total - available\r\nprint(f\"전체 메모리: {total:.0f} MB\")\r\nprint(f\"사용 중: {used:.0f} MB\")\r\nprint(f\"사용 가능: {available:.0f} MB\")",
      "user": "anonymous",
