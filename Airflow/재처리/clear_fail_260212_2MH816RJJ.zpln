    {
      "text": "%spark\r\nimport org.joda.time.format.DateTimeFormat\r\nimport org.joda.time.LocalDate\r\nimport org.joda.time.DateTime\r\nimport java.util.Calendar\r\nimport java.util.Date\r\nimport java.text.SimpleDateFormat\r\nimport org.json.{JSONObject, JSONArray} // JSON 처리를 위한 라이브러리 추가\r\n\r\n/**\r\n * dag 별 실패한 task 조회 후 \r\n * task 재실행 api호출\r\n */\r\ntry {\r\n\r\n  if (airflowReprocessYN \u003d\u003d \"Y\") {\r\n    for (x \u003c- dag_srno_list) {\r\n\r\n      /**\r\n       * Dag의 task중 실행중인 task가 한개라도 있을 시엔 다음 dag로 pass - 실행중인 task가 없을 시 진행 \r\n       * 실행중 task 조회\r\n       */\r\n      var url_run: String \u003d \"http://airflow:9113/api/v1/dags/dag_wf_\" + x + \"/clearTaskInstances\"\r\n      var body_run \u003d \"{\\\"dry_run\\\": true, \\\"only_failed\\\":false, \\\"only_running\\\":true, \\\"include_subdags\\\":true, \\\"include_parentdag\\\":true, \\\"reset_dag_runs\\\":true}\"\r\n\r\n\r\n      var tasklist_result_run \u003d post(url_run, body_run)\r\n      var runJsonObj \u003d new JSONObject(tasklist_result_run)\r\n      \r\n\r\n      var task_instance_temp_run \u003d if (runJsonObj.has(\"task_instances\")) {\r\n          runJsonObj.getJSONArray(\"task_instances\")\r\n      } else {\r\n          new JSONArray()\r\n      }\r\n\r\n      // 실행중인 task가 없을 시 -\u003e 실패 task 재실행 api 호출\r\n      // if(task_instance_temp_run.length() \u003d\u003d 0) { // length -\u003e length() 로 변경됨\r\n\r\n        /**\r\n         * 해당 Dag의 실패한 Task 조회 \r\n         */\r\n        var url: String \u003d \"http://airflow:9113/api/v1/dags/dag_wf_\" + x + \"/clearTaskInstances\"\r\n        var body \u003d \"{\\\"dry_run\\\": true, \\\"only_failed\\\":true, \\\"only_running\\\":false, \\\"include_subdags\\\":true, \\\"include_parentdag\\\":true, \\\"reset_dag_runs\\\":true}\"\r\n\r\n\r\n        var tasklist_result \u003d post(url, body)\r\n        var failJsonObj \u003d new JSONObject(tasklist_result)\r\n        \r\n        var task_instance_temp \u003d if (failJsonObj.has(\"task_instances\")) {\r\n            failJsonObj.getJSONArray(\"task_instances\")\r\n        } else {\r\n            new JSONArray()\r\n        }\r\n\r\n        /**\r\n         * 실패한 task개수가 1개 이상인 경우에만 진행\r\n         */\r\n        if (task_instance_temp.length() \u003e 0 \u0026\u0026 (x !\u003d \"95\")) {\r\n          println(\"\u003cdag_wf_\" + x + \"\u003e       실패건 task 재실행 시작..............\")\r\n          \r\n          // 실패한 task 중 가장 빠른 일자 추출\r\n          var execution_date \u003d \"\"\r\n          \r\n          for (i \u003c- 0 until task_instance_temp.length()) {\r\n            val y \u003d task_instance_temp.getJSONObject(i)\r\n            val tmp_exec_date \u003d if (y.has(\"execution_date\")) y.getString(\"execution_date\") else \"\"\r\n            \r\n            if (i \u003d\u003d 0) {\r\n              execution_date \u003d tmp_exec_date\r\n            } else {\r\n              if (execution_date \u003e tmp_exec_date) {\r\n                execution_date \u003d tmp_exec_date\r\n              }\r\n            }\r\n          }\r\n\r\n          // 추출한 일자로 먼저 그 날짜의 실패 task 부터 돌린다\r\n          var tmp_exec_date \u003d execution_date.split(\"T\")\r\n\r\n          val fmt \u003d DateTimeFormat.forPattern(\"yyyy-MM-dd\")\r\n          var tempDate \u003d new DateTime(tmp_exec_date(0))\r\n          var plusday \u003d fmt.print(tempDate.plusDays(100))\r\n\r\n          // 실행일자 ~ 다음날 일자로 조회조건 추가해서 실행 api 호출 (실패 task중 가장 빠른일자만 실행 )\r\n          var tmp_exec_sta_dt \u003d execution_date\r\n          var tmp_exec_end_dt \u003d plusday + \"T00:00:00+00:00\"\r\n\r\n          println(tmp_exec_sta_dt)\r\n          println(tmp_exec_end_dt)\r\n\r\n          /**\r\n           * 실패 task중 가장 빠른일자만 재실행 시작 ( api호출 )\r\n           */\r\n          var url_exec: String \u003d \"http://airflow:9113/api/v1/dags/dag_wf_\" + x + \"/clearTaskInstances\"\r\n          var body_exec \u003d \"{\\\"dry_run\\\": false, \\\"only_failed\\\":true, \\\"only_running\\\":false, \\\"include_subdags\\\":true, \\\"include_parentdag\\\":true, \\\"reset_dag_runs\\\":true  , \\\"start_date\\\": \\\"\" + tmp_exec_sta_dt + \"\\\" , \\\"end_date\\\": \\\"\" + tmp_exec_end_dt + \"\\\"  }\"\r\n\r\n          println(\"\u003cdag_wf_\" + x + \"\u003e       실패 재시작..............\")\r\n          println(post(url_exec, body_exec))\r\n        } else {\r\n          println(\"\u003cdag_wf_\" + x + \"\u003e       실패건 0개..............\")\r\n        }\r\n\r\n      // } else { // if(task_instance_temp_run.length() \u003d\u003d 0) 의 else 닫기\r\n      //   println(\"\u003cdag_knime_\"+x + \"\u003e      task실행중\")\r\n      // }\r\n\r\n    }\r\n  } else {\r\n    println(\"재배치 처리 비활성화 입니다.\")\r\n  }\r\n\r\n} catch {\r\n  case t: Throwable \u003d\u003e println(t.getMessage)\r\n}",
