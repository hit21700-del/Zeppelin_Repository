    {
      "text": "%spark\r\nimport scala.collection.mutable.ListBuffer\r\nimport org.apache.http.client.methods.{HttpPost, HttpGet}\r\nimport java.sql.{Connection, DriverManager}\r\nimport java.net.URLDecoder\r\nimport java.net.{URL, HttpURLConnection}\r\nimport java.io.{DataOutputStream, OutputStreamWriter}\r\nimport org.json.{JSONObject, JSONArray}\r\nimport scala.util.{Try, Success, Failure}\r\n\r\ndef show(x: Option[String]) \u003d x match {\r\n  case Some(null) \u003d\u003e \"\"\r\n  case Some(s)    \u003d\u003e s\r\n  case None       \u003d\u003e \"\"\r\n  case null       \u003d\u003e \"\"\r\n}\r\n\r\nval daglistAPI \u003d httpGetRequest(\"http://192.168.10.16:9110/knime/getServiceDagListNotDM?auto_retry_yn\u003dY\")\r\nval dagListJsonArray \u003d new JSONArray(daglistAPI)\r\nval dag_srno_list_temp \u003d {\r\n  val temp \u003d new ListBuffer[Map[String, String]]()\r\n  for (i \u003c- 0 until dagListJsonArray.length()) {\r\n    val jo \u003d dagListJsonArray.getJSONObject(i)\r\n    val keys \u003d jo.keys()\r\n    val map \u003d new ListBuffer[(String, String)]()\r\n    while (keys.hasNext()) {\r\n      val key \u003d keys.next()\r\n      map +\u003d (key -\u003e jo.getString(key))\r\n    }\r\n    temp +\u003d map.toMap\r\n  }\r\n  temp.toList\r\n}\r\n\r\nval dag_srno_list \u003d new ListBuffer[String]()\r\nfor (ds \u003c- dag_srno_list_temp) {\r\n  val temp \u003d ds.get(\"dag_srno\")\r\n  dag_srno_list +\u003d show(temp)\r\n}\r\n\r\n\r\nval airflowReprocessYnAPI \u003d httpGetRequest(\"http://192.168.10.16:9110/knime/getCommonCodeData?com_grp_cd\u003dDR\u0026com_cd\u003d01\")\r\nval reprocessJsonObject \u003d new JSONObject(airflowReprocessYnAPI)\r\nval result_temp \u003d {\r\n  val jo \u003d reprocessJsonObject\r\n  val keys \u003d jo.keys()\r\n  val map \u003d new ListBuffer[(String, String)]()\r\n  while (keys.hasNext()) {\r\n    val key \u003d keys.next()\r\n    map +\u003d (key -\u003e jo.getString(key))\r\n  }\r\n  map.toMap\r\n}\r\nval tmpCdNm \u003d result_temp.get(\"com_cd_nm\")\r\nval airflowReprocessYN \u003d show(tmpCdNm)\r\n\r\n//val jdbcDriver \u003d \"org.mariadb.jdbc.Driver\"\r\nval jdbcDriver \u003d \"org.mariadb.jdbc.Driver\"\r\nval dbUrl \u003d \"jdbc:mariadb://mariadb:3306/KNIME\"\r\nval user \u003d \"root\"\r\nval pass \u003d \"root\"\r\n\r\nClass.forName(jdbcDriver)\r\nval conn: Connection \u003d DriverManager.getConnection(dbUrl, user, pass)\r\nval stmt \u003d conn.createStatement()\r\nval sql \u003d \"SELECT * FROM KNIME.TB_ZPPLN_EXEC_EXCEPTION_INFO WHERE CONFIRM_YN \u003d \u0027N\u0027\"\r\nval rs \u003d stmt.executeQuery(sql)\r\n\r\ndef safeDecodeUtf8(s: String): String \u003d {\r\n  if (s \u003d\u003d null) return \"\"\r\n  Try(URLDecoder.decode(s, \"UTF-8\")).getOrElse(s)\r\n}\r\ndef preview35(s: String): String \u003d {\r\n  if (s \u003d\u003d null || s.isEmpty) \"\" \r\n  else if (s.length \u003e 35) s.take(35) + \"...\" \r\n  else s\r\n}\r\n\r\nvar count \u003d 0\r\nval sb \u003d new StringBuilder(\"*제플린 실패 무시(PASS) 리스트*\\n\")\r\n\r\nwhile (rs.next()) {\r\n  count +\u003d 1\r\n\r\n  val exec_srno             \u003d Option(rs.getString(\"EXEC_SRNO\")).getOrElse(\"\")\r\n  val dag_srno              \u003d Option(rs.getString(\"DAG_SRNO\")).getOrElse(\"\")\r\n  val dag_short_nm          \u003d Option(rs.getString(\"DAG_SHORT_NM\")).getOrElse(\"\")\r\n  val workflow_srno         \u003d Option(rs.getString(\"WORKFLOW_SRNO\")).getOrElse(\"\")\r\n  val workflow_path         \u003d Option(rs.getString(\"WORKFLOW_PATH\")).getOrElse(\"\")\r\n  val workflow_short_nm     \u003d Option(rs.getString(\"WORKFLOW_SHORT_NM\")).getOrElse(\"\")\r\n  val zeppelin_ip           \u003d Option(rs.getString(\"ZEPPELIN_IP\")).getOrElse(\"\")\r\n  val zeppelin_port         \u003d Option(rs.getString(\"ZEPPELIN_PORT\")).getOrElse(\"\")\r\n  val zeppelin_note_id      \u003d Option(rs.getString(\"ZEPPELIN_NOTE_ID\")).getOrElse(\"\")\r\n  val zeppelin_paragraph_id \u003d Option(rs.getString(\"ZEPPELIN_PARAGRAPH_ID\")).getOrElse(\"\")\r\n  val last_chg_date         \u003d Option(rs.getString(\"LAST_CHG_DATE\")).getOrElse(\"\")\r\n\r\n  val rawErr   \u003d Option(rs.getString(\"EXEC_ERR_DTL\")).getOrElse(\"\")\r\n  val decErr   \u003d safeDecodeUtf8(rawErr)\r\n  val preview  \u003d preview35(decErr)\r\n\r\n  sb.append(\"\\n---------------------------------------------------------------\\n\")\r\n    .append(s\"Dag명 : $dag_short_nm\\n\")\r\n    .append(s\"실행ID : $exec_srno\\n\")\r\n    .append(s\"워크플로우명 : $workflow_short_nm\\n\")\r\n    .append(s\"제플린addr : $zeppelin_ip:$zeppelin_port\\n\")\r\n    .append(s\"제플린 Note : $zeppelin_note_id\\n\")\r\n    .append(s\"제플린 Paragraph : $zeppelin_paragraph_id\\n\")\r\n    .append(s\"에러내용 : $preview\\n\")\r\n    .append(s\"실행종료일시 : $last_chg_date\\n\")\r\n}\r\n\r\n\r\nrs.close()\r\nstmt.close()\r\nconn.close()",
      "user": "anonymous",
      "dateUpdated": "2026-02-12 06:42:42.232",
      "progress": 0,
