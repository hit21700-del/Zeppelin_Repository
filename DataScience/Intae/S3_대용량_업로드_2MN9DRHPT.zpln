    {
      "title": "시나리오1 실패시 시나리오2 실행",
      "text": "%spark_high.pyspark\r\n\r\nimport os\r\nimport subprocess\r\n\r\naws_env \u003d {\r\n    **os.environ,\r\n    \"AWS_ACCESS_KEY_ID\":     S3_ACCESS_KEY,\r\n    \"AWS_SECRET_ACCESS_KEY\": S3_SECRET_KEY,\r\n}\r\nAWS_BASE \u003d [\"aws\", \"--endpoint-url\", S3_ENDPOINT, \"--no-verify-ssl\"]\r\nS3_TARGET \u003d f\"s3://{S3_BUCKET}/{S3_INSERT_PREFIX}/insert_lines_full.sql\"\r\n\r\nprint(\"\u003d\u003d\u003d [시나리오 1] INSERT 추출 시작 \u003d\u003d\u003d\")\r\nprint(f\"입력: {DUMP_FILE_PATH}\")\r\nprint(f\"출력: {S3_TARGET}\")\r\nprint(\"\")\r\n\r\n# ── aws cli 존재 여부 확인 ───────────────────────────────────\r\naws_check \u003d subprocess.run([\"which\", \"aws\"], capture_output\u003dTrue)\r\nif aws_check.returncode !\u003d 0:\r\n    print(\"aws cli 없음 -\u003e pip install awscli 또는 컨테이너 이미지 확인 필요\")\r\n    raise SystemExit(1)\r\n\r\n# ── 방법 1: grep 스트리밍 → aws s3 cp stdin (권장) ──────────\r\n# 중간 디스크 저장 없이 메모리 효율적으로 처리\r\nprint(\"INSERT 라인 추출 중 (스트리밍)...\")\r\n\r\ngrep_proc \u003d subprocess.Popen(\r\n    [\"grep\", \"-i\", \"^INSERT INTO\", DUMP_FILE_PATH],\r\n    stdout\u003dsubprocess.PIPE,\r\n    stderr\u003dsubprocess.PIPE\r\n)\r\naws_proc \u003d subprocess.Popen(\r\n    AWS_BASE + [\"s3\", \"cp\", \"-\", S3_TARGET,\r\n                \"--expected-size\", \"107374182400\", \"--quiet\"],\r\n    stdin\u003dgrep_proc.stdout,\r\n    stdout\u003dsubprocess.PIPE,\r\n    stderr\u003dsubprocess.PIPE,\r\n    env\u003daws_env\r\n)\r\ngrep_proc.stdout.close()\r\naws_out, aws_err \u003d aws_proc.communicate()\r\ngrep_proc.wait()\r\n\r\nif aws_proc.returncode \u003d\u003d 0:\r\n    print(\"S3 업로드 완료\")\r\n    r \u003d subprocess.run(\r\n        AWS_BASE + [\"s3\", \"ls\", f\"s3://{S3_BUCKET}/{S3_INSERT_PREFIX}/\", \"--human-readable\"],\r\n        capture_output\u003dTrue, text\u003dTrue, env\u003daws_env\r\n    )\r\n    print(r.stdout)\r\n\r\nelse:\r\n    print(f\"방법 1 실패 (grep rc\u003d{grep_proc.returncode}, aws rc\u003d{aws_proc.returncode})\")\r\n    print(aws_err.decode()[:500])\r\n    print(\"\")\r\n\r\n    # ── 방법 2: split 분할 업로드 (방법 1 실패 시) ───────────\r\n    print(\"\u003d\u003d\u003d 방법 2: 분할 업로드 시도 \u003d\u003d\u003d\")\r\n    TMP_DIR \u003d \"/tmp/kmon_inserts\"\r\n    os.makedirs(TMP_DIR, exist_ok\u003dTrue)\r\n\r\n    grep_proc2 \u003d subprocess.Popen(\r\n        [\"grep\", \"-i\", \"^INSERT INTO\", DUMP_FILE_PATH],\r\n        stdout\u003dsubprocess.PIPE\r\n    )\r\n    split_proc \u003d subprocess.Popen(\r\n        [\"split\", \"-b\", \"1073741824\", \"-\", f\"{TMP_DIR}/insert_part_\"],\r\n        stdin\u003dgrep_proc2.stdout\r\n    )\r\n    grep_proc2.stdout.close()\r\n    split_proc.wait()\r\n    grep_proc2.wait()\r\n\r\n    parts \u003d sorted(os.listdir(TMP_DIR))\r\n    print(f\"분할 파일 수: {len(parts)}\")\r\n\r\n    for fname in parts:\r\n        fpath \u003d os.path.join(TMP_DIR, fname)\r\n        fsize \u003d os.path.getsize(fpath)\r\n        print(f\"업로드 중: {fname}  ({fsize / (1024**2):.0f} MB)\")\r\n        r \u003d subprocess.run(\r\n            AWS_BASE + [\"s3\", \"cp\", fpath,\r\n                        f\"s3://{S3_BUCKET}/{S3_INSERT_PREFIX}/{fname}\", \"--quiet\"],\r\n            capture_output\u003dTrue, text\u003dTrue, env\u003daws_env\r\n        )\r\n        if r.returncode \u003d\u003d 0:\r\n            os.remove(fpath)\r\n            print(f\"  완료: {fname}\")\r\n        else:\r\n            print(f\"  실패: {r.stderr[:200]}\")\r\n\r\n    print(\"\u003d\u003d\u003d 분할 업로드 완료 \u003d\u003d\u003d\")\r\n    r \u003d subprocess.run(\r\n        AWS_BASE + [\"s3\", \"ls\", f\"s3://{S3_BUCKET}/{S3_INSERT_PREFIX}/\", \"--human-readable\"],\r\n        capture_output\u003dTrue, text\u003dTrue, env\u003daws_env\r\n    )\r\n    print(r.stdout)\r\n\r\nprint(\"\")\r\nprint(\"\u003d\u003d\u003d 작업 완료 -\u003e P6(Spark 파싱) paragraph로 이동 \u003d\u003d\u003d\")",
