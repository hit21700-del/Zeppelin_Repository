    {
      "title": "IMPORT_2",
      "text": "%spark.pyspark\r\n\r\n#   import os\r\n#   os.environ[\u0027PYSPARK_PYTHON\u0027] \u003d \u0027python3.9\u0027\r\n\r\n#   # executor 환경변수 설정 (SparkContext 시작 전에 적용되어야 효과 있음)\r\n#   spark.conf.set(\"spark.executorEnv.PYSPARK_PYTHON\", \"python3.9\")\r\n\r\n# ── 작업용 SQL 설정 (Zeppelin interpreter 리소스 설정은 그대로 유지) ──\r\nspark.conf.set(\"spark.sql.shuffle.partitions\", SHUFFLE_PARTITIONS)\r\nspark.conf.set(\"spark.sql.adaptive.enabled\", \"true\")\r\nspark.conf.set(\"spark.sql.adaptive.coalescePartitions.enabled\", \"true\")\r\n\r\nprint(\"\u003d\u003d\u003d 작업용 SQL 설정 \u003d\u003d\u003d\")\r\nprint(f\"spark.sql.shuffle.partitions                  : {spark.conf.get(\u0027spark.sql.shuffle.partitions\u0027)}\")\r\nprint(f\"spark.sql.adaptive.enabled                    : {spark.conf.get(\u0027spark.sql.adaptive.enabled\u0027)}\")\r\nprint(f\"spark.sql.adaptive.coalescePartitions.enabled : {spark.conf.get(\u0027spark.sql.adaptive.coalescePartitions.enabled\u0027)}\")\r\n\r\n# ── S3A Hadoop 설정 ─────────────────────────────────────────\r\nhc \u003d sc._jsc.hadoopConfiguration()\r\nhc.set(\"fs.s3a.endpoint\",               S3_ENDPOINT)\r\nhc.set(\"fs.s3a.access.key\",             S3_ACCESS_KEY)\r\nhc.set(\"fs.s3a.secret.key\",             S3_SECRET_KEY)\r\nhc.set(\"fs.s3a.impl\",                   \"org.apache.hadoop.fs.s3a.S3AFileSystem\")\r\nhc.set(\"fs.s3a.path.style.access\",      \"true\")\r\nhc.set(\"fs.s3a.connection.ssl.enabled\", \"false\")\r\nhc.set(\"fs.s3a.signing-algorithm\",      \"S3SignerType\")\r\nhc.set(\"fs.s3a.connection.timeout\",     \"300000\")\r\nhc.set(\"fs.s3a.socket.timeout\",         \"300000\")\r\nhc.set(\"fs.s3a.attempts.maximum\",       \"5\")\r\nhc.set(\"fs.s3a.multipart.size\",         \"134217728\")   # 128MB\r\nhc.set(\"fs.s3a.fast.upload\",            \"true\")\r\nhc.set(\"fs.s3a.fast.upload.buffer\",     \"bytebuffer\")\r\n\r\nprint(\"\\n\u003d\u003d\u003d S3A Hadoop 설정 적용 완료 \u003d\u003d\u003d\")\r\nprint(f\"fs.s3a.endpoint    : {hc.get(\u0027fs.s3a.endpoint\u0027)}\")\r\nprint(f\"fs.s3a.path.style  : {hc.get(\u0027fs.s3a.path.style.access\u0027)}\")\r\nprint(f\"fs.s3a.fast.upload : {hc.get(\u0027fs.s3a.fast.upload\u0027)}\")\r\n\r\n# ── S3 버킷 접근 테스트 ──────────────────────────────────────\r\ntry:\r\n    test_path \u003d f\"s3a://{S3_BUCKET}/\"\r\n    hadoop_path \u003d sc._jvm.org.apache.hadoop.fs.Path(test_path)\r\n    fs \u003d hadoop_path.getFileSystem(sc._jsc.hadoopConfiguration())\r\n    fs.getFileStatus(hadoop_path)\r\n    print(f\"\\n✅ S3 버킷 접근 성공: {test_path}\")\r\nexcept Exception as e:\r\n    print(f\"\\n❌ S3 버킷 접근 실패: {e}\")\r\n    print(\"   → S3_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY, S3_BUCKET 재확인 필요\")",
      "user": "anonymous",
      "dateUpdated": "2026-03-19 05:57:12.111",
      "progress": 0,
      "config": {
