            "data": "S3 INSERT 라인 파일 로드: s3a://parquet/kmon_dump/insert_lines\n\u001b[0;31m---------------------------------------------------------------------------\u001b[0m\n\u001b[0;31mPy4JJavaError\u001b[0m                             Traceback (most recent call last)\nCell \u001b[0;32mIn[28], line 183\u001b[0m\n\u001b[1;32m    180\u001b[0m \u001b[38;5;66;03m# INSERT 라인만 필터\u001b[39;00m\n\u001b[1;32m    181\u001b[0m insert_rdd \u001b[38;5;241m\u003d\u001b[39m raw_rdd\u001b[38;5;241m.\u001b[39mfilter(\u001b[38;5;28;01mlambda\u001b[39;00m line: line\u001b[38;5;241m.\u001b[39mstrip()\u001b[38;5;241m.\u001b[39mupper()\u001b[38;5;241m.\u001b[39mstartswith(\u001b[38;5;124m\u0027\u001b[39m\u001b[38;5;124mINSERT INTO\u001b[39m\u001b[38;5;124m\u0027\u001b[39m))\n\u001b[0;32m--\u003e 183\u001b[0m insert_count \u001b[38;5;241m\u003d\u001b[39m \u001b[43minsert_rdd\u001b[49m\u001b[38;5;241;43m.\u001b[39;49m\u001b[43mcount\u001b[49m\u001b[43m(\u001b[49m\u001b[43m)\u001b[49m\n\u001b[1;32m    184\u001b[0m \u001b[38;5;28mprint\u001b[39m(\u001b[38;5;124mf\u001b[39m\u001b[38;5;124m\"\u001b[39m\u001b[38;5;124mINSERT 라인 수: \u001b[39m\u001b[38;5;132;01m{\u001b[39;00minsert_count\u001b[38;5;132;01m:\u001b[39;00m\u001b[38;5;124m,\u001b[39m\u001b[38;5;132;01m}\u001b[39;00m\u001b[38;5;124m\"\u001b[39m)\n\u001b[1;32m    187\u001b[0m \u001b[38;5;66;03m# ── 테이블별 분리 처리 ────────────────────────────────────────\u001b[39;00m\n\u001b[1;32m    188\u001b[0m \n\u001b[1;32m    189\u001b[0m \u001b[38;5;66;03m# 1단계: 테이블명 목록 수집 (파싱 없이 빠르게)\u001b[39;00m\n\nFile \u001b[0;32m/spark/python/lib/pyspark.zip/pyspark/rdd.py:2316\u001b[0m, in \u001b[0;36mRDD.count\u001b[0;34m(self)\u001b[0m\n\u001b[1;32m   2295\u001b[0m \u001b[38;5;28;01mdef\u001b[39;00m \u001b[38;5;21mcount\u001b[39m(\u001b[38;5;28mself\u001b[39m) \u001b[38;5;241m-\u001b[39m\u001b[38;5;241m\u003e\u001b[39m \u001b[38;5;28mint\u001b[39m:\n\u001b[1;32m   2296\u001b[0m \u001b[38;5;250m    \u001b[39m\u001b[38;5;124;03m\"\"\"\u001b[39;00m\n\u001b[1