    {
      "title": "데이터 csv로 파싱",
      "text": "%spark.pyspark\r\n\r\nimport re\r\nfrom pyspark.sql import Row\r\nfrom pyspark.sql.types import StructType, StructField, StringType\r\n\r\n# ── INSERT 라인 파싱 함수 ────────────────────────────────────\r\n\r\ndef find_matching_paren(s, start):\r\n    \"\"\"start 위치의 \u0027(\u0027 에 대응하는 \u0027)\u0027 인덱스를 반환. 문자열/이스케이프 인식.\"\"\"\r\n    depth \u003d 0\r\n    in_string \u003d False\r\n    escape_next \u003d False\r\n    quote_char \u003d None\r\n    i \u003d start\r\n    while i \u003c len(s):\r\n        c \u003d s[i]\r\n        if escape_next:\r\n            escape_next \u003d False\r\n            i +\u003d 1\r\n            continue\r\n        if c \u003d\u003d \u0027\\\\\u0027 and in_string:\r\n            escape_next \u003d True\r\n            i +\u003d 1\r\n            continue\r\n        if in_string:\r\n            if c \u003d\u003d quote_char:\r\n                in_string \u003d False\r\n        else:\r\n            if c in (\"\u0027\", \u0027\"\u0027):\r\n                in_string \u003d True\r\n                quote_char \u003d c\r\n            elif c \u003d\u003d \u0027(\u0027:\r\n                depth +\u003d 1\r\n            elif c \u003d\u003d \u0027)\u0027:\r\n                depth -\u003d 1\r\n                if depth \u003d\u003d 0:\r\n                    return i\r\n        i +\u003d 1\r\n    return -1\r\n\r\n\r\ndef split_row_values(row_str):\r\n    \"\"\"쉼표로 구분된 필드값 파싱. 문자열 내부 쉼표, 이스케이프, NULL 처리.\"\"\"\r\n    values \u003d []\r\n    current \u003d []\r\n    in_string \u003d False\r\n    escape_next \u003d False\r\n    quote_char \u003d None\r\n\r\n    for c in row_str:\r\n        if escape_next:\r\n            current.append(c)\r\n            escape_next \u003d False\r\n            continue\r\n        if c \u003d\u003d \u0027\\\\\u0027 and in_string:\r\n            escape_next \u003d True\r\n            current.append(c)\r\n            continue\r\n        if in_string:\r\n            if c \u003d\u003d quote_char:\r\n                in_string \u003d False\r\n            current.append(c)\r\n        else:\r\n            if c in (\"\u0027\", \u0027\"\u0027):\r\n                in_string \u003d True\r\n                quote_char \u003d c\r\n                current.append(c)\r\n            elif c \u003d\u003d \u0027,\u0027:\r\n                values.append(\u0027\u0027.join(current).strip())\r\n                current \u003d []\r\n            else:\r\n                current.append(c)\r\n\r\n    if current:\r\n        values.append(\u0027\u0027.join(current).strip())\r\n\r\n    cleaned \u003d []\r\n    for v in values:\r\n        v \u003d v.strip()\r\n        if v.upper() \u003d\u003d \u0027NULL\u0027:\r\n            cleaned.append(None)\r\n        elif len(v) \u003e\u003d 2 and v[0] in (\"\u0027\", \u0027\"\u0027) and v[-1] \u003d\u003d v[0]:\r\n            inner \u003d v[1:-1]\r\n            inner \u003d (inner\r\n                     .replace(\"\\\\\u0027\", \"\u0027\")\r\n                     .replace(\u0027\\\\\"\u0027, \u0027\"\u0027)\r\n                     .replace(\u0027\\\\\\\\\u0027, \u0027\\\\\u0027)\r\n                     .replace(\u0027\\\\n\u0027, \u0027\\n\u0027)\r\n                     .replace(\u0027\\\\r\u0027, \u0027\\r\u0027)\r\n                     .replace(\u0027\\\\t\u0027, \u0027\\t\u0027)\r\n                     .replace(\u0027\\\\0\u0027, \u0027\\x00\u0027))\r\n            cleaned.append(inner)\r\n        else:\r\n            cleaned.append(v if v !\u003d \u0027\u0027 else None)\r\n\r\n    return cleaned\r\n\r\n\r\ndef parse_insert_line(line):\r\n    \"\"\"\r\n    INSERT INTO `table` (`col1`,`col2`) VALUES (v1,v2),(v3,v4);\r\n    또는\r\n    INSERT INTO `table` VALUES (v1,v2),(v3,v4);\r\n    를 파싱하여 (table_name, columns_or_None, [[row_values], ...]) 반환.\r\n    실패 시 None 반환.\r\n    \"\"\"\r\n    line \u003d line.strip()\r\n    if not line.upper().startswith(\u0027INSERT INTO\u0027):\r\n        return None\r\n\r\n    # 테이블명 + 옵션 컬럼 목록 추출\r\n    m \u003d re.match(\r\n        r\"INSERT\\s+INTO\\s+`?(\\w+)`?\\s*(?:\\(([^)]+)\\))?\\s*VALUES\\s*\",\r\n        line, re.IGNORECASE\r\n    )\r\n    if not m:\r\n        return None\r\n\r\n    table_name \u003d m.group(1)\r\n    col_part   \u003d m.group(2)\r\n\r\n    if col_part:\r\n        columns \u003d [c.strip().strip(\u0027`\u0027).strip(\u0027\"\u0027).strip(\"\u0027\") for c in col_part.split(\u0027,\u0027)]\r\n    else:\r\n        columns \u003d None\r\n\r\n    rest \u003d line[m.end():]\r\n\r\n    # VALUES 뒤의 각 (row_data) 추출\r\n    row_strings \u003d []\r\n    pos \u003d 0\r\n    while pos \u003c len(rest):\r\n        c \u003d rest[pos]\r\n        if c \u003d\u003d \u0027(\u0027:\r\n            end_pos \u003d find_matching_paren(rest, pos)\r\n            if end_pos \u003d\u003d -1:\r\n                break\r\n            row_str \u003d rest[pos + 1:end_pos]\r\n            row_strings.append(row_str)\r\n            pos \u003d end_pos + 1\r\n        elif c in (\u0027,\u0027, \u0027 \u0027, \u0027\\t\u0027, \u0027;\u0027, \u0027\\n\u0027, \u0027\\r\u0027):\r\n            pos +\u003d 1\r\n        else:\r\n            pos +\u003d 1\r\n\r\n    if not row_strings:\r\n        return None\r\n\r\n    parsed_rows \u003d []\r\n    for rs in row_strings:\r\n        vals \u003d split_row_values(rs)\r\n        parsed_rows.append(vals)\r\n\r\n    return (table_name, columns, parsed_rows)\r\n\r\n\r\ndef process_partition(lines):\r\n    \"\"\"mapPartitions용: INSERT 라인 파싱 → (table_name, col_count, row_dict) 생성.\"\"\"\r\n    for line in lines:\r\n        result \u003d parse_insert_line(line)\r\n        if result is None:\r\n            continue\r\n        table_name, columns, rows \u003d result\r\n        for row_vals in rows:\r\n            col_count \u003d len(row_vals)\r\n            if columns and len(columns) \u003d\u003d col_count:\r\n                col_names \u003d columns\r\n            else:\r\n                col_names \u003d [f\"col_{i}\" for i in range(col_count)]\r\n            row_dict \u003d {col_names[i]: (str(row_vals[i]) if row_vals[i] is not None else None)\r\n                        for i in range(col_count)}\r\n            row_dict[\u0027_table_name\u0027] \u003d table_name\r\n            yield row_dict\r\n\r\n\r\n# ── S3에서 INSERT 라인 읽기 ──────────────────────────────────\r\nprint(f\"S3 INSERT 라인 파일 로드: {S3_INSERT_PATH}\")\r\n\r\nraw_rdd \u003d sc.textFile(f\"{S3_INSERT_PATH}/*\")\r\n\r\n# INSERT 라인만 필터\r\ninsert_rdd \u003d raw_rdd.filter(lambda line: line.strip().upper().startswith(\u0027INSERT INTO\u0027))\r\n\r\ninsert_count \u003d insert_rdd.count()\r\nprint(f\"INSERT 라인 수: {insert_count:,}\")\r\n\r\n\r\n# ── 테이블별 분리 처리 ────────────────────────────────────────\r\n\r\n# 1단계: 테이블명 목록 수집 (파싱 없이 빠르게)\r\ntable_pattern \u003d re.compile(r\"INSERT\\s+INTO\\s+`?(\\w+)`?\", re.IGNORECASE)\r\n\r\ntable_names \u003d (insert_rdd\r\n               .map(lambda line: table_pattern.match(line.strip()))\r\n               .filter(lambda m: m is not None)\r\n               .map(lambda m: m.group(1))\r\n               .distinct()\r\n               .collect())\r\n\r\nprint(f\"\\n발견된 테이블 목록 ({len(table_names)}개):\")\r\nfor t in table_names:\r\n    print(f\"  - {t}\")\r\n\r\n\r\n# 2단계: 테이블별로 파싱 + CSV 저장\r\nresults \u003d {}\r\n\r\nfor target_table in table_names:\r\n    print(f\"\\n{\u0027\u003d\u0027*60}\")\r\n    print(f\"[{target_table}] 처리 시작\")\r\n\r\n    # 해당 테이블의 INSERT 라인만 필터\r\n    table_rdd \u003d insert_rdd.filter(\r\n        lambda line, t\u003dtarget_table: bool(re.match(\r\n            rf\"INSERT\\s+INTO\\s+`?{re.escape(t)}`?\", line.strip(), re.IGNORECASE\r\n        ))\r\n    )\r\n\r\n    # 파싱\r\n    parsed_rdd \u003d table_rdd.mapPartitions(process_partition)\r\n\r\n    # Row 수 확인\r\n    try:\r\n        # 컬럼 구조 확인 (첫 1개 샘플)\r\n        sample \u003d parsed_rdd.take(1)\r\n        if not sample:\r\n            print(f\"  [경고] {target_table}: 파싱 결과 없음. 건너뜀.\")\r\n            results[target_table] \u003d \"SKIPPED (no data)\"\r\n            continue\r\n\r\n        # 컬럼 목록 (샘플에서 추출, _table_name 제외)\r\n        sample_cols \u003d [k for k in sample[0].keys() if k !\u003d \u0027_table_name\u0027]\r\n        print(f\"  컬럼 수   : {len(sample_cols)}\")\r\n        print(f\"  컬럼 목록 : {sample_cols[:10]}{\u0027...\u0027 if len(sample_cols) \u003e 10 else \u0027\u0027}\")\r\n\r\n        # DataFrame 생성 (전체 컬럼 StringType)\r\n        schema_fields \u003d [StructField(c, StringType(), True) for c in sample_cols]\r\n        schema \u003d StructType(schema_fields)\r\n\r\n        def to_row(d, cols\u003dsample_cols):\r\n            return Row(**{c: d.get(c) for c in cols})\r\n\r\n        row_rdd \u003d parsed_rdd.filter(lambda d: d.get(\u0027_table_name\u0027) \u003d\u003d target_table).map(to_row)\r\n        df \u003d spark.createDataFrame(row_rdd, schema\u003dschema)\r\n\r\n        # 파티션 수 동적 설정 (예상 row 수 기반)\r\n        estimated_rows \u003d df.count()\r\n        num_partitions \u003d max(1, estimated_rows // 500_000)\r\n        print(f\"  총 행 수  : {estimated_rows:,}\")\r\n        print(f\"  파티션 수 : {num_partitions}\")\r\n\r\n        # S3 CSV 저장\r\n        output_path \u003d f\"{S3_OUTPUT_PATH}/{target_table}\"\r\n        print(f\"  저장 경로 : {output_path}\")\r\n\r\n        (df\r\n         .repartition(num_partitions)\r\n         .write\r\n         .mode(WRITE_MODE)\r\n         .option(\"header\", \"true\")\r\n         .option(\"quote\", \u0027\"\u0027)\r\n         .option(\"escape\", \u0027\"\u0027)\r\n         .option(\"nullValue\", \"\")\r\n         .option(\"emptyValue\", \"\")\r\n         .csv(output_path))\r\n\r\n        print(f\"  ✅ [{target_table}] CSV 저장 완료 ({estimated_rows:,}건, {num_partitions}파티션)\")\r\n        results[target_table] \u003d f\"SUCCESS ({estimated_rows:,}건)\"\r\n\r\n    except Exception as e:\r\n        print(f\"  ❌ [{target_table}] 실패: {e}\")\r\n        import traceback\r\n        traceback.print_exc()\r\n        results[target_table] \u003d f\"FAILED: {e}\"\r\n\r\n# ── 최종 결과 요약 ───────────────────────────────────────────\r\nprint(\"\\n\" + \"\u003d\"*60)\r\nprint(\"\u003d\u003d\u003d 전체 처리 결과 요약 \u003d\u003d\u003d\")\r\nfor table, status in results.items():\r\n    print(f\"  {table}: {status}\")\r\nprint(\"\u003d\"*60)",
