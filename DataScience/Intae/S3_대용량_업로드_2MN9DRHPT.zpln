    {
      "title": "검증",
      "text": "%spark_high.pyspark\r\n\r\nimport subprocess\r\n\r\nprint(\"\u003d\u003d\u003d 적재 결과 검증 \u003d\u003d\u003d\\n\")\r\n\r\n# ── 1. S3 파일 목록 확인 ─────────────────────────────────────\r\nprint(f\"[1] S3 CSV 파일 목록: {S3_OUTPUT_PATH}\")\r\ntry:\r\n    hadoop_path \u003d sc._jvm.org.apache.hadoop.fs.Path(S3_OUTPUT_PATH)\r\n    fs \u003d hadoop_path.getFileSystem(sc._jsc.hadoopConfiguration())\r\n    statuses \u003d fs.listStatus(hadoop_path)\r\n    total_size \u003d 0\r\n    for s in statuses:\r\n        name \u003d s.getPath().getName()\r\n        size \u003d s.getLen()\r\n        is_dir \u003d s.isDirectory()\r\n        tag \u003d \"[DIR]\" if is_dir else \"[FILE]\"\r\n        total_size +\u003d size\r\n        print(f\"  {tag} {name}  ({size:,} bytes)\")\r\n    print(f\"\\n  총 크기: {total_size / (1024**3):.2f} GB\")\r\nexcept Exception as e:\r\n    print(f\"  ❌ S3 목록 조회 실패: {e}\")\r\n\r\nprint()\r\n\r\n# ── 2. 테이블별 row count + 샘플 확인 ───────────────────────\r\nprint(f\"[2] 테이블별 row count 및 샘플 데이터\")\r\n\r\ntry:\r\n    hadoop_path \u003d sc._jvm.org.apache.hadoop.fs.Path(S3_OUTPUT_PATH)\r\n    fs \u003d hadoop_path.getFileSystem(sc._jsc.hadoopConfiguration())\r\n    table_dirs \u003d [s.getPath().getName()\r\n                  for s in fs.listStatus(hadoop_path)\r\n                  if s.isDirectory()]\r\nexcept Exception as e:\r\n    print(f\"  ❌ 테이블 디렉토리 조회 실패: {e}\")\r\n    table_dirs \u003d []\r\n\r\nfor table_name in table_dirs:\r\n    table_path \u003d f\"{S3_OUTPUT_PATH}/{table_name}\"\r\n    print(f\"\\n  --- [{table_name}] ---\")\r\n    try:\r\n        df \u003d spark.read.option(\"header\", \"true\").csv(table_path)\r\n        row_count \u003d df.count()\r\n        col_count \u003d len(df.columns)\r\n        print(f\"  row count  : {row_count:,}\")\r\n        print(f\"  컬럼 수    : {col_count}\")\r\n        print(f\"  컬럼 목록  : {df.columns[:8]}{\u0027...\u0027 if col_count \u003e 8 else \u0027\u0027}\")\r\n        print(f\"  샘플 데이터 (상위 3건):\")\r\n        df.show(3, truncate\u003d80)\r\n    except Exception as e:\r\n        print(f\"  ❌ [{table_name}] 읽기 실패: {e}\")\r\n\r\nprint()\r\n\r\n# ── 3. NULL 비율 확인 (데이터 품질) ─────────────────────────\r\nprint(f\"[3] NULL 비율 확인 (첫 번째 테이블)\")\r\nif table_dirs:\r\n    first_table \u003d table_dirs[0]\r\n    first_path \u003d f\"{S3_OUTPUT_PATH}/{first_table}\"\r\n    try:\r\n        df \u003d spark.read.option(\"header\", \"true\").csv(first_path)\r\n        total \u003d df.count()\r\n        print(f\"  테이블: {first_table} (총 {total:,}건)\")\r\n        from pyspark.sql import functions as F\r\n        null_counts \u003d df.select([\r\n            F.sum(F.when(F.col(c).isNull(), 1).otherwise(0)).alias(c)\r\n            for c in df.columns[:10]  # 컬럼 수 많을 경우 상위 10개만\r\n        ])\r\n        null_counts.show(truncate\u003dFalse)\r\n    except Exception as e:\r\n        print(f\"  ❌ NULL 확인 실패: {e}\")\r\n\r\nprint()\r\n\r\n# ── 4. INSERT 원본 라인 수 vs 적재 행 수 비교 ────────────────\r\nprint(f\"[4] 원본 INSERT 라인 수 vs 적재 행 수\")\r\ntry:\r\n    insert_rdd \u003d sc.textFile(f\"{S3_INSERT_PATH}/*\")\r\n    insert_line_count \u003d insert_rdd.filter(\r\n        lambda l: l.strip().upper().startswith(\u0027INSERT INTO\u0027)\r\n    ).count()\r\n    print(f\"  INSERT 라인 수: {insert_line_count:,}\")\r\n    print(f\"  (multi-row INSERT의 경우 적재 행 수 \u003e INSERT 라인 수가 정상)\")\r\nexcept Exception as e:\r\n    print(f\"  ❌ 원본 INSERT 라인 수 확인 실패: {e}\")\r\n\r\nprint()\r\nprint(\"\u003d\u003d\u003d 검증 완료 \u003d\u003d\u003d\")",
