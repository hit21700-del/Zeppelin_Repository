    {
      "title": "IMPORT_1",
      "text": "%spark_high.pyspark\r\n\r\nimport os\r\n\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n# [SETUP] 작업 파라미터 — 여기만 수정하면 됨\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n\r\n# 덤프 파일 경로 (원격 dump 서버 기준)\r\nDUMP_FILE_PATH      \u003d \"/home/feda/dump/kmon_dump.sql\"\r\n\r\n# 원격 dump 서버(192.168.0.109) SSH 접속 정보 (시나리오 2에서 사용)\r\n# 비밀번호는 코드에 직접 기재하지 않음 — Zeppelin 환경변수로 주입\r\nREMOTE_HOST         \u003d \"192.168.0.109\"\r\nREMOTE_USER         \u003d \"feda\"\r\nREMOTE_PASSWORD     \u003d \"feda2024!@\u0026\"                   # ← 직접 입력\r\n\r\n# S3 설정\r\nS3_ENDPOINT         \u003d \"http://192.168.0.105:80\"\r\nS3_ACCESS_KEY       \u003d \"8XTYLABJCSLJKUTQBK94\"\r\nS3_SECRET_KEY       \u003d \"fKlCAYQBPEA9JOoyrfhTsIeVXr2j58M8upPCAVVR\"\r\nS3_BUCKET           \u003d \"parquet\"                 # 버킷명\r\nS3_INSERT_PREFIX    \u003d \"kmon_dump/insert_lines\"  # INSERT 추출 중간 결과 경로\r\nS3_OUTPUT_PREFIX    \u003d \"kmon_dump/csv\"           # 최종 CSV 출력 경로\r\n\r\n# 처리 설정\r\nBATCH_SIZE          \u003d 500_000                   # Spark 파티션당 행 수 목표\r\nWRITE_MODE          \u003d \"overwrite\"               # overwrite | append\r\nSHUFFLE_PARTITIONS  \u003d 200                       # spark.sql.shuffle.partitions\r\n\r\n# 편의 경로 조합\r\nS3_INSERT_PATH \u003d f\"s3a://{S3_BUCKET}/{S3_INSERT_PREFIX}\"\r\nS3_OUTPUT_PATH \u003d f\"s3a://{S3_BUCKET}/{S3_OUTPUT_PREFIX}\"\r\n\r\n# ── 설정 확인 출력 (비밀번호는 절대 출력하지 않음) ──────────\r\nprint(\"\u003d\" * 60)\r\nprint(f\"DUMP_FILE_PATH : {DUMP_FILE_PATH}\")\r\nprint(f\"REMOTE_HOST    : {REMOTE_HOST}\")\r\nprint(f\"REMOTE_USER    : {REMOTE_USER}\")\r\nprint(f\"REMOTE_PASSWORD: {\u0027SET\u0027 if REMOTE_PASSWORD else \u0027⚠ NOT SET — 비밀번호를 입력하세요\u0027}\")\r\nprint(f\"S3_ENDPOINT    : {S3_ENDPOINT}\")\r\nprint(f\"S3_INSERT_PATH : {S3_INSERT_PATH}\")\r\nprint(f\"S3_OUTPUT_PATH : {S3_OUTPUT_PATH}\")\r\nprint(f\"WRITE_MODE     : {WRITE_MODE}\")\r\nprint(\"\u003d\" * 60)",
      "user": "anonymous",
