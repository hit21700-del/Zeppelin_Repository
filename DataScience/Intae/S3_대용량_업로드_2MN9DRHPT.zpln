    {
      "title": "IMPORT_3",
      "text": "%spark_high.pyspark\r\n\r\nimport os\r\nimport subprocess\r\n\r\nprint(\"\u003d\u003d\u003d 파일 접근 사전 점검 \u003d\u003d\u003d\")\r\nprint(\"\")\r\n\r\n# ── [시나리오 1] 파일 직접 접근 가능 여부 ────────────────────\r\nif os.path.isfile(DUMP_FILE_PATH):\r\n    print(f\"[시나리오 1] 파일 직접 접근 가능: {DUMP_FILE_PATH}\")\r\n    print(\"\")\r\n\r\n    file_bytes \u003d os.path.getsize(DUMP_FILE_PATH)\r\n    print(f\"파일 크기: {file_bytes / (1024**3):.1f} GB  ({file_bytes:,} bytes)\")\r\n\r\n    print(\"\")\r\n    print(\"--- 파일 상위 50줄 ---\")\r\n    r \u003d subprocess.run([\"head\", \"-n\", \"50\", DUMP_FILE_PATH], capture_output\u003dTrue, text\u003dTrue)\r\n    print(r.stdout)\r\n\r\n    print(\"--- INSERT INTO 라인 샘플 (최초 3건, 최대 300자) ---\")\r\n    r \u003d subprocess.run(\r\n        f\"grep -m 3 -i \u0027^INSERT INTO\u0027 {DUMP_FILE_PATH} | cut -c1-300\",\r\n        shell\u003dTrue, capture_output\u003dTrue, text\u003dTrue\r\n    )\r\n    print(r.stdout if r.stdout else \"  (INSERT INTO 라인 없음)\")\r\n\r\n    print(\"--- 테이블 목록 ---\")\r\n    r \u003d subprocess.run(\r\n        f\"grep -i \u0027^INSERT INTO\u0027 {DUMP_FILE_PATH} | grep -oP \u0027(?\u003c\u003dINSERT INTO )[^\\\\s`(]+\u0027 | sort -u\",\r\n        shell\u003dTrue, capture_output\u003dTrue, text\u003dTrue\r\n    )\r\n    print(r.stdout if r.stdout else \"  (테이블 없음)\")\r\n\r\n    print(\"--- INSERT INTO 전체 카운트는 시간 소요 — 필요 시 별도 실행 ---\")\r\n    print(f\"  grep -c \u0027INSERT INTO\u0027 {DUMP_FILE_PATH}\")\r\n\r\nelse:\r\n    print(f\"[시나리오 2] 파일 직접 접근 불가: {DUMP_FILE_PATH}\")\r\n    print(\"-\u003e P5(시나리오 2) paragraph 사용\")\r\n    print(\"\")\r\n\r\n    if not REMOTE_PASSWORD:\r\n        print(\"REMOTE_PASSWORD 미설정 -\u003e P1에서 비밀번호를 입력하세요\")\r\n    else:\r\n        try:\r\n            import paramiko\r\n            ssh \u003d paramiko.SSHClient()\r\n            ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())\r\n            ssh.connect(REMOTE_HOST, username\u003dREMOTE_USER, password\u003dREMOTE_PASSWORD, timeout\u003d10)\r\n            _, stdout, stderr \u003d ssh.exec_command(f\"ls -lh {DUMP_FILE_PATH}\")\r\n            out \u003d stdout.read().decode()\r\n            err \u003d stderr.read().decode()\r\n            exit_status \u003d stdout.channel.recv_exit_status()\r\n            ssh.close()\r\n            if exit_status \u003d\u003d 0:\r\n                print(f\"SSH 접근 가능: {out.strip()}\")\r\n                print(\"SSH 접근 가능 -\u003e P5 사용\")\r\n            else:\r\n                print(\"SSH 접근 불가\")\r\n                print(err[:500])\r\n                print(\"확인사항: REMOTE_PASSWORD 값, 네트워크, SSH 포트(22)\")\r\n        except Exception as e:\r\n            print(f\"SSH 접근 실패: {e}\")\r\n            print(\"확인사항: REMOTE_PASSWORD 값, 네트워크, SSH 포트(22)\")\r\n\r\nprint(\"\")\r\nprint(\"\u003d\u003d\u003d 점검 완료 \u003d\u003d\u003d\")",
      "user": "anonymous",
      "dateUpdated": "2026-03-17 02:16:07.596",
      "progress": 0,
