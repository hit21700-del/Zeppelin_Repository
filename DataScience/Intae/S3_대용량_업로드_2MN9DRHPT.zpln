m    138\u001b[0m \u001b[38;5;28;01mexcept\u001b[39;00m \u001b[38;5;167;01mOSError\u001b[39;00m:\n\nFile \u001b[0;32m/opt/conda/envs/python_3_with_R/lib/python3.9/tokenize.py:394\u001b[0m, in \u001b[0;36mopen\u001b[0;34m(filename)\u001b[0m\n\u001b[1;32m    392\u001b[0m buffer \u001b[38;5;241m\u003d\u001b[39m _builtin_open(filename, \u001b[38;5;124m\u0027\u001b[39m\u001b[38;5;124mrb\u001b[39m\u001b[38;5;124m\u0027\u001b[39m)\n\u001b[1;32m    393\u001b[0m \u001b[38;5;28;01mtry\u001b[39;00m:\n\u001b[0;32m--\u003e 394\u001b[0m     encoding, lines \u001b[38;5;241m\u003d\u001b[39m \u001b[43mdetect_encoding\u001b[49m\u001b[43m(\u001b[49m\u001b[43mbuffer\u001b[49m\u001b[38;5;241;43m.\u001b[39;49m\u001b[43mreadline\u001b[49m\u001b[43m)\u001b[49m\n\u001b[1;32m    395\u001b[0m     buffer\u001b[38;5;241m.\u001b[39mseek(\u001b[38;5;241m0\u001b[39m)\n\u001b[1;32m    396\u001b[0m     text \u001b[38;5;241m\u003d\u001b[39m TextIOWrapper(buffer, encoding, line_buffering\u001b[38;5;241m\u003d\u001b[39m\u001b[38;5;28;01mTrue\u001b[39;00m)\n\nFile \u001b[0;32m/opt/conda/envs/python_3_with_R/lib/python3.9/tokenize.py:363\u001b[0m, in \u001b[0;36mdetect_encoding\u001b[0;34m(readline)\u001b[0m\n\u001b[1;32m    360\u001b[0m         encoding \u001b[38;5;241m+\u001b[39m\u001b[38;5;241m\u003d\u001b[39m \u001b[38;5;124m\u0027\u001b[39m\u001b[38;5;124m-sig\u001b[39m\u001b[38;5;124m\u0027\u001b[39m\n\u001b[1;32m    361\u001b[0m     \u001b[38;5;28;01mreturn\u001b[39;00m encoding\n\u001b[0;32m--\u003e 363\u001b[0m first \u001b[38;5;241m\u003d\u001b[39m \u001b[43mread_or_stop\u001b[49m\u001b[43m(\u001b[49m\u001b[43m)\u001b[49m\n\u001b[1;32m    364\u001b[0m \u001b[38;5;28;01mif\u001b[39;00m first\u001b[38;5;241m.\u001b[39mstartswith(BOM_UTF8):\n\u001b[1;32m    365\u001b[0m     bom_found \u001b[38;5;241m\u003d\u001b[39m \u001b[38;5;28;01mTrue\u001b[39;00m\n\nFile \u001b[0;32m/opt/conda/envs/python_3_with_R/lib/python3.9/tokenize.py:321\u001b[0m, in \u001b[0;36mdetect_encoding.\u003clocals\u003e.read_or_stop\u001b[0;34m()\u001b[0m\n\u001b[1;32m    319\u001b[0m \u001b[38;5;28;01mdef\u001b[39;00m \u001b[38;5;21mread_or_stop\u001b[39m():\n\u001b[1;32m    320\u001b[0m     \u001b[38;5;28;01mtry\u001b[39;00m:\n\u001b[0;32m--\u003e 321\u001b[0m         \u001b[38;5;28;01mreturn\u001b[39;00m \u001b[43mreadline\u001b[49m\u001b[43m(\u001b[49m\u001b[43m)\u001b[49m\n\u001b[1;32m    322\u001b[0m     \u001b[38;5;28;01mexcept\u001b[39;00m \u001b[38;5;167;01mStopIteration\u001b[39;00m:\n\u001b[1;32m    323\u001b[0m         \u001b[38;5;28;01mreturn\u001b[39;00m \u001b[38;5;124mb\u001b[39m\u001b[38;5;124m\u0027\u001b[39m\u001b[38;5;124m\u0027\u001b[39m\n\n\u001b[0;31mKeyboardInterrupt\u001b[0m: "
