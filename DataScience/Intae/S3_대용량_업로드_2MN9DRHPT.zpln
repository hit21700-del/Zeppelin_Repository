      "title": "시나리오 2 원격 insert 추출",
      "text": "%spark_high.pyspark\r\n\r\n  import paramiko\r\n  import os\r\n\r\n  S3_TARGET \u003d f\"s3://{S3_BUCKET}/{S3_INSERT_PREFIX}/insert_lines_full.sql\"\r\n\r\n  print(\"\u003d\u003d\u003d [시나리오 2] 원격 INSERT 추출 시작 \u003d\u003d\u003d\")\r\n  print(f\"원격 서버  : {REMOTE_USER}@{REMOTE_HOST}\")\r\n  print(f\"덤프 파일  : {DUMP_FILE_PATH}\")\r\n  print(f\"S3 경로    : {S3_TARGET}\")\r\n  print(\"\")\r\n\r\n  # ── SSH 연결 ──────────────────────────────────────────────────\r\n  client \u003d paramiko.SSHClient()\r\n  client.set_missing_host_key_policy(paramiko.AutoAddPolicy())\r\n  client.connect(REMOTE_HOST, username\u003dREMOTE_USER, password\u003dREMOTE_PASSWORD, timeout\u003d30)\r\n  print(\"SSH 연결 성공\")\r\n\r\n  # ── 원격 파일 정보 확인 ──────────────────────────────────────\r\n  _, stdout, _ \u003d client.exec_command(f\"ls -lh {DUMP_FILE_PATH}\")\r\n  print(\"원격 파일 정보:\", stdout.read().decode().strip())\r\n  print(\"\")\r\n\r\n  # ── 원격 서버에서 grep → S3 업로드 ───────────────────────────\r\n  print(\"원격 서버에서 직접 grep → S3 업로드 시작 (수십 분 소요)\")\r\n\r\n#   remote_script \u003d (\r\n#       f\"export AWS_ACCESS_KEY_ID\u003d\u0027{S3_ACCESS_KEY}\u0027 \u0026\u0026 \"\r\n#       f\"export AWS_SECRET_ACCESS_KEY\u003d\u0027{S3_SECRET_KEY}\u0027 \u0026\u0026 \"\r\n#       f\"awk \u0027\"\r\n#       f\"/^INSERT INTO/{{header\u003d$0; sub(/VALUES[[:space:]]*$/, \\\"VALUES\\\", header); next}}\"\r\n#       f\"/^\\\\(/ \u0026\u0026 header{{row\u003d$0; gsub(/[,;][[:space:]]*$/, \\\"\\\", row); print header \\\" \\\" row \\\";\\\"}}\"\r\n#       f\"\u0027 \u0027{DUMP_FILE_PATH}\u0027 | \"\r\n#       f\"aws --endpoint-url \u0027{S3_ENDPOINT}\u0027 --no-verify-ssl \"\r\n#       f\"s3 cp - \u0027{S3_TARGET}\u0027 --expected-size 107374182400 --quiet \u0026\u0026 \"\r\n#       f\"echo UPLOAD_DONE\"\r\n#   )\r\n\r\n#   _, stdout, stderr \u003d client.exec_command(remote_script, timeout\u003d7200)\r\n#   stdout_data \u003d stdout.read().decode()\r\n#   stderr_data \u003d stderr.read().decode()\r\n#   client.close()\r\n  remote_script \u003d (\r\n    f\"nohup bash -c \\\"\"\r\n    f\"export AWS_ACCESS_KEY_ID\u003d\u0027{S3_ACCESS_KEY}\u0027 \u0026\u0026 \"\r\n    f\"export AWS_SECRET_ACCESS_KEY\u003d\u0027{S3_SECRET_KEY}\u0027 \u0026\u0026 \"\r\n    f\"awk \u0027/^INSERT INTO/{{header\u003d$0; sub(/VALUES[[:space:]]*$/, \\\\\\\"VALUES\\\\\\\", header); next}}\"\r\n    f\"/^\\\\(/ \u0026\u0026 header{{row\u003d$0; gsub(/[,;][[:space:]]*$/, \\\\\\\"\\\\\\\", row); print header \\\\\\\" \\\\\\\" row \\\\\\\";\\\\\\\"}}\u0027 \u0027{DUMP_FILE_PATH}\u0027 | \"\r\n    f\"aws --endpoint-url \u0027{S3_ENDPOINT}\u0027 --no-verify-ssl \"\r\n    f\"s3 cp - \u0027{S3_TARGET}\u0027 --expected-size 107374182400 --quiet \u0026\u0026 \"\r\n    f\"touch /tmp/upload_done\"\r\n    f\"\\\" \u003e /tmp/upload.log 2\u003e\u00261 \u0026\"\r\n  )\r\n\r\n  _, stdout, _ \u003d client.exec_command(remote_script)\r\n  stdout.channel.recv_exit_status()\r\n  print(\"백그라운드 실행 시작됨. 완료 확인은 아래 셀로 폴링\")\r\n  client.close()\r\n\r\n  if \"UPLOAD_DONE\" in stdout_data:\r\n      print(\"S3 업로드 완료\")\r\n  else:\r\n      print(f\"업로드 실패\")\r\n      print(stdout_data[:500])\r\n      if stderr_data.strip():\r\n          print(stderr_data[:500])\r\n\r\n  print(\"\")\r\n  print(\"\u003d\u003d\u003d 작업 완료 -\u003e P6(Spark 파싱) paragraph로 이동 \u003d\u003d\u003d\")",
