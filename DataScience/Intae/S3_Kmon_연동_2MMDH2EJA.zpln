    {
      "title": "[v13] MySQL-\u003eParquet 1억건 (indate predicates 병렬읽기)",
      "text": "%spark_high.pyspark\n\n# [v13] MySQL-\u003eParquet 1억건 (indate weekly predicates 병렬 읽기)\n# OOM 해결: repartition 없이 MySQL에서 58개 JDBC connection으로 병렬 읽기\n# indate 인덱스(BTREE standalone) 활용 -\u003e 각 파티션 약 200만건\n\nS3_PATH_PARQ \u003d \"s3a://bigdata/kmon/parquet\"\n\nJDBC_URL_V13 \u003d (\n    \"jdbc:mysql://\" + MYSQL_HOST + \":\" + MYSQL_PORT + \"/\" + MYSQL_DB\n    + \"?useSSL\u003dfalse\u0026allowPublicKeyRetrieval\u003dtrue\"\n)\n\nprops \u003d {\n    \"user\":     MYSQL_USER,\n    \"password\": MYSQL_PASSWORD,\n    \"driver\":   \"com.mysql.cj.jdbc.Driver\",\n    \"fetchsize\": \"10000\",\n}\n\npredicates \u003d [\n    \"indate \u003e\u003d \u00272024-09-01\u0027 AND indate \u003c \u00272024-09-08\u0027\",\n    \"indate \u003e\u003d \u00272024-09-08\u0027 AND indate \u003c \u00272024-09-15\u0027\",\n    \"indate \u003e\u003d \u00272024-09-15\u0027 AND indate \u003c \u00272024-09-22\u0027\",\n    \"indate \u003e\u003d \u00272024-09-22\u0027 AND indate \u003c \u00272024-09-29\u0027\",\n    \"indate \u003e\u003d \u00272024-09-29\u0027 AND indate \u003c \u00272024-10-06\u0027\",\n    \"indate \u003e\u003d \u00272024-10-06\u0027 AND indate \u003c \u00272024-10-13\u0027\",\n    \"indate \u003e\u003d \u00272024-10-13\u0027 AND indate \u003c \u00272024-10-20\u0027\",\n    \"indate \u003e\u003d \u00272024-10-20\u0027 AND indate \u003c \u00272024-10-27\u0027\",\n    \"indate \u003e\u003d \u00272024-10-27\u0027 AND indate \u003c \u00272024-11-03\u0027\",\n    \"indate \u003e\u003d \u00272024-11-03\u0027 AND indate \u003c \u00272024-11-10\u0027\",\n    \"indate \u003e\u003d \u00272024-11-10\u0027 AND indate \u003c \u00272024-11-17\u0027\",\n    \"indate \u003e\u003d \u00272024-11-17\u0027 AND indate \u003c \u00272024-11-24\u0027\",\n    \"indate \u003e\u003d \u00272024-11-24\u0027 AND indate \u003c \u00272024-12-01\u0027\",\n    \"indate \u003e\u003d \u00272024-12-01\u0027 AND indate \u003c \u00272024-12-08\u0027\",\n    \"indate \u003e\u003d \u00272024-12-08\u0027 AND indate \u003c \u00272024-12-15\u0027\",\n    \"indate \u003e\u003d \u00272024-12-15\u0027 AND indate \u003c \u00272024-12-22\u0027\",\n    \"indate \u003e\u003d \u00272024-12-22\u0027 AND indate \u003c \u00272024-12-29\u0027\",\n    \"indate \u003e\u003d \u00272024-12-29\u0027 AND indate \u003c \u00272025-01-05\u0027\",\n    \"indate \u003e\u003d \u00272025-01-05\u0027 AND indate \u003c \u00272025-01-12\u0027\",\n    \"indate \u003e\u003d \u00272025-01-12\u0027 AND indate \u003c \u00272025-01-19\u0027\",\n    \"indate \u003e\u003d \u00272025-01-19\u0027 AND indate \u003c \u00272025-01-26\u0027\",\n    \"indate \u003e\u003d \u00272025-01-26\u0027 AND indate \u003c \u00272025-02-02\u0027\",\n    \"indate \u003e\u003d \u00272025-02-02\u0027 AND indate \u003c \u00272025-02-09\u0027\",\n    \"indate \u003e\u003d \u00272025-02-09\u0027 AND indate \u003c \u00272025-02-16\u0027\",\n    \"indate \u003e\u003d \u00272025-02-16\u0027 AND indate \u003c \u00272025-02-23\u0027\",\n    \"indate \u003e\u003d \u00272025-02-23\u0027 AND indate \u003c \u00272025-03-02\u0027\",\n    \"indate \u003e\u003d \u00272025-03-02\u0027 AND indate \u003c \u00272025-03-09\u0027\",\n    \"indate \u003e\u003d \u00272025-03-09\u0027 AND indate \u003c \u00272025-03-16\u0027\",\n    \"indate \u003e\u003d \u00272025-03-16\u0027 AND indate \u003c \u00272025-03-23\u0027\",\n    \"indate \u003e\u003d \u00272025-03-23\u0027 AND indate \u003c \u00272025-03-30\u0027\",\n    \"indate \u003e\u003d \u00272025-03-30\u0027 AND indate \u003c \u00272025-04-06\u0027\",\n    \"indate \u003e\u003d \u00272025-04-06\u0027 AND indate \u003c \u00272025-04-13\u0027\",\n    \"indate \u003e\u003d \u00272025-04-13\u0027 AND indate \u003c \u00272025-04-20\u0027\",\n    \"indate \u003e\u003d \u00272025-04-20\u0027 AND indate \u003c \u00272025-04-27\u0027\",\n    \"indate \u003e\u003d \u00272025-04-27\u0027 AND indate \u003c \u00272025-05-04\u0027\",\n    \"indate \u003e\u003d \u00272025-05-04\u0027 AND indate \u003c \u00272025-05-11\u0027\",\n    \"indate \u003e\u003d \u00272025-05-11\u0027 AND indate \u003c \u00272025-05-18\u0027\",\n    \"indate \u003e\u003d \u00272025-05-18\u0027 AND indate \u003c \u00272025-05-25\u0027\",\n    \"indate \u003e\u003d \u00272025-05-25\u0027 AND indate \u003c \u00272025-06-01\u0027\",\n    \"indate \u003e\u003d \u00272025-06-01\u0027 AND indate \u003c \u00272025-06-08\u0027\",\n    \"indate \u003e\u003d \u00272025-06-08\u0027 AND indate \u003c \u00272025-06-15\u0027\",\n    \"indate \u003e\u003d \u00272025-06-15\u0027 AND indate \u003c \u00272025-06-22\u0027\",\n    \"indate \u003e\u003d \u00272025-06-22\u0027 AND indate \u003c \u00272025-06-29\u0027\",\n    \"indate \u003e\u003d \u00272025-06-29\u0027 AND indate \u003c \u00272025-07-06\u0027\",\n    \"indate \u003e\u003d \u00272025-07-06\u0027 AND indate \u003c \u00272025-07-13\u0027\",\n    \"indate \u003e\u003d \u00272025-07-13\u0027 AND indate \u003c \u00272025-07-20\u0027\",\n    \"indate \u003e\u003d \u00272025-07-20\u0027 AND indate \u003c \u00272025-07-27\u0027\",\n    \"indate \u003e\u003d \u00272025-07-27\u0027 AND indate \u003c \u00272025-08-03\u0027\",\n    \"indate \u003e\u003d \u00272025-08-03\u0027 AND indate \u003c \u00272025-08-10\u0027\",\n    \"indate \u003e\u003d \u00272025-08-10\u0027 AND indate \u003c \u00272025-08-17\u0027\",\n    \"indate \u003e\u003d \u00272025-08-17\u0027 AND indate \u003c \u00272025-08-24\u0027\",\n    \"indate \u003e\u003d \u00272025-08-24\u0027 AND indate \u003c \u00272025-08-31\u0027\",\n    \"indate \u003e\u003d \u00272025-08-31\u0027 AND indate \u003c \u00272025-09-07\u0027\",\n    \"indate \u003e\u003d \u00272025-09-07\u0027 AND indate \u003c \u00272025-09-14\u0027\",\n    \"indate \u003e\u003d \u00272025-09-14\u0027 AND indate \u003c \u00272025-09-21\u0027\",\n    \"indate \u003e\u003d \u00272025-09-21\u0027 AND indate \u003c \u00272025-09-28\u0027\",\n    \"indate \u003e\u003d \u00272025-09-28\u0027 AND indate \u003c \u00272025-10-04\u0027\",\n    \"indate IS NULL\",\n]\n\nprint(\"predicates 수: \" + str(len(predicates)))\nprint(\"MySQL 1억건 병렬 읽기 시작 (indate 인덱스)...\")\ndf \u003d spark.read.jdbc(\n    url\u003dJDBC_URL_V13,\n    table\u003d\"kmon\",\n    predicates\u003dpredicates,\n    properties\u003dprops\n)\n\nprint(\"Spark 파티션 수: \" + str(df.rdd.getNumPartitions()))\nprint(\"Parquet 저장 시작 -\u003e \" + S3_PATH_PARQ)\ndf.write.mode(\"overwrite\")     .option(\"compression\", \"snappy\")     .option(\"maxRecordsPerFile\", \"2000000\")     .parquet(S3_PATH_PARQ)\n\nparq \u003d spark.read.parquet(S3_PATH_PARQ)\nsaved \u003d parq.count()\nprint(\"저장 건수: \" + str(saved))\nprint(\"저장 컬럼: \" + str(len(parq.columns)))\nprint(\"완료 -\u003e \" + S3_PATH_PARQ)\n",
      "user": "anonymous",
      "dateUpdated": "2026-03-23 22:11:22.684",
      "progress": 90,
