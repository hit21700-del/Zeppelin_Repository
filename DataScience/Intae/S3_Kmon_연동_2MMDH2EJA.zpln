      "title": "[v12] 검증 (kmon 1억건)",
      "text": "%spark_high.pyspark\nS3_PATH_PARQ \u003d \"s3a://bigdata/kmon/parquet\"\nS3_PATH_CSV  \u003d \"s3a://bigdata/kmon/csv\"\nparq_df \u003d spark.read.parquet(S3_PATH_PARQ)\ncsv_df  \u003d spark.read.option(\"header\",\"true\").csv(S3_PATH_CSV)\nparq_count \u003d parq_df.count()\ncsv_count  \u003d csv_df.count()\nhadoop_conf \u003d spark._jsc.hadoopConfiguration()\nfs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jvm.java.net.URI(\"s3a://bigdata\"), hadoop_conf)\ndef s3_gb(path):\n    p \u003d spark._jvm.org.apache.hadoop.fs.Path(path)\n    return round(fs.getContentSummary(p).getLength() / 1024**3, 2)\nprint(\"\u003d\" * 60)\nprint(\"   최종 검증 (kmon, 1억건)\")\nprint(\"\u003d\" * 60)\nprint(\"Parquet | 건수: \" + str(parq_count) + \" | \" + str(s3_gb(S3_PATH_PARQ)) + \" GB\")\nprint(\"CSV     | 건수: \" + str(csv_count)  + \" | \" + str(s3_gb(S3_PATH_CSV))  + \" GB\")\nprint(\"\u003d\" * 60)\nif parq_count \u003d\u003d csv_count:\n    print(\"OK: \" + str(parq_count) + \"건 일치\")\nelse:\n    print(\"NG 불일치: Parquet\u003d\" + str(parq_count) + \" CSV\u003d\" + str(csv_count))\n",
      "user": "anonymous",
      "dateUpdated": "2026-03-23 22:11:18.984",
      "progress": 98,
      "config": {
