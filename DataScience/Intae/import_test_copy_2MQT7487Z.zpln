    {
      "title": "",
      "text": "%python\r\nimport subprocess\r\n\r\ntest_imports \u003d [\r\n    (\"numpy\", \"import numpy as np; print(np.__version__)\"),\r\n    (\"pandas\", \"import pandas as pd; print(pd.__version__)\"),\r\n    (\"scikit-learn\", \"import sklearn; print(sklearn.__version__)\"),\r\n    (\"xgboost\", \"import xgboost as xgb; print(xgb.__version__)\"),\r\n    (\"lightgbm\", \"import lightgbm as lgb; print(lgb.__version__)\"),\r\n    (\"tensorflow\", \"import tensorflow as tf; print(tf.__version__)\"),\r\n    (\"keras\", \"import keras; print(keras.__version__)\"),\r\n    (\"mlflow\", \"import mlflow; print(mlflow.__version__)\"),\r\n    (\"matplotlib\", \"import matplotlib; print(matplotlib.__version__)\"),\r\n    (\"scipy\", \"import scipy; print(scipy.__version__)\"),\r\n    (\"statsmodels\", \"import statsmodels; print(statsmodels.__version__)\"),\r\n    (\"polars\", \"import polars as pl; print(pl.__version__)\"),\r\n    (\"pyarrow\", \"import pyarrow as pa; print(pa.__version__)\"),\r\n    (\"s3fs\", \"import s3fs; print(s3fs.__version__)\"),\r\n]\r\n\r\npython_bin \u003d \u0027/opt/zeppelin/packages/miniforge3/envs/ai/bin/python\u0027\r\n\r\nfor name, code in test_imports:\r\n    result \u003d subprocess.run(\r\n        [python_bin, \u0027-c\u0027, code],\r\n        capture_output\u003dTrue, text\u003dTrue\r\n    )\r\n    if result.returncode \u003d\u003d 0:\r\n        print(f\"✅ {name}: {result.stdout.strip()}\")\r\n    else:\r\n        print(f\"❌ {name}: {result.stderr.strip()[:80]}\")",
