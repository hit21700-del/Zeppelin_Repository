    {
      "title": "",
      "text": "%python\r\nimport importlib\r\n\r\nchecks \u003d [\r\n    (\"tensorflow\",   \"tf\",          \"2.19.1\"),\r\n    (\"keras\",        \"keras\",       \"3.\"),\r\n    (\"numba\",        \"numba\",       \"0.63.1\"),\r\n    (\"numpy\",        \"np\",          \"2.1.3\"),   \r\n    (\"pandas\",       \"pd\",          \"2.2.3\"),   \r\n    (\"scipy\",        \"scipy\",       \"1.16.3\"),\r\n    (\"sklearn\",      \"sklearn\",     \"1.8.0\"),\r\n    (\"xgboost\",      \"xgboost\",     \"3.2.0\"),\r\n    (\"lightgbm\",     \"lightgbm\",    \"4.6.0\"),\r\n    (\"statsmodels\",  \"statsmodels\", \"0.14.6\"),\r\n    (\"mlflow\",       \"mlflow\",      \"3.10.1\"),  \r\n    (\"matplotlib\",   \"matplotlib\",  \"3.10.8\"),\r\n    (\"seaborn\",      \"seaborn\",     \"0.13.2\"),\r\n    (\"pybamm\",       \"pybamm\",      \"25.12.2\"),\r\n    (\"casadi\",       \"casadi\",      \"3.6.7\"),\r\n    (\"polars\",       \"polars\",      None),\r\n    (\"pyarrow\",      \"pyarrow\",     None),\r\n    (\"s3fs\",         \"s3fs\",        None),\r\n    (\"sqlalchemy\",   \"sqlalchemy\",  None),\r\n]\r\n\r\nprint(\"\u003d\" * 55)\r\nprint(f\"{\u0027패키지\u0027:\u003c15} {\u0027설치버전\u0027:\u003c15} {\u0027기대버전\u0027:\u003c15} {\u0027상태\u0027}\")\r\nprint(\"\u003d\" * 55)\r\n\r\nfor pkg, alias, expected in checks:\r\n    try:\r\n        mod \u003d importlib.import_module(pkg)\r\n        ver \u003d getattr(mod, \u0027__version__\u0027, \u0027unknown\u0027)\r\n        if expected:\r\n            ok \u003d \"✅\" if ver.startswith(expected.rstrip(\u0027.\u0027)) else \"⚠️ 버전 불일치\"\r\n        else:\r\n            ok \u003d \"✅\"\r\n        print(f\"{pkg:\u003c15} {ver:\u003c15} {expected or \u0027any\u0027:\u003c15} {ok}\")\r\n    except ImportError as e:\r\n        print(f\"{pkg:\u003c15} {\u0027없음\u0027:\u003c15} {expected or \u0027any\u0027:\u003c15} ❌ MISSING\")\r\n\r\nprint(\"\u003d\" * 55)\r\n\r\n# Keras 레이어 로드\r\nprint(\"\\n[Keras 레이어]\")\r\ntry:\r\n    from keras.layers import Input, GRU, Dense, Dropout\r\n    from keras.layers import RepeatVector, TimeDistributed\r\n    from keras.layers import Multiply, Concatenate, Lambda\r\n    from keras.layers import Embedding, Flatten\r\n    from keras.callbacks import EarlyStopping\r\n    print(\"✅ Keras layers: OK\")\r\nexcept Exception as e:\r\n    print(f\"❌ Keras layers: {e}\")\r\n\r\n# Numba JIT\r\nprint(\"\\n[Numba JIT]\")\r\ntry:\r\n    import numpy as np\r\n    from numba import jit\r\n\r\n    @jit(nopython\u003dTrue)\r\n    def test_jit(x): return x * 2.0\r\n\r\n    result \u003d test_jit(np.array([1.0, 2.0]))\r\n    print(f\"✅ Numba JIT: {result}\")\r\nexcept Exception as e:\r\n    print(f\"❌ Numba JIT: {e}\")\r\n\r\n# PyBaMM SPM 모델\r\nprint(\"\\n[PyBaMM]\")\r\ntry:\r\n    import pybamm\r\n    model \u003d pybamm.lithium_ion.SPM()\r\n    print(\"✅ PyBaMM SPM model: OK\")\r\nexcept Exception as e:\r\n    print(f\"❌ PyBaMM: {e}\")\r\n\r\n# Matplotlib Agg 백엔드\r\nprint(\"\\n[Matplotlib Agg 백엔드]\")\r\ntry:\r\n    import matplotlib\r\n    matplotlib.use(\u0027Agg\u0027)\r\n    import matplotlib.pyplot as plt\r\n    print(f\"✅ Agg 백엔드: {matplotlib.get_backend()}\")\r\nexcept Exception as e:\r\n    print(f\"❌ Matplotlib Agg: {e}\")\r\n\r\n# sklearn 주요 모듈\r\nprint(\"\\n[sklearn 모듈]\")\r\ntry:\r\n    from sklearn.preprocessing import StandardScaler\r\n    from sklearn.ensemble import IsolationForest\r\n    from sklearn.metrics import roc_auc_score\r\n    print(\"✅ StandardScaler, IsolationForest, roc_auc_score: OK\")\r\nexcept Exception as e:\r\n    print(f\"❌ sklearn 모듈: {e}\")",
      "user": "anonymous",
