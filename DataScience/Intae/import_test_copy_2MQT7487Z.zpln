    {
      "title": "",
      "text": "%python\r\nimport tensorflow as tf\r\nimport keras\r\nimport numba\r\nimport numpy as np\r\nimport pandas as pd\r\nimport scipy\r\nimport sklearn\r\nimport xgboost\r\nimport lightgbm\r\nimport statsmodels\r\nimport matplotlib\r\nimport seaborn\r\nimport mlflow\r\nimport pybamm\r\nimport gc, os, glob\r\n\r\nprint(\u0027TF:         \u0027, tf.__version__)        # 2.19.1\r\nprint(\u0027Keras:      \u0027, keras.__version__)     # 3.x\r\nprint(\u0027Numba:      \u0027, numba.__version__)     # 0.63.1\r\nprint(\u0027NumPy:      \u0027, np.__version__)        # 2.2.6\r\nprint(\u0027Pandas:     \u0027, pd.__version__)        # 3.0.1\r\nprint(\u0027SciPy:      \u0027, scipy.__version__)     # 1.16.3\r\nprint(\u0027sklearn:    \u0027, sklearn.__version__)   # 1.8.0\r\nprint(\u0027XGBoost:    \u0027, xgboost.__version__)   # 3.2\r\nprint(\u0027LightGBM:   \u0027, lightgbm.__version__)  # 4.6\r\nprint(\u0027Statsmodels:\u0027, statsmodels.__version__) # 0.14.6\r\nprint(\u0027MLflow:     \u0027, mlflow.__version__)    # \u003e\u003d 3.4\r\nprint(\u0027PyBaMM:     \u0027, pybamm.__version__)    # 25.12.2\r\n\r\n# GPU 확인 (GPU 환경 한정)\r\nprint(\u0027GPU:\u0027, tf.config.list_physical_devices(\u0027GPU\u0027))\r\n\r\n# Keras 레이어 로드 확인\r\nfrom keras.layers import Input, GRU, Dense, Dropout\r\nfrom keras.layers import RepeatVector, TimeDistributed\r\nfrom keras.layers import Multiply, Concatenate, Lambda\r\nfrom keras.layers import Embedding, Flatten\r\nfrom keras.callbacks import EarlyStopping\r\nprint(\u0027Keras layers: OK\u0027)\r\n\r\n# Numba JIT 동작 확인\r\nfrom numba import jit\r\n\r\n@jit(nopython\u003dTrue)\r\ndef test_jit(x): return x * 2.0\r\nprint(\u0027Numba JIT:\u0027, test_jit(np.array([1.0, 2.0])))\r\n\r\n# PyBaMM 기본 동작 확인\r\nmodel \u003d pybamm.lithium_ion.SPM()\r\nprint(\u0027PyBaMM SPM model: OK\u0027)",
