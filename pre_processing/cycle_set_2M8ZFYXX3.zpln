    {
      "text": "%spark.pyspark\r\n\r\nimport os\r\nimport sys\r\n#sys.path.append(\"/home/kadap/python/pre_processing\") # 이전 테스트 경로\r\nsys.path.append(\"/home/kadap/QH/Pre_Processed\")\r\nimport logging\r\nfrom datetime import datetime\r\nfrom typing import Optional, List, Dict, Any\r\nfrom pyspark.sql import functions as F\r\nfrom pyspark.sql import SparkSession, DataFrame\r\nfrom pyspark.sql.functions import (\r\n    col, lit, when, count, sum, min, max, avg, \r\n    to_timestamp, unix_timestamp, from_unixtime,\r\n    date_format, hour, minute, second, \r\n    lag, lead, window, expr, round, row_number, \r\n    dense_rank, last, coalesce, concat, abs, first, length, substring,Tuple,filter\r\n)\r\n\r\nfrom pyspark.sql.window import Window\r\nfrom pyspark.sql.types import (\r\n    StructType, StructField, StringType, IntegerType, \r\n    DoubleType, TimestampType, BooleanType\r\n)\r\n\r\nfrom kslab_config import CYCLE_IO_CONFIG, DB_QUERY_PP_DATA, DB_QUERY_CYCLE_CC_DATA, PP_IO_CONFIG,PROCESSING_PARAMS, PARQUET_CYCLE_PATH\r\nfrom kslab_utils import (\r\n    print_timestamp, print_dfcount, create_spark_session,\r\n    load_data_from_db, load_data_from_csv, save_to_csv, save_to_db,\r\n    load_data_from_parquet,save_to_parquet, load_pp_for_cycle\r\n)\r\nfrom kslab_cycle_func import(\r\n    convert_cycle_data,filter_cycle,add_charge_cycle,\r\n    merge_cycle,aggregate_post_merge,add_cycle_metric,add_cycle_cnt,select_cycle_cols,logger, get_last_processed_start_date\r\n    )\r\n",
