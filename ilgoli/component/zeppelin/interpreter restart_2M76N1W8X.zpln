      "text": "import json\n\nimport os\ninput \u003d z.input(\u0027node_nm\u0027)\n#value \u003d z.input(\u0027value\u0027)\nconfigValue \u003d z.input(\u0027data_info\u0027)\ninput3 \u003d z.input(\u0027table_info\u0027)\n\nbeforeHdfsPath \u003d z.input(\u0027before_hdfs_path\u0027)\nschemaPath \u003d z.input(\u0027schema_path\u0027)\nhdfsPath \u003d z.input(\u0027hdfs_path\u0027)\n\n#value \u003d value.replace(\"\u0027\", \u0027\"\u0027)\nconfigValue \u003d configValue.replace(\"\u0027\", \u0027\"\u0027)\n\nconfigData \u003d json.loads(configValue)\n#valueJson \u003d json.loads(value)\n\n# 테스트 코드(임시)\n\nbeforeSchemaPath \u003d z.input(\u0027beforeSchemaPath\u0027)\nbeforeHdfsPath \u003d z.input(\u0027beforeHdfsPath\u0027)\n\ndockerBasePath \u003d \u0027/opt/zeppelin/result/\u0027\nif beforeHdfsPath.strip() !\u003d \"\":\n    csv_path \u003d \u0027/opt/zeppelin/result/\u0027 + beforeHdfsPath.replace(\"\\\\\", \"/\") + \"/result.csv\"\n    print(\"CSV 파일 경로:\", csv_path)\n    \n    if os.path.exists(csv_path):\n        inputDf \u003d pd.read_csv(csv_path)\n        print(\"Read DataFrame from:\", csv_path)\n        print(inputDf)\n    else:\n        print(\"result.csv 파일을 찾을 수 없습니다:\", csv_path)",
