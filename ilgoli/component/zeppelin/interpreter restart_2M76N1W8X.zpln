      "text": "\nimport requests\n\nzeppelin_host \u003d \u0027http://host.docker.internal:18085\u0027  \n\nurl \u003d f\"{zeppelin_host}/api/interpreter/setting/restart/{configData[\u0027interpreterId\u0027]}\"\n\n# 요청 페이로드: 인터프리터 ID를 지정\npayload \u003d {\n    \"noteId\": configData[\u0027noteId\u0027]\n}\n\nheaders \u003d {\n    \"Content-Type\": \"application/json\"\n}\n\n# POST 요청 전송\nresponse \u003d requests.put(url, json\u003dpayload, headers\u003dheaders)\n\n# 결과 출력\nif response.ok:\n    print(\"인터프리터 초기화 성공:\")\n    print(response.json())\nelse:\n    print(\"인터프리터 초기화 실패:\")\n    print(response.status_code, response.text)\n",
