    {
      "text": "%spark_single.pyspark\r\n\"\"\"\r\nSOH Forecast Preprocess (Bulk Version) : 통합 데이터를 읽어 모델링용 데이터셋 생성\r\n\r\n- 입력: Step 2 결과 (soh_summary_result_all.csv)\r\n- 처리:\r\n    1. \u0027일(day)\u0027 단위로 데이터 재집계 (summary_by_day) - 차량별 그룹핑\r\n    2. 학습/테스트 분리 플래그(train_flag) 추가 - 차량별 시계열 기준 80% Train\r\n- 출력: HDFS에 단일 Parquet 파일 (forecast_preprocessed_all.parquet) 저장\r\n\"\"\"\r\n\r\nimport os\r\nimport sys\r\nfrom typing import Optional\r\nimport logging\r\nfrom datetime import datetime\r\n\r\n# Spark 관련 모듈\r\nfrom pyspark.sql import SparkSession, DataFrame\r\nfrom pyspark.sql.functions import (\r\n    col, expr, round as pyspark_round, max as pyspark_max, avg as pyspark_avg,\r\n    count, lit, date_format, split, transform, row_number, concat_ws, regexp_replace\r\n)\r\nfrom pyspark.sql import functions as F\r\nfrom pyspark.sql.window import Window\r\nfrom pyspark.sql.types import StructType, DoubleType\r\n\r\n# 로깅 설정\r\nlogging.basicConfig(\r\n    level\u003dlogging.INFO,\r\n    format\u003d\u0027%(asctime)s - %(levelname)s - %(message)s\u0027\r\n)\r\nlogger \u003d logging.getLogger(__name__)\r\n\r\n# ####################################################################\r\n# ## --- 1. Configuration (Bulk) ---\r\n# ####################################################################\r\n\r\nVEHICLE_ID \u003d \"ALL\"\r\n\r\n# 3단계(Forecast Preprocess) I/O 설정 (HDFS)\r\nSOH_FORECAST_PREPROCESS_IO_CONFIG \u003d {\r\n    \u0027input\u0027: {\r\n        \u0027source\u0027: \u0027csv\u0027,\r\n        # [수정] Step 2에서 생성한 통합 파일 경로\r\n        \u0027csv_path\u0027: z.input(\"auto_base_path\") + \"/soh_summary_result_all.csv\"\r\n    },\r\n    \u0027output\u0027: {\r\n        \u0027format\u0027: \u0027parquet\u0027,\r\n        # [수정] 결과 파일명도 통합된 이름으로 변경\r\n        \u0027parquet_path\u0027: z.input(\"parquet_glob\") + \"/intermediate/forecast_preprocessed_all.parquet\"\r\n    }\r\n}\r\n\r\n# [체크] 이미 생성된 글로벌 모델이 있는지 확인할 경로\r\nGLOBAL_MODEL_CHECK_PATH \u003d z.input(\"parquet_glob\") + \"/models/xgb_model/model_global.pkl\"\r\n\r\n\r\n# ####################################################################\r\n# ## --- 2. Utility Functions ---\r\n# ####################################################################\r\n\r\ndef print_timestamp(message: str) -\u003e None:\r\n    \"\"\"Print message with current timestamp\"\"\"\r\n    print(f\"[{datetime.now().strftime(\u0027%Y-%m-%d %H:%M:%S\u0027)}] {message}\")\r\n\r\ndef print_dfcount(df: DataFrame, message: str) -\u003e None:\r\n    \"\"\"Print DataFrame count with message\"\"\"\r\n    count \u003d df.count()\r\n    print_timestamp(f\"{message}: {count:,} rows\")\r\n\r\ndef load_data_from_csv(spark: SparkSession, file_path: str) -\u003e DataFrame:\r\n    \"\"\"Load data from a HDFS CSV file.\"\"\"\r\n    print_timestamp(f\"Loading data from HDFS CSV: {file_path}\")\r\n    try:\r\n        # 통합 파일이므로 직접 읽음\r\n        df \u003d spark.read.csv(file_path, header\u003dTrue, inferSchema\u003dTrue)\r\n        return df\r\n    except Exception as e:\r\n        print_timestamp(f\"[ERROR] Failed to read HDFS CSV file: {file_path}\")\r\n        print(e)\r\n        return spark.createDataFrame([], schema\u003dStructType([]))\r\n\r\ndef save_to_parquet(df: DataFrame, output_path: str) -\u003e str:\r\n    \"\"\"\r\n    Spark DataFrame을 HDFS에 *단일* Parquet 파일로 저장합니다.\r\n    \"\"\"\r\n    print_timestamp(f\"Saving data to HDFS *single file*: {output_path}\")\r\n\r\n    import os\r\n    base_dir \u003d os.path.dirname(output_path)\r\n    temp_dir \u003d os.path.join(base_dir, \".temp_parquet_save_dir_all\") \r\n    \r\n    print_timestamp(f\"Using temporary save directory: {temp_dir}\")\r\n\r\n    try:\r\n        (df.coalesce(1)\r\n           .write\r\n           .option(\"compression\", \"snappy\")\r\n           .mode(\"overwrite\")\r\n           .parquet(temp_dir))\r\n\r\n        fs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jsc.hadoopConfiguration())\r\n        \r\n        part_file_pattern \u003d spark._jvm.org.apache.hadoop.fs.Path(f\"{temp_dir}/part-*.snappy.parquet\")\r\n        file_list_status \u003d fs.globStatus(part_file_pattern)\r\n\r\n        if not file_list_status:\r\n            # Snappy가 아닐 경우 대비\r\n            part_file_pattern_generic \u003d spark._jvm.org.apache.hadoop.fs.Path(f\"{temp_dir}/part-*.parquet\")\r\n            file_list_status \u003d fs.globStatus(part_file_pattern_generic)\r\n            if not file_list_status:\r\n                 raise Exception(f\"No \u0027part-\u0027 file found in temp directory: {temp_dir}\")\r\n        \r\n        source_file_path \u003d file_list_status[0].getPath()\r\n        print_timestamp(f\"Found temporary data file: {source_file_path}\")\r\n\r\n        dest_file_path \u003d spark._jvm.org.apache.hadoop.fs.Path(output_path)\r\n\r\n        print_timestamp(f\"Checking for existing file and deleting if present: {output_path}\")\r\n        if fs.exists(dest_file_path):\r\n            fs.delete(dest_file_path, False)\r\n            print_timestamp(\"Existing file deleted.\")\r\n\r\n        print_timestamp(f\"Moving file to final destination: {output_path}\")\r\n        fs.rename(source_file_path, dest_file_path)\r\n        \r\n        print_timestamp(f\"Cleaning up temporary directory: {temp_dir}\")\r\n        fs.delete(spark._jvm.org.apache.hadoop.fs.Path(temp_dir), True)\r\n\r\n        print_timestamp(f\"Successfully saved to single HDFS Parquet file: {output_path}\")\r\n        \r\n    except Exception as e:\r\n        print_timestamp(f\"[ERROR] Failed to save to single HDFS Parquet file: {output_path}\")\r\n        print(e)\r\n        try:\r\n            fs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jsc.hadoopConfiguration())\r\n            fs.delete(spark._jvm.org.apache.hadoop.fs.Path(temp_dir), True)\r\n            print_timestamp(\"Cleaned up temporary directory after error.\")\r\n        except:\r\n            pass\r\n        raise\r\n        \r\n    return output_path\r\n\r\n\r\n# ####################################################################\r\n# ## --- 3. Core SOH Forecast Preprocess Logic (Bulk) ---\r\n# ####################################################################\r\n\r\ndef summary_by_day(df):\r\n    \"\"\"\r\n    \u0027시퀀스(ch_seq)\u0027별 데이터를 \u0027일(day)\u0027 단위로 재집계.\r\n    Bulk 처리이므로 vehicle_id를 그룹 키에 포함해야 함.\r\n    \"\"\"\r\n    \r\n    # 이상치 필터링\r\n    df \u003d df.filter((col(\"delta_soc\") \u003e\u003d 5) \u0026 (col(\"c_rate\") \u003e 0) \u0026 (col(\"c_rate\") \u003c 2.0))\r\n    \r\n    # Group By에 vehicle_id 포함\r\n    df_agg \u003d df.groupBy(\"vehicle_id\", \"day_of_soh\").agg(\r\n        pyspark_round(pyspark_avg(\"mileage\"), 2).alias(\"mileage\"),\r\n        pyspark_round(pyspark_max(\"acc_cycle_cnt\"), 0).alias(\"acc_cycle_cnt\"),\r\n        pyspark_round(pyspark_avg(\"avg_bat_temp\"), 1).alias(\"avg_bat_temp\"),\r\n        pyspark_round(pyspark_max(\"cvdiff\"), 3).alias(\"cvdiff\"),\r\n        pyspark_round(pyspark_max(\"ctdiff\"), 3).alias(\"ctdiff\"),\r\n        pyspark_round(pyspark_avg(\"c_rate\"), 2).alias(\"c_rate\"),\r\n        pyspark_round(pyspark_avg(\"soh_avg\"), 2).alias(\"soh_avg\"), # Target\r\n    )\r\n\r\n    # 일(day) 기준 해당 차량의 마지막 soh_list 가져오기\r\n    w_last_time_of_day \u003d Window.partitionBy(\"vehicle_id\", \"day_of_soh\").orderBy(col(\"start_time\").desc())\r\n    \r\n    df_last_soh_of_day \u003d (\r\n        df.withColumn(\"rn\", row_number().over(w_last_time_of_day))\r\n          .filter(col(\"rn\") \u003d\u003d 1)\r\n          .select(\"vehicle_id\", \"day_of_soh\", col(\"soh\").alias(\"soh_list\"))\r\n    )\r\n    \r\n    df_agg \u003d df_agg.join(df_last_soh_of_day, [\"vehicle_id\", \"day_of_soh\"], \"left\")\r\n\r\n    return df_agg\r\n\r\ndef process_forecast_preprocess_bulk(spark: SparkSession):\r\n    \"\"\"\r\n    SOH Forecast Bulk Preprocessing (HDFS CSV -\u003e HDFS Parquet)\r\n    \"\"\"\r\n    # Step 0: Load data\r\n    print_timestamp(\"Step 0\u003e Loading Bulk Summary Data (CSV)\")\r\n    \r\n    csv_path \u003d SOH_FORECAST_PREPROCESS_IO_CONFIG[\u0027input\u0027][\u0027csv_path\u0027]\r\n    df \u003d load_data_from_csv(spark, csv_path)\r\n    \r\n    if df.count() \u003d\u003d 0:\r\n        print(\"No Data Loaded. Exiting.\")\r\n        sys.exit(\"Program terminated due to empty input data.\")\r\n        \r\n    print_timestamp(f\"Step 0 - Loaded {df.count()} rows\")\r\n\r\n    # \u0027soh\u0027 컬럼(문자열)을 배열로 변환\r\n    print_timestamp(\"Converting \u0027soh\u0027 string column back to ArrayType...\")\r\n    df \u003d df.withColumn(\"soh\",   \r\n        transform(\r\n            split(regexp_replace(col(\"soh\"), r\"[\\[\\]]\", \"\"), \",\"),\r\n            lambda x: x.cast(\"double\")\r\n        ).alias(\"soh\")\r\n    )\r\n    \r\n    # Step 0.5: 피처/타겟 컬럼 타입을 Double로 강제 변환\r\n    print_timestamp(\"Step 0.5\u003e Casting feature/target columns to Double...\")\r\n    \r\n    feature_cols \u003d [\"acc_cycle_cnt\", \"avg_bat_temp\", \"c_rate\", \"cvdiff\", \"ctdiff\"]\r\n    target_col \u003d \"soh_avg\"\r\n    other_numeric_cols \u003d [\"delta_soc\", \"mileage\"]\r\n    \r\n    numeric_cols \u003d feature_cols + [target_col] + other_numeric_cols\r\n    \r\n    for col_name in numeric_cols:\r\n        if col_name in df.columns:\r\n            # 대괄호 제거 및 Double 형변환\r\n            df \u003d df.withColumn(col_name, regexp_replace(col(col_name), r\"[\\[\\]]\", \"\"))\r\n            df \u003d df.withColumn(col_name, col(col_name).cast(DoubleType()))\r\n\r\n    # Step 1: \u0027일(Day)\u0027 단위로 데이터 요약 (차량별)\r\n    print_timestamp(\"Step 1\u003e Summarizing data by day per vehicle\")\r\n    df_summary_day \u003d summary_by_day(df) \r\n\r\n    # Step 2: 학습/테스트 분리 플래그 생성\r\n    # [중요] 차량별로(partitionBy vehicle_id) 날짜순 정렬하여 80% 지점 계산\r\n    print_timestamp(\"Step 2\u003e Creating train/test split flag (per vehicle)\")\r\n    \r\n    df_summary_day \u003d df_summary_day.orderBy(\"vehicle_id\", \"day_of_soh\")\r\n    \r\n    w_order \u003d Window.partitionBy(\"vehicle_id\").orderBy(\"day_of_soh\")\r\n    w_count \u003d Window.partitionBy(\"vehicle_id\") # 차량별 전체 일수\r\n\r\n    df_preprocessed \u003d (\r\n        df_summary_day\r\n        .withColumn(\"rownum\", row_number().over(w_order))\r\n        .withColumn(\"cnt\", count(lit(1)).over(w_count))\r\n        .withColumn(\r\n            \"train_flag\",\r\n            (col(\"rownum\") \u003c\u003d col(\"cnt\") * lit(0.8)).cast(\"boolean\")\r\n        )\r\n    )\r\n\r\n    # Step 3: 모델링에 필요한 컬럼 선택\r\n    print_timestamp(\"Step 3\u003e Selecting final columns\")\r\n    \r\n    output_df \u003d df_preprocessed.select(\r\n        \"vehicle_id\",\r\n        \"day_of_soh\",\r\n        *feature_cols,\r\n        target_col,    # soh_avg\r\n        \"train_flag\",\r\n        \"soh_list\"\r\n    )\r\n\r\n    return output_df\r\n\r\n# ####################################################################\r\n# ## --- 4. Main Execution ---\r\n# ####################################################################\r\n\r\ndef main():\r\n    try:\r\n        # HDFS 파일시스템 객체\r\n        fs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jsc.hadoopConfiguration())\r\n        \r\n        # 🔽 [모델 존재 확인 로직] 통합 모델(global model) 확인 🔽\r\n        model_hdfs_path \u003d spark._jvm.org.apache.hadoop.fs.Path(GLOBAL_MODEL_CHECK_PATH)\r\n        \r\n        if fs.exists(model_hdfs_path):\r\n            logger.info(f\"Existing GLOBAL Model found at: {GLOBAL_MODEL_CHECK_PATH}\")\r\n            logger.info(\"통합 모델이 이미 존재하므로, 3단계 전처리(forecast_preprocess)를 건너뜁니다.\")\r\n            return # 종료\r\n        else:\r\n            logger.info(f\"Global Model NOT found at: {GLOBAL_MODEL_CHECK_PATH}\")\r\n            logger.info(\"모델이 없으므로, 3단계 전처리를 진행합니다.\")\r\n        \r\n        # 전처리 실행\r\n        print_timestamp(\"Step 0~3\u003e Starting Bulk Forecast Preprocess...\")\r\n        result_df \u003d process_forecast_preprocess_bulk(spark)\r\n        \r\n        # 결과 저장 (Parquet)\r\n        print_timestamp(\"Step 4\u003e Saving preprocessed results to HDFS Parquet\")\r\n        \r\n        output_path \u003d SOH_FORECAST_PREPROCESS_IO_CONFIG[\u0027output\u0027][\u0027parquet_path\u0027]\r\n        save_to_parquet(result_df, output_path)\r\n        print(f\"Preprocessed data saved to: {output_path}\")\r\n\r\n    except Exception as e:\r\n        import traceback\r\n        traceback.print_exc()\r\n        raise\r\n    finally:\r\n        print_timestamp(\"Main function (Forecast Preprocess Bulk) finished.\")\r\n\r\nmain()",
      "user": "anonymous",
      "dateUpdated": "2025-11-24 15:21:44.274",
