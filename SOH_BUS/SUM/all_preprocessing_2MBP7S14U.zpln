{
  "paragraphs": [
    {
      "text": "%spark_single.pyspark\r\n\"\"\"\r\nsoh base (Bulk Version) : 모든 차량의 CSV 데이터를 한 번에 읽어 전처리\r\n\r\n- raw data 입력 : HDFS의 CSV 파일들이 있는 디렉토리 (와일드카드 * 사용)\r\n- 처리 : 모든 차량 데이터 일괄 로드 -\u003e 전처리 -\u003e 필터링 -\u003e 파생변수 생성\r\n- 결과 데이터셋 : vehicle_id 컬럼이 포함된 통합 데이터\r\n- 결과 저장 : HDFS에 단일 CSV 파일(soh_base_result_all.csv)로 저장\r\n\"\"\"\r\n\r\nimport os\r\nimport sys\r\nfrom typing import Optional, List, Dict, Any\r\nimport logging\r\nfrom datetime import datetime\r\n\r\n# Spark 관련 모듈\r\nfrom pyspark.sql import SparkSession, DataFrame\r\nfrom pyspark.sql.functions import (\r\n    col, lit, when, count, sum, min, max, avg,\r\n    to_timestamp, unix_timestamp, from_unixtime,\r\n    date_format, hour, minute, second, \r\n    lag, lead, window, expr, round, regexp_extract,\r\n    concat, concat_ws\r\n)\r\nfrom pyspark.sql.window import Window\r\nfrom pyspark.sql.types import (\r\n    StructType, StructField, StringType, IntegerType,\r\n    DoubleType, TimestampType, BooleanType\r\n)\r\n\r\n# 로깅 설정\r\nlogging.basicConfig(\r\n    level\u003dlogging.INFO,\r\n    format\u003d\u0027%(asctime)s - %(levelname)s - %(message)s\u0027\r\n)\r\nlogger \u003d logging.getLogger(__name__)\r\n\r\n# ####################################################################\r\n# ## --- 1. Configuration (Modified for Bulk Processing) ---\r\n# ####################################################################\r\n\r\n# 특정 ID 대신 전체를 의미하는 태그 사용\r\nVEHICLE_ID \u003d \"ALL\"\r\n\r\n# Preprocessing Input/Output configuration\r\nSOH_BASE_IO_CONFIG \u003d {\r\n    \u0027input\u0027: {\r\n        \u0027source\u0027: \u0027csv\u0027,\r\n        # [수정] *.csv를 사용하여 해당 폴더의 모든 csv 파일을 읽습니다.\r\n        # 경로가 /Data/soh/csv/ 라면 /Data/soh/csv/*.csv 로 지정\r\n        \u0027csv_path\u0027: z.input(\"parquet_glob\") \r\n    },\r\n    \u0027output\u0027: {\r\n        \u0027format\u0027: \u0027csv\u0027,\r\n        # [수정] 결과 파일명도 통합된 이름으로 변경\r\n        \u0027csv_path\u0027: z.input(\"auto_base_path\") + \"/soh_base_result_all.csv\"\r\n    }\r\n}\r\n\r\n\r\n# ####################################################################\r\n# ## --- 2. Utility Functions ---\r\n# ####################################################################\r\n\r\ndef print_timestamp(message: str) -\u003e None:\r\n    \"\"\"Print message with current timestamp\"\"\"\r\n    print(f\"[{datetime.now().strftime(\u0027%Y-%m-%d %H:%M:%S\u0027)}] {message}\")\r\n\r\ndef load_data_from_csv(spark: SparkSession, file_path: str) -\u003e DataFrame:\r\n    \"\"\"Load data from CSV files (supports wildcards).\"\"\"\r\n    print_timestamp(f\"Loading data from HDFS CSV (Bulk): {file_path}\")\r\n    try:\r\n        # header\u003dTrue로 설정하면 여러 파일을 읽을 때도 헤더를 자동으로 처리합니다.\r\n        df \u003d spark.read.csv(file_path, header\u003dTrue, inferSchema\u003dTrue)\r\n        return df\r\n    except Exception as e:\r\n        print_timestamp(f\"[ERROR] Failed to read HDFS CSV file: {file_path}\")\r\n        print(e)\r\n        return spark.createDataFrame([], schema\u003dStructType([]))\r\n\r\ndef save_to_csv(df: DataFrame, output_path: str) -\u003e str:\r\n    \"\"\"\r\n    Spark DataFrame을 HDFS에 *단일* CSV 파일로 저장합니다.\r\n    \"\"\"\r\n    print_timestamp(f\"Saving data to HDFS *single file*: {output_path}\")\r\n    \r\n    import os\r\n    base_dir \u003d os.path.dirname(output_path)\r\n    temp_dir \u003d os.path.join(base_dir, \".temp_save_dir_all\") # 임시 디렉터리 이름 변경\r\n    \r\n    print_timestamp(f\"Using temporary save directory: {temp_dir}\")\r\n\r\n    try:\r\n        # coalese(1)을 사용하여 모든 데이터를 하나의 파티션으로 모읍니다.\r\n        # 데이터가 매우 클 경우(수십 GB 이상)에는 repartition(1)을 쓰거나\r\n        # 분할 저장 후 병합하는 방식을 고려해야 하지만, 10대 분량은 충분합니다.\r\n        (df.coalesce(1)\r\n           .write\r\n           .option(\"header\", \"true\")\r\n           .mode(\"overwrite\")\r\n           .csv(temp_dir))\r\n\r\n        fs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jsc.hadoopConfiguration())\r\n        \r\n        part_file_pattern \u003d spark._jvm.org.apache.hadoop.fs.Path(f\"{temp_dir}/part-*.csv\")\r\n        file_list_status \u003d fs.globStatus(part_file_pattern)\r\n\r\n        if not file_list_status:\r\n            raise Exception(f\"No \u0027part-\u0027 file found in temp directory: {temp_dir}\")\r\n            \r\n        source_file_path \u003d file_list_status[0].getPath() \r\n        print_timestamp(f\"Found temporary data file: {source_file_path}\")\r\n\r\n        dest_file_path \u003d spark._jvm.org.apache.hadoop.fs.Path(output_path)\r\n        \r\n        if fs.exists(dest_file_path):\r\n            fs.delete(dest_file_path, False)\r\n            print_timestamp(\"Existing file deleted.\")\r\n\r\n        fs.rename(source_file_path, dest_file_path)\r\n        \r\n        fs.delete(spark._jvm.org.apache.hadoop.fs.Path(temp_dir), True)\r\n\r\n        print_timestamp(f\"Successfully saved to single HDFS file: {output_path}\")\r\n        \r\n    except Exception as e:\r\n        print_timestamp(f\"[ERROR] Failed to save to single HDFS file: {output_path}\")\r\n        print(e)\r\n        try:\r\n            fs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jsc.hadoopConfiguration())\r\n            fs.delete(spark._jvm.org.apache.hadoop.fs.Path(temp_dir), True)\r\n        except:\r\n            pass \r\n        raise \r\n        \r\n    return output_path\r\n\r\n\r\n# ####################################################################\r\n# ## --- 3. Core SOH Base Logic ---\r\n# ####################################################################\r\n\r\ndef convert_df(df: DataFrame) -\u003e DataFrame:\r\n    # 리스트 타입 변환 함수\r\n    def parse_list_column(col_name):\r\n        return expr(f\"transform(split(regexp_replace(CAST({col_name} AS STRING), \u0027[{{}}]\u0027, \u0027\u0027), \u0027,\u0027), x -\u003e CAST(trim(x) AS DOUBLE))\")\r\n\r\n    # 시간 파싱\r\n    df \u003d df.withColumn(\r\n        \"time_str\",\r\n        when(col(\"time\").isNull(), lit(None))\r\n        .otherwise(\r\n            regexp_extract(\r\n                col(\"time\").cast(\"string\"),\r\n                r\"(\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2})\",\r\n                1\r\n            )\r\n        )\r\n    ).withColumn(\r\n        \"time\",\r\n        to_timestamp(col(\"time_str\"), \"yyyy-MM-dd HH:mm:ss\")\r\n    ).drop(\"time_str\") \\\r\n        .withColumn(\"vehicle_id\", col(\"vehicle_id\").cast(\"string\")) \\\r\n        .withColumn(\"voltage\", parse_list_column(\"voltage\")) \\\r\n        .withColumn(\"current\", parse_list_column(\"current\")) \\\r\n        .withColumn(\"soc\", parse_list_column(\"soc\")) \\\r\n        .withColumn(\"soh\", parse_list_column(\"soh\")) \\\r\n        .withColumn(\"cell_min_v\", parse_list_column(\"cell_min_v\")) \\\r\n        .withColumn(\"cell_max_v\", parse_list_column(\"cell_max_v\")) \\\r\n        .withColumn(\"cell_min_t\", parse_list_column(\"cell_min_t\")) \\\r\n        .withColumn(\"cell_max_t\", parse_list_column(\"cell_max_t\")) \\\r\n        .withColumn(\"bus_speed\", col(\"bus_speed\").cast(\"int\")) \\\r\n        .withColumn(\"mileage\", col(\"mileage\").cast(\"double\")) \\\r\n        .withColumn(\"is_key_on\", col(\"is_key_on\").cast(\"boolean\")) \\\r\n        .withColumn(\"is_parking_brake_on\", col(\"is_parking_brake_on\").cast(\"boolean\")) \\\r\n        .withColumn(\"is_charger_connected\", col(\"is_charger_connected\").cast(\"boolean\")) \\\r\n        .withColumn(\"dnr\", col(\"dnr\").cast(\"string\")) \\\r\n        .withColumn(\"retarder\", col(\"retarder\").cast(\"int\")) \\\r\n        .withColumn(\"warn_temp_trac\", col(\"warn_temp_trac\").cast(\"boolean\")) \\\r\n        .withColumn(\"warn_bms_idiot_light\", col(\"warn_bms_idiot_light\").cast(\"boolean\")) \\\r\n        .withColumn(\"warn_trac_limit\", col(\"warn_trac_limit\").cast(\"boolean\")) \\\r\n        .withColumn(\"warn_isolation_low\", col(\"warn_isolation_low\").cast(\"boolean\")) \\\r\n        .withColumn(\"warn_front_air\", col(\"warn_front_air\").cast(\"boolean\")) \\\r\n        .withColumn(\"warn_rear_air\", col(\"warn_rear_air\").cast(\"boolean\"))\r\n\r\n    return df\r\n\r\ndef add_status(df: DataFrame) -\u003e DataFrame:\r\n    df \u003d df.withColumn(\"status\",\r\n    when(col(\"is_charger_connected\") \u003d\u003d True, \"CHARGE\")\r\n    .when((col(\"is_key_on\") \u003d\u003d True) \u0026 (col(\"is_parking_brake_on\") \u003d\u003d False), \"DRIVING\")\r\n    .otherwise(\"STOP\")\r\n    )      \r\n    return df\r\n\r\ndef add_list_columns(df: DataFrame) -\u003e DataFrame:\r\n    df \u003d df.withColumn(\r\n        \u0027pvdiff\u0027,\r\n        expr(\u0027zip_with(cell_max_v, cell_min_v, (x, y) -\u003e CAST(x AS DOUBLE) - CAST(y AS DOUBLE))\u0027)\r\n    )\r\n    df \u003d df.withColumn(\r\n        \u0027ptdiff\u0027,\r\n        expr(\u0027zip_with(cell_max_t, cell_min_t, (x, y) -\u003e CAST(x AS DOUBLE) - CAST(y AS DOUBLE))\u0027)\r\n    )\r\n    return df\r\n\r\ndef add_columns_avg(df: DataFrame) -\u003e DataFrame:\r\n    array_cols \u003d [\u0027voltage\u0027, \u0027current\u0027, \u0027soc\u0027, \u0027soh\u0027, \u0027pvdiff\u0027,\u0027ptdiff\u0027]\r\n\r\n    for arr_col in array_cols:\r\n        for i in range(1, 7):\r\n            df \u003d df.withColumn(f\"{arr_col}_{i}\", col(arr_col)[i-1])\r\n\r\n    from functools import reduce\r\n    from operator import add\r\n    \r\n    for arr_col in array_cols:\r\n        sum_col \u003d reduce(add, [when(col(f\"{arr_col}_{i}\") !\u003d 0, col(f\"{arr_col}_{i}\")).otherwise(0) for i in range(1, 7)])\r\n        count_col \u003d reduce(add, [when(col(f\"{arr_col}_{i}\") !\u003d 0, 1).otherwise(0) for i in range(1, 7)])\r\n        df \u003d df.withColumn(f\"{arr_col}_avg\", when(count_col \u003e 0, sum_col / count_col).otherwise(0.0))\r\n\r\n    drop_cols \u003d [f\"{c}_{i}\" for c in array_cols for i in range(1, 7)]\r\n    df \u003d df.drop(*drop_cols)\r\n\r\n    df \u003d df.withColumn(\"voltage_avg\", round(col(\"voltage_avg\"), 2))\r\n    df \u003d df.withColumn(\"current_avg\", round(col(\"current_avg\"), 2))\r\n    df \u003d df.withColumn(\"soc_avg\", round(col(\"soc_avg\"), 2))\r\n    df \u003d df.withColumn(\"soh_avg\", round(col(\"soh_avg\"), 2))\r\n    df \u003d df.withColumn(\"mileage\", round(col(\"mileage\"), 2))\r\n    df \u003d df.withColumn(\"pvdiff_avg\", round(col(\"pvdiff_avg\"), 2))\r\n    df \u003d df.withColumn(\"ptdiff_avg\", round(col(\"ptdiff_avg\"), 2))\r\n\r\n    return df\r\n\r\ndef add_columns(df: DataFrame) -\u003e DataFrame:\r\n    df \u003d add_list_columns(df)\r\n    df \u003d add_columns_avg(df)    \r\n\r\n    df \u003d df.withColumn(\r\n        \"cell_avg_temp\",\r\n        expr(\"transform(zip_with(cell_min_t, cell_max_t, (a, b) -\u003e (CAST(a AS DOUBLE) + CAST(b AS DOUBLE)) / 2.0), x -\u003e round(x, 2))\")\r\n    )\r\n\r\n    df \u003d df.withColumn(\r\n        \"bat_temp\",\r\n        round(expr(\"CASE WHEN size(cell_avg_temp) \u003e 0 THEN aggregate(cell_avg_temp, 0D, (acc, x) -\u003e acc + x) / size(cell_avg_temp) ELSE NULL END\"), 2)\r\n    )\r\n\r\n    return df\r\n\r\n\r\n# ####################################################################\r\n# ## --- 4. Main Process Function (Modified for Bulk) ---\r\n# ####################################################################\r\n\r\ndef process_soh_base_data_bulk(spark: SparkSession, day_of_soh: Optional[str] \u003d None) -\u003e None:\r\n    \"\"\"\r\n    SOH Base Bulk Data Processing\r\n    \"\"\"\r\n\r\n    # Step 1: Load data (csv with wildcard)\r\n    print_timestamp(\"Step 1\u003e Loading ALL data from HDFS CSVs\")\r\n\r\n    # 와일드카드가 포함된 경로 사용\r\n    csv_path \u003d SOH_BASE_IO_CONFIG[\u0027input\u0027][\u0027csv_path\u0027]\r\n    logger.info(f\"Target HDFS CSV Path: {csv_path}\")\r\n\r\n    # [수정] vehicle_id 파라미터 체크 로직 제거 -\u003e 바로 로드\r\n    df \u003d load_data_from_csv(spark, csv_path)\r\n    \r\n    # [수정] day_of_soh가 있으면 날짜 필터링 (전체 차량에 대해)\r\n    if day_of_soh:\r\n        df \u003d df.filter(date_format(col(\"time\"), \"yyyy-MM-dd\") \u003d\u003d day_of_soh)\r\n        logger.info(f\"Filtered by Day of SOH: {day_of_soh}\")\r\n        \r\n    # [수정] vehicle_id 필터링 제거 -\u003e 모든 ID 포함\r\n\r\n    if df.count() \u003e 0:\r\n        print(f\"Loaded Total Data Count: {df.count()} rows\")\r\n        # 데이터에 어떤 차량들이 있는지 확인용 로그\r\n        try:\r\n            unique_vehicles \u003d [row.vehicle_id for row in df.select(\"vehicle_id\").distinct().collect()]\r\n            print(f\"Included Vehicles: {unique_vehicles}\")\r\n        except:\r\n            pass\r\n    else:\r\n        print(\"No Data Loaded\")\r\n        sys.exit(\"Program terminated due to empty input data.\")\r\n\r\n    # Step 2: Convert column names and data types\r\n    print_timestamp(\"Step 2\u003e Converting column names and data types\")\r\n    df \u003d convert_df(df)\r\n    \r\n    # Step 3: Add status column\r\n    print_timestamp(\"Step 3\u003e Adding status column\")\r\n    df \u003d add_status(df)\r\n\r\n    # Step 4: Filtering data\r\n    print_timestamp(\"Step 4\u003e filtering data (Charge, Error, Mileage)\")\r\n    df \u003d df.filter(col(\"status\") \u003d\u003d \"CHARGE\")\r\n    df \u003d df.filter(~(col(\u0027warn_temp_trac\u0027) \u003d\u003d True) \u0026 ~(col(\u0027warn_bms_idiot_light\u0027) \u003d\u003d True) \u0026 ~(col(\u0027warn_trac_limit\u0027) \u003d\u003d True) \u0026 ~(col(\u0027warn_isolation_low\u0027) \u003d\u003d True))\r\n    df \u003d df.filter((col(\"mileage\") \u003e 0) \u0026 (col(\"bus_speed\") \u003d\u003d 0))\r\n    \r\n    # Step 5: Add columns\r\n    print_timestamp(\"Step 5\u003e Adding derived columns\")\r\n    df \u003d add_columns(df)\r\n\r\n    print_timestamp(\"Step 6\u003e Selecting final columns\")\r\n    SELECTED_COLUMNS_BASE \u003d [\r\n        \u0027vehicle_id\u0027, \u0027time\u0027, \u0027status\u0027,\u0027mileage\u0027,\u0027voltage_avg\u0027,\u0027current_avg\u0027,\u0027soc_avg\u0027,\u0027soh_avg\u0027,\u0027bat_temp\u0027,\u0027pvdiff_avg\u0027,\u0027ptdiff_avg\u0027,\u0027soh\u0027]\r\n    result_df \u003d df.select(*SELECTED_COLUMNS_BASE)\r\n    \r\n    result_df \u003d result_df.withColumn(\r\n        \"soh_str\",\r\n        concat(\r\n            lit(\"[\"),\r\n            concat_ws(\", \", col(\"soh\")),\r\n            lit(\"]\")\r\n        )\r\n    ).drop(\"soh\").withColumnRenamed(\"soh_str\", \"soh\")\r\n\r\n    print(f\"Final DataFrame shape: {result_df.count()} rows\")\r\n\r\n    try:\r\n        # Step 7: Save results - HDFS Single CSV\r\n        print_timestamp(\"Step 7\u003e Saving merged results to HDFS\")\r\n        \r\n        # 통합된 출력 경로 사용\r\n        output_path \u003d SOH_BASE_IO_CONFIG[\u0027output\u0027][\u0027csv_path\u0027]\r\n        \r\n        # Spark HDFS CSV 저장 함수 호출\r\n        save_to_csv(result_df, output_path) \r\n        print(f\"Results saved to HDFS: {output_path}\")\r\n\r\n    except Exception as e:\r\n        print(f\"Error during processing: {str(e)}\")\r\n        raise\r\n            \r\n    print_timestamp(\"Processing complete.\")\r\n    \r\n\r\n# ####################################################################\r\n# ## --- 5. Main Execution ---\r\n# ####################################################################\r\n\r\ndef main():\r\n    try:\r\n        # Bulk 처리를 위해 ID 인자 제거\r\n        day_of_soh \u003d None \r\n        \r\n        process_soh_base_data_bulk(spark, day_of_soh\u003dday_of_soh)\r\n        \r\n    except Exception as e:\r\n        import traceback\r\n        traceback.print_exc()\r\n        raise\r\n    finally:\r\n        print_timestamp(\"Main function finished.\")\r\n        pass\r\n\r\nmain()",
      "user": "anonymous",
      "dateUpdated": "2025-11-24 15:30:18.289",
