              "jobUrl": "http://127.0.0.1:44040/jobs/job?id\u003d12"
            }
          ],
          "interpreterSettingId": "spark_single"
        }
      },
      "progressUpdateIntervalMs": 500,
      "jobName": "paragraph_1763963533567_926111000",
      "id": "paragraph_1763963533567_926111000",
      "dateCreated": "2025-11-24 14:52:13.567",
      "dateStarted": "2025-11-24 14:58:51.123",
      "dateFinished": "2025-11-24 15:03:01.022",
      "status": "FINISHED"
    },
    {
      "text": "%spark_single.pyspark\r\n\"\"\"\r\nsoh summary (Bulk Version) : 통합 데이터를 읽어 차량별 SOH 요약 정보 생성\r\n\r\n- 입력 데이터셋(soh_base_result_all.csv): Step 1에서 생성된 통합 CSV\r\n- 처리:\r\n    1. 충전 시퀀스(ch_seq) 넘버링 (차량별)\r\n    2. 시퀀스 단위 요약 (Summary)\r\n    3. 누적 DoD 및 초기 DoD(회귀분석) 산출 (차량별)\r\n    4. C-rate 산출\r\n- 결과 데이터셋(soh_summary_result_all.csv) : HDFS에 단일 통합 CSV 파일로 저장\r\n\"\"\"\r\n\r\nimport os\r\nimport sys\r\nfrom typing import Optional, List, Dict, Any\r\nimport logging\r\nfrom datetime import datetime\r\n\r\n# Spark 관련 모듈\r\nfrom pyspark.sql import SparkSession, DataFrame\r\nfrom pyspark.sql.functions import (\r\n    lag, lead, col, when, expr, round as pyspark_round, sum as pyspark_sum,\r\n    max as pyspark_max, min as pyspark_min, avg as pyspark_avg,\r\n    abs as pyspark_abs, first as pyspark_first, count, lit, coalesce, unix_timestamp, date_format,\r\n    row_number, split, transform, concat_ws\r\n)\r\nfrom pyspark.sql import functions as F\r\nfrom pyspark.sql.window import Window\r\nfrom pyspark.sql.types import (\r\n    StructType, StructField, StringType, IntegerType,\r\n    DoubleType, TimestampType, BooleanType, ArrayType\r\n)\r\n\r\n# Pandas/Numpy/Sklearn (cal_accum_dod용)\r\nimport pandas as pd\r\nimport numpy as np\r\nfrom sklearn.linear_model import LinearRegression\r\n\r\n# 로깅 설정\r\nlogging.basicConfig(\r\n    level\u003dlogging.INFO,\r\n    format\u003d\u0027%(asctime)s - %(levelname)s - %(message)s\u0027\r\n)\r\nlogger \u003d logging.getLogger(__name__)\r\n\r\n# ####################################################################\r\n# ## --- 1. Configuration (Bulk) ---\r\n# ####################################################################\r\n\r\n#VEHICLE_ID \u003d \"ALL\"\r\n\r\n# SOH Summary Input/Output configuration\r\nSOH_SUMMARY_IO_CONFIG \u003d {\r\n    \u0027input\u0027: {\r\n        \u0027source\u0027: \u0027csv\u0027,\r\n        # [수정] Step 1에서 생성한 통합 파일 경로\r\n        \u0027csv_path\u0027: z.input(\"parquet_glob\") + \"/soh_base_result_all.csv\"\r\n    },\r\n    \u0027output\u0027: {\r\n        \u0027format\u0027: \u0027csv\u0027,\r\n        # [수정] 결과 파일명도 통합된 이름으로 변경\r\n        \u0027csv_path\u0027: z.input(\"auto_base_path\") + \"/soh_summary_result_all.csv\"\r\n    }\r\n}\r\n\r\n\r\n# ####################################################################\r\n# ## --- 2. Utility Functions ---\r\n# ####################################################################\r\n\r\ndef print_timestamp(message: str) -\u003e None:\r\n    \"\"\"Print message with current timestamp\"\"\"\r\n    print(f\"[{datetime.now().strftime(\u0027%Y-%m-%d %H:%M:%S\u0027)}] {message}\")\r\n\r\ndef print_dfcount(df: DataFrame, message: str) -\u003e None:\r\n    \"\"\"Print DataFrame count with message\"\"\"\r\n    count \u003d df.count()\r\n    print_timestamp(f\"{message}: {count:,} rows\")\r\n\r\n\r\ndef load_data_from_csv(spark: SparkSession, file_path: str) -\u003e DataFrame:\r\n    \"\"\"Load data from a CSV file.\"\"\"\r\n    print_timestamp(f\"Loading data from HDFS CSV: {file_path}\")\r\n    try:\r\n        # Step 1 결과는 단일 CSV 파일이므로 직접 읽음\r\n        df \u003d spark.read.csv(file_path, header\u003dTrue, inferSchema\u003dTrue)\r\n        return df\r\n    except Exception as e:\r\n        print_timestamp(f\"[ERROR] Failed to read HDFS CSV file: {file_path}\")\r\n        print(e)\r\n        return spark.createDataFrame([], schema\u003dStructType([]))\r\n\r\ndef save_to_csv(df: DataFrame, output_path: str) -\u003e str:\r\n    \"\"\"\r\n    Spark DataFrame을 HDFS에 *단일* CSV 파일로 저장합니다.\r\n    \"\"\"\r\n    print_timestamp(f\"Saving data to HDFS *single file*: {output_path}\")\r\n    \r\n    import os\r\n    base_dir \u003d os.path.dirname(output_path)\r\n    temp_dir \u003d os.path.join(base_dir, \".temp_summary_save_dir_all\") # 임시 폴더명 변경\r\n    \r\n    print_timestamp(f\"Using temporary save directory: {temp_dir}\")\r\n\r\n    try:\r\n        (df.coalesce(1)\r\n           .write\r\n           .option(\"header\", \"true\")\r\n           .mode(\"overwrite\")\r\n           .csv(temp_dir))\r\n\r\n        fs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jsc.hadoopConfiguration())\r\n        \r\n        part_file_pattern \u003d spark._jvm.org.apache.hadoop.fs.Path(f\"{temp_dir}/part-*.csv\")\r\n        file_list_status \u003d fs.globStatus(part_file_pattern)\r\n\r\n        if not file_list_status:\r\n            raise Exception(f\"No \u0027part-\u0027 file found in temp directory: {temp_dir}\")\r\n            \r\n        source_file_path \u003d file_list_status[0].getPath()\r\n        print_timestamp(f\"Found temporary data file: {source_file_path}\")\r\n\r\n        dest_file_path \u003d spark._jvm.org.apache.hadoop.fs.Path(output_path)\r\n\r\n        print_timestamp(f\"Checking for existing file and deleting if present: {output_path}\")\r\n        if fs.exists(dest_file_path):\r\n            fs.delete(dest_file_path, False)\r\n            print_timestamp(\"Existing file deleted.\")\r\n\r\n        fs.rename(source_file_path, dest_file_path)\r\n        \r\n        fs.delete(spark._jvm.org.apache.hadoop.fs.Path(temp_dir), True)\r\n\r\n        print_timestamp(f\"Successfully saved to single HDFS file: {output_path}\")\r\n        \r\n    except Exception as e:\r\n        print_timestamp(f\"[ERROR] Failed to save to single HDFS file: {output_path}\")\r\n        print(e)\r\n        try:\r\n            fs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jsc.hadoopConfiguration())\r\n            fs.delete(spark._jvm.org.apache.hadoop.fs.Path(temp_dir), True)\r\n        except:\r\n            pass \r\n        raise \r\n        \r\n    return output_path\r\n\r\n\r\n# ####################################################################\r\n# ## --- 3. Core SOH Summary Logic (Modified for Bulk) ---\r\n# ####################################################################\r\n\r\ndef number_sequence(df):\r\n    # [설명] vehicle_id 파티션이 이미 적용되어 있어 여러 차량 데이터가 섞여 있어도\r\n    # 차량별로 독립적으로 시퀀스를 계산합니다. 수정 불필요.\r\n    \r\n    # vehicle_id와 time으로 정렬\r\n    df \u003d df.orderBy(\"vehicle_id\", \"time\")\r\n\r\n    # 이전 행과 비교하기 위한 Window 함수 (차량별 파티션)\r\n    w \u003d Window.partitionBy(\"vehicle_id\").orderBy(\"time\")\r\n\r\n    # 이전 time과 soc_avg 값 가져오기\r\n    df \u003d df \\\r\n        .withColumn(\"prev_time\", lag(\"time\", 1).over(w)) \\\r\n        .withColumn(\"prev_soc\", lag(\"soc_avg\", 1).over(w))\r\n\r\n    # 충전 시퀀스 구분 조건\r\n    df \u003d df.withColumn(\"new_seq_flag\",\r\n        when(\r\n            (unix_timestamp(col(\"time\")) - unix_timestamp(col(\"prev_time\")) \u003e\u003d 600) \u0026\r\n            (col(\"prev_soc\") - col(\"soc_avg\") \u003e\u003d 5),\r\n            1\r\n        ).otherwise(0)\r\n    )\r\n\r\n    # vehicle_id별로 누적 합으로 시퀀스 번호 생성\r\n    w2 \u003d Window.partitionBy(\"vehicle_id\").orderBy(\"time\").rowsBetween(Window.unboundedPreceding, Window.currentRow)\r\n    df \u003d df.withColumn(\"ch_seq\", pyspark_sum(\"new_seq_flag\").over(w2) + 1)\r\n\r\n    # 중간 컬럼 제거\r\n    df \u003d df.drop(\"prev_time\", \"prev_soc\", \"new_seq_flag\")\r\n\r\n    return df\r\n\r\ndef summary_by_seq(df):\r\n    # [설명] vehicle_id를 그룹 키에 포함시켜 차량별/시퀀스별 요약 수행\r\n    df_agg \u003d df.groupBy(\"vehicle_id\", \"ch_seq\").agg(\r\n        pyspark_min(\"time\").alias(\"start_time\"),\r\n        pyspark_max(\"time\").alias(\"end_time\"),\r\n        pyspark_round(pyspark_avg(\"mileage\"), 2).alias(\"mileage\"),\r\n        pyspark_round(pyspark_avg(\"bat_temp\"), 1).alias(\"avg_bat_temp\"),\r\n        pyspark_round(pyspark_max(\"pvdiff_avg\"), 3).alias(\"cvdiff\"),\r\n        pyspark_round(pyspark_max(\"ptdiff_avg\"), 3).alias(\"ctdiff\"),\r\n        pyspark_round(pyspark_min(\"soc_avg\"), 2).alias(\"start_soc\"),\r\n        pyspark_round(pyspark_max(\"soc_avg\"), 2).alias(\"end_soc\"),\r\n        pyspark_round(pyspark_avg(\"soh_avg\"), 2).alias(\"soh_avg\"),\r\n        pyspark_round((pyspark_max(\"soc_avg\") - pyspark_min(\"soc_avg\")), 2).alias(\"delta_soc\"),\r\n        pyspark_round(pyspark_avg(\"current_avg\"), 2).alias(\"current_avg_mean\"),\r\n    )\r\n\r\n    # 동일 (vehicle_id, ch_seq) 내에서 마지막 soh 값 추가\r\n    w_last \u003d Window.partitionBy(\"vehicle_id\", \"ch_seq\").orderBy(col(\"time\").desc())\r\n    df_last_soh \u003d (\r\n        df.withColumn(\"rn\", row_number().over(w_last))\r\n          .filter(col(\"rn\") \u003d\u003d 1)\r\n          .select(\"vehicle_id\", \"ch_seq\", col(\"soh\").alias(\"soh\"))\r\n    )\r\n\r\n    df_agg \u003d df_agg.join(df_last_soh, [\"vehicle_id\", \"ch_seq\"], \"left\")\r\n\r\n    return df_agg\r\n\r\ndef cal_accum_dod(df):\r\n    \"\"\"\r\n    누적 DoD 계산 함수 (Bulk 버전)\r\n    - accum_dod는 Spark Window로 계산 (차량별)\r\n    - initial_dod는 Pandas로 수집 후 차량별로 회귀분석 수행하여 Join\r\n    \"\"\"\r\n    # 1) vehicle_id, ch_seq로 정렬\r\n    df \u003d df.orderBy(\"vehicle_id\", \"ch_seq\")\r\n    \r\n    # 2) accum_dod \u003d delta_soc / 100을 누적으로 더함 (차량별 파티션)\r\n    w \u003d Window.partitionBy(\"vehicle_id\").orderBy(\"ch_seq\").rowsBetween(Window.unboundedPreceding, Window.currentRow)\r\n    df \u003d df.withColumn(\"accum_dod\", pyspark_sum((col(\"delta_soc\") / lit(100))).over(w))\r\n    \r\n    # 3) initial_dod 계산 (Linear Regression)\r\n    # [수정] 차량별로 회귀식을 돌려야 하므로, 데이터를 요약해서 가져온 뒤 차량별 Loop 수행\r\n    \r\n    print_timestamp(\"Collecting summary data to Pandas for Linear Regression (per vehicle)...\")\r\n    \r\n    # Summary 데이터는 용량이 매우 작으므로(차량당 수천 건) collect해도 안전합니다.\r\n    # mileage와 accum_dod, vehicle_id만 가져옵니다.\r\n    pdf_for_reg \u003d df.select(\"vehicle_id\", \"mileage\", \"accum_dod\").toPandas()\r\n    \r\n    unique_vehicles \u003d pdf_for_reg[\u0027vehicle_id\u0027].unique()\r\n    initial_dod_list \u003d []\r\n\r\n    print_timestamp(f\"Calculating initial_dod for {len(unique_vehicles)} vehicles...\")\r\n\r\n    for vid in unique_vehicles:\r\n        # 해당 차량 데이터 필터링\r\n        pdf_v \u003d pdf_for_reg[pdf_for_reg[\u0027vehicle_id\u0027] \u003d\u003d vid]\r\n        \r\n        # NaN 제거\r\n        pdf_v \u003d pdf_v.dropna(subset\u003d[\"mileage\", \"accum_dod\"])\r\n        \r\n        X \u003d pdf_v[[\"mileage\"]].values\r\n        y \u003d pdf_v[\"accum_dod\"].values\r\n        \r\n        initial_dod \u003d 0.0\r\n        if len(X) \u003e 1:\r\n            try:\r\n                reg \u003d LinearRegression()\r\n                reg.fit(X, y)\r\n                initial_dod \u003d abs(reg.intercept_)\r\n            except Exception as e:\r\n                print(f\"Regression failed for vehicle {vid}: {e}\")\r\n        \r\n        initial_dod_list.append((str(vid), float(initial_dod)))\r\n\r\n    # 차량별 initial_dod를 담은 DataFrame 생성\r\n    initial_dod_schema \u003d StructType([\r\n        StructField(\"vehicle_id\", StringType(), True),\r\n        StructField(\"initial_dod\", DoubleType(), True)\r\n    ])\r\n    \r\n    initial_dod_df \u003d spark.createDataFrame(initial_dod_list, schema\u003dinitial_dod_schema)\r\n    \r\n    # 4) 원본 df에 initial_dod 조인\r\n    df \u003d df.join(initial_dod_df, \"vehicle_id\", \"left\")\r\n    \r\n    # 조인 후 null값(혹시 모를) 처리\r\n    df \u003d df.fillna(0.0, subset\u003d[\"initial_dod\"])\r\n\r\n    # 5) acc_cycle_cnt 계산\r\n    df \u003d df.withColumn(\"acc_cycle_cnt\", col(\"accum_dod\") + col(\"initial_dod\"))\r\n    df \u003d df.withColumn(\"acc_cycle_cnt\", pyspark_round(col(\"acc_cycle_cnt\"), 2))\r\n    \r\n    return df\r\n\r\n\r\n# ####################################################################\r\n# ## --- 4. Main Process Function (Modified for Bulk) ---\r\n# ####################################################################\r\n\r\ndef process_summary_data_bulk(spark: SparkSession, day_of_soh: Optional[str] \u003d None):\r\n    \"\"\"\r\n    SOH Summary Bulk Data Processing\r\n    \"\"\"\r\n    # Step 0: Load data\r\n    print_timestamp(\"Step 0\u003e Loading data (Bulk)\")\r\n    \r\n    csv_path \u003d SOH_SUMMARY_IO_CONFIG[\u0027input\u0027][\u0027csv_path\u0027]\r\n    df \u003d load_data_from_csv(spark, csv_path)\r\n\r\n    if day_of_soh:\r\n        df \u003d df.filter(date_format(col(\"time\"), \"yyyy-MM-dd\") \u003c\u003d day_of_soh)\r\n        logger.info(f\"Filtered data up to: {day_of_soh}\")\r\n\r\n    if df.count() \u003d\u003d 0:\r\n        print(\"No Data Loaded. Exiting.\")\r\n        sys.exit(\"Program terminated due to empty input data.\")\r\n        \r\n    print_timestamp(f\"Step 0 - Initial data count: {df.count()}\")\r\n\r\n    # [수정] Step 1의 결과에서 soh는 문자열로 저장되었으므로 다시 배열로 변환\r\n    print_timestamp(\"Converting \u0027soh\u0027 string column back to ArrayType...\")\r\n    # 문자열 \"[98.1, 98.2]\" -\u003e 배열로 변환\r\n    df \u003d df.withColumn(\"soh\", \r\n        transform(\r\n            split(\r\n                expr(\"regexp_replace(soh, \u0027\\\\[|\\\\]\u0027, \u0027\u0027)\"), # 대괄호 제거\r\n                \",\"\r\n            ),\r\n            lambda x: x.cast(\"double\")\r\n        ).alias(\"soh\")\r\n    )\r\n\r\n    # 1. data filtering\r\n    print_timestamp(\"Step 1\u003e Filtering data (Charge only, etc.)\")\r\n    df \u003d df.filter(col(\"status\") \u003d\u003d \"CHARGE\")\r\n    df \u003d df.filter((col(\"mileage\") \u003e 0) \u0026 (col(\"soc_avg\") \u003e 0) \u0026 (col(\"soc_avg\") \u003c 100) \u0026 (col(\"current_avg\") \u003c -0.5)) \r\n    print_dfcount(df, \"After Step 1 filtering\")\r\n     \r\n    # 2. Numbering sequence (Partitioned by vehicle_id)\r\n    print_timestamp(\"Step 2\u003e Numbering charge sequence\")\r\n    df \u003d number_sequence(df)\r\n\r\n    # 3. Summary (Group by vehicle_id, ch_seq)\r\n    print_timestamp(\"Step 3\u003e Summarizing by sequence\")\r\n    df_agg \u003d summary_by_seq(df)\r\n\r\n    # day_of_soh 추가\r\n    df_agg \u003d df_agg.withColumn(\"day_of_soh\", date_format(col(\"start_time\"), \"yyyy-MM-dd\"))\r\n\r\n    # 4. 누적 DoD 계산 (차량별 회귀분석 포함)\r\n    print_timestamp(\"Step 4\u003e Calculating accumulated DoD (per vehicle)\")\r\n    df_agg \u003d cal_accum_dod(df_agg)\r\n\r\n    # 5. C-rate 계산\r\n    print_timestamp(\"Step 5\u003e Calculating C-rate\")\r\n    df_agg \u003d df_agg.withColumn(\"delta_t_hour\", (unix_timestamp(col(\"end_time\")) - unix_timestamp(col(\"start_time\"))) / 3600)\\\r\n        .withColumn(\r\n            \"c_rate\",\r\n            pyspark_round(\r\n                when(col(\"delta_t_hour\") !\u003d 0,\r\n                     (col(\"delta_soc\") / lit(100)) / col(\"delta_t_hour\"))\r\n                .otherwise(lit(0.0)),\r\n                2\r\n            )\r\n        )\r\n\r\n    print_timestamp(\"Step 6\u003e Selecting final columns\")\r\n    df_result \u003d df_agg.filter(col(\"c_rate\") \u003e 0)\r\n    \r\n    # Select columns\r\n    final_cols \u003d [\"vehicle_id\", \"day_of_soh\", \"ch_seq\", \"start_time\", \"end_time\", \"mileage\", \"acc_cycle_cnt\", \"avg_bat_temp\", \"cvdiff\", \"ctdiff\",\"start_soc\", \"end_soc\", \"delta_soc\", \"c_rate\",\"soh_avg\", \"soh\"]\r\n    df_result \u003d df_result.select(*final_cols)\r\n    \r\n    print_dfcount(df_result, \"Final result count\")\r\n    \r\n    return df_result\r\n\r\n# ####################################################################\r\n# ## --- 5. Main Execution ---\r\n# ####################################################################\r\n\r\ndef main():\r\n    try:\r\n        # Bulk 처리이므로 ID는 없음\r\n        day_of_soh \u003d None \r\n            \r\n        result_df \u003d process_summary_data_bulk(spark, day_of_soh\u003dday_of_soh)\r\n        \r\n        # Save to HDFS CSV\r\n        print_timestamp(\"Step 7\u003e Saving results to HDFS\")\r\n        \r\n        # 저장 전 \u0027soh\u0027 배열을 다시 문자열로 변환 (CSV 호환)\r\n        result_df_for_csv \u003d result_df.withColumn(\"soh\", concat_ws(\",\", col(\"soh\")))\r\n        \r\n        # 정렬 (차량별, 시퀀스별)\r\n        result_df_for_csv \u003d result_df_for_csv.orderBy(\"vehicle_id\", \"ch_seq\")\r\n        \r\n        output_path \u003d SOH_SUMMARY_IO_CONFIG[\u0027output\u0027][\u0027csv_path\u0027]\r\n        save_to_csv(result_df_for_csv, output_path) \r\n        print(f\"Results saved to HDFS: {output_path}\")\r\n\r\n    except Exception as e:\r\n        import traceback\r\n        traceback.print_exc()\r\n        raise\r\n    finally:\r\n        print_timestamp(\"Main function finished.\")\r\n\r\nmain()",
      "user": "anonymous",
      "dateUpdated": "2025-11-24 15:20:01.095",
      "progress": 0,
      "config": {
        "editorSetting": {
          "language": "python",
          "editOnDblClick": false,
          "completionKey": "TAB",
          "completionSupport": true
        },
        "colWidth": 12.0,
        "editorMode": "ace/mode/python",
        "fontSize": 9.0,
