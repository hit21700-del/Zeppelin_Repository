{
  "paragraphs": [
    {
      "text": "%spark_single.pyspark\n\"\"\"\nsoh summary : soh예측을 위한 summary코드 (Config/Utils 통합 및 HDFS 버전)\n\n- 입력 데이터셋(bus_soh_base): HDFS의 CSV 파일 입력\n- 충전데이터셋 발췌, 충전 seq 넘버링, accum_cycle_cnt, c_rate 산출\n- 결과 데이터셋(bus_soh_summary) : HDFS에 단일 CSV 파일로 저장\n\"\"\"\n\nimport os\nimport sys\nfrom typing import Optional, List, Dict, Any\nimport logging\nfrom datetime import datetime\n\n# Spark 관련 모듈\nfrom pyspark.sql import SparkSession, DataFrame\nfrom pyspark.sql.functions import (\n    lag, lead, col, when, expr, round as pyspark_round, sum as pyspark_sum,\n    max as pyspark_max, min as pyspark_min, avg as pyspark_avg,\n    abs as pyspark_abs, first as pyspark_first, count, lit, coalesce, unix_timestamp, date_format,\n    row_number, split, transform, concat_ws\n)\nfrom pyspark.sql import functions as F\nfrom pyspark.sql.window import Window\nfrom pyspark.sql.types import (\n    StructType, StructField, StringType, IntegerType,\n    DoubleType, TimestampType, BooleanType, ArrayType\n)\n\n# Pandas/Numpy/Sklearn (cal_accum_dod용)\nimport pandas as pd\nimport numpy as np\nfrom sklearn.linear_model import LinearRegression\n\nVEHICLE_ID \u003d \"95\"\n\n# 로깅 설정\nlogging.basicConfig(\n    level\u003dlogging.INFO,\n    format\u003d\u0027%(asctime)s - %(levelname)s - %(message)s\u0027\n)\nlogger \u003d logging.getLogger(__name__)\n\n# ####################################################################\n# ## --- 1. Configuration (kslab_bus_config.py) ---\n# ####################################################################\n\n\n# SOH Summary Input/Output configuration (HDFS 경로)\n\nSOH_SUMMARY_IO_CONFIG \u003d {\n    \u0027input\u0027: {\n        \u0027source\u0027: \u0027csv\u0027,  # \u0027csv\u0027 or \u0027db\u0027 선택 (csv로 고정)\n        \u0027csv_path\u0027: z.input(\"parquet_glob\")+\"/soh_base_result.csv\" #\"/Data/soh/csv/woojin_93.csv\" \n            \n    },\n    \u0027output\u0027: {\n        \u0027format\u0027: \u0027csv\u0027,  # \u0027csv\u0027 or \u0027db\u0027 (csv로 고정)\n        \u0027csv_path\u0027: z.input(\"auto_base_path\")+\"/soh_summary_result.csv\" #\"/Data/soh/result/93/20251119\"+\"/soh_base_result.csv\"\n            \n        \n    }\n}\n\n\n# ####################################################################\n# ## --- 2. Utility Functions (kslab_bus_utils.py) ---\n# ####################################################################\n\ndef print_timestamp(message: str) -\u003e None:\n    \"\"\"Print message with current timestamp\"\"\"\n    print(f\"[{datetime.now().strftime(\u0027%Y-%m-%d %H:%M:%S\u0027)}] {message}\")\n\ndef print_dfcount(df: DataFrame, message: str) -\u003e None:\n    \"\"\"Print DataFrame count with message\"\"\"\n    count \u003d df.count()\n    print_timestamp(f\"{message}: {count:,} rows\")\n\n\ndef load_data_from_csv(spark: SparkSession, file_path: str) -\u003e DataFrame:\n    \"\"\"Load data from a CSV file (HDFS or local).\"\"\"\n    print_timestamp(f\"Loading data from HDFS CSV: {file_path}\")\n    try:\n        # 1단계에서 저장한 part- 파일을 읽기 위해 디렉터리 경로를 사용\n        df \u003d spark.read.csv(file_path, header\u003dTrue, inferSchema\u003dTrue)\n        return df\n    except Exception as e:\n        # 만약 1단계에서 \u0027단일 파일\u0027로 저장했다면, 이 경로로 읽어야 함\n        if \"is not a valid_path\" in str(e) or \"Path does not exist\" in str(e):\n             print_timestamp(f\"Directory read failed (expected for single file), trying to read as file: {file_path}\")\n             try:\n                 # HDFS에 단일 파일로 저장된 경우, 스파크는 해당 경로를 디렉터리로 오인할 수 있음\n                 # 이 경우, 스파크가 생성한 디렉터리 내부의 part- 파일을 직접 읽어야 할 수도 있으나\n                 # 1단계의 save_to_csv가 rename을 사용하므로 이 코드는 필요 없음.\n                 # 1단계에서 `part-` 파일을 `soh_base_result.csv`로 rename 했으므로,\n                 # `spark.read.csv`는 이 파일을 직접 읽을 수 있어야 함.\n                 \n                 # 위의 `spark.read.csv`가 실패했다면, HDFS 경로 자체의 문제일 수 있음\n                 print_timestamp(f\"[ERROR] File not found or not readable: {file_path}\")\n                 print(e)\n             except Exception as e2:\n                 print_timestamp(f\"[ERROR] Also failed to read as single file: {e2}\")\n                 \n        print_timestamp(f\"[ERROR] Failed to read HDFS CSV file: {file_path}\")\n        print(e)\n        return spark.createDataFrame([], schema\u003dStructType([]))\n\ndef save_to_csv(df: DataFrame, output_path: str) -\u003e str:\n    \"\"\"\n    Spark DataFrame을 HDFS에 *단일* CSV 파일로 저장합니다 (덮어쓰기 지원).\n    \"\"\"\n    print_timestamp(f\"Saving data to HDFS *single file*: {output_path}\")\n    \n    import os\n    base_dir \u003d os.path.dirname(output_path)\n    temp_dir \u003d os.path.join(base_dir, \".temp_summary_save_dir\") # 임시 디렉터리 이름\n    \n    print_timestamp(f\"Using temporary save directory: {temp_dir}\")\n\n    try:\n        # 1. 데이터를 임시 디렉터리에 저장합니다.\n        (df.coalesce(1)\n           .write\n           .option(\"header\", \"true\")\n           .mode(\"overwrite\")\n           .csv(temp_dir))\n\n        # 2. HDFS 파일시스템(Java API)에 접근합니다.\n        fs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jsc.hadoopConfiguration())\n        \n        # 3. 임시 디렉터리에서 스파크가 생성한 \u0027part-\u0027 파일을 찾습니다.\n        part_file_pattern \u003d spark._jvm.org.apache.hadoop.fs.Path(f\"{temp_dir}/part-*.csv\")\n        file_list_status \u003d fs.globStatus(part_file_pattern)\n\n        if not file_list_status:\n            raise Exception(f\"No \u0027part-\u0027 file found in temp directory: {temp_dir}\")\n            \n        source_file_path \u003d file_list_status[0].getPath()\n        print_timestamp(f\"Found temporary data file: {source_file_path}\")\n\n        # 4. 최종 목적지 파일 경로를 Hadoop Path 객체로 정의합니다.\n        dest_file_path \u003d spark._jvm.org.apache.hadoop.fs.Path(output_path)\n\n        # 5. 덮어쓰기를 위해 기존 파일을 먼저 삭제합니다.\n        print_timestamp(f\"Checking for existing file and deleting if present: {output_path}\")\n        if fs.exists(dest_file_path):\n            fs.delete(dest_file_path, False) # False \u003d 재귀삭제 안함 (파일이므로)\n            print_timestamp(\"Existing file deleted.\")\n\n        # 6. \u0027part-\u0027 파일의 이름을 원하는 파일 이름(output_path)으로 변경(이동)합니다.\n        print_timestamp(f\"Moving file to final destination: {output_path}\")\n        fs.rename(source_file_path, dest_file_path)\n        \n        # 7. 임시 디렉터리를 삭제합니다.\n        print_timestamp(f\"Cleaning up temporary directory: {temp_dir}\")\n        fs.delete(spark._jvm.org.apache.hadoop.fs.Path(temp_dir), True) # True \u003d 재귀적으로 삭제\n\n        print_timestamp(f\"Successfully saved to single HDFS file: {output_path}\")\n        \n    except Exception as e:\n        print_timestamp(f\"[ERROR] Failed to save to single HDFS file: {output_path}\")\n        print(e)\n        # 에러 발생 시에도 임시 디렉터리 정리를 시도합니다.\n        try:\n            fs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jsc.hadoopConfiguration())\n            fs.delete(spark._jvm.org.apache.hadoop.fs.Path(temp_dir), True)\n            print_timestamp(\"Cleaned up temporary directory after error.\")\n        except:\n            pass\n        raise\n        \n    return output_path\n\n\n# ####################################################################\n# ## --- 3. Core SOH Summary Logic (kslab_bus_soh_summary_v2.py) ---\n# ####################################################################\n\ndef number_sequence(df):\n\n    # vehicle_id와 time으로 정렬\n    df \u003d df.orderBy(\"vehicle_id\", \"time\")\n\n    # 이전 행과 비교하기 위한 Window 함수\n    w \u003d Window.partitionBy(\"vehicle_id\").orderBy(\"time\")\n\n    # 이전 time과 soc_avg 값 가져오기\n    df \u003d df \\\n        .withColumn(\"prev_time\", lag(\"time\", 1).over(w)) \\\n        .withColumn(\"prev_soc\", lag(\"soc_avg\", 1).over(w))\n\n    # 충전 시퀀스 구분 조건\n    # 조건: 이전 time과 현재 time이 10분(600초) 이상 차이 AND 이전 soc가 현재 soc보다 5 이상 큼\n    df \u003d df.withColumn(\"new_seq_flag\",\n        when(\n            (unix_timestamp(col(\"time\")) - unix_timestamp(col(\"prev_time\")) \u003e\u003d 600) \u0026\n            (col(\"prev_soc\") - col(\"soc_avg\") \u003e\u003d 5),\n            1\n        ).otherwise(0)\n    )\n\n    # vehicle_id별로 누적 합으로 시퀀스 번호 생성\n    w2 \u003d Window.partitionBy(\"vehicle_id\").orderBy(\"time\").rowsBetween(Window.unboundedPreceding, Window.currentRow)\n    df \u003d df.withColumn(\"ch_seq\", pyspark_sum(\"new_seq_flag\").over(w2) + 1)\n\n    # 중간 컬럼 제거\n    df \u003d df.drop(\"prev_time\", \"prev_soc\", \"new_seq_flag\")\n\n\n    return df\n\ndef summary_by_seq(df):\n    df_agg \u003d df.groupBy(\"vehicle_id\", \"ch_seq\").agg(\n        pyspark_min(\"time\").alias(\"start_time\"),  # 시퀀스 시작 시간\n        pyspark_max(\"time\").alias(\"end_time\"),  # 시퀀스 종료 시간\n        pyspark_round(pyspark_avg(\"mileage\"), 2).alias(\"mileage\"),  # mileage 평균\n        pyspark_round(pyspark_avg(\"bat_temp\"), 1).alias(\"avg_bat_temp\"),  # bat_temp 평균\n        pyspark_round(pyspark_max(\"pvdiff_avg\"), 3).alias(\"cvdiff\"),  # CELL_VOLT_DIFF 최대\n        pyspark_round(pyspark_max(\"ptdiff_avg\"), 3).alias(\"ctdiff\"),  # CELL_TEMP_DIFF 최대\n        pyspark_round(pyspark_min(\"soc_avg\"), 2).alias(\"start_soc\"),  # 시작 SOC\n        pyspark_round(pyspark_max(\"soc_avg\"), 2).alias(\"end_soc\"),  # 종료 SOC\n        pyspark_round(pyspark_avg(\"soh_avg\"), 2).alias(\"soh_avg\"),  # SOH_AVG 평균\n        pyspark_round((pyspark_max(\"soc_avg\") - pyspark_min(\"soc_avg\")), 2).alias(\"delta_soc\"),  # 최대 SOC - 최소 SOC\n        pyspark_round(pyspark_avg(\"current_avg\"), 2).alias(\"current_avg_mean\"),  # current_avg 평균\n        #pyspark_sum(\"current_avg\").alias(\"current_avg_sum\")  # current_avg 합계\n    )\n\n    # 동일 (vehicle_id, ch_seq) 내에서 마지막 soh 값 추가\n    # [참고] 이때 \u0027soh\u0027 컬럼은 1단계에서 변환된 \u0027ARRAY\u003cDOUBLE\u003e\u0027 타입임\n    w_last \u003d Window.partitionBy(\"vehicle_id\", \"ch_seq\").orderBy(col(\"time\").desc())\n    df_last_soh \u003d (\n        df.withColumn(\"rn\", row_number().over(w_last))\n          .filter(col(\"rn\") \u003d\u003d 1)\n          .select(\"vehicle_id\", \"ch_seq\", col(\"soh\").alias(\"soh\"))\n    )\n\n    df_agg \u003d df_agg.join(df_last_soh, [\"vehicle_id\", \"ch_seq\"], \"left\")\n\n    return df_agg\n\ndef cal_accum_dod(df):\n    \"\"\"\n    누적 DoD 계산 함수 (원본 로직: collect 사용)\n    \"\"\"\n    # 1) vehicle_id, ch_seq로 정렬\n    df \u003d df.orderBy(\"vehicle_id\", \"ch_seq\")\n    \n    # 2) accum_dod \u003d delta_soc / 100을 누적으로 더함\n    w \u003d Window.partitionBy(\"vehicle_id\").orderBy(\"ch_seq\").rowsBetween(Window.unboundedPreceding, Window.currentRow)\n    df \u003d df.withColumn(\"accum_dod\", pyspark_sum((col(\"delta_soc\") / lit(100))).over(w))\n    \n    # 3) mileage와 accum_dod의 회귀식을 계산하여 y절편을 구하고, 절대값을 취해 initial_dod 저장\n    # [경고] .collect()는 대용량 데이터에서 드라이버 메모리 초과를 유발할 수 있음.\n    print_timestamp(\"Collecting data to Pandas for Linear Regression (cal_accum_dod)...\")\n    rows \u003d df.select(\"mileage\", \"accum_dod\").collect()\n    pdf \u003d pd.DataFrame([row.asDict() for row in rows])\n    print_timestamp(f\"Collected {len(pdf)} rows.\")\n    \n    # 전체 데이터에 대해 회귀식 계산\n    X \u003d pdf[[\"mileage\"]].values\n    y \u003d pdf[\"accum_dod\"].values\n    \n    if len(X) \u003e 1 and not np.isnan(X).any() and not np.isnan(y).any():\n        # 선형 회귀 모델 학습\n        reg \u003d LinearRegression()\n        reg.fit(X, y)\n        \n        # y절편 (intercept)의 절대값\n        initial_dod \u003d abs(reg.intercept_)\n    else:\n        # 데이터가 부족하거나 NaN이 있는 경우 0으로 설정\n        initial_dod \u003d 0.0\n    \n    print_timestamp(f\"Calculated initial_dod: {initial_dod}\")\n    \n    # initial_dod를 모든 행에 추가 (상수값)\n    df \u003d df.withColumn(\"initial_dod\", lit(float(initial_dod)))\n    \n    # 4) accum_dod + initial_dod \u003d acc_cycle_cnt\n    df \u003d df.withColumn(\"acc_cycle_cnt\", col(\"accum_dod\") + col(\"initial_dod\"))\n    \n    # 5) acc_cycle_cnt는 소수점 2자리까지 표현\n    df \u003d df.withColumn(\"acc_cycle_cnt\", pyspark_round(col(\"acc_cycle_cnt\"), 2))\n    \n    return df\n\n\n# ####################################################################\n# ## --- 4. Main Process Function (수정됨) ---\n# ####################################################################\n\ndef process_summary_data(spark: SparkSession, vehicle_id: Optional[str] \u003d None, day_of_soh: Optional[str] \u003d None):\n    \"\"\"\n    SOH Summary 데이터 처리 함수 (HDFS CSV 전용)\n    \"\"\"\n    # Step 0: Load data (csv only) \n    print_timestamp(\"Step 0\u003e Loading data\")\n    \n    csv_path_tmpl \u003d SOH_SUMMARY_IO_CONFIG[\u0027input\u0027][\u0027csv_path\u0027]\n    \n    if vehicle_id and \u0027{vehicle_id}\u0027 in csv_path_tmpl:\n        csv_path \u003d csv_path_tmpl.format(vehicle_id\u003dvehicle_id)\n        logger.info(f\"HDFS CSV 입력 경로(치환됨): {csv_path}\")\n        \n    # 2. 템플릿이 없지만 경로 문자열은 있는 경우 -\u003e 그대로 사용\n    elif csv_path_tmpl:\n        csv_path \u003d csv_path_tmpl\n        logger.info(f\"HDFS CSV 입력 경로(고정값): {csv_path}\")\n        \n    # 3. 경로 자체가 없는 경우 -\u003e 에러\n    else:\n        logger.error(\"CSV 경로 설정이 잘못되었습니다.\")\n        sys.exit(0)\n        \n    df \u003d load_data_from_csv(spark, csv_path)\n\n    # CSV 소스일 때도 vehicle_id와 day_of_soh로 필터링\n    # (주의: 1단계에서 이미 차량별/전체기간으로 파일을 만들었다면 필터는 불필요할 수 있음)\n    if vehicle_id:\n        # load_data_from_csv가 이미 1단계에서 생성된 파일을 읽으므로,\n        # 이 파일은 해당 vehicle_id만 포함하고 있다고 가정\n        # df \u003d df.filter(col(\"vehicle_id\") \u003d\u003d vehicle_id)\n        logger.info(f\"데이터는 {vehicle_id} 차량 전용으로 간주합니다.\")\n    \n    if day_of_soh:\n        # day_of_soh가 있으면 해당일 이전 전체 데이터 가져올 것\n        df \u003d df.filter(date_format(col(\"time\"), \"yyyy-MM-dd\") \u003c\u003d day_of_soh)\n        logger.info(f\"CSV 데이터에서 Day of SOH: {day_of_soh} 이전 데이터 필터링\")\n\n\n    if df.count() \u003d\u003d 0:\n        print(\"No Data Loaded. Exiting.\")\n        sys.exit(\"Program terminated due to empty input data.\")\n        \n    print_timestamp(f\"Step 0 - Initial data count: {df.count()}\")\n\n\n    # [수정] 1단계에서 문자열로 저장한 \u0027soh\u0027 컬럼을 다시 \u0027배열\u0027로 변환\n    print_timestamp(\"Converting \u0027soh\u0027 string column back to ArrayType...\")\n    df \u003d df.withColumn(\"soh\", \n        transform(\n            split(col(\"soh\"), \",\"),\n            lambda x: x.cast(\"double\")\n        ).alias(\"soh\")\n    )\n\n    # 1. data filtering (충전데이터만 사용)\n    print_timestamp(\"Step 1\u003e Filtering data\")\n    df \u003d df.filter(col(\"status\") \u003d\u003d \"CHARGE\")\n    df \u003d df.filter((col(\"mileage\") \u003e 0) \u0026 (col(\"soc_avg\") \u003e0) \u0026 (col(\"soc_avg\") \u003c 100) \u0026 (col(\"current_avg\") \u003c -0.5)) \n    print_dfcount(df, \"After Step 1 filtering\")\n     \n    # 2. number_sequence 함수 호출\n    print_timestamp(\"Step 2\u003e Numbering charge sequence\")\n    df \u003d number_sequence(df)\n\n    # 3. summary 테이블 생성\n    print_timestamp(\"Step 3\u003e Summarizing by sequence\")\n    df_agg \u003d summary_by_seq(df)\n\n    # day_of_soh 추가\n    df_agg \u003d df_agg.withColumn(\"day_of_soh\", date_format(col(\"start_time\"), \"yyyy-MM-dd\"))\n\n    # 누적 dod 계산\n    print_timestamp(\"Step 4\u003e Calculating accumulated DoD\")\n    df_agg \u003d cal_accum_dod(df_agg)\n\n    # c-rate 계산\n    print_timestamp(\"Step 5\u003e Calculating C-rate\")\n    df_agg \u003d df_agg.withColumn(\"delta_t_hour\", (unix_timestamp(col(\"end_time\")) - unix_timestamp(col(\"start_time\"))) / 3600)\\\n        .withColumn(\n            \"c_rate\",\n            pyspark_round(\n                when(col(\"delta_t_hour\") !\u003d 0,\n                     (col(\"delta_soc\") / lit(100)) / col(\"delta_t_hour\"))\n                .otherwise(lit(0.0)),\n                2\n            )\n        )\n\n    print_timestamp(\"Step 6\u003e Selecting final columns\")\n    df_result\u003ddf_agg.filter(col(\"c_rate\") \u003e 0)\n    df_result\u003ddf_result.select(\"vehicle_id\", \"day_of_soh\", \"ch_seq\", \"start_time\", \"end_time\", \"mileage\", \"acc_cycle_cnt\", \"avg_bat_temp\", \"cvdiff\", \"ctdiff\",\"start_soc\", \"end_soc\", \"delta_soc\", \"c_rate\",\"soh_avg\", \"soh\")\n    \n    print_dfcount(df_result, \"Final result count\")\n    \n    return df_result\n\n# ####################################################################\n# ## --- 5. Main Execution (Zeppelin 용) ---\n# ####################################################################\n\ndef main():\n    try:\n        \n        vehicle_id \u003d VEHICLE_ID\n        day_of_soh \u003d None # None이면 전체 기간, \u0027YYYY-MM-DD\u0027 형식이면 해당일 이전\n            \n        if not vehicle_id:\n            logger.error(\"Vehicle_id가 필수 인자로 제공되어야 합니다.\")\n            raise ValueError(\"Vehicle_id가 필수 인자로 제공되어야 합니다.\")\n\n        # 제플린이 제공한 \u0027spark\u0027 세션을 그대로 전달합니다.\n        result_df \u003d process_summary_data(spark, vehicle_id\u003dvehicle_id, day_of_soh\u003dday_of_soh)\n        \n        # [수정] HDFS CSV로 저장하기 전, \u0027soh\u0027 배열 컬럼을 다시 문자열로 변환\n        print_timestamp(\"Converting \u0027soh\u0027 ArrayType back to string for CSV saving...\")\n        result_df_for_csv \u003d result_df.withColumn(\"soh\", concat_ws(\",\", col(\"soh\")))\n        \n        # Save results - HDFS CSV로 저장\n        print_timestamp(\"Step 7\u003e Saving results to HDFS\")\n        \n        output_path_tmpl \u003d SOH_SUMMARY_IO_CONFIG[\u0027output\u0027][\u0027csv_path\u0027]\n        output_path \u003d output_path_tmpl.format(vehicle_id\u003dvehicle_id)\n        \n        # vehicle_id와 ch_seq별로 정렬\n        result_df_for_csv \u003d result_df_for_csv.orderBy(\"vehicle_id\", \"ch_seq\")\n        \n        # Spark HDFS CSV 저장 함수 호출\n        save_to_csv(result_df_for_csv, output_path) \n        print(f\"Results saved to HDFS directory: {output_path}\")\n\n        \n    except Exception as e:\n        import traceback\n        traceback.print_exc()\n        raise\n    finally:\n        print_timestamp(\"Main function finished.\")\n        pass\n\n# [필수] 제플린에서 실행하기 위해 main()을 직접 호출\nmain()",
      "user": "anonymous",
