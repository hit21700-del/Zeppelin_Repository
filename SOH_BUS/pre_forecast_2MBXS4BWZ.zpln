{
  "paragraphs": [
    {
      "text": "%spark_single.pyspark\r\n\"\"\"\r\nsoh forecast : soh예측을 위한 forecast코드 (Config/Utils 통합 및 HDFS 버전)\r\n\r\n- 입력 데이터셋(bus_soh_summary): HDFS의 CSV 파일 입력\r\n- XGBoost 모델 학습 및 SOH 예측\r\n- 결과 데이터셋(bus_soh_forecast) : HDFS에 단일 CSV 파일로 저장\r\n\"\"\"\r\n\r\nimport os\r\nimport sys\r\nfrom typing import Optional, List, Dict, Any\r\nimport logging\r\nfrom datetime import datetime\r\n\r\n# Spark 관련 모듈\r\nfrom pyspark.sql import SparkSession, DataFrame\r\nfrom pyspark.sql.functions import (\r\n    lag, lead, col, when, expr, round as pyspark_round, sum as pyspark_sum,\r\n    max as pyspark_max, min as pyspark_min, avg as pyspark_avg,\r\n    abs as pyspark_abs, first as pyspark_first, count, lit, coalesce, unix_timestamp, date_format,\r\n    row_number, split, transform, concat_ws\r\n)\r\nfrom pyspark.sql import functions as F\r\nfrom pyspark.sql.window import Window\r\nfrom pyspark.sql.types import (\r\n    StructType, StructField, StringType, IntegerType,\r\n    DoubleType, TimestampType, BooleanType, ArrayType\r\n)\r\n\r\n# ML/Pandas 관련 모듈\r\nfrom xgboost import XGBRegressor\r\nfrom sklearn.metrics import mean_absolute_error, mean_squared_error\r\nimport pandas as pd\r\nimport numpy as np\r\nimport shap\r\nimport joblib\r\n\r\n# 로깅 설정\r\nlogging.basicConfig(\r\n    level\u003dlogging.INFO,\r\n    format\u003d\u0027%(asctime)s - %(levelname)s - %(message)s\u0027\r\n)\r\nlogger \u003d logging.getLogger(__name__)\r\n\r\n# ####################################################################\r\n# ## --- 1. Configuration (kslab_bus_config.py) ---\r\n# ####################################################################\r\n\r\n# Spark configuration\r\nSPARK_CONFIG \u003d {\r\n    \u0027app_name\u0027: \u0027kslab_busdata_soh_forecast\u0027,\r\n    \u0027executor_memory\u0027: \u002716g\u0027,\r\n    \u0027driver_memory\u0027: \u002716g\u0027,\r\n    \u0027max_to_string_fields\u0027: 100\r\n}\r\n\r\n# SOH Forecast Input/Output configuration (HDFS 경로)\r\nSOH_FORECAST_IO_CONFIG \u003d {\r\n    \u0027input\u0027: {\r\n        \u0027source\u0027: \u0027csv\u0027,\r\n        # ◀◀◀ 2단계(summary)의 출력 경로를 입력으로 사용\r\n        \u0027csv_path\u0027: \"/Data/soh/data/{vehicle_id}/soh_summary_result.csv\",\r\n    },\r\n    \u0027output\u0027: {\r\n        \u0027format\u0027: \u0027csv\u0027,\r\n         # ◀◀◀ 3단계(forecast)의 최종 출력 경로\r\n        \u0027csv_path\u0027: \"/Data/soh/data/{vehicle_id}/soh_forecast_result.csv\",\r\n    }\r\n}\r\n\r\n# ####################################################################\r\n# ## --- 2. Utility Functions (kslab_bus_utils.py) ---\r\n# ####################################################################\r\n\r\ndef print_timestamp(message: str) -\u003e None:\r\n    \"\"\"Print message with current timestamp\"\"\"\r\n    print(f\"[{datetime.now().strftime(\u0027%Y-%m-%d %H:%M:%S\u0027)}] {message}\")\r\n\r\ndef print_dfcount(df: DataFrame, message: str) -\u003e None:\r\n    \"\"\"Print DataFrame count with message\"\"\"\r\n    count \u003d df.count()\r\n    print_timestamp(f\"{message}: {count:,} rows\")\r\n\r\n\r\ndef load_data_from_csv(spark: SparkSession, file_path: str) -\u003e DataFrame:\r\n    \"\"\"Load data from a CSV file (HDFS or local).\"\"\"\r\n    print_timestamp(f\"Loading data from HDFS CSV: {file_path}\")\r\n    try:\r\n        df \u003d spark.read.csv(file_path, header\u003dTrue, inferSchema\u003dTrue)\r\n        return df\r\n    except Exception as e:\r\n        print_timestamp(f\"[ERROR] Failed to read HDFS CSV file: {file_path}\")\r\n        print(e)\r\n        return spark.createDataFrame([], schema\u003dStructType([]))\r\n\r\ndef save_to_csv(df: DataFrame, output_path: str) -\u003e str:\r\n    \"\"\"\r\n    Spark DataFrame을 HDFS에 *단일* CSV 파일로 저장합니다 (덮어쓰기 지원).\r\n    \"\"\"\r\n    print_timestamp(f\"Saving data to HDFS *single file*: {output_path}\")\r\n    \r\n    import os\r\n    base_dir \u003d os.path.dirname(output_path)\r\n    temp_dir \u003d os.path.join(base_dir, \".temp_forecast_save_dir\") # 임시 디렉터리 이름\r\n    \r\n    print_timestamp(f\"Using temporary save directory: {temp_dir}\")\r\n\r\n    try:\r\n        # 1. 데이터를 임시 디렉터리에 저장합니다.\r\n        (df.coalesce(1)\r\n           .write\r\n           .option(\"header\", \"true\")\r\n           .mode(\"overwrite\")\r\n           .csv(temp_dir))\r\n\r\n        # 2. HDFS 파일시스템(Java API)에 접근합니다.\r\n        fs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jsc.hadoopConfiguration())\r\n        \r\n        # 3. 임시 디렉터리에서 스파크가 생성한 \u0027part-\u0027 파일을 찾습니다.\r\n        part_file_pattern \u003d spark._jvm.org.apache.hadoop.fs.Path(f\"{temp_dir}/part-*.csv\")\r\n        file_list_status \u003d fs.globStatus(part_file_pattern)\r\n\r\n        if not file_list_status:\r\n            raise Exception(f\"No \u0027part-\u0027 file found in temp directory: {temp_dir}\")\r\n            \r\n        source_file_path \u003d file_list_status[0].getPath()\r\n        print_timestamp(f\"Found temporary data file: {source_file_path}\")\r\n\r\n        # 4. 최종 목적지 파일 경로를 Hadoop Path 객체로 정의합니다.\r\n        dest_file_path \u003d spark._jvm.org.apache.hadoop.fs.Path(output_path)\r\n\r\n        # 5. 덮어쓰기를 위해 기존 파일을 먼저 삭제합니다.\r\n        print_timestamp(f\"Checking for existing file and deleting if present: {output_path}\")\r\n        if fs.exists(dest_file_path):\r\n            fs.delete(dest_file_path, False) # False \u003d 재귀삭제 안함 (파일이므로)\r\n            print_timestamp(\"Existing file deleted.\")\r\n\r\n        # 6. \u0027part-\u0027 파일의 이름을 원하는 파일 이름(output_path)으로 변경(이동)합니다.\r\n        print_timestamp(f\"Moving file to final destination: {output_path}\")\r\n        fs.rename(source_file_path, dest_file_path)\r\n        \r\n        # 7. 임시 디렉터리를 삭제합니다.\r\n        print_timestamp(f\"Cleaning up temporary directory: {temp_dir}\")\r\n        fs.delete(spark._jvm.org.apache.hadoop.fs.Path(temp_dir), True) # True \u003d 재귀적으로 삭제\r\n\r\n        print_timestamp(f\"Successfully saved to single HDFS file: {output_path}\")\r\n        \r\n    except Exception as e:\r\n        print_timestamp(f\"[ERROR] Failed to save to single HDFS file: {output_path}\")\r\n        print(e)\r\n        # 에러 발생 시에도 임시 디렉터리 정리를 시도합니다.\r\n        try:\r\n            fs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jsc.hadoopConfiguration())\r\n            fs.delete(spark._jvm.org.apache.hadoop.fs.Path(temp_dir), True)\r\n            print_timestamp(\"Cleaned up temporary directory after error.\")\r\n        except:\r\n            pass\r\n        raise\r\n        \r\n    return output_path\r\n\r\n\r\n# ####################################################################\r\n# ## --- 3. Core SOH Forecast Logic (kslab_bus_soh_forecast_v2.py) ---\r\n# ####################################################################\r\n\r\ndef summary_by_day(df):\r\n    \r\n    print_timestamp(\"Summarizing data by day...\")\r\n\r\n    df \u003d df.filter((col(\"delta_soc\")\u003e\u003d5) \u0026 (col(\"c_rate\")\u003e0) \u0026 (col(\"c_rate\")\u003c2.0))\r\n    df \u003d df.withColumn(\"day_of_soh\", date_format(col(\"start_time\"), \"yyyy-MM-dd\"))\r\n\r\n    df_agg \u003d df.groupBy(\"vehicle_id\", \"day_of_soh\").agg(\r\n        pyspark_round(pyspark_avg(\"mileage\"), 2).alias(\"mileage\"),  # mileage 평균\r\n        pyspark_round(pyspark_max(\"acc_cycle_cnt\"), 0).alias(\"acc_cycle_cnt\"),  # acc_cycle_cnt 최대\r\n        pyspark_round(pyspark_avg(\"avg_bat_temp\"), 1).alias(\"avg_bat_temp\"),  # bat_temp 평균\r\n        pyspark_round(pyspark_max(\"cvdiff\")/1000, 3).alias(\"cvdiff\"),  # CELL_VOLT_DIFF 최대\r\n        pyspark_round(pyspark_max(\"ctdiff\"), 3).alias(\"ctdiff\"),  # CELL_TEMP_DIFF 최대\r\n        pyspark_round(pyspark_avg(\"c_rate\"), 2).alias(\"c_rate\"),  # C-RATE 평균\r\n        pyspark_round(pyspark_avg(\"soh_avg\"), 2).alias(\"soh_avg\"),  # SOH_AVG 평균(longterm_soh)\r\n    )\r\n\r\n    # 동일 (vehicle_id, soh_date) 내에서 마지막 soh 값 추가 (max(time) 방식)\r\n    df_last_time \u003d df.groupBy(\"vehicle_id\", \"day_of_soh\").agg(pyspark_max(\"start_time\").alias(\"last_time\"))\r\n    df_last_soh \u003d (\r\n        df.join(df_last_time, [\"vehicle_id\", \"day_of_soh\"])  # join on keys\r\n          .where(col(\"start_time\") \u003d\u003d col(\"last_time\"))\r\n          .select(\"vehicle_id\", \"day_of_soh\", col(\"soh\").alias(\"soh_list_raw\"))\r\n    )\r\n    \r\n    # [수정] soh_list 처리: 2단계에서 저장한 문자열(\"97.2,97.2,...\")을 파싱\r\n    # 원본 로직(regexp_replace) 대신 split을 사용\r\n    df_last_soh \u003d df_last_soh.withColumn(\r\n        \"soh_list\",\r\n        expr(\"\"\"\r\n            transform(\r\n                slice(\r\n                    transform(\r\n                        split(CAST(soh_list_raw AS STRING), \u0027,\u0027),\r\n                        x -\u003e CAST(trim(x) AS DOUBLE)\r\n                    ),\r\n                    1, 6\r\n                ),\r\n                x -\u003e round(x / 1000.0, 3) \r\n            )\r\n        \"\"\")\r\n    ).drop(\"soh_list_raw\")\r\n    \r\n    df_agg \u003d df_agg.join(df_last_soh, [\"vehicle_id\", \"day_of_soh\"], \"left\")\r\n\r\n    return df_agg\r\n\r\ndef process_soh_forecast(spark, vehicle_id\u003dNone, day_of_soh\u003dNone):\r\n    \"\"\"\r\n    SOH 예측 함수 (HDFS CSV 전용)\r\n    \"\"\"\r\n    # Step 0: Load data (csv only) \r\n    print_timestamp(\"Step 0\u003e Loading data\")\r\n\r\n    csv_path_tmpl \u003d SOH_FORECAST_IO_CONFIG[\u0027input\u0027][\u0027csv_path\u0027]\r\n    if vehicle_id and \u0027{vehicle_id}\u0027 in csv_path_tmpl:\r\n        csv_path \u003d csv_path_tmpl.format(vehicle_id\u003dvehicle_id)\r\n        logger.info(f\"HDFS CSV 입력 경로: {csv_path}\")\r\n    else:\r\n        logger.error(\"vehicle_id가 필요합니다.\")\r\n        sys.exit(0)\r\n        \r\n    df \u003d load_data_from_csv(spark, csv_path)\r\n\r\n    # CSV 소스일 때도 vehicle_id와 day_of_soh로 필터링\r\n    if vehicle_id:\r\n        # df \u003d df.filter(col(\"vehicle_id\") \u003d\u003d vehicle_id) # 이미 ID별 파일\r\n        logger.info(f\"CSV 데이터에서 ID: {vehicle_id} 로 간주\")\r\n    \r\n    if day_of_soh:\r\n        # day_of_soh가 있으면 해당일 이전 전체 데이터 가져올 것 (계산은 전체 데이터로)\r\n        df \u003d df.filter(col(\"day_of_soh\") \u003c\u003d day_of_soh)\r\n        logger.info(f\"CSV 데이터에서 Day of SOH: {day_of_soh} 이전 전체 데이터 필터링\")\r\n\r\n\r\n    if df.count() \u003d\u003d 0:\r\n        print(\"No Data Loaded. Exiting.\")\r\n        sys.exit(\"Program terminated due to empty input data.\")\r\n        \r\n    print_timestamp(f\"Step 0 - Initial data count: {df.count()}\")\r\n\r\n    df_summary \u003d summary_by_day(df)\r\n\r\n    # vehicle_id 확인 (DataFrame에서 가져오기)\r\n    if vehicle_id is None:\r\n        vehicle_id \u003d df_summary.select(\u0027vehicle_id\u0027).first()[\u0027vehicle_id\u0027]\r\n        logger.info(f\"DataFrame에서 vehicle_id 추출: {vehicle_id}\")\r\n\r\n    # 모델 입력용 데이터프레임 (시간순 정렬)\r\n    df_summary \u003d df_summary.orderBy(\"vehicle_id\", \"day_of_soh\")\r\n    \r\n    w \u003d Window.partitionBy(\"vehicle_id\").orderBy(\"day_of_soh\")\r\n    df_model \u003d (\r\n        df_summary\r\n        .withColumn(\"day_index\", F.row_number().over(w).cast(\"double\"))\r\n    )\r\n\r\n    # 사용할 feature/target 컬럼\r\n    feature_cols \u003d [\"acc_cycle_cnt\", \"avg_bat_temp\", \"c_rate\", \"cvdiff\", \"ctdiff\"]\r\n    target_col \u003d \"soh_avg\" # 98.4와 같은 스케일의 값\r\n\r\n    # 2. 시계열 분할 (Train/Test)\r\n    print_timestamp(\"Step 2\u003e Splitting data into Train/Test\")\r\n    w3_cnt \u003d Window.partitionBy(\"vehicle_id\")\r\n    df_splittable \u003d (\r\n        df_model\r\n        .withColumn(\"rownum\", F.row_number().over(w))  # day_of_soh 순서로 번호 매김\r\n        .withColumn(\"cnt\", F.count(F.lit(1)).over(w3_cnt))\r\n        .withColumn(\r\n            \"train_flag\",\r\n            (F.col(\"rownum\") \u003c\u003d F.col(\"cnt\") * F.lit(0.8)).cast(\"boolean\")\r\n        )\r\n    )\r\n\r\n    # Spark → pandas 변환 (전체 데이터)\r\n    print_timestamp(\"Step 3\u003e Collecting data to Pandas for ML\")\r\n    rows \u003d df_splittable.select(\"vehicle_id\",\"day_of_soh\",*feature_cols,target_col,\"train_flag\").collect()\r\n    pdf \u003d pd.DataFrame([r.asDict() for r in rows])\r\n    print_timestamp(f\"Collected {len(pdf)} rows.\")\r\n\r\n    # 정렬\r\n    pdf \u003d pdf.sort_values([\"vehicle_id\", \"day_of_soh\"]).reset_index(drop\u003dTrue)\r\n\r\n    # 3. Train/Test 분리\r\n    train_df \u003d pdf[pdf[\"train_flag\"] \u003d\u003d True].copy()\r\n    test_df  \u003d pdf[pdf[\"train_flag\"] \u003d\u003d False].copy()\r\n\r\n    X_train \u003d train_df[feature_cols].values\r\n    y_train \u003d train_df[target_col].values\r\n\r\n    X_test  \u003d test_df[feature_cols].values\r\n    y_test  \u003d test_df[target_col].values\r\n    \r\n    print_timestamp(f\"Train/Test split: {len(X_train)} train, {len(X_test)} test rows.\")\r\n\r\n\r\n    # 4. XGBoost 회귀 모델 학습 또는 로드\r\n    print_timestamp(\"Step 4\u003e Training or Loading XGBoost model\")\r\n    \r\n    # [수정] 모델 경로를 HDFS가 아닌 Zeppelin 서버의 로컬 경로로 설정\r\n    model_dir \u003d f\u0027/tmp/soh_models/{vehicle_id}\u0027 # HDFS가 아닌 로컬 경로\r\n    model_filename \u003d f\u0027xgb_model_{vehicle_id}.pkl\u0027\r\n    model_path \u003d os.path.join(model_dir, model_filename)\r\n    \r\n    # 기존 모델이 있으면 로드, 없으면 학습 후 저장\r\n    if os.path.exists(model_path):\r\n        logger.info(f\"기존 모델 로드: {model_path} (Zeppelin Local FS)\")\r\n        xgb_model \u003d joblib.load(model_path)\r\n    else:\r\n        logger.info(f\"새 모델 학습 시작: {model_path} (Zeppelin Local FS)\")\r\n        xgb_model \u003d XGBRegressor(\r\n            n_estimators\u003d150,\r\n            max_depth\u003d3,\r\n            learning_rate\u003d0.05,\r\n            subsample\u003d0.8,\r\n            colsample_bytree\u003d0.8,\r\n            reg_lambda\u003d2.0,\r\n            reg_alpha\u003d1.0,\r\n            objective\u003d\"reg:squarederror\",\r\n            random_state\u003d42\r\n        )\r\n        \r\n        xgb_model.fit(X_train, y_train)\r\n        \r\n        # 모델 저장\r\n        os.makedirs(model_dir, exist_ok\u003dTrue)\r\n        joblib.dump(xgb_model, model_path)\r\n        logger.info(f\"모델 저장 완료: {model_path}\")\r\n\r\n    # 5. 성능 평가\r\n    print_timestamp(\"Step 5\u003e Evaluating model performance\")\r\n    if len(X_test) \u003e 0:\r\n        y_pred \u003d xgb_model.predict(X_test)\r\n        mae  \u003d mean_absolute_error(y_test, y_pred)\r\n        rmse \u003d mean_squared_error(y_test, y_pred, squared\u003dFalse)\r\n        logger.info(f\"Model Performance - MAE: {mae:.4f}, RMSE: {rmse:.4f}\")\r\n\r\n    # 6. 전 행에 대한 예측 및 변수 중요도 부여 (SHAP 사용)\r\n    print_timestamp(\"Step 6\u003e Calculating predictions and SHAP values\")\r\n\r\n    # 전체 데이터 예측\r\n    pdf[\"soh_pred\"] \u003d xgb_model.predict(pdf[feature_cols].values)\r\n    pdf[\"soh_pred\"] \u003d pdf[\"soh_pred\"].round(2)\r\n    \r\n    # SHAP 값 계산 (변수 중요도 계산용)\r\n    if len(X_test) \u003e 0:\r\n        shap_data \u003d X_test\r\n    else:\r\n        shap_data \u003d pdf[feature_cols].values\r\n    \r\n    try:\r\n        explainer \u003d shap.TreeExplainer(xgb_model)\r\n        shap_values \u003d explainer.shap_values(shap_data)\r\n        \r\n        # 변수 중요도 계산 (SHAP 값의 절대 평균)\r\n        raw_importance \u003d {}\r\n        for i, feature in enumerate(feature_cols):\r\n            importance \u003d np.abs(shap_values[:, i]).mean()\r\n            raw_importance[feature] \u003d float(importance)\r\n        \r\n        if all(v \u003d\u003d 0 for v in raw_importance.values()):\r\n            logger.info(\"SHAP 값이 모두 0입니다. feature_importances_를 사용합니다.\")\r\n            feature_importances \u003d xgb_model.feature_importances_\r\n            for i, feature in enumerate(feature_cols):\r\n                raw_importance[feature] \u003d float(feature_importances[i])\r\n        \r\n        # 중요도 정규화\r\n        total_importance \u003d sum(raw_importance.values())\r\n        \r\n        if total_importance \u003d\u003d 0:\r\n            n_features \u003d len(raw_importance)\r\n            normalized_importance \u003d {k: np.log1p(100.0 / n_features) for k in raw_importance.keys()}\r\n        else:\r\n            normalized_importance \u003d {k: np.log1p((v/total_importance) * 100) for k, v in raw_importance.items()}\r\n        \r\n        formatted_importance \u003d \", \".join([f\"{name}:{round(float(val), 3):.3f}\" for name, val in normalized_importance.items()])\r\n        \r\n    except Exception as e:\r\n        logger.warning(f\"SHAP 계산 중 오류 발생: {e}. feature_importances_를 사용합니다.\")\r\n        importance_vals \u003d xgb_model.feature_importances_.tolist()\r\n        formatted_importance \u003d \", \".join([f\"{name}:{round(float(val), 3):.3f}\" for name, val in zip(feature_cols, importance_vals)])\r\n    \r\n    pdf[\"feature_importance\"] \u003d [formatted_importance] * len(pdf)\r\n    \r\n    # feature_value 딕셔너리 문자열 생성\r\n    def create_feature_value(row):\r\n        items \u003d []\r\n        for name in feature_cols:\r\n            val \u003d row[name]\r\n            if isinstance(val, (int, float)):\r\n                items.append(f\"{name}: {round(float(val), 2):.2f}\")\r\n            else:\r\n                items.append(f\"{name}: {val}\")\r\n        return \"{\" + \", \".join(items) + \"}\"\r\n    \r\n    pdf[\"feature_value\"] \u003d pdf.apply(create_feature_value, axis\u003d1)\r\n\r\n    # Spark DF로 변환\r\n    print_timestamp(\"Step 7\u003e Converting Pandas back to Spark DF\")\r\n    df_pred \u003d spark.createDataFrame(pdf)\r\n    \r\n    # soh_list를 df_agg에서 조인해 가져오기\r\n    df_pred \u003d df_pred.join(df_summary.select(\"vehicle_id\", \"day_of_soh\", \"soh_list\"), [\"vehicle_id\", \"day_of_soh\"], \"left\")\r\n\r\n    # 컬럼명 변경 및 값 변환 (100으로 나누고 소수점 3자리 반올림)\r\n    df_pred \u003d (df_pred\r\n        .withColumnRenamed(\"soh_pred\", \"daily_soh\")\r\n        .withColumnRenamed(\"soh_avg\", \"longterm_soh\")\r\n        .withColumn(\"daily_soh\", pyspark_round(F.col(\"daily_soh\") / 100.0, 3))\r\n        .withColumn(\"longterm_soh\", pyspark_round(F.col(\"longterm_soh\") / 100.0, 3))\r\n    )\r\n\r\n    # 최종 컬럼 순서\r\n    df_pred \u003d df_pred.select(\"vehicle_id\", \"day_of_soh\", \"daily_soh\", \"longterm_soh\", \"feature_value\", \"feature_importance\", \"soh_list\")\r\n    \r\n    # soh_list를 문자열 형태로 변환 (CSV 저장용)\r\n    df_pred \u003d df_pred.withColumn(\r\n        \"soh_list\",\r\n        expr(\"\"\"\r\n            concat(\u0027{\u0027, \r\n                concat_ws(\u0027, \u0027, \r\n                    transform(soh_list, x -\u003e CAST(x AS STRING))\r\n                ), \r\n            \u0027}\u0027)\r\n        \"\"\")\r\n    )\r\n\r\n    return df_pred\r\n\r\n# ####################################################################\r\n# ## --- 5. Main Execution (Zeppelin 용) ---\r\n# ####################################################################\r\n\r\ndef main():\r\n    \r\n    try:\r\n        # ◀◀◀ [수정] vehicle_id를 여기서 하드코딩합니다.\r\n        vehicle_id \u003d \"93\" # 1/2단계에서 사용한 ID와 동일해야 함\r\n        day_of_soh \u003d None # None: 전체 재계산, \u0027YYYY-MM-DD\u0027: 해당일자만 갱신\r\n            \r\n        if not vehicle_id:\r\n            logger.error(\"Vehicle_id가 필수 인자로 제공되어야 합니다.\")\r\n            raise ValueError(\"Vehicle_id가 필수 인자로 제공되어야 합니다.\")\r\n\r\n        # 데이터 처리 실행 (전체 데이터로 계산)\r\n        result_df \u003d process_soh_forecast(spark, vehicle_id\u003dvehicle_id, day_of_soh\u003dday_of_soh)\r\n        \r\n        # HDFS에 저장\r\n        print_timestamp(\"Step 8\u003e Saving results to HDFS\")\r\n        \r\n        output_path_tmpl \u003d SOH_FORECAST_IO_CONFIG[\u0027output\u0027][\u0027csv_path\u0027]\r\n        output_path \u003d output_path_tmpl.format(vehicle_id\u003dvehicle_id)\r\n        \r\n        # HDFS 파일시스템(Java API)에 접근 (파일 존재 여부 확인용)\r\n        fs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jsc.hadoopConfiguration())\r\n        dest_file_path \u003d spark._jvm.org.apache.hadoop.fs.Path(output_path)\r\n        \r\n        # day_of_soh가 지정되었을 때: 기존 파일 읽기 -\u003e 해당일자 제거 -\u003e 새 데이터 추가\r\n        if day_of_soh and fs.exists(dest_file_path):\r\n            logger.info(f\"기존 파일 발견: {output_path}\")\r\n            logger.info(f\"해당일자({day_of_soh}) 데이터를 제거하고 새 데이터를 추가합니다.\")\r\n            \r\n            # 1. HDFS에서 기존 파일 읽기\r\n            existing_df \u003d load_data_from_csv(spark, output_path)\r\n            \r\n            # 2. 해당일자 데이터 제거\r\n            existing_df \u003d existing_df.filter(date_format(col(\"day_of_soh\"), \"yyyy-MM-dd\") !\u003d day_of_soh)\r\n            \r\n            # 3. 새로 계산한 데이터에서 해당일자만 필터링\r\n            new_data_df \u003d result_df.filter(date_format(col(\"day_of_soh\"), \"yyyy-MM-dd\") \u003d\u003d day_of_soh)\r\n            \r\n            # 4. 기존 데이터 + 새 데이터 합치기\r\n            if new_data_df.count() \u003e 0:\r\n                result_df \u003d existing_df.union(new_data_df)\r\n                logger.info(f\"기존 데이터: {existing_df.count()}건, 추가할 새 데이터: {new_data_df.count()}건\")\r\n            else:\r\n                result_df \u003d existing_df\r\n                logger.info(f\"추가할 새 데이터가 없습니다. 기존 데이터만 유지합니다.\")\r\n        \r\n        else:\r\n            if day_of_soh:\r\n                logger.info(f\"day_of_soh가 지정되었으나 기존 파일이 없습니다. 전체 데이터를 새로 씁니다.\")\r\n            else:\r\n                logger.info(f\"전체 데이터를 새로 씁니다.\")\r\n        \r\n        # vehicle_id와 day_of_soh로 정렬\r\n        result_df \u003d result_df.orderBy(\"vehicle_id\", \"day_of_soh\")\r\n        \r\n        # Spark HDFS CSV 저장 함수 호출\r\n        save_to_csv(result_df, output_path) \r\n        print(f\"Results saved to HDFS directory: {output_path}\")\r\n\r\n        \r\n    except Exception as e:\r\n        import traceback\r\n        traceback.print_exc()\r\n        raise\r\n    finally:\r\n        print_timestamp(\"Main function finished.\")\r\n        pass\r\n\r\n# [필수] 제플린에서 실행하기 위해 main()을 직접 호출\r\nmain()",
      "user": "anonymous",
