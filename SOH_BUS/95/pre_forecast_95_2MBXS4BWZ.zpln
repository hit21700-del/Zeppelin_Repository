    {
      "text": "%spark_single.pyspark\n\nimport org.apache.spark.sql.types.DoubleType\n\n# ◀◀◀ 확인할 Parquet 파일 경로\nparquet_path \u003d \"/Data/soh/result/104/intermediate/forecast_preprocessed_104.parquet\"\nvehicle_id \u003d \"104\"\n\nprint(f\"--- {vehicle_id}번 차량의 Parquet 파일 확인 ---\")\nprint(f\"경로: {parquet_path}\\n\")\n\ntry:\n    # 1. Parquet 파일 읽기\n    df \u003d spark.read.parquet(parquet_path)\n\n    # 2. 스키마(컬럼별 타입) 출력\n    print(\"--- 1. 컬럼별 데이터 타입 (스키마) ---\")\n    df.printSchema()\n\n    # 3. 데이터 샘플 10개 출력 (전체 확인)\n    print(\"\\n--- 2. 데이터 샘플 (상위 10개) ---\")\n    df.show(10, truncate\u003dFalse)\n\n    # 4. SHAP이 문제 삼는 피처 컬럼들만 따로 확인\n    print(\"\\n--- 3. 주요 피처(Feature) 컬럼 상세 확인 ---\")\n    feature_cols \u003d [\"acc_cycle_cnt\", \"avg_bat_temp\", \"c_rate\", \"cvdiff\", \"ctdiff\", \"soh_avg\"]\n    df.select(feature_cols).show(20)\n    \n    # 5. (추가) 강제로 Double로 변환 시도해보기 (에러 나는 데이터 찾기)\n    print(\"\\n--- 4. 피처 컬럼 Double 타입 변환 테스트 ---\")\n    try:\n        df_cast_test \u003d df.select(\n            col(\"acc_cycle_cnt\").cast(DoubleType()).alias(\"acc_cycle_cnt_cast\"),\n            col(\"c_rate\").cast(DoubleType()).alias(\"c_rate_cast\"),\n            col(\"cvdiff\").cast(DoubleType()).alias(\"cvdiff_cast\")\n        )\n        df_cast_test.show(10)\n        print(\"\u003e\u003e\u003e Double 타입 변환 테스트 성공 (데이터에 문자열 없음)\")\n    except Exception as e:\n        print(f\"!!! Double 타입 변환 테스트 실패 !!!\")\n        print(e)\n\n\nexcept Exception as e:\n    print(f\"파일을 읽는 중 에러 발생: {parquet_path}\")\n    print(e)",
