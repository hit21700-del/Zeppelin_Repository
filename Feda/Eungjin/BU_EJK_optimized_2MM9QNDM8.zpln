    {
      "text": "%python\n\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n# PARAGRAPH 9 — Save Results to S3 (Parquet)\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n\n# FIX 10: Parquet/snappy instead of CSV → 80% smaller, faster to reload\noutput_cols \u003d [c for c in [\n    \u0027vehicle_id\u0027, \u0027time_1min\u0027, \u0027state\u0027,\n    \u0027alarm_level\u0027, \u0027L1_anomaly_score\u0027,\n    \u0027if_anomaly_state\u0027,\n    \u0027L3_main_anomaly\u0027, \u0027L3_aux_anomaly\u0027, \u0027L3_combined_anomaly\u0027,\n] if c in v95_eval.columns]\n\n# Results\nres_path \u003d f\"s3://{BUCKET_NAME}/{OUTPUT_FOLDER}/level3_phase2_v95_results.parquet\"\nwith fs.open(res_path, \u0027wb\u0027) as f:\n    v95_eval[output_cols].to_parquet(\n        f, engine\u003d\u0027pyarrow\u0027, compression\u003d\u0027snappy\u0027, index\u003dFalse\n    )\nprint(f\"✅ Results     → {res_path}\")\n\n# Summary\nsum_path \u003d f\"s3://{BUCKET_NAME}/{OUTPUT_FOLDER}/level3_improvement_comparison.parquet\"\nwith fs.open(sum_path, \u0027wb\u0027) as f:\n    pd.DataFrame({\n        \u0027version\u0027:     [\u0027previous\u0027, \u0027improved\u0027],\n        \u0027L3_TPR\u0027:      [12.60,  round(L3_tpr, 4)],\n        \u0027L1_L2_L3_OR\u0027: [51.78,  round(L1_L2_L3_OR, 4)],\n    }).to_parquet(f, engine\u003d\u0027pyarrow\u0027, compression\u003d\u0027snappy\u0027, index\u003dFalse)\nprint(f\"✅ Summary     → {sum_path}\")\n\n# State breakdown\nst_path \u003d f\"s3://{BUCKET_NAME}/{OUTPUT_FOLDER}/level3_state_breakdown.parquet\"\nwith fs.open(st_path, \u0027wb\u0027) as f:\n    pd.DataFrame(state_results).to_parquet(\n        f, engine\u003d\u0027pyarrow\u0027, compression\u003d\u0027snappy\u0027, index\u003dFalse\n    )\nprint(f\"✅ State table → {st_path}\")\n\nlog_mem(\"final\")\nprint(\"\\n✅ P9 done — Level 3 Phase 2 complete!\")",
