    {
      "text": "%python\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n# PARAGRAPH 3 — Load \u0026 Prepare Data\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\nlog_mem(\"before data load\")\r\n# ── Main data ───────────────────────────────────────────────────────────────\r\nmain_path \u003d f\"s3://{BUCKET_NAME}/{INPUT_FOLDER}/df_1min_alarm_v3_p99.csv\"\r\nprint(f\"Loading: {main_path}\")\r\nwith fs.open(main_path, \u0027rb\u0027) as f:\r\n    df \u003d pd.read_csv(f, dtype\u003dDTYPE_MAP, low_memory\u003dFalse)\r\ndf[\u0027time_1min\u0027] \u003d pd.to_datetime(df[\u0027time_1min\u0027])\r\nlog_mem(\"after CSV load\")\r\nprint(f\"  Rows: {len(df):,}  RAM: {df.memory_usage(deep\u003dTrue).sum()/1e6:.0f} MB\")\r\n# ── Derived features ────────────────────────────────────────────────────────\r\n# FIX 2: vectorized sum — no copy\r\ncurrent_cols \u003d [f\u0027current_P{i}\u0027 for i in range(1, 9) if f\u0027current_P{i}\u0027 in df.columns]\r\ndf[\u0027current_total\u0027] \u003d df[current_cols].sum(axis\u003d1).astype(np.float32)\r\n# FIX 3: .transform() avoids .rolling().max().values intermediate copy\r\nfor col in [\u0027max_temp\u0027, \u0027c_rate\u0027, \u0027pack_soc_std\u0027]:\r\n    if col in df.columns:\r\n        df[f\u0027{col}_rolling_max\u0027] \u003d (\r\n            df.groupby(\u0027vehicle_id\u0027)[col]\r\n            .transform(lambda x: x.rolling(5, min_periods\u003d1).max())\r\n            .astype(np.float32)\r\n        )\r\nlog_mem(\"after derived features\")\r\n# ── Level 2 results ─────────────────────────────────────────────────────────\r\nl2_path \u003d f\"s3://{BUCKET_NAME}/{INPUT_FOLDER}/level2_results.csv\"\r\nprint(f\"\\nLoading Level 2: {l2_path}\")\r\nwith fs.open(l2_path, \u0027rb\u0027) as f:\r\n    df_l2 \u003d pd.read_csv(\r\n        f,\r\n        dtype\u003d{\u0027vehicle_id\u0027: \u0027int16\u0027, \u0027if_anomaly_state\u0027: \u0027int8\u0027},\r\n        low_memory\u003dFalse\r\n    )\r\ndf_l2[\u0027time_1min\u0027] \u003d pd.to_datetime(df_l2[\u0027time_1min\u0027])\r\nl2_cols \u003d [c for c in [\u0027vehicle_id\u0027, \u0027time_1min\u0027,\r\n                        \u0027if_score_charging\u0027, \u0027if_score_driving\u0027,\r\n                        \u0027if_score_idling\u0027, \u0027if_score_resting\u0027,\r\n                        \u0027if_anomaly_state\u0027] if c in df_l2.columns]\r\ndf \u003d df.merge(df_l2[l2_cols], on\u003d[\u0027vehicle_id\u0027, \u0027time_1min\u0027], how\u003d\u0027left\u0027)\r\n# Free L2 immediately after merge\r\ndel df_l2; gc.collect()\r\nlog_mem(\"after L2 merge\")\r\n# FIX 4: .query() returns a view — no DataFrame copy unlike .copy()\r\ndf_normal \u003d df.query(\u0027alarm_level \u003d\u003d 0\u0027)\r\nprint(f\"\\n✅ P3 done | total\u003d{len(df):,}  normal\u003d{len(df_normal):,}\")",
