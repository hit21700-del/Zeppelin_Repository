    {
      "text": "%python\r\n\r\ndef get_s3_fs():\r\n    return s3fs.S3FileSystem(\r\n        key\u003d\u00278XTYLABJCSLJKUTQBK94\u0027,\r\n        secret\u003d\u0027fKlCAYQBPEA9JOoyrfhTsIeVXr2j58M8upPCAVVR\u0027,\r\n        endpoint_url\u003d\u0027http://192.168.0.105:80\u0027,\r\n        client_kwargs\u003d{\u0027endpoint_url\u0027: \u0027http://192.168.0.105:80\u0027}\r\n    )\r\n\r\n\r\ndef log_memory(label: str) -\u003e float:\r\n    avail    \u003d psutil.virtual_memory().available / 1e9\r\n    used_pct \u003d psutil.virtual_memory().percent\r\n    print(f\"    [MEM] {label}: available\u003d{avail:.1f}GB  used\u003d{used_pct}%\")\r\n    return avail\r\n\r\n\r\ndef get_valid_cols(df, prefix, max_pack\u003d8):\r\n    \"\"\"Return only pack columns that contain real data.\"\"\"\r\n    valid \u003d []\r\n    for j in range(1, max_pack + 1):\r\n        col \u003d f\u0027{prefix}_P{j}\u0027\r\n        if col not in df.columns:\r\n            continue\r\n        if df[col].eq(0).all() or df[col].nunique() \u003c\u003d 1:\r\n            continue\r\n        valid.append(col)\r\n    return valid\r\n\r\n\r\ndef make_agg_dict(df, exclude_cols):\r\n    \"\"\"Auto-generate aggregation rules based on column names/types.\"\"\"\r\n    agg \u003d {}\r\n    for col in df.columns:\r\n        if col in exclude_cols:\r\n            continue\r\n        if col in [\u0027soc_group\u0027, \u0027temp_group\u0027, \u0027state\u0027, \u0027dnr\u0027, \u0027driving_mode\u0027]:\r\n            agg[col] \u003d \u0027first\u0027\r\n        elif any(x in col for x in [\r\n            \u0027risk_score\u0027, \u0027warn_\u0027, \u0027is_charging\u0027, \u0027is_stopped\u0027,\r\n            \u0027is_key_on\u0027, \u0027is_parking_brake_on\u0027, \u0027is_charger_connected\u0027,\r\n            \u0027thermal_risk\u0027, \u0027voltage_risk\u0027, \u0027retarder\u0027, \u0027rest_start\u0027\r\n        ]):\r\n            agg[col] \u003d \u0027max\u0027\r\n        elif any(x in col for x in [\r\n            \u0027max_temp\u0027, \u0027max_cell\u0027, \u0027temp_gradient\u0027, \u0027temp_change\u0027,\r\n            \u0027temp_acceleration\u0027, \u0027heat_generation\u0027, \u0027joule_heat\u0027,\r\n            \u0027voltage_change\u0027, \u0027dW_dt\u0027\r\n        ]):\r\n            agg[col] \u003d \u0027max\u0027\r\n        elif \u0027soh\u0027 in col.lower():\r\n            agg[col] \u003d \u0027min\u0027\r\n        elif col \u003d\u003d \u0027mileage\u0027:\r\n            agg[col] \u003d \u0027max\u0027\r\n        elif any(x in col for x in [\r\n            \u0027rest_voltage_recovery\u0027, \u0027rest_dV_dt\u0027, \u0027dV_dAh_charging\u0027\r\n        ]):\r\n            agg[col] \u003d \u0027mean\u0027\r\n        elif \u0027_normalized\u0027 in col:\r\n            agg[col] \u003d \u0027mean\u0027\r\n        elif df[col].dtype in [\u0027float64\u0027, \u0027int64\u0027, \u0027float32\u0027, \u0027int32\u0027]:\r\n            agg[col] \u003d \u0027mean\u0027\r\n        else:\r\n            agg[col] \u003d \u0027first\u0027\r\n    return agg\r\n\r\n\r\ndef list_s3_input_files(fs):\r\n    \"\"\"List all cleaned_*.csv files in the S3 input folder.\"\"\"\r\n    all_files \u003d fs.ls(f\"s3://{BUCKET_NAME}/{INPUT_FOLDER}/\")\r\n    return sorted([\r\n        f\"s3://{f}\" for f in all_files\r\n        if re.search(r\u0027cleaned_\\d+\\.csv$\u0027, f)\r\n    ])\r\n\r\nprint(\"✅ P2 done — utility functions ready\")\r\n\r\n",
      "user": "anonymous",
      "dateUpdated": "2026-03-26 10:13:04.005",
      "progress": 0,
