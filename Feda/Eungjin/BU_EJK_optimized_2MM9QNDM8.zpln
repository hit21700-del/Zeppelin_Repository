    {
      "text": "%python\n\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n# PARAGRAPH 6 — Train Auxiliary Model (Driving + Charging)\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n\nlog_mem(\"before aux model\")\n\n# FIX 7: .query() — no .copy()\naux_data \u003d df_normal.query(\"state in [\u0027driving\u0027, \u0027charging\u0027]\")\nprint(f\"Aux data: {len(aux_data):,} rows\")\nfor s in [\u0027driving\u0027, \u0027charging\u0027]:\n    print(f\"  {s}: {(aux_data[\u0027state\u0027] \u003d\u003d s).sum():,}\")\n\naux_seqs, aux_scaler \u003d create_sequences_fast(\n    aux_data, OPTIMAL_FEATURES, OPTIMAL_SEQ_LEN\n)\nprint(f\"Sequences: {len(aux_seqs):,}  RAM: {aux_seqs.nbytes/1e6:.0f} MB\")\n\naux_model \u003d build_gru_ae(OPTIMAL_SEQ_LEN, len(OPTIMAL_FEATURES))\naux_model.fit(aux_seqs, aux_seqs, epochs\u003d50, batch_size\u003d256,\n                  validation_split\u003d0.1,\n                  callbacks\u003d[EarlyStopping(monitor\u003d\u0027val_loss\u0027, patience\u003d5, restore_best_weights\u003dTrue)],\n                  verbose\u003d1)\n\naux_errors    \u003d reconstruction_errors(aux_seqs, aux_model)\naux_threshold \u003d np.percentile(aux_errors, 90)\nprint(f\"✓ P90 \u003d {aux_threshold:.4f}\")\n\ndel aux_seqs, aux_errors; gc.collect()\nlog_mem(\"after aux model\")\nprint(\"✅ P6 done\")\n\n",
      "user": "anonymous",
      "dateUpdated": "2026-03-26 10:13:04.006",
