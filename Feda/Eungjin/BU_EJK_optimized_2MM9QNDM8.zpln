    {
      "text": "%python\n\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n# PARAGRAPH 5 — Train Main Models (4 states)\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n\nmain_models     \u003d {}\nmain_thresholds \u003d {}\nmain_scalers    \u003d {}\n\nfor state in [\u0027charging\u0027, \u0027driving\u0027, \u0027idling\u0027, \u0027resting\u0027]:\n    print(f\"\\n[Main model: {state}]\")\n\n    # FIX 6: .query() — no .copy() of df_normal\n    state_data \u003d df_normal.query(\u0027state \u003d\u003d @state\u0027)\n    print(f\"  Rows: {len(state_data):,}\")\n    for vid in ALL_VEHICLES:\n        cnt \u003d (state_data[\u0027vehicle_id\u0027] \u003d\u003d vid).sum()\n        print(f\"    vehicle {vid}: {cnt:,}\")\n\n    seqs, scaler \u003d create_sequences_fast(state_data, OPTIMAL_FEATURES, OPTIMAL_SEQ_LEN)\n\n    if len(seqs) \u003c 100:\n        print(f\"  ⚠️  Insufficient data — skipping\")\n        continue\n\n    print(f\"  Sequences: {len(seqs):,}  RAM: {seqs.nbytes/1e6:.0f} MB\")\n    log_mem(f\"before {state} fit\")\n\n    model \u003d build_gru_ae(OPTIMAL_SEQ_LEN, len(OPTIMAL_FEATURES))\n    model.fit(seqs, seqs, epochs\u003d50, batch_size\u003d256,\n              validation_split\u003d0.1,\n              callbacks\u003d[EarlyStopping(monitor\u003d\u0027val_loss\u0027, patience\u003d5, restore_best_weights\u003dTrue)],\n              verbose\u003d1)\n\n    errors    \u003d reconstruction_errors(seqs, model)\n    pct       \u003d 85 if state \u003d\u003d \u0027resting\u0027 else 90\n    threshold \u003d np.percentile(errors, pct)\n    print(f\"  ✓ P{pct} \u003d {threshold:.4f}\")\n\n    main_models[state]     \u003d model\n    main_thresholds[state] \u003d threshold\n    main_scalers[state]    \u003d scaler\n\n    # Free sequences right after threshold is computed\n    del seqs, errors; gc.collect()\n    log_mem(f\"after {state} cleanup\")\n\nprint(f\"\\n✅ P5 done — models trained: {list(main_models.keys())}\")\n\n",
      "user": "anonymous",
      "dateUpdated": "2026-03-26 10:13:04.006",
