    {
      "text": "%python\n\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n# PARAGRAPH 2 — Load Phase 1 Config from S3\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n\nconfig_path \u003d f\"s3://{BUCKET_NAME}/{INPUT_FOLDER}/level3_phase1_optimal_config.json\"\n\ntry:\n    with fs.open(config_path, \u0027r\u0027) as f:\n        cfg \u003d json.load(f)\n    OPTIMAL_SEQ_LEN  \u003d cfg[\u0027sequence_length\u0027]\n    OPTIMAL_FEATURES \u003d cfg[\u0027features\u0027]\n    print(f\"Config loaded from S3\")\nexcept Exception as e:\n    print(f\"Config load failed ({e}) — using defaults\")\n    OPTIMAL_SEQ_LEN  \u003d 60\n    OPTIMAL_FEATURES \u003d [\n        \u0027max_temp\u0027, \u0027max_cell_t_diff\u0027, \u0027max_temp_rolling_max\u0027,\n        \u0027joule_heat\u0027, \u0027c_rate\u0027, \u0027c_rate_rolling_max\u0027,\n        \u0027cooling_efficiency\u0027,\n        \u0027pack_soc_std\u0027, \u0027pack_soc_std_rolling_max\u0027,\n        \u0027max_cell_v_diff\u0027, \u0027voltage_volatility\u0027,\n        \u0027current_total\u0027,\n    ]\n\nprint(f\"  Sequence length : {OPTIMAL_SEQ_LEN}\")\nprint(f\"  Features        : {len(OPTIMAL_FEATURES)}\")\nprint(\"P2 done\")",
      "user": "anonymous",
