    {
      "text": "%python\r\n\r\nimport pandas as pd\r\nimport numpy as np\r\nfrom datetime import datetime\r\nimport warnings\r\nimport re\r\nimport os\r\nimport gc\r\nimport time\r\nimport psutil\r\nimport s3fs\r\nfrom numba import jit\r\nfrom multiprocessing import Pool, cpu_count\r\nwarnings.filterwarnings(\u0027ignore\u0027)\r\n\r\n# S3 Configuration\r\nBUCKET_NAME   \u003d \"quantum\"\r\nINPUT_FOLDER  \u003d \"data_folder\"\r\nOUTPUT_FOLDER \u003d \"output_folder\"\r\n\r\n# dtype map — float32 saves ~50% RAM vs default float64\r\nDTYPE_MAP \u003d {\r\n    \u0027vehicle_id\u0027:           \u0027int16\u0027,\r\n    \u0027bus_speed\u0027:            \u0027float32\u0027,\r\n    \u0027is_key_on\u0027:            \u0027int8\u0027,\r\n    \u0027is_charger_connected\u0027: \u0027int8\u0027,\r\n    \u0027is_parking_brake_on\u0027:  \u0027int8\u0027,\r\n    \u0027mileage\u0027:              \u0027float32\u0027,\r\n}\r\nfor _prefix in [\u0027cell_max_t\u0027, \u0027cell_min_t\u0027, \u0027cell_max_v\u0027, \u0027cell_min_v\u0027,\r\n                 \u0027voltage\u0027, \u0027current\u0027, \u0027soc\u0027, \u0027soh\u0027]:\r\n    for _j in range(1, 9):\r\n        DTYPE_MAP[f\u0027{_prefix}_P{_j}\u0027] \u003d \u0027float32\u0027\r\n\r\nprint(\"✅ P1 done — imports \u0026 config ready\")\r\n\r\n",
      "user": "anonymous",
      "dateUpdated": "2026-03-26 10:13:04.005",
      "progress": 0,
