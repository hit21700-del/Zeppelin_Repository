      "text": "%python\r\n\r\nimport psutil\r\nimport os\r\n\r\n# CPU\r\nprint(f\"CPU cores (logical): {psutil.cpu_count()}\")\r\nprint(f\"CPU cores (physical): {psutil.cpu_count(logical\u003dFalse)}\")\r\n\r\n# Memory - cgroup limit (Pod actual limit)\r\ntry:\r\n    with open(\u0027/sys/fs/cgroup/memory/memory.limit_in_bytes\u0027) as f:\r\n        limit \u003d int(f.read().strip())\r\n    print(f\"\\nPod memory limit: {limit/1e9:.1f} GB\")\r\nexcept:\r\n    try:\r\n        with open(\u0027/sys/fs/cgroup/memory.max\u0027) as f:\r\n            val \u003d f.read().strip()\r\n        print(f\"\\nPod memory limit: {\u0027unlimited\u0027 if val \u003d\u003d \u0027max\u0027 else f\u0027{int(val)/1e9:.1f} GB\u0027}\")\r\n    except:\r\n        print(\"\\nPod memory limit: unknown\")\r\n\r\n# psutil (host level)\r\nvm \u003d psutil.virtual_memory()\r\nprint(f\"Host total RAM: {vm.total/1e9:.1f} GB\")\r\nprint(f\"Host available: {vm.available/1e9:.1f} GB\")\r\n\r\n# CPU quota (cgroup)\r\ntry:\r\n    with open(\u0027/sys/fs/cgroup/cpu/cpu.cfs_quota_us\u0027) as f:\r\n        quota \u003d int(f.read().strip())\r\n    with open(\u0027/sys/fs/cgroup/cpu/cpu.cfs_period_us\u0027) as f:\r\n        period \u003d int(f.read().strip())\r\n    if quota \u003e 0:\r\n        print(f\"\\nPod CPU limit: {quota/period:.1f} cores\")\r\n    else:\r\n        print(f\"\\nPod CPU limit: unlimited\")\r\nexcept:\r\n    try:\r\n        with open(\u0027/sys/fs/cgroup/cpu.max\u0027) as f:\r\n            val \u003d f.read().strip()\r\n        print(f\"\\nPod CPU limit: {val}\")\r\n    except:\r\n        print(\"\\nPod CPU limit: unknown\")",
      "user": "anonymous",
