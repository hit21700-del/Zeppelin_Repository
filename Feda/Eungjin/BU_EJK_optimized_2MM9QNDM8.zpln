      "id": "paragraph_1774485833476_2141390093",
      "dateCreated": "2026-03-26 10:13:04.005",
      "status": "READY"
    },
    {
      "text": "%python\r\n\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\n# PARAGRAPH 4 — Core Functions: process_single_file \u0026 merge_and_save\r\n# (Run once per session)\r\n# \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\r\ndef process_single_file(s3_path: str):\r\n    \"\"\"\r\n    Stream a single cleaned_*.csv from S3.\r\n    - float32 dtype       → ~50% less RAM\r\n    - .transform()        → no intermediate DataFrame copies\r\n    - Numba JIT           → fast DCIR and dT/dAh loops\r\n    - Parquet output      → 80% smaller than CSV\r\n    \"\"\"\r\n    fs \u003d get_s3_fs()\r\n\r\n    match       \u003d re.search(r\u0027cleaned_(\\d+)\\.csv\u0027, s3_path)\r\n    file_number \u003d match.group(1) if match else \u00270\u0027\r\n\r\n    print(f\"\\n{\u0027\u003d\u0027*70}\")\r\n    print(f\"[File {file_number}] {os.path.basename(s3_path)}\")\r\n    print(f\"{\u0027\u003d\u0027*70}\")\r\n\r\n    # ------------------------------------------------------------------\r\n    # 1. Memory-efficient load from S3\r\n    # ------------------------------------------------------------------\r\n    log_memory(\"before load\")\r\n    with fs.open(s3_path, \u0027rb\u0027) as f:\r\n        df \u003d pd.read_csv(f, dtype\u003dDTYPE_MAP, low_memory\u003dFalse)\r\n    df[\u0027time\u0027] \u003d pd.to_datetime(df[\u0027time\u0027])\r\n    log_memory(\"after load\")\r\n    print(f\"  Loaded: {len(df):,} rows / {len(df.columns)} cols  \"\r\n          f\"({df.memory_usage(deep\u003dTrue).sum()/1e6:.1f} MB)\")\r\n\r\n    # ------------------------------------------------------------------\r\n    # 2. Detect valid pack columns\r\n    # ------------------------------------------------------------------\r\n    temp_max_cols   \u003d get_valid_cols(df, \u0027cell_max_t\u0027)\r\n    temp_min_cols   \u003d get_valid_cols(df, \u0027cell_min_t\u0027)\r\n    cell_max_v_cols \u003d get_valid_cols(df, \u0027cell_max_v\u0027)\r\n    cell_min_v_cols \u003d get_valid_cols(df, \u0027cell_min_v\u0027)\r\n    voltage_cols    \u003d get_valid_cols(df, \u0027voltage\u0027)\r\n    current_cols    \u003d get_valid_cols(df, \u0027current\u0027)\r\n    soc_cols        \u003d get_valid_cols(df, \u0027soc\u0027)\r\n    soh_cols        \u003d get_valid_cols(df, \u0027soh\u0027)\r\n    print(f\"  Valid packs: {len(voltage_cols)}\")\r\n\r\n    # Pre-compute numpy arrays once — reused throughout\r\n    temp_max_arr   \u003d df[temp_max_cols].values.astype(np.float32)\r\n    temp_min_arr   \u003d df[temp_min_cols].values.astype(np.float32)\r\n    cell_max_v_arr \u003d df[cell_max_v_cols].values.astype(np.float32)\r\n    cell_min_v_arr \u003d df[cell_min_v_cols].values.astype(np.float32)\r\n    voltage_arr    \u003d df[voltage_cols].values.astype(np.float32)\r\n    current_arr    \u003d df[current_cols].values.astype(np.float32)\r\n    soc_arr        \u003d df[soc_cols].values.astype(np.float32)\r\n    soh_arr        \u003d df[soh_cols].values.astype(np.float32)\r\n\r\n    voltage_mean \u003d voltage_arr.mean(axis\u003d1)\r\n    current_sum  \u003d current_arr.sum(axis\u003d1)\r\n\r\n    # ------------------------------------------------------------------\r\n    # A. Original 30 derived features (fully vectorized)\r\n    # ------------------------------------------------------------------\r\n    print(\"  [A] Original 30 features...\")\r\n\r\n    df[\u0027max_temp\u0027]        \u003d temp_max_arr.max(axis\u003d1).astype(np.float32)\r\n    df[\u0027max_cell_t_diff\u0027] \u003d (temp_max_arr.max(axis\u003d1) - temp_min_arr.min(axis\u003d1)).astype(np.float32)\r\n    df[\u0027max_cell_v_diff\u0027] \u003d np.abs(cell_max_v_arr.max(axis\u003d1) - cell_min_v_arr.min(axis\u003d1)).astype(np.float32)\r\n    df[\u0027cell_v_std\u0027]      \u003d voltage_arr.std(axis\u003d1).astype(np.float32)\r\n    df[\u0027pack_soc_mean\u0027]   \u003d soc_arr.mean(axis\u003d1).astype(np.float32)\r\n    df[\u0027pack_soc_std\u0027]    \u003d soc_arr.std(axis\u003d1).astype(np.float32)\r\n    df[\u0027soh_min\u0027]         \u003d soh_arr.min(axis\u003d1).astype(np.float32)\r\n    df[\u0027total_power_kw\u0027]  \u003d (voltage_mean * current_sum / 1000).astype(np.float32)\r\n\r\n    v_s    \u003d pd.Series(voltage_mean, index\u003ddf.index)\r\n    c_s    \u003d pd.Series(current_sum,  index\u003ddf.index)\r\n    v_diff \u003d df.groupby(\u0027vehicle_id\u0027)[\u0027vehicle_id\u0027].transform(lambda x: v_s.diff())\r\n    c_diff \u003d df.groupby(\u0027vehicle_id\u0027)[\u0027vehicle_id\u0027].transform(lambda x: c_s.diff())\r\n    df[\u0027estimated_resistance\u0027] \u003d np.where(\r\n        np.abs(c_diff) \u003e 1, np.abs(v_diff / c_diff), np.nan\r\n    ).astype(np.float32)\r\n    del v_diff, c_diff\r\n\r\n    df[\u0027thermal_risk_score\u0027] \u003d (\r\n        (df[\u0027max_temp\u0027] \u003e\u003d 50).astype(np.int8) +\r\n        (df[\u0027max_cell_t_diff\u0027] \u003e\u003d 8).astype(np.int8)\r\n    )\r\n    df[\u0027voltage_risk_score\u0027] \u003d (\r\n        (df[\u0027max_cell_v_diff\u0027] \u003e 200).astype(np.int8) +\r\n        (df[\u0027cell_v_std\u0027] \u003e 50).astype(np.int8)\r\n    )\r\n    df[\u0027temp_gradient\u0027] \u003d (\r\n        df.groupby(\u0027vehicle_id\u0027)[\u0027max_temp\u0027]\r\n        .transform(lambda x: x.diff()).astype(np.float32)\r\n    )\r\n    df[\u0027temp_acceleration\u0027] \u003d (\r\n        df.groupby(\u0027vehicle_id\u0027)[\u0027temp_gradient\u0027]\r\n        .transform(lambda x: x.diff()).astype(np.float32)\r\n    )\r\n    df[\u0027cell_v_cv\u0027]      \u003d (df[\u0027cell_v_std\u0027] / (voltage_mean + 1e-6)).astype(np.float32)\r\n    df[\u0027pack_soc_range\u0027] \u003d (soc_arr.max(axis\u003d1) - soc_arr.min(axis\u003d1)).astype(np.float32)\r\n    df[\u0027soh_std\u0027]        \u003d soh_arr.std(axis\u003d1).astype(np.float32)\r\n\r\n    BATTERY_CAPACITY \u003d 300\r\n    df[\u0027c_rate\u0027]        \u003d (np.abs(current_sum) / BATTERY_CAPACITY).astype(np.float32)\r\n    df[\u0027power_density\u0027] \u003d (df[\u0027total_power_kw\u0027] / len(voltage_cols)).astype(np.float32)\r\n\r\n    df[\u0027temp_rolling_std_5min\u0027] \u003d (\r\n        df.groupby(\u0027vehicle_id\u0027)[\u0027max_temp\u0027]\r\n        .transform(lambda x: x.rolling(300, min_periods\u003d1).std()).astype(np.float32)\r\n    )\r\n    df[\u0027voltage_volatility\u0027] \u003d (\r\n        df.groupby(\u0027vehicle_id\u0027)[\u0027vehicle_id\u0027]\r\n        .transform(lambda x: pd.Series(voltage_mean, index\u003dx.index)\r\n                   .rolling(60, min_periods\u003d1).std()).astype(np.float32)\r\n    )\r\n    df[\u0027accel_rate\u0027] \u003d (\r\n        df.groupby(\u0027vehicle_id\u0027)[\u0027bus_speed\u0027]\r\n        .transform(lambda x: x.diff()).astype(np.float32)\r\n    )\r\n    df[\u0027decel_rate\u0027] \u003d df[\u0027accel_rate\u0027].clip(upper\u003d0).astype(np.float32)\r\n    df[\u0027is_stopped\u0027] \u003d ((df[\u0027bus_speed\u0027] \u003d\u003d 0) \u0026 (df[\u0027is_key_on\u0027] \u003d\u003d 1)).astype(np.int8)\r\n    df[\u0027regen_ratio\u0027] \u003d (\r\n        pd.Series((current_sum \u003c 0).astype(np.int8), index\u003ddf.index)\r\n        .rolling(60, min_periods\u003d1).mean().astype(np.float32)\r\n    )\r\n    df[\u0027driving_mode\u0027] \u003d pd.cut(\r\n        df[\u0027bus_speed\u0027], bins\u003d[-1, 0, 20, 60, 120], labels\u003d[0, 1, 2, 3]\r\n    ).astype(np.int8)\r\n    df[\u0027is_charging\u0027] \u003d (\r\n        (df[\u0027is_charger_connected\u0027] \u003d\u003d 1) | (current_sum \u003c 0)\r\n    ).astype(np.int8)\r\n\r\n    soc_chg \u003d df.groupby(\u0027vehicle_id\u0027)[\u0027pack_soc_mean\u0027].transform(lambda x: x.diff())\r\n    df[\u0027depth_of_discharge\u0027] \u003d soc_chg.clip(upper\u003d0).abs().astype(np.float32)\r\n    del soc_chg\r\n\r\n    ct \u003d np.abs(current_sum)\r\n    df[\u0027peak_current_ratio\u0027] \u003d np.where(\r\n        pd.Series(ct).rolling(60, min_periods\u003d1).mean().values \u003e 0,\r\n        pd.Series(ct).rolling(60, min_periods\u003d1).max().values /\r\n        pd.Series(ct).rolling(60, min_periods\u003d1).mean().values, 1\r\n    ).astype(np.float32)\r\n    del ct\r\n\r\n    temp_chg \u003d df.groupby(\u0027vehicle_id\u0027)[\u0027max_temp\u0027].transform(lambda x: x.diff())\r\n    df[\u0027cooling_efficiency\u0027] \u003d temp_chg.clip(upper\u003d0).abs().astype(np.float32)\r\n    del temp_chg\r\n\r\n    df[\u0027heat_generation\u0027] \u003d (\r\n        (current_sum ** 2) * df[\u0027estimated_resistance\u0027].fillna(0)\r\n    ).astype(np.float32)\r\n\r\n    gc.collect()\r\n    print(f\"      ✓ Done  |  cols: {len(df.columns)}\")\r\n    log_memory(\"after A\")\r\n\r\n    # ------------------------------------------------------------------\r\n    # B. New 28 derived features\r\n    # ------------------------------------------------------------------\r\n    print(\"  [B] New 28 features...\")\r\n\r\n    df[\u0027state\u0027] \u003d \u0027unknown\u0027\r\n    df.loc[df[\u0027is_charger_connected\u0027] \u003d\u003d 1, \u0027state\u0027] \u003d \u0027charging\u0027\r\n    df.loc[(df[\u0027is_key_on\u0027] \u003d\u003d 0) \u0026 (df[\u0027state\u0027] \u003d\u003d \u0027unknown\u0027), \u0027state\u0027] \u003d \u0027resting\u0027\r\n    df.loc[(df[\u0027is_key_on\u0027] \u003d\u003d 1) \u0026 (df[\u0027bus_speed\u0027] \u003e 5)  \u0026 (df[\u0027state\u0027] \u003d\u003d \u0027unknown\u0027), \u0027state\u0027] \u003d \u0027driving\u0027\r\n    df.loc[(df[\u0027is_key_on\u0027] \u003d\u003d 1) \u0026 (df[\u0027bus_speed\u0027] \u003c\u003d 5) \u0026 (df[\u0027state\u0027] \u003d\u003d \u0027unknown\u0027), \u0027state\u0027] \u003d \u0027idling\u0027\r\n\r\n    vr_std \u003d df.groupby(\u0027vehicle_id\u0027)[\u0027vehicle_id\u0027].transform(\r\n        lambda x: pd.Series(voltage_mean, index\u003dx.index).rolling(60, min_periods\u003d1).std()\r\n    )\r\n    tr_std \u003d df.groupby(\u0027vehicle_id\u0027)[\u0027max_temp\u0027].transform(\r\n        lambda x: x.rolling(60, min_periods\u003d1).std()\r\n    )\r\n    is_lc \u003d pd.Series(np.abs(current_sum) \u003c 10, index\u003ddf.index)\r\n    cd2   \u003d df.groupby(\u0027vehicle_id\u0027)[\u0027vehicle_id\u0027].transform(\r\n        lambda x: pd.Series(current_sum, index\u003dx.index).diff(2).abs()\r\n    )\r\n    current_jump \u003d (\r\n        (vr_std \u003c 0.5).shift(10).fillna(False) \u0026\r\n        (tr_std \u003c 0.2).shift(10).fillna(False) \u0026\r\n        is_lc.shift(10).fillna(False) \u0026\r\n        (~is_lc) \u0026 (cd2 \u003e 30)\r\n    )\r\n    del vr_std, tr_std, is_lc, cd2\r\n\r\n    df[\u0027DCIR\u0027] \u003d np.nan\r\n    for v in df[\u0027vehicle_id\u0027].unique():\r\n        m \u003d df[\u0027vehicle_id\u0027] \u003d\u003d v\r\n        df.loc[m, \u0027DCIR\u0027] \u003d calculate_dcir_numba(\r\n            voltage_mean[m], current_sum[m],\r\n            current_jump[m].fillna(False).values\r\n        ).astype(np.float32)\r\n    del current_jump; gc.collect()\r\n\r\n    df[\u0027pack_current_CV\u0027]    \u003d (current_arr.std(axis\u003d1) / (np.abs(current_arr.mean(axis\u003d1)) + 1e-6)).astype(np.float32)\r\n    df[\u0027pack_current_range\u0027] \u003d (current_arr.max(axis\u003d1) - current_arr.min(axis\u003d1)).astype(np.float32)\r\n    df[\u0027pack_voltage_std\u0027]   \u003d voltage_arr.std(axis\u003d1).astype(np.float32)\r\n    dSOC_list \u003d [df.groupby(\u0027vehicle_id\u0027)[c].transform(lambda x: x.diff()) for c in soc_cols]\r\n    df[\u0027dSOC_dt_std\u0027] \u003d (\r\n        np.nanstd(np.column_stack(dSOC_list), axis\u003d1).astype(np.float32)\r\n        if dSOC_list else np.nan\r\n    )\r\n    del dSOC_list\r\n    df[\u0027impedance_instant\u0027] \u003d (\r\n        voltage_mean / np.where(current_sum !\u003d 0, current_sum, np.nan)\r\n    ).astype(np.float32)\r\n\r\n    df[\u0027joule_heat\u0027] \u003d ((current_sum ** 2) * df[\u0027estimated_resistance\u0027].fillna(0)).astype(np.float32)\r\n    df[\u0027dW_dt\u0027]      \u003d (\r\n        df.groupby(\u0027vehicle_id\u0027)[\u0027joule_heat\u0027]\r\n        .transform(lambda x: x.diff() / (10/60)).astype(np.float32)\r\n    )\r\n    dI_dt \u003d df.groupby(\u0027vehicle_id\u0027)[\u0027vehicle_id\u0027].transform(\r\n        lambda x: pd.Series(current_sum, index\u003dx.index).diff() / (10/60)\r\n    )\r\n    dR_dt \u003d df.groupby(\u0027vehicle_id\u0027)[\u0027estimated_resistance\u0027].transform(\r\n        lambda x: x.diff() / (10/60)\r\n    )\r\n    df[\u0027dW_dt_current_contrib\u0027]    \u003d (2 * current_sum * df[\u0027estimated_resistance\u0027].fillna(0) * dI_dt).astype(np.float32)\r\n    df[\u0027dW_dt_resistance_contrib\u0027] \u003d ((current_sum ** 2) * dR_dt).astype(np.float32)\r\n    del dI_dt, dR_dt; gc.collect()\r\n\r\n    df[\u0027Ah_cumulative\u0027] \u003d (current_sum / 3600).cumsum().astype(np.float32)\r\n    vd_s \u003d df.groupby(\u0027vehicle_id\u0027)[\u0027vehicle_id\u0027].transform(\r\n        lambda x: pd.Series(voltage_mean, index\u003dx.index).diff().abs()\r\n    )\r\n    td_s \u003d df.groupby(\u0027vehicle_id\u0027)[\u0027max_temp\u0027].transform(lambda x: x.diff().abs())\r\n    is_stable  \u003d (np.abs(current_sum) \u003c 5) \u0026 (td_s \u003c 0.1) \u0026 (vd_s \u003c 1)\r\n    stab_reset \u003d is_stable.shift(1).fillna(False) \u0026 ~is_stable\r\n    del vd_s, td_s, is_stable\r\n\r\n    df[\u0027Ah_since_stable\u0027] \u003d df[\u0027temp_since_stable\u0027] \u003d 0.0\r\n    for v in df[\u0027vehicle_id\u0027].unique():\r\n        m \u003d df[\u0027vehicle_id\u0027] \u003d\u003d v\r\n        Av, Tv \u003d calculate_dT_dAh_numba(\r\n            stab_reset[m].fillna(False).values,\r\n            df.loc[m, \u0027max_temp\u0027].values,\r\n            current_sum[m]\r\n        )\r\n        df.loc[m, \u0027Ah_since_stable\u0027]   \u003d Av.astype(np.float32)\r\n        df.loc[m, \u0027temp_since_stable\u0027] \u003d Tv.astype(np.float32)\r\n    del stab_reset; gc.collect()\r\n\r\n    df[\u0027dT_dAh\u0027] \u003d np.where(\r\n        df[\u0027Ah_since_stable\u0027] \u003e 0.1,\r\n        df[\u0027temp_since_stable\u0027] / df[\u0027Ah_since_stable\u0027], np.nan\r\n    ).astype(np.float32)\r\n    df[\u0027dW_dAh\u0027] \u003d np.where(\r\n        df[\u0027Ah_cumulative\u0027].diff() \u003e 0.1,\r\n        df[\u0027joule_heat\u0027].diff() / df[\u0027Ah_cumulative\u0027].diff(), np.nan\r\n    ).astype(np.float32)\r\n\r\n    df[\u0027DCIR_increase_rate\u0027] \u003d (\r\n        df.groupby(\u0027vehicle_id\u0027)[\u0027DCIR\u0027]\r\n        .transform(lambda x: x.pct_change(360)).astype(np.float32)\r\n    )\r\n    df[\u0027thermal_resistance_risk\u0027] \u003d (\r\n        ((df[\u0027DCIR_increase_rate\u0027] \u003e 0.1).fillna(False).astype(np.float32) * 0.5) +\r\n        ((df[\u0027temp_gradient\u0027] \u003e 1.0).fillna(False).astype(np.float32) * 0.5)\r\n    ).astype(np.float32)\r\n\r\n    df[\u0027soc_imbalance_validation\u0027] \u003d (\r\n        (df[\u0027pack_soc_std\u0027] \u003e 0.4).astype(np.int8) +\r\n        (df[\u0027pack_voltage_std\u0027] \u003e 5).astype(np.int8) +\r\n        (df[\u0027pack_current_CV\u0027] \u003e 0.10).astype(np.int8)\r\n    )\r\n\r\n    df[\u0027dV_dAh_charging\u0027] \u003d np.nan\r\n    mc \u003d (df[\u0027state\u0027] \u003d\u003d \u0027charging\u0027) \u0026 (df[\u0027Ah_cumulative\u0027].diff() \u003e 0.01)\r\n    if mc.sum() \u003e 0:\r\n        vd \u003d pd.Series(voltage_mean, index\u003ddf.index).diff()\r\n        Ad \u003d df[\u0027Ah_cumulative\u0027].diff()\r\n        df.loc[mc, \u0027dV_dAh_charging\u0027] \u003d (vd[mc] / Ad[mc]).astype(np.float32)\r\n    del mc\r\n\r\n    prev_state \u003d df.groupby(\u0027vehicle_id\u0027)[\u0027state\u0027].shift(1)\r\n    rad \u003d (df[\u0027state\u0027] \u003d\u003d \u0027resting\u0027) \u0026 (prev_state \u003d\u003d \u0027driving\u0027)\r\n    rac \u003d (df[\u0027state\u0027] \u003d\u003d \u0027resting\u0027) \u0026 (prev_state \u003d\u003d \u0027charging\u0027)\r\n    del prev_state\r\n\r\n    df[\u0027rest_voltage_recovery_driving\u0027]  \u003d np.nan\r\n    df[\u0027rest_voltage_recovery_charging\u0027] \u003d np.nan\r\n    df[\u0027rest_dV_dt\u0027] \u003d np.nan\r\n\r\n    for idx in np.where(rad.fillna(False))[0]:\r\n        if idx + 6 \u003c len(df):\r\n            df.iloc[idx, df.columns.get_loc(\u0027rest_voltage_recovery_driving\u0027)] \u003d (\r\n                voltage_mean[idx + 6] - voltage_mean[idx]\r\n            )\r\n            x \u003d np.arange(6, dtype\u003dnp.float32)\r\n            y \u003d voltage_mean[idx:idx + 6].astype(np.float32)\r\n            df.iloc[idx, df.columns.get_loc(\u0027rest_dV_dt\u0027)] \u003d float(np.polyfit(x, y, 1)[0] * 6)\r\n\r\n    for idx in np.where(rac.fillna(False))[0]:\r\n        if idx + 6 \u003c len(df):\r\n            df.iloc[idx, df.columns.get_loc(\u0027rest_voltage_recovery_charging\u0027)] \u003d (\r\n                voltage_mean[idx + 6] - voltage_mean[idx]\r\n            )\r\n    del rad, rac; gc.collect()\r\n\r\n    df[\u0027soc_group\u0027] \u003d pd.cut(\r\n        df[\u0027pack_soc_mean\u0027], bins\u003d[0, 20, 40, 60, 80, 100],\r\n        labels\u003d[\u0027very_low\u0027, \u0027low\u0027, \u0027medium\u0027, \u0027high\u0027, \u0027very_high\u0027]\r\n    )\r\n    df[\u0027temp_group\u0027] \u003d pd.cut(\r\n        df[\u0027max_temp\u0027], bins\u003d[-40, 20, 25, 30, 35, 85],\r\n        labels\u003d[\u0027cold\u0027, \u0027cool\u0027, \u0027normal\u0027, \u0027warm\u0027, \u0027hot\u0027]\r\n    )\r\n\r\n    for feat in [\u0027pack_soc_std\u0027, \u0027max_cell_v_diff\u0027, \u0027pack_current_CV\u0027,\r\n                 \u0027DCIR\u0027, \u0027thermal_resistance_risk\u0027]:\r\n        if feat not in df.columns:\r\n            continue\r\n        gs \u003d df.groupby([\u0027soc_group\u0027, \u0027temp_group\u0027])[feat].agg([\u0027mean\u0027, \u0027std\u0027])\r\n        df[f\u0027{feat}_normalized\u0027] \u003d np.nan\r\n        for (sg, tg), s in gs.iterrows():\r\n            m \u003d (df[\u0027soc_group\u0027] \u003d\u003d sg) \u0026 (df[\u0027temp_group\u0027] \u003d\u003d tg)\r\n            df.loc[m, f\u0027{feat}_normalized\u0027] \u003d (\r\n                ((df.loc[m, feat] - s[\u0027mean\u0027]) / s[\u0027std\u0027]).astype(np.float32)\r\n                if s[\u0027std\u0027] \u003e 0 else np.float32(0)\r\n            )\r\n\r\n    for periods, sfx in [(6, \u00271min\u0027), (30, \u00275min\u0027), (60, \u002710min\u0027)]:\r\n        df[f\u0027temp_change_{sfx}\u0027] \u003d (\r\n            df.groupby(\u0027vehicle_id\u0027)[\u0027max_temp\u0027]\r\n            .transform(lambda x, p\u003dperiods: x.diff(p)).astype(np.float32)\r\n        )\r\n        df[f\u0027voltage_change_{sfx}\u0027] \u003d (\r\n            df.groupby(\u0027vehicle_id\u0027)[\u0027vehicle_id\u0027]\r\n            .transform(lambda x, p\u003dperiods:\r\n                       pd.Series(voltage_mean, index\u003dx.index).diff(p)).astype(np.float32)\r\n        )\r\n\r\n    print(f\"      ✓ Done  |  total cols: {len(df.columns)}\")\r\n    log_memory(\"after B\")\r\n\r\n    # ------------------------------------------------------------------\r\n    # C. Time aggregation → Parquet shards → S3\r\n    # ------------------------------------------------------------------\r\n    print(\"  [C] Aggregation + S3 upload...\")\r\n    results \u003d {}\r\n    for freq, label, tcol in [\r\n        (\u002710s\u0027,  \u002710s\u0027,  \u0027time_10s\u0027),\r\n        (\u00271min\u0027, \u00271min\u0027, \u0027time_1min\u0027),\r\n        (\u00275min\u0027, \u00275min\u0027, \u0027time_5min\u0027),\r\n    ]:\r\n        df[tcol] \u003d df[\u0027time\u0027].dt.floor(freq)\r\n        agg_dict \u003d make_agg_dict(\r\n            df, exclude_cols\u003d[\u0027time\u0027, \u0027time_10s\u0027, \u0027time_1min\u0027, \u0027time_5min\u0027, \u0027vehicle_id\u0027]\r\n        )\r\n        df_agg \u003d df.groupby([\u0027vehicle_id\u0027, tcol]).agg(agg_dict).reset_index()\r\n        print(f\"      {label}: {len(df):,} → {len(df_agg):,} rows\")\r\n\r\n        s3_out \u003d f\"s3://{BUCKET_NAME}/{OUTPUT_FOLDER}/agg_{label}_{file_number}.parquet\"\r\n        with fs.open(s3_out, \u0027wb\u0027) as fout:\r\n            df_agg.to_parquet(fout, engine\u003d\u0027pyarrow\u0027, compression\u003d\u0027snappy\u0027, index\u003dFalse)\r\n        print(f\"      ✓ Saved: {s3_out}\")\r\n\r\n        results[label] \u003d s3_out\r\n        del df_agg; gc.collect()\r\n\r\n    del df; gc.collect()\r\n    log_memory(\"after cleanup\")\r\n    print(f\"[File {file_number}] Complete!\")\r\n    return results\r\n\r\n\r\ndef merge_and_save(fs, resolution: str, shard_paths: list):\r\n    print(f\"\\n{\u0027\u003d\u0027*70}\")\r\n    print(f\"Merging {resolution} ({len(shard_paths)} shards)...\")\r\n    dfs \u003d []\r\n    for i, path in enumerate(shard_paths, 1):\r\n        with fs.open(path, \u0027rb\u0027) as f:\r\n            chunk \u003d pd.read_parquet(f)\r\n        dfs.append(chunk)\r\n        print(f\"  [{i}/{len(shard_paths)}] {os.path.basename(path)}: {len(chunk):,} rows\")\r\n        del chunk; gc.collect()\r\n\r\n    merged   \u003d pd.concat(dfs, ignore_index\u003dTrue)\r\n    out_path \u003d f\"s3://{BUCKET_NAME}/{OUTPUT_FOLDER}/df_{resolution}_all.parquet\"\r\n    with fs.open(out_path, \u0027wb\u0027) as f:\r\n        merged.to_parquet(f, engine\u003d\u0027pyarrow\u0027, compression\u003d\u0027snappy\u0027, index\u003dFalse)\r\n    print(f\"  ✓ Merged {len(merged):,} rows → {out_path}\")\r\n    del merged, dfs; gc.collect()\r\n    return out_path\r\n\r\nprint(\"✅ P4 done — core functions ready\")\r\n\r\n",
      "user": "anonymous",
