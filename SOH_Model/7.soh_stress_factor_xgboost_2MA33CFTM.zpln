    {
      "text": "%spark_user.pyspark\r\ndef load_stress_source(spark, day_of_soh\u003dNone):\r\n    soh_path \u003d STRESS_FACTOR_IO_CONFIG[\u0027input\u0027][\u0027parquet_path\u0027]\r\n    capa_path \u003d MLP_IO_CONFIG[\u0027input\u0027][\u0027parquet_path\u0027]\r\n\r\n    # load_data_from_parquet() 금지 — partition 컬럼 보존 위해 직접 로드\r\n    soh_raw \u003d (\r\n        spark.read\r\n             .format(\"parquet\")\r\n             .load(soh_path)\r\n    )\r\n\r\n    capa_raw \u003d (\r\n        spark.read\r\n             .format(\"parquet\")\r\n             .load(capa_path)\r\n    )\r\n    # -----------------------------------------------\r\n\r\n    # deviceId 처리\r\n    if \"deviceId\" in soh_raw.columns:\r\n        soh \u003d soh_raw\r\n    elif \"id\" in soh_raw.columns:\r\n        soh \u003d soh_raw.withColumnRenamed(\"id\", \"deviceId\")\r\n    else:\r\n        raise ValueError(\"[Stress] soh_final에 deviceId/id 컬럼이 없습니다.\")\r\n\r\n    soh \u003d soh.withColumn(\"deviceId\", lpad(col(\"deviceId\").cast(\"string\"), 11, \"0\")) \\\r\n             .select(\"deviceId\",\"day_of_soh\",\"accum_dod\",\"avg_bms_temp\",\r\n                     \"discharge_rate\",\"daily_soh\",\"longterm_soh\")\r\n\r\n    capa \u003d capa_raw.withColumn(\r\n        \"deviceId\", lpad(col(\"deviceId\").cast(\"string\"), 11, \"0\")\r\n    ).select(\r\n        \"deviceId\",\"day_of_soh\",\"dod\",\"avg_out_temp\",\"max_mileage\",\r\n        \"avg_speed\",\"avg_torque\",\"parking_cnt\",\"parking_time\",\"discharge_time\",\r\n        \"dvdq\",\"cvdiff\",\"ctdiff\",\"sob\",\"sot\",\r\n        \"volt_based_efficiency\",\"energy_efficiency\",\"composite_efficiency\",\"driving_efficiency\"\r\n    )\r\n\r\n    if day_of_soh is not None:\r\n        soh  \u003d soh.filter(col(\"day_of_soh\") \u003c\u003d day_of_soh)\r\n        capa \u003d capa.filter(col(\"day_of_soh\") \u003c\u003d day_of_soh)\r\n\r\n    joined \u003d soh.join(capa, [\"deviceId\",\"day_of_soh\"], \"inner\")\r\n    return joined.cache()\r\n\r\n",
      "user": "anonymous",
      "dateUpdated": "2025-11-19 15:23:02.444",
