    {
      "text": "%spark_user.pyspark\ndef run_stress_for_all_devices(spark, src_df):\n    device_ids \u003d [r[\"deviceId\"] for r in src_df.select(\"deviceId\").distinct().collect()]\n    result_df_all \u003d None\n\n    for did in device_ids:\n        df_device \u003d src_df.filter(col(\"deviceId\") \u003d\u003d did)\n\n        # 기존 연산 로직 그대로 사용 (Pandas + XGBoost + SHAP)\n        pdf \u003d calculate_stress_factors(df_device)\n\n        if pdf is None or len(pdf) \u003d\u003d 0:\n            continue\n\n        sdf \u003d spark.createDataFrame(pdf)\n\n        if result_df_all is None:\n            result_df_all \u003d sdf\n        else:\n            result_df_all \u003d result_df_all.unionByName(sdf)\n\n    return result_df_all\n",
      "user": "anonymous",
