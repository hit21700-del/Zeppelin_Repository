    {
      "text": "%spark_user.pyspark\ndef run_stress_batch_once(spark, day_of_soh_cut\u003dNone):\n    # 1) 전체 데이터 로드 (여러 deviceId 포함)\n    src_df \u003d load_stress_source(spark, day_of_soh\u003dday_of_soh_cut)\n\n    if src_df.rdd.isEmpty():\n        logger.info(\"[BATCH] 소스 데이터 없음.\")\n        return\n\n    # 2) 단말기별 stress factor 연산\n    new_df \u003d run_stress_for_all_devices(spark, src_df)\n\n    if new_df is None or new_df.rdd.isEmpty():\n        logger.info(\"[BATCH] 결과 없음.\")\n        return\n\n    # 3) 전체 overwrite\n    save_stress_overwrite(spark, new_df)\n\n    logger.info(\"[BATCH] StressFactor 전체 배치 완료.\")\n",
