    {
      "title": "3. 헬퍼 함수 및 단말기 목록 조회",
      "text": "%spark_high.pyspark\r\n\r\ndef get_device_ids(raw_base):\r\n    \"\"\"bigdata 버킷 id\u003d 파티션 폴더에서 전체 단말기 ID 목록 추출\"\"\"\r\n    jvm  \u003d spark._jvm\r\n    conf \u003d sc._jsc.hadoopConfiguration()\r\n    path \u003d jvm.org.apache.hadoop.fs.Path(raw_base)\r\n    fs   \u003d path.getFileSystem(conf)\r\n    return sorted([\r\n        s.getPath().getName().replace(\"id\u003d\", \"\")\r\n        for s in fs.listStatus(path)\r\n        if s.getPath().getName().startswith(\"id\u003d\")\r\n    ])\r\n\r\ndef get_device_max_dates(output_base):\r\n    \"\"\"output _deviceId\u003d 폴더에서 단말기별 max _date 조회 (증분용)\"\"\"\r\n    try:\r\n        jvm  \u003d spark._jvm\r\n        conf \u003d sc._jsc.hadoopConfiguration()\r\n        path \u003d jvm.org.apache.hadoop.fs.Path(output_base)\r\n        fs   \u003d path.getFileSystem(conf)\r\n        if not fs.exists(path):\r\n            return {}\r\n        result \u003d {}\r\n        for device in fs.listStatus(path):\r\n            name \u003d device.getPath().getName()\r\n            if not name.startswith(\"_deviceId\u003d\"):\r\n                continue\r\n            device_id \u003d name.replace(\"_deviceId\u003d\", \"\")\r\n            dates \u003d [\r\n                s.getPath().getName().replace(\"_date\u003d\", \"\")\r\n                for s in fs.listStatus(device.getPath())\r\n                if s.getPath().getName().startswith(\"_date\u003d\")\r\n            ]\r\n            if dates:\r\n                result[device_id] \u003d max(dates)\r\n        return result\r\n    except Exception as e:\r\n        print(f\"  [WARN] get_device_max_dates 실패: {e}\")\r\n        return {}\r\n\r\n# ── 전체 단말기 목록 및 처리 이력 조회 ────────────────────\r\nall_device_ids \u003d get_device_ids(RAW_BASE_PATH)\r\nprocessed_map  \u003d get_device_max_dates(OUTPUT_BASE_PATH)\r\n\r\nprint(f\"전체 단말기 수   : {len(all_device_ids)}\")\r\nprint(f\"처리 완료 단말기 : {len(processed_map)}\")\r\nprint(f\"전체 단말기 목록 : {all_device_ids}\")",
      "user": "anonymous",
      "dateUpdated": "2026-04-06 06:28:40.922",
      "progress": 0,
      "config": {
