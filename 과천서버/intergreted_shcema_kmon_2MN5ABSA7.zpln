    {
      "title": "5. 변환 및 저장 실행",
      "text": "%spark_high.pyspark\r\nimport traceback\r\nfrom datetime import datetime\r\n\r\nDROP_COLS \u003d [\r\n    \"c_state\", \"mcu_state\", \"bms_state\", \"m_curr\", \"o_state\", \"oce\",\r\n    \"pss\", \"hvptc\", \"group_code\", \"seq\", \"car_num\",\r\n    \"bmv_1\", \"bmv_2\", \"bmv_3\", \"bmv_4\"\r\n]\r\n\r\n# ── 체크포인트 설정 ────────────────────────────────────────\r\nPP_CHECKPOINT \u003d \"s3a://parquet/kslab_kmon/checkpoint/completed.txt\"\r\n\r\npp_fs \u003d spark._jvm.org.apache.hadoop.fs.FileSystem.get(\r\n    spark._jvm.java.net.URI(\"s3a://parquet\"),\r\n    sc._jsc.hadoopConfiguration()\r\n)\r\n\r\ndef pp_checkpoint_load():\r\n    p \u003d spark._jvm.org.apache.hadoop.fs.Path(PP_CHECKPOINT)\r\n    if not pp_fs.exists(p):\r\n        return set()\r\n    stream \u003d pp_fs.open(p)\r\n    reader \u003d spark._jvm.java.io.BufferedReader(\r\n        spark._jvm.java.io.InputStreamReader(stream)\r\n    )\r\n    completed \u003d set()\r\n    line \u003d reader.readLine()\r\n    while line is not None:\r\n        if line.strip():\r\n            completed.add(line.strip())\r\n        line \u003d reader.readLine()\r\n    reader.close()\r\n    return completed\r\n\r\ndef pp_checkpoint_save(dev_id, completed):\r\n    completed.add(dev_id)\r\n    p \u003d spark._jvm.org.apache.hadoop.fs.Path(PP_CHECKPOINT)\r\n    stream \u003d pp_fs.create(p, True)\r\n    writer \u003d spark._jvm.java.io.PrintWriter(\r\n        spark._jvm.java.io.OutputStreamWriter(stream, \"UTF-8\")\r\n    )\r\n    for d in sorted(completed):\r\n        writer.println(d)\r\n    writer.close()\r\n\r\ndef process_one_device(device_id, last_date\u003dNone) -\u003e str:\r\n    try:\r\n        raw_path \u003d f\"{RAW_BASE_PATH}/id\u003d{device_id}\"\r\n\r\n        # ── 1. 전체 데이터 한 번만 read → cache ──────────────\r\n        df_full \u003d spark.read.parquet(raw_path)\r\n\r\n        if \"id\" not in df_full.columns:\r\n            df_full \u003d df_full.withColumn(\"id\", F.lit(device_id))\r\n\r\n        # ── 2. 증분 필터 ──────────────────────────────────────\r\n        if last_date:\r\n            df_full \u003d df_full.filter(F.col(\"c_date\").substr(1, 10) \u003e\u003d last_date)\r\n\r\n        df_full \u003d df_full.cache()\r\n        total   \u003d df_full.count()\r\n        print_timestamp(f\"[START] {device_id} | {total:,}건 (cache 완료)\")\r\n\r\n        # ── 3. master 조인 ────────────────────────────────────\r\n        df \u003d df_full\r\n        df \u003d df.withColumn(\r\n            \"id_norm\",\r\n            F.when(\r\n                (F.length(F.col(\"id\").cast(\"string\")) \u003d\u003d 10) \u0026\r\n                (F.substring(F.col(\"id\").cast(\"string\"), 1, 1) !\u003d F.lit(\u00270\u0027)),\r\n                F.lpad(F.col(\"id\").cast(\"string\"), 11, \u00270\u0027)\r\n            ).otherwise(F.col(\"id\").cast(\"string\"))\r\n        )\r\n        df \u003d (\r\n            df.join(df_master_bc,\r\n                    on\u003dF.col(\"id_norm\") \u003d\u003d F.col(\"deviceId_norm\"),\r\n                    how\u003d\"left\")\r\n              .drop(\"deviceId_norm\", \"id_norm\")\r\n              .fillna({\"groupCode\": 0, \"vehicleNumber\": \"\"})\r\n        )\r\n\r\n        # ── 4. 통합스키마 변환 ────────────────────────────────\r\n        df \u003d convert_df_new(df)\r\n        df \u003d add_row_uuid(df, col_name\u003d\"id\")\r\n        df \u003d bit_process(df)\r\n        df \u003d add_status(df)\r\n        df \u003d combine_bmt_columns(df)\r\n        df \u003d drop_if_exists(df, DROP_COLS)\r\n        df \u003d add_missing_columns(df, ADD_COLUMNS)\r\n        df \u003d cast_risky_columns(df, RISKY_CAST_MAP)\r\n        df \u003d select_columns(df)\r\n\r\n        # ── 5. 파티션 컬럼 추가 ───────────────────────────────\r\n        df \u003d (\r\n            df.withColumn(\"_deviceId\", F.col(\"deviceId\"))\r\n              .withColumn(\"_date\", F.date_format(F.col(\"createdAt\"), \"yyyy-MM-dd\"))\r\n        )\r\n\r\n        # ── 6. 저장 ───────────────────────────────────────────\r\n        (\r\n            df.write\r\n              .mode(\"append\")\r\n              .option(\"compression\", \"snappy\")\r\n              .option(\"maxRecordsPerFile\", \"2000000\")\r\n              .partitionBy(\"_deviceId\", \"_date\")\r\n              .parquet(OUTPUT_BASE_PATH)\r\n        )\r\n\r\n        df_full.unpersist()\r\n        spark.catalog.clearCache()\r\n        print_timestamp(f\"[DONE] {device_id}\")\r\n        return \"OK\"\r\n\r\n    except Exception as e:\r\n        print_timestamp(f\"[FAIL] {device_id} → {e}\")\r\n        traceback.print_exc()\r\n        try:\r\n            df_full.unpersist()\r\n        except:\r\n            pass\r\n        spark.catalog.clearCache()\r\n        return f\"FAIL: {e}\"\r\n\r\n\r\n# ── 체크포인트 로드 ────────────────────────────────────────\r\npp_completed \u003d pp_checkpoint_load()\r\nprint(f\"체크포인트 로드: 완료된 단말기 {len(pp_completed)}개\")\r\n\r\n# ── 실행 ──────────────────────────────────────────────────\r\nresults     \u003d {}\r\nbatch_start \u003d datetime.now()\r\n\r\nfor device_id in target_device_ids:\r\n    if device_id in pp_completed:\r\n        print_timestamp(f\"[SKIP] {device_id} (체크포인트)\")\r\n        results[device_id] \u003d \"SKIP\"\r\n        continue\r\n\r\n    last_date      \u003d processed_map.get(device_id)\r\n    result         \u003d process_one_device(device_id, last_date)\r\n    results[device_id] \u003d result\r\n\r\n    if result \u003d\u003d \"OK\":\r\n        pp_checkpoint_save(device_id, pp_completed)\r\n\r\ntotal_elapsed \u003d datetime.now() - batch_start\r\n\r\n# ── 결과 요약 ──────────────────────────────────────────────\r\nok_cnt   \u003d sum(1 for v in results.values() if v \u003d\u003d \"OK\")\r\nskip_cnt \u003d sum(1 for v in results.values() if v \u003d\u003d \"SKIP\")\r\nfail_cnt \u003d sum(1 for v in results.values() if v.startswith(\"FAIL\"))\r\n\r\nprint(f\"\\n\u003d\u003d\u003d 결과 요약 \u003d\u003d\u003d\")\r\nprint(f\"  성공  : {ok_cnt}\")\r\nprint(f\"  스킵  : {skip_cnt}\")\r\nprint(f\"  실패  : {fail_cnt}\")\r\nprint(f\"  총 소요: {total_elapsed}\")\r\n\r\nif fail_cnt:\r\n    print(\"\\n실패 단말기:\")\r\n    for k, v in results.items():\r\n        if v.startswith(\"FAIL\"):\r\n            print(f\"  {k}: {v}\")",
      "user": "anonymous",
      "dateUpdated": "2026-04-06 06:29:12.179",
