    {
      "title": "2.모듈 다운로드 및 import",
      "text": "%spark_high.pyspark\r\nimport boto3, os, sys\r\n\r\n# ── 인증정보 직접 명시 ─────────────────────────────────────\r\ns3 \u003d boto3.client(\r\n    \"s3\",\r\n    endpoint_url          \u003d \"http://192.168.0.105:80\",\r\n    aws_access_key_id     \u003d \"8XTYLABJCSLJKUTQBK94\",\r\n    aws_secret_access_key \u003d \"fKlCAYQBPEA9JOoyrfhTsIeVXr2j58M8upPCAVVR\",\r\n    region_name           \u003d \"us-east-1\"\r\n)\r\n\r\nlocal_dir \u003d \"/tmp/kmon\"\r\nos.makedirs(local_dir, exist_ok\u003dTrue)\r\n\r\nfor f in [\"kmon_kslab_config.py\", \"kmon_kslab_pp_func.py\", \"kmon_kslab_utils.py\"]:\r\n    s3.download_file(\"quantum\", f\"data_folder/Intergrated_Schema/kmon/{f}\", f\"{local_dir}/{f}\")\r\n    print(f\"Downloaded: {f}\")\r\n\r\nsys.path.insert(0, local_dir)\r\n\r\nfrom kmon_kslab_config import ADD_COLUMNS, RISKY_CAST_MAP\r\nfrom kmon_kslab_pp_func import (\r\n    convert_df_new, bit_process, add_status, combine_bmt_columns,\r\n    drop_if_exists, add_row_uuid, select_columns,\r\n    add_missing_columns, cast_risky_columns\r\n)\r\nfrom kmon_kslab_utils import print_timestamp\r\n\r\nprint(\"\u003d\u003d\u003d OK \u003d\u003d\u003d\")",
      "user": "anonymous",
      "dateUpdated": "2026-04-06 06:28:28.468",
