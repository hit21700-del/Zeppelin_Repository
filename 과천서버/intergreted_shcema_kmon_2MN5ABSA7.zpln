            "type": "TEXT",
            "data": "실행 대상 단말기 수: 64\n실행 대상 목록    : [\u002701229168898\u0027, \u002701229198901\u0027, \u002701229219366\u0027, \u002701229238905\u0027, \u002701229258900\u0027, \u002701229268895\u0027, \u002701229279367\u0027, \u002701229298900\u0027, \u002701229408898\u0027, \u002701229428953\u0027, \u002701229438897\u0027, \u002701229438903\u0027, \u002701229438904\u0027, \u002701229438905\u0027, \u002701229508904\u0027, \u002701229518902\u0027, \u002701229518904\u0027, \u002701229518905\u0027, \u002701229528904\u0027, \u002701229528905\u0027, \u002701229559364\u0027, \u002701229618901\u0027, \u002701229628897\u0027, \u002701229638933\u0027, \u002701229668904\u0027, \u002701229828903\u0027, \u002701229828961\u0027, \u002701229838902\u0027, \u002701229838910\u0027, \u002701229838915\u0027, \u002701229838918\u0027, \u002701229838969\u0027, \u002701229848911\u0027, \u002701229848920\u0027, \u002701229848956\u0027, \u002701229848978\u0027, \u002701229858910\u0027, \u002701229859021\u0027, \u002701229868912\u0027, \u002701229868966\u0027, \u002701229888910\u0027, \u002701229888959\u0027, \u002701229889022\u0027, \u002701229898903\u0027, \u002701229898910\u0027, \u002701229898913\u0027, \u002701229898935\u0027, \u002701229898943\u0027, \u002701229898971\u0027, \u002701229898996\u0027, \u002701229938960\u0027, \u002701229948937\u0027, \u002701229948960\u0027, \u002701229948961\u0027, \u002701229958960\u0027, \u002701229958961\u0027, \u002701229958978\u0027, \u002701229968960\u0027, \u002701229968961\u0027, \u002701229968962\u0027, \u002701229968965\u0027, \u002701229968996\u0027, \u002701229978913\u0027, \u002701229978961\u0027]\nmaster 로드 완료 : 233 건\n"
