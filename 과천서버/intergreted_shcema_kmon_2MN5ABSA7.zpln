    {
      "title": "4.실행 대상 단말기 선택 및 master 로드",
      "text": "%spark_high.pyspark\r\n\r\n# ════════════════════════════════════════════════════════════\r\n# 실행 대상 단말기 설정 (필요에 따라 아래 3가지 중 하나만 사용)\r\n# ════════════════════════════════════════════════════════════\r\n\r\n# Case 1. 전체 단말기 실행 (기본)\r\n#target_device_ids \u003d all_device_ids\r\n\r\n# Case 2. 특정 단말기만 선택 (주석 해제 후 사용)\r\n# target_device_ids \u003d [\r\n#     \"01229848911\",\r\n#     \"01229438897\",\r\n# ]\r\n\r\n# Case 3. 특정 단말기 제외 (주석 해제 후 사용)\r\nEXCLUDE_DEVICE_IDS \u003d [\r\n    \"01229208905\", # 무조건 제외 c_date 엉망인 단말기\r\n    \"01229459372\",\r\n    \"01229858987\",\r\n    \"01229848988\",\r\n    #\"01229628897\", 그룹코드3으로 65대 정리한 문서에는 없지만, db에는 정리됨\r\n    \"01229808904\",\r\n    \"01229848907\",\r\n    \"01229608897\",\r\n]\r\ntarget_device_ids \u003d [d for d in all_device_ids if d not in EXCLUDE_DEVICE_IDS]\r\n\r\n# ════════════════════════════════════════════════════════════\r\n\r\nprint(f\"실행 대상 단말기 수: {len(target_device_ids)}\")\r\nprint(f\"실행 대상 목록    : {target_device_ids}\")\r\n\r\n# ── master 데이터 로드 ─────────────────────────────────────\r\ndf_master \u003d (\r\n    spark.read.format(\"csv\")\r\n        .option(\"header\", \"true\")\r\n        .option(\"multiLine\", \"true\")\r\n        .option(\"escape\", \"\\\"\")\r\n        .load(MASTER_CSV_PATH)\r\n        .select(\r\n            F.col(\"deviceId\").cast(\"string\").alias(\"deviceId\"),\r\n            F.col(\"sourceCode\").cast(\"string\").alias(\"sourceCode\"),\r\n            F.col(\"groupCode\").cast(\"int\").alias(\"groupCode\"),\r\n            F.col(\"vehicleNumber\").cast(\"string\").alias(\"vehicleNumber\")\r\n        )\r\n        .dropna(subset\u003d[\"deviceId\"])\r\n        .dropDuplicates([\"deviceId\"])\r\n        .withColumn(\r\n            \"deviceId_norm\",\r\n            F.when(\r\n                (F.length(F.col(\"deviceId\")) \u003d\u003d 10) \u0026\r\n                (F.substring(F.col(\"deviceId\"), 1, 1) !\u003d F.lit(\u00270\u0027)),\r\n                F.lpad(F.col(\"deviceId\"), 11, \u00270\u0027)\r\n            ).otherwise(F.col(\"deviceId\"))\r\n        )\r\n)\r\n\r\ndf_master_bc \u003d F.broadcast(\r\n    df_master.select(\"deviceId_norm\", \"sourceCode\", \"groupCode\", \"vehicleNumber\")\r\n)\r\n\r\nprint(f\"master 로드 완료 : {df_master.count():,} 건\")",
      "user": "anonymous",
      "dateUpdated": "2026-04-06 06:29:04.294",
