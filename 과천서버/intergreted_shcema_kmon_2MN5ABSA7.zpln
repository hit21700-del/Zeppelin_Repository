    {
      "title": "1.S3 설정 및 경로 정의",
      "text": "%spark_high.pyspark\r\nimport boto3, os, sys, re, traceback\r\nfrom datetime import datetime\r\nfrom pyspark.sql import functions as F\r\n# ── S3 설정 ────────────────────────────────────────────────\r\nhc \u003d sc._jsc.hadoopConfiguration()\r\nhc.set(\"fs.s3a.endpoint\",                    \"http://192.168.0.105:80\")\r\nhc.set(\"fs.s3a.access.key\",                  \"8XTYLABJCSLJKUTQBK94\")\r\nhc.set(\"fs.s3a.secret.key\",                  \"fKlCAYQBPEA9JOoyrfhTsIeVXr2j58M8upPCAVVR\")\r\nhc.set(\"fs.s3a.path.style.access\",           \"true\")\r\nhc.set(\"fs.s3a.impl\",                        \"org.apache.hadoop.fs.s3a.S3AFileSystem\")\r\nhc.set(\"fs.s3a.connection.ssl.enabled\",      \"false\")\r\nhc.set(\"fs.s3a.signing-algorithm\",           \"S3SignerType\")\r\n# ── S3 커넥션 안정성 설정 (타임아웃/재시도) ───────────────\r\nhc.set(\"fs.s3a.connection.timeout\",          \"600000\")\r\nhc.set(\"fs.s3a.socket.timeout\",              \"600000\")\r\nhc.set(\"fs.s3a.connection.establish.timeout\",\"600000\")\r\nhc.set(\"fs.s3a.attempts.maximum\",            \"10\")\r\nhc.set(\"fs.s3a.retry.limit\",                 \"10\")\r\nhc.set(\"fs.s3a.retry.interval\",              \"500ms\")\r\n# ── Connection pool 유지 설정 ─────────────────────────────\r\nhc.set(\"fs.s3a.connection.ttl\",              \"-1\")\r\nhc.set(\"fs.s3a.connection.idle.time\",        \"3600000\")\r\nhc.set(\"fs.s3a.pool.timeout\",                \"3600000\")\r\n# ── 경로 설정 ──────────────────────────────────────────────\r\nRAW_BASE_PATH    \u003d \"s3a://bigdata/kmon/parquet\"\r\nMASTER_CSV_PATH  \u003d \"s3a://quantum/data_folder/metaData/VehicleMaster.csv\"\r\nOUTPUT_BASE_PATH \u003d \"s3a://parquet/kslab_kmon\"\r\nprint(\"S3 설정 완료\")\r\nprint(f\"  RAW : {RAW_BASE_PATH}\")\r\nprint(f\"  OUT : {OUTPUT_BASE_PATH}\")",
      "user": "anonymous",
      "dateUpdated": "2026-04-06 06:28:12.825",
      "progress": 0,
